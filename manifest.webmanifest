      { name: "グルン", stores: ["ougicho"], days: ["月", "火", "木", "金"], slots: [], times: ["9-13", "9-17"], tags: ["主婦", "固定", "月金9-13固定", "火木9-17固定", "45分休憩", "扇町責任者候補"], support: false },
      { name: "下田", stores: ["ougicho", "higashicho", "miyanoshita"], days: ["月", "火", "水", "木", "金", "土", "日"], slots: [], times: ["6-15", "9-15", "17-22", "18-24"], tags: ["基本:月火木金は東町", "水土日は扇町9-15", "扇町では9-17なし", "扇町木曜17-22", "宮下18-24のみ", "人不足時6時からOK", "45分休憩", "東町責任者候補"], support: false },
      { name: "芳澤", stores: ["ougicho", "miyanoshita"], days: ["月", "火", "水", "木", "金", "土", "日"], slots: [], times: ["6-9", "9-17", "17-22", "22-6"], tags: ["フリーター", "どの曜日時間OK", "責任者同伴のみ", "電話対応不可", "クレーム対応不可", "下田と組合せNG"], support: false },
      { name: "鈴木（久華）", stores: ["ougicho"], days: ["金", "土"], slots: [], times: ["17-22"], tags: ["学生", "夕方", "固定", "金土17-22固定", "扇町鈴木"], support: false },
      { name: "植村", stores: ["ougicho"], days: ["水", "木", "金", "土", "日"], slots: [], times: ["6-9"], tags: ["一般", "朝", "固定", "残業不可"], support: false },
      { name: "ミミ", stores: ["ougicho", "higashicho"], days: ["月", "火", "水", "木", "金", "土", "日"], slots: [], times: ["6-9", "6-15", "9-13", "9-17", "13-18", "16-22", "17-22", "17-24", "18-3", "22-2", "22-3", "22-6"], tags: ["フリーター", "どの曜日もOK", "どの時間もOK", "多く勤務希望", "扇町東町", "月1回土日休み希望"], support: false },
      { name: "中込", stores: ["ougicho"], days: ["金"], slots: [], times: ["22-6"], tags: ["主婦", "夜勤のみ", "扇町2-7ワンオペ可"], support: false },
