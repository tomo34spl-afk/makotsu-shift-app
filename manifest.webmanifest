<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Makotsu Shift りえちゃん運用版 v14 PWA</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f7f9;
      --panel: #ffffff;
      --panel-2: #f0f3f7;
      --text: #1d2430;
      --muted: #5e6878;
      --line: #d7dde6;
      --strong: #111827;
      --accent: #0f766e;
      --accent-2: #0b5f59;
      --warn: #b45309;
      --danger: #b42318;
      --ok: #16703c;
      --shadow: 0 12px 34px rgba(18, 28, 45, .08);
      --radius: 8px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.45;
    }

    button,
    input,
    select {
      font: inherit;
    }

    button {
      cursor: pointer;
    }

    .app {
      max-width: 1320px;
      margin: 0 auto;
      padding: 18px;
    }

    .topbar {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      margin-bottom: 14px;
    }

    .status-bar {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      padding: 8px 10px;
      margin-bottom: 12px;
    }

    .status-bar.ready {
      color: var(--ok);
      border-color: #b8dec6;
      background: #f3fbf6;
    }

    .status-bar.fallback {
      color: var(--warn);
      border-color: #efd49d;
      background: #fffbeb;
    }

    .brand {
      min-width: 0;
    }

    .brand h1 {
      margin: 0;
      font-size: 24px;
      line-height: 1.2;
      color: var(--strong);
      letter-spacing: 0;
    }

    .brand p {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 14px;
    }

    .role-switch {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .btn {
      border: 1px solid var(--line);
      background: var(--panel);
      color: var(--text);
      border-radius: var(--radius);
      min-height: 38px;
      padding: 8px 12px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
    }

    .btn:hover {
      border-color: #b9c2cf;
      background: #f8fafc;
    }

    .btn.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .btn.primary:hover {
      background: var(--accent-2);
      border-color: var(--accent-2);
    }

    .btn.ghost {
      background: transparent;
    }

    .btn.small {
      min-height: 31px;
      padding: 5px 9px;
      font-size: 13px;
    }

    .btn.active {
      background: var(--strong);
      border-color: var(--strong);
      color: #fff;
    }

    .layout {
      display: grid;
      grid-template-columns: 250px minmax(0, 1fr);
      gap: 14px;
      align-items: start;
    }

    .sidebar,
    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .sidebar {
      padding: 12px;
      position: sticky;
      top: 12px;
    }

    .nav {
      display: grid;
      gap: 7px;
    }

    .nav button {
      width: 100%;
      text-align: left;
      justify-content: flex-start;
    }

    .nav .sub {
      margin: 10px 0 5px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .04em;
    }

    .main {
      display: grid;
      gap: 14px;
      min-width: 0;
    }

    .panel {
      padding: 14px;
      min-width: 0;
    }

    .panel h2 {
      margin: 0 0 10px;
      color: var(--strong);
      font-size: 18px;
      letter-spacing: 0;
    }

    .panel h3 {
      margin: 0 0 8px;
      color: var(--strong);
      font-size: 15px;
      letter-spacing: 0;
    }

    .muted {
      color: var(--muted);
    }

    .grid {
      display: grid;
      gap: 10px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      padding: 12px;
      min-width: 0;
    }

    .metric-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .metric-value {
      font-size: 24px;
      font-weight: 700;
      color: var(--strong);
      line-height: 1.2;
    }

    .metric-sub {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: end;
      margin-bottom: 12px;
    }

    label {
      display: grid;
      gap: 4px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    select,
    input {
      min-height: 38px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 7px 9px;
      background: #fff;
      color: var(--text);
      min-width: 120px;
    }

    input[type="number"] {
      width: 78px;
      min-width: 78px;
    }

    .split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 310px;
      gap: 14px;
      align-items: start;
    }

    .table-wrap {
      width: 100%;
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
    }

    .weekly-mobile-list {
      display: none;
      gap: 10px;
    }

    .weekly-day-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      overflow: hidden;
    }

    .weekly-day-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      padding: 10px;
      background: var(--panel-2);
      color: var(--strong);
      font-weight: 800;
    }

    .weekly-slot-card {
      display: grid;
      gap: 6px;
      border-top: 1px solid var(--line);
      border-right: 0;
      border-bottom: 0;
      border-left: 0;
      padding: 10px;
      width: 100%;
      background: #fff;
      color: var(--text);
      text-align: left;
      border-radius: 0;
    }

    .weekly-slot-card.selected {
      outline: 2px solid var(--accent);
      outline-offset: -2px;
      background: #f0fdfa;
    }

    .weekly-slot-top {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 860px;
      font-size: 13px;
    }

    th,
    td {
      border-bottom: 1px solid var(--line);
      border-right: 1px solid var(--line);
      vertical-align: top;
      text-align: left;
    }

    th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: var(--panel-2);
      color: var(--strong);
      padding: 9px;
      font-size: 12px;
      white-space: nowrap;
    }

    td {
      background: #fff;
      padding: 6px;
      min-height: 70px;
    }

    th:last-child,
    td:last-child {
      border-right: 0;
    }

    tr:last-child td {
      border-bottom: 0;
    }

    .date-cell {
      width: 86px;
      min-width: 86px;
      color: var(--strong);
      font-weight: 700;
      background: #fbfcfe;
    }

    .dow {
      display: block;
      color: var(--muted);
      font-weight: 600;
      font-size: 12px;
      margin-top: 2px;
    }

    .weekend {
      color: var(--warn);
    }

    .slot-cell {
      min-width: 150px;
      cursor: pointer;
    }

    .slot-cell:hover {
      outline: 2px solid rgba(15, 118, 110, .26);
      outline-offset: -2px;
    }

    .slot-cell.selected {
      outline: 2px solid var(--accent);
      outline-offset: -2px;
      background: #f0fdfa;
    }

    .cell-top {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      color: var(--muted);
      font-size: 11px;
      margin-bottom: 5px;
    }

    .need.bad {
      color: var(--danger);
      font-weight: 700;
    }

    .need.ok {
      color: var(--ok);
      font-weight: 700;
    }

    .person {
      display: flex;
      justify-content: space-between;
      gap: 5px;
      align-items: center;
      border: 1px solid #d9e4e2;
      background: #f7fbfa;
      border-radius: 6px;
      padding: 4px 5px;
      margin-top: 4px;
      color: var(--strong);
      word-break: keep-all;
    }

    .person .time {
      color: var(--muted);
      font-size: 11px;
      white-space: nowrap;
    }

    .person.support {
      border-color: #e7d7ad;
      background: #fffbeb;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 12px;
      font-weight: 700;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--muted);
    }

    .tag.bad {
      color: var(--danger);
      border-color: #f3b4ad;
      background: #fff5f4;
    }

    .tag.ok {
      color: var(--ok);
      border-color: #b8dec6;
      background: #f3fbf6;
    }

    .tag.warn {
      color: var(--warn);
      border-color: #efd49d;
      background: #fffbeb;
    }

    .side-card {
      display: grid;
      gap: 10px;
    }

    .detail-box {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fbfcfe;
      padding: 10px;
    }

    .timeline-map {
      display: grid;
      gap: 12px;
      margin-bottom: 12px;
    }

    .timeline-row {
      display: grid;
      grid-template-columns: 74px minmax(0, 1fr) 116px;
      gap: 10px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      padding: 10px;
    }

    .timeline-store {
      color: var(--strong);
      font-weight: 700;
      white-space: nowrap;
    }

    .timeline-track {
      position: relative;
      height: 42px;
      border-top: 2px solid #b9c2cf;
      margin-top: 16px;
    }

    .timeline-tick {
      position: absolute;
      top: -9px;
      width: 1px;
      height: 14px;
      background: #8b95a3;
    }

    .timeline-tick span {
      position: absolute;
      top: -18px;
      left: -10px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .hole-segment {
      position: absolute;
      top: -7px;
      height: 18px;
      min-width: 10px;
      border: 1px solid #e59f25;
      background: repeating-linear-gradient(135deg, #fff7ed 0 5px, #fed7aa 5px 9px);
      border-radius: 3px;
      color: var(--warn);
      font-size: 11px;
      font-weight: 800;
      text-align: center;
      line-height: 16px;
      overflow: hidden;
      padding: 0;
      cursor: pointer;
    }

    .hole-segment.bad {
      border-color: #e17b72;
      background: repeating-linear-gradient(135deg, #fff5f4 0 5px, #fca5a5 5px 9px);
      color: var(--danger);
    }

    .hole-segment.selected {
      outline: 2px solid var(--strong);
      outline-offset: 2px;
    }

    .timeline-summary {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      text-align: right;
    }

    .candidate-list {
      display: grid;
      gap: 7px;
    }

    .candidate {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 6px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 8px;
      background: #fff;
    }

    .candidate strong {
      color: var(--strong);
    }

    .reason {
      color: var(--muted);
      font-size: 12px;
      margin-top: 2px;
    }

    .status-row {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      align-items: center;
      margin: 8px 0 0;
    }

    .requirements {
      display: grid;
      grid-template-columns: repeat(5, minmax(78px, 1fr));
      gap: 8px;
      margin-bottom: 10px;
    }

    .req-item {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 8px;
      background: #fff;
    }

    .req-item span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 5px;
    }

    .print-sheet {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .print-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px;
      border-bottom: 1px solid var(--line);
      background: var(--panel-2);
    }

    .print-head strong {
      color: var(--strong);
      font-size: 16px;
    }

    .weekly-sheet {
      margin-bottom: 14px;
    }

    .weekly-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .weekly-print-note {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .rest-summary {
      border-top: 1px solid var(--line);
      padding: 10px 12px 12px;
      background: #fff;
    }

    .rest-summary-title {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: baseline;
      margin-bottom: 8px;
      color: var(--strong);
      font-size: 13px;
      font-weight: 900;
    }

    .rest-summary-title span {
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
    }

    .rest-count-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 6px;
    }

    .rest-count-item {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 7px 8px;
      background: var(--panel-2);
      font-size: 12px;
    }

    .rest-count-item.rest-ok {
      background: #f0fdf4;
      border-color: #bbf7d0;
    }

    .rest-count-item.rest-warn {
      background: #fffbeb;
      border-color: #fed7aa;
    }

    .rest-count-item strong {
      color: var(--strong);
      font-size: 12px;
    }

    .rest-count-item .rest-meta {
      color: var(--muted);
      font-size: 11px;
      white-space: nowrap;
    }

    .weekly-print-active .monthly-print-section {
      display: none;
    }

    .monthly-print-active .weekly-print-section {
      display: none;
    }

    .hidden {
      display: none !important;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      background: rgba(15, 23, 42, .45);
    }

    .modal {
      width: min(760px, 100%);
      max-height: min(92vh, 760px);
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      box-shadow: var(--shadow);
      padding: 16px;
    }

    .modal-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .modal-head h3 {
      margin: 0 0 4px;
    }

    .modal-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .modal-grid label.full {
      grid-column: 1 / -1;
    }

    .panel:target {
      display: block !important;
      scroll-margin-top: 12px;
    }

    .no-js-fallback {
      margin: 0 0 14px;
    }

    body.js-ready .no-js-fallback {
      display: none;
    }

    .staff-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .today-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .owner-grid {
      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 12px;
      align-items: start;
    }

    .today-store {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      padding: 10px;
      min-width: 0;
    }


    .rie-master-list {
      display: grid;
      gap: 6px;
      max-height: 420px;
      overflow: auto;
    }

    .rie-master-row {
      display: grid;
      grid-template-columns: 88px 70px minmax(0, 1fr) 72px auto;
      gap: 6px;
      align-items: center;
      padding: 7px 8px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      font-size: 12px;
    }

    .rie-master-row strong {
      color: var(--strong);
    }

    .comparison-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 2px 7px;
      background: #fff;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .comparison-badge.ok {
      border-color: #99f6e4;
      background: #ecfdf5;
      color: var(--ok);
    }

    .comparison-badge.warn {
      border-color: #fde68a;
      background: #fffbeb;
      color: #92400e;
    }

    .comparison-badge.bad {
      border-color: #fecaca;
      background: #fff7f6;
      color: var(--danger);
    }

    .small-note {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
    }

    .today-store h3 {
      margin-bottom: 10px;
    }

    .today-row {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr);
      gap: 8px;
      padding: 6px 0;
      border-top: 1px solid var(--line);
    }

    .today-row:first-of-type {
      border-top: 0;
    }

    .today-slot {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .availability-list {
      display: grid;
      gap: 6px;
    }

    .textarea {
      min-height: 130px;
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 10px;
      resize: vertical;
      background: #fff;
      color: var(--text);
      font: inherit;
    }

    .danger-row td {
      background: #fff7f6;
    }

    .warn-row td {
      background: #fffbeb;
    }

    .toolbar-right {
      margin-left: auto;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .staff-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 10px;
      background: #fff;
    }

    .staff-card strong {
      color: var(--strong);
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      background: var(--strong);
      color: #fff;
      border-radius: var(--radius);
      padding: 9px 12px;
      box-shadow: var(--shadow);
      opacity: 0;
      pointer-events: none;
      transition: opacity .18s ease;
      z-index: 20;
      font-size: 13px;
    }

    .toast.show {
      opacity: 1;
    }

    @media (max-width: 980px) {
      .layout,
      .split,
      .owner-grid {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
      }

      .cards {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .staff-grid,
      .today-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .timeline-row {
        grid-template-columns: 1fr;
      }

      .timeline-summary {
        text-align: left;
      }
    }

    @media (max-width: 620px) {
      .app {
        padding: 10px;
      }

      .topbar {
        grid-template-columns: 1fr;
      }

      .role-switch {
        justify-content: flex-start;
      }

      .cards,
      .staff-grid,
      .today-grid,
      .modal-grid,
      .requirements {
        grid-template-columns: 1fr;
      }

      .controls {
        align-items: stretch;
      }

      .controls label,
      .controls button,
      select,
      input {
        width: 100%;
      }

      #weeklyCloseView .table-wrap {
        display: none;
      }

      .weekly-mobile-list {
        display: grid;
      }

      .weekly-day-head {
        position: sticky;
        top: 0;
        z-index: 2;
      }

      .timeline-track {
        min-width: 300px;
      }

      .rie-master-row {
        grid-template-columns: 1fr auto;
      }

      .rie-master-row .small-note {
        grid-column: 1 / -1;
      }
    }

    @media print {
      body {
        background: #fff;
      }

      .topbar,
      .sidebar,
      .controls,
      .side-card,
      .no-print,
      .status-bar,
      .no-js-fallback {
        display: none !important;
      }

      .app {
        max-width: none;
        padding: 0;
      }

      .layout,
      .split {
        display: block;
      }

      .panel {
        border: 0;
        box-shadow: none;
        padding: 0;
      }

      .table-wrap {
        overflow: visible;
        border: 1px solid #999;
      }

      table {
        min-width: 0;
        font-size: 10px;
      }

      th,
      td {
        border-color: #999;
        padding: 4px;
      }

      .weekly-print-active .monthly-print-section {
        display: none !important;
      }

      .monthly-print-active .weekly-print-section {
        display: none !important;
      }

      .weekly-print-active .weekly-print-section {
        display: block !important;
      }

      .weekly-print-section {
        page-break-after: avoid;
      }

      .rest-summary {
        padding: 6px 8px;
      }

      .rest-summary-title {
        margin-bottom: 5px;
        font-size: 11px;
      }

      .rest-count-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 4px;
      }

      .rest-count-item {
        border-radius: 0;
        padding: 4px 5px;
        font-size: 9px;
      }

      .rest-count-item strong,
      .rest-count-item .rest-meta {
        font-size: 9px;
      }
    }


    .paper-cell-list {
      display: grid;
      gap: 8px;
      max-height: 280px;
      overflow: auto;
    }

    .paper-cell-row,
    .paper-unified-row {
      display: grid;
      grid-template-columns: 88px 72px 70px 1fr 90px;
      gap: 8px;
      align-items: center;
      padding: 8px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fff;
      font-size: 13px;
    }

    .paper-unified-row {
      grid-template-columns: 88px 72px 1fr 90px 120px;
    }

    .timeline-note {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px;
    }

    .warning-list {
      display: grid;
      gap: 6px;
      max-height: 240px;
      overflow: auto;
    }

    .warning-item {
      border: 1px solid #f3d7a3;
      background: #fff8e8;
      border-radius: 8px;
      padding: 7px 8px;
      font-size: 12px;
    }

    @media (max-width: 760px) {
      .paper-cell-row,
      .paper-unified-row {
        grid-template-columns: 1fr;
      }
    }

  
    .release-gate-panel {
      margin: 12px 0;
      padding: 14px;
      border: 2px solid #9ca3af;
      border-radius: 12px;
      background: #f8fafc;
    }
    .release-gate-panel.pass {
      border-color: #16a34a;
      background: #f0fdf4;
    }
    .release-gate-panel.fail {
      border-color: #dc2626;
      background: #fef2f2;
    }
    .release-gate-title {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .release-gate-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 8px;
      margin-bottom: 10px;
    }
    .release-gate-card {
      padding: 10px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      background: white;
      line-height: 1.5;
    }
    .release-save-button[disabled] {
      opacity: .45;
      cursor: not-allowed;
    }


    .release-gate-status-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .release-gate-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 13px;
      background: #e5e7eb;
      color: #374151;
    }
    .release-gate-panel.pass .release-gate-badge {
      background: #dcfce7;
      color: #166534;
    }
    .release-gate-panel.fail .release-gate-badge {
      background: #fee2e2;
      color: #991b1b;
    }
    .release-gate-time {
      font-size: 12px;
      color: #64748b;
    }
    .release-gate-card .metric-ok {
      color: #166534;
      font-weight: 700;
    }
    .release-gate-card .metric-ng {
      color: #b91c1c;
      font-weight: 700;
    }
    .release-action-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }


    .workflow-panel {
      margin: 14px;
      padding: 16px;
      border: 2px solid #1f2937;
      border-radius: 14px;
      background: #ffffff;
    }
    .workflow-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .workflow-title {
      font-size: 22px;
      font-weight: 800;
    }
    .workflow-state {
      padding: 6px 12px;
      border-radius: 999px;
      background: #e5e7eb;
      font-weight: 800;
    }
    .workflow-state.ok {
      background: #dcfce7;
      color: #166534;
    }
    .workflow-state.warn {
      background: #fef3c7;
      color: #92400e;
    }
    .workflow-state.ng {
      background: #fee2e2;
      color: #991b1b;
    }
    .workflow-steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 8px;
      margin: 12px 0;
    }
    .workflow-step {
      padding: 10px;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      background: #f8fafc;
    }
    .workflow-step.active {
      border-color: #0f766e;
      background: #f0fdfa;
    }
    .workflow-step.done {
      border-color: #16a34a;
      background: #f0fdf4;
    }
    .workflow-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 12px 0;
    }
    .workflow-summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 8px;
    }
    .workflow-summary-card {
      padding: 10px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      background: #fff;
    }
    .workflow-audit-list {
      margin-top: 10px;
      padding: 10px;
      border-radius: 10px;
      background: #f8fafc;
      white-space: pre-wrap;
      font-size: 13px;
    }
    .workflow-locked {
      opacity: .7;
      pointer-events: none;
    }
    .staff-advanced-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

</style>

<style id="nativeFusionStyles">
#nativeFusionBar{
  position:sticky;
  top:0;
  z-index:99999;
  background:#0f172a;
