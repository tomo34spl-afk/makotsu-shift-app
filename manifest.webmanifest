          "9-13": ["赤瀬", "グルン", "永井", "下田", "ミミ", "芳澤"],
          "13-17": ["扇町 店長（齋藤）", "赤瀬", "グルン", "ミミ", "芳澤", "ゆうな"],
          "17-22": ["芳澤", "ミミ", "扇町 店長（齋藤）", "分部", "下田", "工藤"],
          "22-6": ["木村", "河野", "宮崎", "ディパック", "中込", "ミミ"]
        },
