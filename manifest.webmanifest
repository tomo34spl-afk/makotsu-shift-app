                  </select>
                </label>
                <button class="btn primary" id="runSavedValidationCurrentBtn" type="button">保存済み結果を検証</button>
                <button class="btn" id="runSavedValidationJsonBtn" type="button">JSON欄の保存済み結果を検証</button>
                <button class="btn" id="runSavedRepairPreviewCurrentBtn" type="button">今の画面の差分を適用プレビュー（非推奨）</button>
                <button class="btn primary" id="runNoMasterGenerationJsonBtn" type="button">JSON欄のフル保存JSONで正本なし過剰分散実行</button>
                <button class="btn" id="runNoMasterGenerationCurrentBtn" type="button">今の画面で正本なし強制生成</button>
                <button class="btn" id="runSavedRepairPreviewJsonBtn" type="button">JSON欄のフル保存JSONで差分プレビュー（正本あり検証用）</button>
                <button class="btn" id="runValidationCurrentBtn" type="button">再生成して検証（旧診断）</button>
                <button class="btn" id="runValidationJsonBtn" type="button">JSON欄を再生成検証（旧診断）</button>
                <button class="btn" id="copyValidationResultBtn" type="button">検証結果JSONコピー</button>
                <button class="btn" id="saveValidationResultBtn" type="button">検証結果JSONを保存</button>
                <span id="validationExportStatus" style="margin-left:8px;font-weight:700;"></span>
              </div>
              <textarea id="validationOutput" class="textarea" placeholder="検証結果JSONがここに出ます"></textarea>
            </div>
          </div>
        </section>
