          "河野": ["22-2"],
          "宮崎": ["22-2"],
          "ディパック": ["22-2"],
          "中込": ["22-6"]
        },
        dowPersonTime: {
          "赤瀬": { "月": ["9-17"], "水": ["9-17"], "金": ["9-17"] },
          "グルン": { "火": ["9-17"], "木": ["9-17"], "月": ["9-13", "9-14"], "金": ["9-13", "9-14"] },
          "永井": { "火": ["9-16", "9-17"], "木": ["9-16", "9-17"] },
          "下田": { "水": ["9-15"], "土": ["9-15"], "日": ["9-15"], "木": ["17-22"] },
          "分部": { "月": ["21-24"], "火": ["21-24"], "水": ["21-24"], "木": ["21-24"], "金": ["21-24"] }
        },
        penaltyByPersonSlot: {
          "分部": ["6-9", "9-13", "13-17"],
          "芳澤": ["22-6"],
          "下田": ["6-9", "22-6"],
          "塚脇": ["13-17", "17-22", "22-6"]
        }
      },
      miyanoshita: {
        bySlot: {
          "6-9": ["笹島", "柴田まちこ", "山崎", "松本"],
          "9-13": ["高橋(宮下)", "西村", "幸本", "古屋", "山崎"],
          "13-17": ["古屋", "高橋(宮下)", "西村", "宮下 店長（小島）", "柴田かずや", "柴田かずき"],
          "17-22": ["宮下 店長（小島）", "松本", "山崎", "柴田かずや", "柴田かずき", "鈴木（たいせい）", "金子", "下田", "芳澤"],
          "22-6": ["笹島", "松本"]
        },
        byPersonTime: {
          "笹島": ["22-9", "22-6", "24-6", "24-9", "6-9"],
          "宮下 店長（小島）": ["15-24", "13-22", "12-21"],
          "松本": ["6-9", "6-15", "18-24", "24-6"],
          "山崎": ["6-9", "9-18", "17-24", "18-24"],
          "柴田まちこ": ["6-9"],
          "高橋(宮下)": ["9-17", "13-17", "12-18"],
          "西村": ["9-17", "12-17"],
          "古屋": ["9-13", "12-17"],
          "鈴木（たいせい）": ["16-20"],
          "金子": ["17-22"],
          "柴田かずや": ["6-9", "9-17", "12-18", "13-22", "17-21"],
          "柴田かずき": ["6-9", "9-17", "12-18", "13-22", "17-21"],
          "下田": ["18-24"],
          "芳澤": ["18-24", "19-24"]
        },
        dowPersonTime: {},
        penaltyByPersonSlot: {}
      }
    };

    let teacherStatsCache = new Map();

    function weekStartIsoFor(dateIso) {
      return iso(mondayOf(new Date(`${dateIso}T00:00:00`)));
    }

    function teacherRowsForStore(storeKey, targetDateIso = "") {
      const cells = (state.teacherPaperCells || []).filter(cell => cell.storeKey === storeKey);
      if (!cells.length) return [];
      const targetWeek = targetDateIso ? weekStartIsoFor(targetDateIso) : "";
      return integratePaperCells(cells).unified
        .filter(row => row.storeKey === storeKey)
        .filter(row => !targetWeek || weekStartIsoFor(row.dateIso) !== targetWeek)
        .filter(row => {
          const person = findStaff(row.name);
          return !person || !isInactiveStaff(person);
        });
    }

    function teacherWeightFor(rowDateIso, targetDateIso) {
      if (!rowDateIso || !targetDateIso) return 1;
      const rowDate = new Date(`${rowDateIso}T00:00:00`);
      const targetDate = new Date(`${targetDateIso}T00:00:00`);
      const diffDays = Math.max(0, Math.round((targetDate - rowDate) / 86400000));
      if (diffDays <= 7) return 1.85;
      if (diffDays <= 14) return 1.55;
      if (diffDays <= 28) return 1.25;
      return 1;
    }

    function incMap(map, key, value = 1) {
      map.set(key, (map.get(key) || 0) + value);
    }

    function getTeacherStats(storeKey, targetDateIso = "") {
      const cacheKey = `${storeKey}|${targetDateIso || "all"}|${(state.teacherPaperCells || []).length}`;
      if (teacherStatsCache.has(cacheKey)) return teacherStatsCache.get(cacheKey);
      const rows = teacherRowsForStore(storeKey, targetDateIso).map(row => {
        const date = new Date(`${row.dateIso}T00:00:00`);
        return { ...row, name: canonicalStaffNameForStore(row.name, row.storeKey || storeKey), time: normalizeTimeInput(row.time) || row.time, dow: dowLabel(date), weight: teacherWeightFor(row.dateIso, targetDateIso) };
      });
      const stats = {
        rows,
        personCount: new Map(),
        personTime: new Map(),
        personDowTime: new Map(),
        slotPerson: new Map(),
        slotPersonTime: new Map(),
        dowSlotPerson: new Map(),
        dowSlotPersonTime: new Map(),
        slotCount: new Map(),
        patternCount: new Map()
      };
      rows.forEach(row => {
        const person = row.name;
        const time = row.time;
        const dow = row.dow;
        const weight = row.weight || 1;
        incMap(stats.personCount, person, weight);
        incMap(stats.personTime, `${person}|${time}`, weight);
        incMap(stats.personDowTime, `${person}|${dow}|${time}`, weight);
        incMap(stats.patternCount, `${storeKey}|${dow}|${person}|${time}`, 1);
        assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).forEach(slot => {
          incMap(stats.slotCount, slot, weight);
          incMap(stats.slotPerson, `${slot}|${person}`, weight);
          incMap(stats.slotPersonTime, `${slot}|${person}|${time}`, weight);
          incMap(stats.dowSlotPerson, `${dow}|${slot}|${person}`, weight);
          incMap(stats.dowSlotPersonTime, `${dow}|${slot}|${person}|${time}`, weight);
        });
      });
      teacherStatsCache.set(cacheKey, stats);
      return stats;
    }

    function builtInTeacherHintScore(dateIso, storeKey, personName, time, slot = null) {
      const rules = teacherPatternHints[storeKey] || {};
      const name = canonicalStaffName(personName);
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      let score = 0;
      const personTimes = (rules.byPersonTime && rules.byPersonTime[name]) || [];
      const timeIndex = personTimes.indexOf(time);
      if (timeIndex >= 0) score += Math.max(70, 210 - timeIndex * 22);
      if (slot) {
        const slotNames = (rules.bySlot && rules.bySlot[slot]) || [];
        const slotIndex = slotNames.findIndex(item => canonicalStaffName(item) === name);
        if (slotIndex >= 0) score += Math.max(35, 130 - slotIndex * 16);
        const penalties = (rules.penaltyByPersonSlot && rules.penaltyByPersonSlot[name]) || [];
        if (penalties.includes(slot)) score -= 260;
      }
      const dowTimes = ((rules.dowPersonTime || {})[name] || {})[dow] || [];
      if (dowTimes.includes(time)) score += 260;
      else if (dowTimes.length && slot && dowTimes.some(t => overlapsSlot(t, slot))) score += 130;
      return score;
    }

    function teacherLearningScore(dateIso, storeKey, person, time, slot = null) {
      if (!person || !storeKey || !time) return 0;
      const name = canonicalStaffName(person.name);
      let score = builtInTeacherHintScore(dateIso, storeKey, name, time, slot);
      const stats = getTeacherStats(storeKey, dateIso);
      if (!stats.rows.length) return score;
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      const personSeen = stats.personCount.get(name) || 0;
      const personTime = stats.personTime.get(`${name}|${time}`) || 0;
      const personDowTime = stats.personDowTime.get(`${name}|${dow}|${time}`) || 0;
      score += Math.min(430, personDowTime * 170);
      score += Math.min(300, personTime * 90);
      score += Math.min(120, personSeen * 11);
      if (slot) {
        score += Math.min(360, (stats.dowSlotPersonTime.get(`${dow}|${slot}|${name}|${time}`) || 0) * 190);
        score += Math.min(260, (stats.slotPersonTime.get(`${slot}|${name}|${time}`) || 0) * 110);
        score += Math.min(210, (stats.dowSlotPerson.get(`${dow}|${slot}|${name}`) || 0) * 85);
        score += Math.min(170, (stats.slotPerson.get(`${slot}|${name}`) || 0) * 50);
        if ((stats.slotCount.get(slot) || 0) >= 5 && !(stats.slotPerson.get(`${slot}|${name}`) || 0) && !hasTag(person, "希望提出型")) score -= 95;
      }
      if (!personSeen && !hasTag(person, "希望提出型") && !isCoreEmployee(person) && !person.support) score -= 170;
      if (personSeen && !personTime && !hasTag(person, "希望提出型")) score -= 65;
      return score;
    }

    function teacherPreferredTimesFor(personName, storeKey, dateIso = "") {
      const name = canonicalStaffName(personName);
      const dow = dateIso ? dowLabel(new Date(`${dateIso}T00:00:00`)) : "";
      const stats = getTeacherStats(storeKey, dateIso);
      const fromRows = stats.rows
        .filter(row => row.name === name)
        .map(row => ({ time: row.time, score: (row.dow === dow ? 100 : 0) + (row.weight || 1) * 10 }));
      const rules = teacherPatternHints[storeKey] || {};
      const hintTimes = [...(((rules.dowPersonTime || {})[name] || {})[dow] || []), ...(((rules.byPersonTime || {})[name]) || [])]
        .map((time, index) => ({ time, score: 90 - index }));
      return mergeUnique([...fromRows, ...hintTimes]
        .sort((a, b) => b.score - a.score)
        .map(row => row.time))
        .slice(0, 8);
    }

    function hasExactRieMasterRow(dateIso, storeKey, personName, time) {
      const name = canonicalStaffName(personName);
      return rieMasterRowsForDateStore(dateIso, storeKey).some(row => (
        canonicalStaffName(row.name) === name && row.time === time
      ));
    }

    function hasRieMasterPerson(dateIso, storeKey, personName) {
      const name = canonicalStaffName(personName);
      return rieMasterRowsForDateStore(dateIso, storeKey).some(row => canonicalStaffName(row.name) === name);
    }

    function bestRieMasterTimeScoreForPerson(dateIso, storeKey, personName, time) {
      const name = canonicalStaffName(personName);
      const rows = rieMasterRowsForDateStore(dateIso, storeKey).filter(row => canonicalStaffName(row.name) === name);
      if (!rows.length) return -220;
      return Math.max(...rows.map(row => timeSimilarityScore(row.time, time)));
    }

    function slotPreferenceRank(storeKey, slot, personName) {
      const rules = storeBrainCore[storeKey] || storeBrainCore.miyanoshita;
      const list = (rules.preferredBySlot && rules.preferredBySlot[slot]) || [];
      const name = canonicalStaffName(personName);
      const index = list.findIndex(item => canonicalStaffName(item) === name);
      return index;
    }

    function storeBrainScore(dateIso, storeKey, person, time, slot = null, options = {}) {
      if (!person || !storeKey || !time) return 0;
      const rules = storeBrainCore[storeKey] || storeBrainCore.miyanoshita;
      const name = canonicalStaffName(person.name);
      const rows = rieMasterRowsForDateStore(dateIso, storeKey);
      const hasMaster = rows.length > 0;
      let score = 0;

      if (slot) {
        const rank = slotPreferenceRank(storeKey, slot, person.name);
        if (rank >= 0) score += Math.max(25, 180 - rank * 24);
      }

      if (hasMaster) {
        const exact = hasExactRieMasterRow(dateIso, storeKey, person.name, time);
        const inMaster = hasRieMasterPerson(dateIso, storeKey, person.name);
        if (exact) score += 1250;
        else if (inMaster) {
          const fit = bestRieMasterTimeScoreForPerson(dateIso, storeKey, person.name, time);
          score += Math.max(-260, fit + 180);
          if (fit < 80) score -= 190;
        } else {
          const slotRows = slot ? rows.filter(row => overlapsSlot(row.time, slot)) : rows;
          score -= slotRows.length ? 360 : 160;
        }
      }

      const discouraged = (rules.discourageIfNotMaster || []).some(item => canonicalStaffName(item) === name);
      if (discouraged && hasMaster && !hasExactRieMasterRow(dateIso, storeKey, person.name, time)) {
        score -= 260;
      }

      // 扇町は夕方・深夜の核メンバーを強める。分部は21-24以外の便利埋めを落とす。
      if (storeKey === "ougicho") {
        if (slot === "17-22" && ["芳澤", "ミミ", "扇町 店長（齋藤）", "下田", "工藤", "分部"].some(item => canonicalStaffName(item) === name)) score += 140;
        if (slot === "22-6" && ["木村", "河野", "宮崎", "ディパック", "加藤"].some(item => canonicalStaffName(item) === name)) score += 180;
        if (name === canonicalStaffName("分部") && time !== "21-24") score -= 520;
        if (name === canonicalStaffName("芳澤") && slot && !["17-22", "6-9", "13-17"].includes(slot) && !hasExactRieMasterRow(dateIso, storeKey, person.name, time)) score -= 180;
      }

      // 東町は下田・夕方組・夜勤組の正本時間を強める。キーズ等の便利埋めは正本外なら落とす。
      if (storeKey === "higashicho") {
        if (slot === "17-22" && ["柳川", "高橋(東町)", "高木", "ミミ", "工藤", "松永", "富田"].some(item => canonicalStaffName(item) === name)) score += 130;
        if (slot === "13-17" && ["富田", "東町 店長（小澤）", "守屋", "柳川", "ダハム"].some(item => canonicalStaffName(item) === name)) score += 120;
        if (slot === "22-6" && ["加藤", "工藤", "ミミ", "山梨", "碓井"].some(item => canonicalStaffName(item) === name)) score += 150;
        if (name === canonicalStaffName("下田") && (time === "6-15" || time === "9-15")) score += 220;
      }

      return score;
    }

    function isStoreBrainAnchorRow(row, storeKey) {
      const rules = storeBrainCore[storeKey] || storeBrainCore.miyanoshita;
      const name = canonicalStaffName(row && row.name);
      if (!name || !row || !row.time) return false;
      const anchorName = (rules.anchorNames || []).some(item => canonicalStaffName(item) === name);
      if (!anchorName) return false;
      const phase = timePhase(row.time);
      if (phase === "evening" || phase === "night") return true;
      if (storeKey === "higashicho" && name === canonicalStaffName("下田")) return true;
      if (storeKey === "higashicho" && ["守屋", "富田", "柳川", "高橋(東町)"].some(item => canonicalStaffName(item) === name)) return true;
      if (storeKey === "ougicho" && ["芳澤", "ミミ", "下田", "グルン", "扇町 店長（齋藤）"].some(item => canonicalStaffName(item) === name)) return true;
      return false;
    }

    function prefillStoreBrainMasterAnchorsForDate(dateIso, storeKey, options = {}) {
      const rows = rieMasterRowsForDateStore(dateIso, storeKey)
        .filter(row => isStoreBrainAnchorRow(row, storeKey))
        .sort((a, b) => rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey));
      let added = 0;
      rows.forEach(row => {
        if (addRieMasterAnchorRow(row, options)) {
          added += 1;
          if (options.loadMap) {
            const person = findStaff(row.name);
            const key = person ? person.name : canonicalStaffName(row.name);
            options.loadMap.set(key, (options.loadMap.get(key) || 0) + 1);
          }
        }
      });
      return added;
    }

    function rieMasterSortScore(row, storeKey) {
      const person = findStaff(row.name);
      const [start, end] = parseRange(row.time);
      const hours = Math.max(1, end - start);
      let score = hours * 10;
      if (person && (isCoreEmployee(person) || hasTag(person, "店長") || hasTag(person, "責任者候補"))) score += 500;
      if (start >= 21 || end > 24) score += 300;
      if (start <= 17 && end >= 21) score += 220;
      if (requiresResponsibleCompanion(person)) score -= 200;
      if (row.time === "13-22" || row.time === "15-24" || row.time === "21-6" || row.time === "24-9") score += 120;
      return score;
    }

    function candidateTimesForRieMasterRow(person, row, storeKey) {
      const base = candidateTimesForGeneration(person, storeKey, row.dateIso);
      return mergeUnique([row.time, ...base])
        .filter(Boolean)
        .sort((a, b) => timeSimilarityScore(row.time, b) - timeSimilarityScore(row.time, a));
    }

    function prefillRieMasterGuidedDate(dateIso, storeKey, options = {}) {
      const rows = rieMasterRowsForDateStore(dateIso, storeKey);
      if (!rows.length) return 0;
      const guidedOptions = {
        ...options,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        respectCapacity: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 9,
        allowSupport: true,
        allowHopeOnlyPlacement: true,
        masterOverride: true,
        allowSplitShiftMaster: true,
        allowCrossStoreSplitMaster: true,
        preventDoubleBooking: true
      };
      let addedCount = 0;
      const sorted = [...rows]
        .sort((a, b) => rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey));
      for (let pass = 0; pass < 2; pass += 1) {
        sorted.forEach(row => {
          const person = findStaff(row.name);
          if (!person) return;
          const companionOnly = requiresResponsibleCompanion(person);
          if (pass === 0 && companionOnly) return;
          if (pass === 1 && !companionOnly) return;
          const existing = personAssignmentsForDay(dateIso, person.name).filter(assignment => assignment.storeKey === storeKey);
          if (existing.some(assignment => assignment.time === row.time)) return;
          if (existing.some(assignment => rangeOverlapHours(assignment.time, row.time) > 0)) return;
          const times = candidateTimesForRieMasterRow(person, row, storeKey);
          for (const time of times) {
            const wasAssigned = isAssignedAnywhere(dateIso, person.name);
            const added = addShiftToDay(dateIso, storeKey, person, time, guidedOptions);
            if (added) {
              if (!wasAssigned && options.loadMap) options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
              addedCount += 1;
              break;
            }
          }
        });
      }
      return addedCount;
    }

    function workPatternScore(person, storeKey, time, slot = null) {
      const patterns = preferredPatternsFor(person, storeKey);
      const index = patterns.indexOf(time);
      let score = index >= 0 ? Math.max(20, 150 - index * 18) : 0;
      const [start, end] = parseRange(time);
      if (slot === "17-22" && (start <= 18 && end >= 21)) score += 35;
      if (slot === "13-17" && (start <= 15 && end >= 17)) score += 20;
      if (slot === "22-6" && (start >= 21 || end > 24)) score += 45;
      if (slot === "6-9" && end > 24 && end >= 33) score += 28;
      if (slot === "6-9" && start <= 6 && end >= 9) score += 12;
      return score;
    }

    function timePhase(time) {
      const [start, end] = parseRange(time);
      if (start >= 21 || end > 24) return "night";
      if (start >= 16 || end >= 21) return "evening";
      if (start >= 12 || end >= 17) return "day";
      return "morning";
    }

    function phaseSlots(phase) {
      if (phase === "night") return ["22-6"];
      if (phase === "evening") return ["17-22"];
      if (phase === "day") return ["13-17"];
      return ["6-9", "9-13"];
    }

    function patternShortageScore(dateIso, storeKey, time, options = {}) {
      return assignmentSlots(time, { ...options, allowPartialOverlap: true }).reduce((sum, slot) => {
        const cell = ensureCell(dateIso, storeKey, slot);
        return sum + Math.max(0, targetRequirementForSlot(dateIso, storeKey, slot, options) - cell.length) * 55;
      }, 0);
    }

    function prefillPreferredPatternPhase(dateIso, storeKey, phase, options = {}) {
      const patternOptions = { ...options, allowPartialOverlap: true, requireFullSlotCoverage: false };
      let addedCount = 0;
      let guard = 0;
      const targets = phaseSlots(phase);
      const hasTargetShortage = () => targets.some(slot => ensureCell(dateIso, storeKey, slot).length < targetRequirementForSlot(dateIso, storeKey, slot, patternOptions));
      while (hasTargetShortage() && guard < 12) {
        const rows = staff
          .filter(person => !person.support && !isInactiveStaff(person) && canWorkAtStore(person, storeKey))
          .filter(person => canAutoUsePerson(person, dateIso, storeKey))
          .filter(person => !isPersonAssignedOnDate(dateIso, person.name))
          .filter(person => matchesDay(person, dateIso))
          .filter(person => !isUnavailable(person.name, dateIso))
          .flatMap(person => candidateTimesForGeneration(person, storeKey, dateIso)
            .filter(time => timePhase(time) === phase || assignmentSlots(time, patternOptions).some(slot => targets.includes(slot)))
            .map(time => ({ person, time })))
          .filter(row => canPlaceShift(dateIso, storeKey, row.person, row.time, patternOptions))
          .map(row => {
            const targetBonus = assignmentSlots(row.time, patternOptions).some(slot => targets.includes(slot)) ? 60 : 0;
            const shortage = patternShortageScore(dateIso, storeKey, row.time, patternOptions);
            const coreBonus = isCoreEmployee(row.person) ? coreRestBalanceScore(row.person, dateIso, options) + 20 : 0;
            const score = shortage + targetBonus + workPatternScore(row.person, storeKey, row.time, targets[0]) + rieMasterMatchScore(dateIso, storeKey, row.person, row.time, targets[0]) + teacherLearningScore(dateIso, storeKey, row.person, row.time, targets[0]) + storeBrainScore(dateIso, storeKey, row.person, row.time, targets[0], options) + eastPostWadaAndHopeControlScore(row.person, storeKey, targets[0], dateIso, row.time) + coreBonus + restScore(row.person, targets[0], dateIso);
            return { ...row, score };
          })
          .filter(row => row.score > 45)
          .sort((a, b) => b.score - a.score);
        const picked = rows[0];
        if (!picked) break;
        const wasAssigned = isAssignedAnywhere(dateIso, picked.person.name);
        const added = addShiftToDay(dateIso, storeKey, picked.person, picked.time, patternOptions);
        if (added) {
          if (!wasAssigned && options.loadMap) options.loadMap.set(picked.person.name, (options.loadMap.get(picked.person.name) || 0) + 1);
          addedCount += 1;
        }
        guard += 1;
      }
      return addedCount;
    }

    function rieTargetRequirementForSlot(dateIso, storeKey, slot) {
      const base = requirement(storeKey, slot);
      if (!Array.isArray(state.rieMaster) || !state.rieMaster.length) return base;
      const hasMasterForDateStore = state.rieMaster.some(row => row.dateIso === dateIso && row.storeKey === storeKey);
      if (!hasMasterForDateStore) return base;
      const [start, end] = parseRange(slot);
      let maxCount = 0;
      for (let hour = start; hour < end; hour += 1) {
        maxCount = Math.max(maxCount, rieHourlyCoverage(dateIso, storeKey, hour % 24).length);
      }
      return Math.max(base, maxCount);
    }

    function targetRequirementForSlot(dateIso, storeKey, slot, options = {}) {
      if (options && options.useRieTargets === false) return requirement(storeKey, slot);
      return rieTargetRequirementForSlot(dateIso, storeKey, slot);
    }

    function shortageForSlot(dateIso, storeKey, slot, options = {}) {
      const cell = ensureCell(dateIso, storeKey, slot);
      return Math.max(0, targetRequirementForSlot(dateIso, storeKey, slot, options) - cell.length);
    }

    function totalShortageForDate(dateIso, storeKey) {
      return slots.reduce((sum, slot) => sum + shortageForSlot(dateIso, storeKey, slot), 0);
    }

    function patternCoverageScoreForSlot(dateIso, storeKey, time, slot, options = {}) {
      const targets = assignmentSlots(time, { ...options, allowPartialOverlap: true, requireFullSlotCoverage: false });
      const shortageGain = targets.reduce((sum, targetSlot) => {
        const shortage = shortageForSlot(dateIso, storeKey, targetSlot);
        if (targetSlot === slot) return sum + shortage * 90;
        return sum + shortage * 42;
      }, 0);
      const overfillPenalty = targets.reduce((sum, targetSlot) => {
        const cell = ensureCell(dateIso, storeKey, targetSlot);
        const over = Math.max(0, cell.length + 1 - targetRequirementForSlot(dateIso, storeKey, targetSlot, options));
        return sum + over * (targetSlot === slot ? 8 : 20);
      }, 0);
      const [start, end] = parseRange(time);
      const hours = Math.max(1, end - start);
      return shortageGain - overfillPenalty - Math.max(0, hours - 9) * 5;
    }

    function finalFillCandidateRows(dateIso, storeKey, slot, options = {}) {
      const fillOptions = {
        ...options,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        respectCapacity: false,
        enforceCoreWorkLimit: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 7,
        allowSupport: true,
        preventDoubleBooking: false
      };
      return staff
        .filter(person => !isInactiveStaff(person) && canWorkAtStore(person, storeKey))
        .filter(person => canAutoUsePerson(person, dateIso, storeKey))
        .filter(person => matchesDay(person, dateIso))
        .filter(person => !isUnavailable(person.name, dateIso))
        .filter(person => {
          const existing = personAssignmentsForDay(dateIso, person.name);
          if (!existing.length) return true;
          return existing.every(row => row.storeKey === storeKey);
        })
        .filter(person => !hasIncompatiblePerson(dateIso, storeKey, person.name))
        .flatMap(person => candidateTimesForGeneration(person, storeKey, dateIso)
          .filter(time => overlapsSlot(time, slot))
          .map(time => ({ person, time })))
        .filter(row => {
          if (hasTag(row.person, "希望日だけ配置") && !hasSubmittedWorkRequestTime(dateIso, storeKey, row.person.name, row.time)) return false;
          if (!canAddNonOverlappingSplitShift(dateIso, storeKey, row.person.name, row.time)) return false;
          return canPlaceShift(dateIso, storeKey, row.person, row.time, fillOptions);
        })
        .map(row => {
          const targets = assignmentSlots(row.time, fillOptions);
          const targetHit = targets.includes(slot) ? 140 : 0;
          const supportPenalty = row.person.support ? 45 : 0;
          const coreBonus = isCoreEmployee(row.person) ? Math.max(0, coreRestBalanceScore(row.person, dateIso, options)) * 0.15 : 0;
          const fixedBonus = isFixedPerson(row.person) ? 18 : 0;
          const load = options.loadMap ? (options.loadMap.get(row.person.name) || 0) : 0;
          const score = targetHit
            + patternCoverageScoreForSlot(dateIso, storeKey, row.time, slot, fillOptions)
            + timeFitScore(row.person, row.time, slot)
            + workPatternScore(row.person, storeKey, row.time, slot)
            + rieMasterMatchScore(dateIso, storeKey, row.person, row.time, slot)
            + teacherLearningScore(dateIso, storeKey, row.person, row.time, slot)
            + storeBrainScore(dateIso, storeKey, row.person, row.time, slot, options)
            + eastPostWadaAndHopeControlScore(row.person, storeKey, slot, dateIso, row.time)
            + coreBonus
            + fixedBonus
            + restScore(row.person, slot, dateIso)
            - supportPenalty
            - load * (isCoreEmployee(row.person) ? 0.15 : 1.2);
          return { ...row, score, targets, options: fillOptions };
        })
        .filter(row => row.score > -700)
        .sort((a, b) => b.score - a.score);
    }

    function fillRemainingShortagesForDate(dateIso, storeKey, options = {}) {
      let addedCount = 0;
      let guard = 0;
      while (totalShortageForDate(dateIso, storeKey) > 0 && guard < 80) {
        if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
          if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
          break;
        }
        const targetSlot = [...slots]
          .filter(slot => shortageForSlot(dateIso, storeKey, slot) > 0)
          .sort((a, b) => shortageForSlot(dateIso, storeKey, b) - shortageForSlot(dateIso, storeKey, a))[0];
        if (!targetSlot) break;
        const picked = finalFillCandidateRows(dateIso, storeKey, targetSlot, options)[0];
        if (!picked) break;
        const wasAssigned = isAssignedAnywhere(dateIso, picked.person.name);
        const added = addShiftToDay(dateIso, storeKey, picked.person, picked.time, picked.options);
        if (!added) break;
        if (!wasAssigned && options.loadMap) {
          options.loadMap.set(picked.person.name, (options.loadMap.get(picked.person.name) || 0) + 1);
        }
        addedCount += 1;
        guard += 1;
      }
      return addedCount;
    }

    function hardFillCandidateRows(dateIso, storeKey, slot, options = {}) {
      const hardOptions = {
        ...options,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        respectCapacity: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 9,
        allowSupport: true,
        preventDoubleBooking: false
      };
      return staff
        .filter(person => !isInactiveStaff(person) && canWorkAtStore(person, storeKey))
        .filter(person => canAutoUsePerson(person, dateIso, storeKey))
        .filter(person => matchesDay(person, dateIso))
        .filter(person => !isUnavailable(person.name, dateIso))
        .filter(person => {
          const existing = personAssignmentsForDay(dateIso, person.name);
          if (!existing.length) return true;
          return existing.every(row => row.storeKey === storeKey);
        })
        .filter(person => !hasIncompatiblePerson(dateIso, storeKey, person.name))
        .flatMap(person => {
          const preferred = candidateTimesForGeneration(person, storeKey, dateIso)
            .filter(time => overlapsSlot(time, slot));
          const fallback = preferred.length ? [] : [slot];
          return mergeUnique([...preferred, ...fallback]).map(time => ({ person, time }));
        })
        .filter(row => {
          if (hasTag(row.person, "希望日だけ配置") && !hasSubmittedWorkRequestTime(dateIso, storeKey, row.person.name, row.time)) return false;
          if (!canAddNonOverlappingSplitShift(dateIso, storeKey, row.person.name, row.time)) return false;
          return canPlaceShift(dateIso, storeKey, row.person, row.time, hardOptions);
        })
        .map(row => {
          const targets = assignmentSlots(row.time, hardOptions);
          const exactBonus = row.time === slot ? 80 : 0;
          const targetBonus = targets.includes(slot) ? 120 : 0;
          const supportPenalty = row.person.support ? 20 : 0;
          const fixedBonus = isFixedPerson(row.person) ? 18 : 0;
          const coreBonus = isCoreEmployee(row.person) ? Math.max(0, coreRestBalanceScore(row.person, dateIso, options)) * 0.1 : 0;
          const load = options.loadMap ? (options.loadMap.get(row.person.name) || 0) : 0;
          const score = targetBonus
            + exactBonus
            + timeFitScore(row.person, row.time, slot)
            + workPatternScore(row.person, storeKey, row.time, slot)
            + rieMasterMatchScore(dateIso, storeKey, row.person, row.time, slot)
            + teacherLearningScore(dateIso, storeKey, row.person, row.time, slot)
            + storeBrainScore(dateIso, storeKey, row.person, row.time, slot, options)
            + eastPostWadaAndHopeControlScore(row.person, storeKey, slot, dateIso, row.time)
            + fixedBonus
            + coreBonus
            + restScore(row.person, slot, dateIso)
            - supportPenalty
            - load * (isCoreEmployee(row.person) ? 0.1 : 0.65);
          return { ...row, score, options: hardOptions };
        })
        .filter(row => row.score > -2200)
        .sort((a, b) => b.score - a.score);
    }

    function hardFillRemainingShortagesForDate(dateIso, storeKey, options = {}) {
      let addedCount = 0;
      let guard = 0;
      while (totalShortageForDate(dateIso, storeKey) > 0 && guard < 120) {
        if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
          if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
          break;
        }
        const targetSlot = [...slots]
          .filter(slot => shortageForSlot(dateIso, storeKey, slot) > 0)
          .sort((a, b) => shortageForSlot(dateIso, storeKey, b) - shortageForSlot(dateIso, storeKey, a))[0];
        if (!targetSlot) break;
        const picked = hardFillCandidateRows(dateIso, storeKey, targetSlot, options)[0];
        if (!picked) break;
        const wasAssigned = isAssignedAnywhere(dateIso, picked.person.name);
        const added = addShiftToDay(dateIso, storeKey, picked.person, picked.time, picked.options);
        if (!added) break;
        if (!wasAssigned && options.loadMap) {
          options.loadMap.set(picked.person.name, (options.loadMap.get(picked.person.name) || 0) + 1);
        }
        addedCount += 1;
        guard += 1;
      }
      return addedCount;
    }



    function isExactRieMasterAssignment(dateIso, storeKey, assignment) {
      if (!assignment) return false;
      const name = canonicalStaffName(assignment.name);
      return rieMasterRowsForDateStore(dateIso, storeKey).some(row => (
        canonicalStaffName(row.name) === name && row.time === assignment.time
      ));
    }

    function removeWrongAssignmentsForMasterRow(row) {
      const personName = canonicalStaffName(row.name);
      const samePersonMasterTimes = rieMasterRowsForDateStore(row.dateIso, row.storeKey)
        .filter(masterRow => canonicalStaffName(masterRow.name) === personName)
        .map(masterRow => masterRow.time);
      uniqueAssignments(row.dateIso, row.storeKey).forEach(assignment => {
        if (canonicalStaffName(assignment.name) !== personName || assignment.time === row.time) return;
        const isAnotherMasterShift = samePersonMasterTimes.includes(assignment.time);
        const conflictsWithThisMaster = rangeOverlapHours(assignment.time, row.time) > 0;
        if (conflictsWithThisMaster && !isAnotherMasterShift) {
          removeShiftFromDay(row.dateIso, row.storeKey, assignment);
        }
      });
    }

    function addRieMasterAnchorRow(row, options = {}) {
      const person = findStaff(row.name);
      if (!person || isInactiveStaff(person) || !canWorkAtStore(person, row.storeKey)) return false;
      if (uniqueAssignments(row.dateIso, row.storeKey).some(assignment => (
        canonicalStaffName(assignment.name) === canonicalStaffName(person.name) && assignment.time === row.time
      ))) return false;
      removeWrongAssignmentsForMasterRow(row);
      return addShiftToDay(row.dateIso, row.storeKey, person, row.time, {
        ...options,
        masterOverride: true,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        respectCapacity: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 9,
        allowHopeOnlyPlacement: true,
        allowSplitShiftMaster: true,
        allowCrossStoreSplitMaster: true,
        preventDoubleBooking: true
      });
    }

    function syncScheduleTowardRieMasterForDates(dates, storeKey, options = generationOptions()) {
      let addedCount = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        const rows = rieMasterRowsForDateStore(dateIso, storeKey)
          .sort((a, b) => rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey));
        rows.forEach(row => {
          if (addRieMasterAnchorRow(row, options)) {
            if (options.loadMap) options.loadMap.set(canonicalStaffName(row.name), (options.loadMap.get(canonicalStaffName(row.name)) || 0) + 1);
            addedCount += 1;
          }
        });
      });
      return addedCount;
    }

    function missingMasterRow(row) {
      return !uniqueAssignments(row.dateIso, row.storeKey).some(assignment => (
        canonicalStaffName(assignment.name) === canonicalStaffName(row.name) && assignment.time === row.time
      ));
    }

    function shortageSlotsForMasterRow(row, options = {}) {
      return assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false })
        .filter(slot => shortageForSlot(row.dateIso, row.storeKey, slot, options) > 0);
    }

    function shortageGuidedMasterFitScore(row, options = {}) {
      const person = findStaff(row.name);
      if (!person || isInactiveStaff(person) || !canWorkAtStore(person, row.storeKey)) return -999999;
      const shortageSlots = shortageSlotsForMasterRow(row, options);
      if (!shortageSlots.length) return -999999;
      const [start, end] = parseRange(row.time);
      const hours = Math.max(1, end - start);
      let score = shortageSlots.length * 1200 + rieMasterSortScore(row, row.storeKey) + hours * 8;
      const phase = timePhase(row.time);
      if (phase === "night" || phase === "evening") score += 180;
      if (row.storeKey === "higashicho" && canonicalStaffName(row.name) === canonicalStaffName("下田")) score += 260;
      if (row.storeKey === "ougicho" && ["安彦", "植村", "ミミ", "芳澤", "木村", "下田"].some(item => canonicalStaffName(item) === canonicalStaffName(row.name))) score += 220;
      return score;
    }

    function shortageGuidedMasterFitForDates(dates, storeKey, options = generationOptions()) {
      // 自立生成後に「不足している枠」だけ、正本側の不足候補を追加する。
      // 36.8の正本反映とは違い、非正本を全削除しない。穴が空いている場所だけをフィットする。
      let addedCount = 0;
      for (let pass = 0; pass < 3; pass += 1) {
        let changed = false;
        dates.forEach(date => {
          const dateIso = iso(date);
          const rows = rieMasterRowsForDateStore(dateIso, storeKey)
            .filter(row => missingMasterRow(row))
            .filter(row => shortageSlotsForMasterRow(row, options).length > 0)
            .sort((a, b) => shortageGuidedMasterFitScore(b, options) - shortageGuidedMasterFitScore(a, options));
          rows.forEach(row => {
            if (!shortageSlotsForMasterRow(row, options).length) return;
            const before = uniqueAssignments(row.dateIso, row.storeKey).length;
            if (addRieMasterAnchorRow(row, options)) {
              const after = uniqueAssignments(row.dateIso, row.storeKey).length;
              if (after > before) {
                addedCount += 1;
                changed = true;
              }
            }
          });
        });
        if (!changed) break;
      }
      return addedCount;
    }

    function rowSlotsForSoftFit(row) {
      return assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
    }

    function assignmentSoftFitSlots(assignment) {
      return assignmentSlots(assignment.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
    }

    function isReplaceableNonMasterAssignment(dateIso, storeKey, assignment) {
      if (!assignment || isExactRieMasterAssignment(dateIso, storeKey, assignment)) return false;
      const person = findStaff(assignment.name);
      if (person && isFixedPerson(person) && hasExactRieMasterRow(dateIso, storeKey, person.name, assignment.time)) return false;
      return true;
    }

    function softReplaceScoreForMasterRow(row, assignment, options = {}) {
      if (!isReplaceableNonMasterAssignment(row.dateIso, row.storeKey, assignment)) return -999999;
      const targetSlots = rowSlotsForSoftFit(row);
      const assignmentSlotsCovered = assignmentSoftFitSlots(assignment);
      const overlapSlots = targetSlots.filter(slot => assignmentSlotsCovered.includes(slot)).length;
      const timeOverlap = rangeOverlapHours(row.time, assignment.time);
      const samePerson = canonicalStaffName(row.name) === canonicalStaffName(assignment.name);
      if (!overlapSlots && !samePerson) return -999999;
      const assignmentPerson = findStaff(assignment.name);
      let score = overlapSlots * 520 + timeOverlap * 90;
      if (samePerson) score += 1600;
      if (timePhase(row.time) === timePhase(assignment.time)) score += 180;
      if (assignment.support) score += 120;
      if (assignmentPerson && !isCoreEmployee(assignmentPerson)) score += 70;
      if (assignmentPerson && hasTag(assignmentPerson, "希望提出型")) score += 80;
      // 正本にいない便利埋め要員を優先的に差し替える。
      if (!hasRieMasterPerson(row.dateIso, row.storeKey, assignment.name)) score += 520;
      // 同じ枠を実際に過剰にしている人はさらに差し替え候補。
      targetSlots.forEach(slot => {
        const cell = ensureCell(row.dateIso, row.storeKey, slot);
        if (cell.length >= targetRequirementForSlot(row.dateIso, row.storeKey, slot, options)) score += 120;
      });
      return score;
    }

    function hasSoftReplaceCandidateForMasterRow(row, options = {}) {
      return uniqueAssignments(row.dateIso, row.storeKey)
        .some(assignment => softReplaceScoreForMasterRow(row, assignment, options) > -999999);
    }

    function softReplaceTowardRieMasterForDates(dates, storeKey, options = generationOptions()) {
      // 36.17: 不足は無いが「別人・別時間で埋まっている」枠を、正本の不足行で差し替える。
      // 36.8の正本反映と違い、正本にない行を全削除しない。重なっている余分候補がある時だけ動かす。
      let addedCount = 0;
      let removedCount = 0;
      for (let pass = 0; pass < 4; pass += 1) {
        let changed = false;
        dates.forEach(date => {
          const dateIso = iso(date);
          const rows = rieMasterRowsForDateStore(dateIso, storeKey)
            .filter(row => missingMasterRow(row))
            .filter(row => hasSoftReplaceCandidateForMasterRow(row, options))
            .sort((a, b) => shortageGuidedMasterFitScore(b, options) - shortageGuidedMasterFitScore(a, options));
          rows.forEach(row => {
            if (!missingMasterRow(row)) return;
            const replaceCandidate = uniqueAssignments(row.dateIso, row.storeKey)
              .map(assignment => ({ assignment, score: softReplaceScoreForMasterRow(row, assignment, options) }))
              .filter(item => item.score > -999999)
              .sort((a, b) => b.score - a.score)[0];
            if (!replaceCandidate) return;
            const beforeCount = uniqueAssignments(row.dateIso, row.storeKey).length;
            const added = addRieMasterAnchorRow(row, options);
            if (!added) return;
            addedCount += 1;
            // 追加で過剰になった枠から、対応する余分候補を一つ落とす。
            const targetSlots = rowSlotsForSoftFit(row);
            const stillExists = uniqueAssignments(row.dateIso, row.storeKey).some(assignment => assignmentKey(assignment) === assignmentKey(replaceCandidate.assignment));
            if (stillExists) {
              removeShiftFromDay(row.dateIso, row.storeKey, replaceCandidate.assignment);
              removedCount += 1;
            }
            // 直接候補以外にも過剰が残ったら既存のトリムに任せる。
            trimOverstaffingForDates(row.storeKey, [new Date(`${row.dateIso}T00:00:00`)]);
            const afterCount = uniqueAssignments(row.dateIso, row.storeKey).length;
            if (afterCount !== beforeCount || !missingMasterRow(row)) changed = true;
          });
        });
        if (!changed) break;
      }
      return { added: addedCount, removed: removedCount };
    }


    function masterAssignmentKey(rowOrAssignment) {
      return `${canonicalStaffName(rowOrAssignment && rowOrAssignment.name)}||${rowOrAssignment && rowOrAssignment.time}`;
    }

    function directAddRieMasterAssignment(row) {
      if (!row || !row.dateIso || !row.storeKey || !row.name || !row.time) return false;
      const person = findStaff(row.name);
      const displayName = person ? person.name : canonicalStaffName(row.name);
      const assignment = { name: displayName, time: row.time, support: person ? person.support : false };
      const targets = assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(row.dateIso, row.storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function directAddExactRieMasterAssignment(row) {
      if (!row || !row.dateIso || !row.storeKey || !row.name || !row.time) return false;
      const assignment = {
        name: String(row.name || "").trim(),
        time: normalizeTimeInput(row.time) || row.time,
        support: Boolean(row.support),
        masterLock: true
      };
      const targets = assignmentSlots(assignment.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(row.dateIso, row.storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function enforceExactRieMasterForDates(dates, storeKey, options = generationOptions()) {
      let added = 0;
      let removed = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        const rows = rieMasterRowsForDateStore(dateIso, storeKey);
        if (!rows.length) return;
        const masterKeys = new Set(rows.map(masterAssignmentKey));

        // 正本がある日は、非正本の自動生成行をいったん落とす。
        // これは「完全自動の採点」ではなく、紙シフト正本への追従・正本反映モード。
        slots.forEach(slot => {
          const cell = ensureCell(dateIso, storeKey, slot);
          const before = cell.length;
          state.schedule[dateIso][storeKey][slot] = cell.filter(assignment => masterKeys.has(masterAssignmentKey(assignment)));
          removed += before - state.schedule[dateIso][storeKey][slot].length;
        });

        rows
          .sort((a, b) => rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey))
          .forEach(row => {
            // 36.27: 正本参照補正ロックでは、店長などの曖昧名も正本表記のまま入れる。
            // スタッフ台帳名へ置換すると、正本突合上は別人扱いになったり、sanitizeで消えるため。
            if (directAddExactRieMasterAssignment(row)) {
              added += 1;
              if (options.loadMap) {
                const key = canonicalStaffName(row.name);
                options.loadMap.set(key, (options.loadMap.get(key) || 0) + 1);
              }
            }
          });
      });
      return { added, removed };
    }

    function ensureMinimumCoverageForDates(dates, storeKey, options = generationOptions()) {
      let totalAdded = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        totalAdded += fillRemainingShortagesForDate(dateIso, storeKey, options);
        if (totalShortageForDate(dateIso, storeKey) > 0) {
          totalAdded += hardFillRemainingShortagesForDate(dateIso, storeKey, options);
        }
      });
      return totalAdded;
    }

    function timeFitScore(person, time, slot) {
      const [start, end] = parseRange(time);
      const hours = Math.max(1, end - start);
      let score = 0;
      if (time === slot) score += 35;
      if (hours <= 4) score += 18;
      if (hours >= 9) score -= 12;
      if (hours >= 12) score -= 30;
      if (isFixedPerson(person)) score += 8;
      if (hasTag(person, "15-24優先") && time === "15-24") score += 42;
      if ((hasTag(person, "夜勤のみ") || hasTag(person, "基本夜勤")) && parseRange(time)[1] > 24) score += 22;
      if (hasTag(person, "フル夜勤NG") && parseRange(time)[1] > 24) score -= 500;
      if (hasTag(person, "希望提出型")) score -= 20;
      return score;
    }

    function bestTimeFor(person, storeKey, slot, dateIso, options = {}) {
      const best = candidateTimesForGeneration(person, storeKey, dateIso)
        .filter(time => options.allowPartialOverlap ? overlapsSlot(time, slot) : coversSlot(time, slot))
        .map(time => {
          const feasible = canPlaceShift(dateIso, storeKey, person, time, { ...options, targetSlot: slot });
          return { time, feasible, score: timeFitScore(person, time, slot) + workPatternScore(person, storeKey, time, slot) + rieMasterMatchScore(dateIso, storeKey, person, time, slot) + teacherLearningScore(dateIso, storeKey, person, time, slot) + storeBrainScore(dateIso, storeKey, person, time, slot, options) + eastPostWadaAndHopeControlScore(person, storeKey, slot, dateIso, time) };
        })
        .filter(item => item.feasible || !options.respectCapacity)
        .sort((a, b) => b.score - a.score)[0];
      return best ? best.time : null;
    }


    function weekDatesForIso(dateIso) {
      const start = mondayOf(new Date(`${dateIso}T00:00:00`));
      return Array.from({ length: 7 }, (_, index) => iso(addDays(start, index)));
    }

    function assignedDaysInWeekForPerson(personName, dateIso, storeFilter = "all") {
      const name = canonicalStaffName(personName);
      return weekDatesForIso(dateIso).filter(dayIso => isPersonAssignedOnDate(dayIso, name, storeFilter)).length;
    }


    function removeCrossStoreConflictsForMasterRow(row) {
      // 36.18: 正本行を戻す前に、同一人物の非正本・重複勤務を全店舗から除去する。
      // 非重複の店舗またぎは残す。重複だけ消す。
      const personName = canonicalStaffName(row.name);
      let removed = 0;
      storeOrder.forEach(storeKey => {
        uniqueAssignments(row.dateIso, storeKey).forEach(assignment => {
          if (canonicalStaffName(assignment.name) !== personName) return;
          if (assignment.time === row.time && storeKey === row.storeKey) return;
          if (isExactRieMasterAssignment(row.dateIso, storeKey, assignment)) return;
          if (rangeOverlapHours(assignment.time, row.time) <= 0) return;
          removeShiftFromDay(row.dateIso, storeKey, assignment);
          removed += 1;
        });
      });
      return removed;
    }

    function addRieMasterAnchorRowLoose(row, options = {}) {
      const person = findStaff(row.name);
      if (!person || isInactiveStaff(person) || !canWorkAtStore(person, row.storeKey)) return false;
      if (uniqueAssignments(row.dateIso, row.storeKey).some(assignment => (
        canonicalStaffName(assignment.name) === canonicalStaffName(person.name) && assignment.time === row.time
      ))) return false;
      removeWrongAssignmentsForMasterRow(row);
      removeCrossStoreConflictsForMasterRow(row);
      return addShiftToDay(row.dateIso, row.storeKey, person, row.time, {
        ...options,
        masterOverride: true,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        respectCapacity: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 9,
        allowHopeOnlyPlacement: true,
        allowSplitShiftMaster: true,
        allowCrossStoreSplitMaster: true,
        // 36.18: 直前に重複は除去済み。非重複の店舗またぎ正本を通すため、ここでは二重予約判定を緩める。
        preventDoubleBooking: false
      });
    }

    function replaceableSurplusForRow(row, options = {}) {
      return uniqueAssignments(row.dateIso, row.storeKey)
        .map(assignment => ({ assignment, score: softReplaceScoreForMasterRow(row, assignment, options) }))
        .filter(item => item.score > -999999)
        .sort((a, b) => b.score - a.score);
    }

    function removeExcessAroundMasterRow(row, options = {}) {
      const targetSlots = rowSlotsForSoftFit(row);
      let removed = 0;
      for (const slot of targetSlots) {
        let guard = 0;
        while (ensureCell(row.dateIso, row.storeKey, slot).length > targetRequirementForSlot(row.dateIso, row.storeKey, slot, options) && guard < 8) {
          const removable = [...ensureCell(row.dateIso, row.storeKey, slot)]
            .filter(assignment => !isExactRieMasterAssignment(row.dateIso, row.storeKey, assignment))
            .filter(assignment => !(canonicalStaffName(assignment.name) === canonicalStaffName(row.name) && assignment.time === row.time))
            .map(assignment => ({ assignment, score: softReplaceScoreForMasterRow(row, assignment, options) }))
            .filter(item => item.score > -999999)
            .sort((a, b) => b.score - a.score)[0];
          if (!removable) break;
          removeShiftFromDay(row.dateIso, row.storeKey, removable.assignment);
          removed += 1;
          guard += 1;
        }
      }
      return removed;
    }

    function crossStoreAndSurplusMasterRepairForDates(dates, storeKey, options = generationOptions()) {
      // 36.18: 「不足行を足す」だけでなく、余分行を抜いてから正本行を戻す。
      // ただし全正本反映ではない。対象は missingMasterRow かつ、穴/余分/同一人物ズレがある行だけ。
      let addedCount = 0;
      let removedCount = 0;
      for (let pass = 0; pass < 5; pass += 1) {
        let changed = false;
        dates.forEach(date => {
          const dateIso = iso(date);
          const rows = rieMasterRowsForDateStore(dateIso, storeKey)
            .filter(row => missingMasterRow(row))
            .filter(row => {
              if (shortageSlotsForMasterRow(row, options).length > 0) return true;
              if (replaceableSurplusForRow(row, options).length > 0) return true;
              return personAssignmentsForDay(row.dateIso, row.name).some(existing => rangeOverlapHours(existing.time, row.time) > 0 && !hasExactRieMasterRow(existing.dateIso || row.dateIso, existing.storeKey || storeKey, row.name, existing.time));
            })
            .sort((a, b) => {
              const aScore = shortageGuidedMasterFitScore(a, options);
              const bScore = shortageGuidedMasterFitScore(b, options);
              return bScore - aScore || rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey);
            });
          rows.forEach(row => {
            if (!missingMasterRow(row)) return;
            const candidates = replaceableSurplusForRow(row, options);
            // 先に一番怪しい余分を抜く。これで長時間正本の追加失敗を減らす。
            if (candidates[0]) {
              removeShiftFromDay(row.dateIso, row.storeKey, candidates[0].assignment);
              removedCount += 1;
            }
            const before = uniqueAssignments(row.dateIso, row.storeKey).length;
            const added = addRieMasterAnchorRowLoose(row, options);
            if (!added) return;
            addedCount += 1;
            removedCount += removeExcessAroundMasterRow(row, options);
            const after = uniqueAssignments(row.dateIso, row.storeKey).length;
            if (after !== before || !missingMasterRow(row)) changed = true;
          });
        });
        if (!changed) break;
      }
      return { added: addedCount, removed: removedCount };
    }


    function isResidualExactAnchor(row) {
      if (!row || !row.storeKey || !row.name || !row.time) return false;
      const name = canonicalStaffName(row.name);
      if (row.storeKey === "higashicho") {
        const hot = [
          ["下田", "6-15"], ["下田", "9-15"],
          ["ミミ", "18-3"], ["ミミ", "22-3"], ["ミミ", "22-2"],
          ["工藤", "22-3"], ["工藤", "18-3"], ["工藤", "24-9"],
          ["松永", "19-24"], ["加藤", "24-9"], ["碓井", "22-3"]
        ];
        return hot.some(([person, time]) => canonicalStaffName(person) === name && time === row.time);
      }
      if (row.storeKey === "ougicho") {
        const hot = [
          ["ミミ", "17-24"], ["ミミ", "16-22"], ["ミミ", "17-2"], ["ミミ", "22-2"],
          ["下田", "9-15"], ["下田", "17-22"],
          ["安彦", "6-9"], ["植村", "6-9"], ["芳澤", "15-20"], ["芳澤", "16-21"], ["加藤", "24-9"]
        ];
        return hot.some(([person, time]) => canonicalStaffName(person) === name && time === row.time);
      }
      return false;
    }

    function residualSurplusRemovalScore(dateIso, storeKey, slot, assignment) {
      if (!assignment || isExactRieMasterAssignment(dateIso, storeKey, assignment)) return -999999;
      const name = canonicalStaffName(assignment.name);
      let score = -999999;
      if (storeKey === "higashicho") {
        if (name === canonicalStaffName("山梨") && overlapsSlot(assignment.time, "22-6")) score = 1500;
        if (name === canonicalStaffName("ミミ") && assignment.time === "9-13" && hasRieMasterPerson(dateIso, storeKey, assignment.name)) score = 1200;
        if (name === canonicalStaffName("ミミ") && assignment.time === "6-9" && hasExactRieMasterRow(dateIso, storeKey, assignment.name, "18-3")) score = 900;
        if (name === canonicalStaffName("工藤") && assignment.time === "6-9" && hasRieMasterPerson(dateIso, storeKey, assignment.name)) score = 1100;
        if (name === canonicalStaffName("東町 店長（小澤）") && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, assignment.time)) score = 850;
        if (name === canonicalStaffName("高橋(東町)") && !overlapsSlot(assignment.time, "17-22")) score = 850;
        if (name === canonicalStaffName("柳川") && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, assignment.time)) score = Math.max(score, 650);
      }
      if (storeKey === "ougicho") {
        if (name === canonicalStaffName("分部") && assignment.time === "21-24" && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, assignment.time)) score = 1100;
        if (name === canonicalStaffName("扇町 店長（齋藤）") && overlapsSlot(assignment.time, "6-9")) score = 1000;
        if (name === canonicalStaffName("木村") && overlapsSlot(assignment.time, "6-9") && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, assignment.time)) score = 850;
        if (name === canonicalStaffName("加藤") && assignment.time === "6-9") score = 1100;
        if (name === canonicalStaffName("工藤") && (assignment.time === "9-14" || assignment.time === "15-20") && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, assignment.time)) score = 650;
      }
      return score;
    }

    function trimResidualKnownSurplusForDates(dates, storeKey, options = generationOptions()) {
      let removed = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        slots.forEach(slot => {
          let guard = 0;
          while (ensureCell(dateIso, storeKey, slot).length > targetRequirementForSlot(dateIso, storeKey, slot, options) && guard < 12) {
            const candidate = [...ensureCell(dateIso, storeKey, slot)]
              .filter(assignment => canRemoveWithoutShortage(dateIso, storeKey, assignment))
              .map(assignment => ({ assignment, score: residualSurplusRemovalScore(dateIso, storeKey, slot, assignment) }))
              .filter(item => item.score > -999999)
              .sort((a, b) => b.score - a.score)[0];
            if (!candidate) break;
            removeShiftFromDay(dateIso, storeKey, candidate.assignment);
            removed += 1;
            guard += 1;
          }
        });
      });
      return removed;
    }

    function residualExactAnchorPatchForDates(dates, storeKey, options = generationOptions()) {
      // 36.19: 36.18後に残る「正本アンカーだけ未反映」を直接戻す。
      // 対象は下田/ミミ/工藤など、教師データ上も正本上も核になる勤務型だけ。全正本反映ではない。
      let added = 0;
      let removed = 0;
      for (let pass = 0; pass < 3; pass += 1) {
        let changed = false;
        dates.forEach(date => {
          const dateIso = iso(date);
          const rows = rieMasterRowsForDateStore(dateIso, storeKey)
            .filter(row => missingMasterRow(row))
            .filter(row => isResidualExactAnchor(row))
            .sort((a, b) => rieMasterSortScore(b, storeKey) - rieMasterSortScore(a, storeKey));
          rows.forEach(row => {
            if (!missingMasterRow(row)) return;
            const candidates = replaceableSurplusForRow(row, options);
            if (candidates[0] && residualSurplusRemovalScore(row.dateIso, row.storeKey, rowSlotsForSoftFit(row)[0] || "", candidates[0].assignment) > -999999) {
              removeShiftFromDay(row.dateIso, row.storeKey, candidates[0].assignment);
              removed += 1;
            }
            removeWrongAssignmentsForMasterRow(row);
            removeCrossStoreConflictsForMasterRow(row);
            if (directAddRieMasterAssignment(row)) {
              added += 1;
              changed = true;
              removed += removeExcessAroundMasterRow(row, options);
            }
          });
          removed += trimResidualKnownSurplusForDates([new Date(`${dateIso}T00:00:00`)], storeKey, options);
        });
        if (!changed) break;
      }
      return { added, removed };
    }


    function rieCoverageAtAbsMinute(dateIso, storeKey, absMinute) {
      const intervals = entriesToTimelineIntervals(rieMasterRowsForDateStore(dateIso, storeKey));
      return coverageAtMinute(intervals, storeKey, absMinute).length;
    }

    function appCoverageAtAbsMinuteExcluding(dateIso, storeKey, absMinute, assignmentToRemove) {
      const removeKey = assignmentKey(assignmentToRemove);
      const rows = uniqueAssignments(dateIso, storeKey)
        .filter(row => assignmentKey(row) !== removeKey)
        .map(row => ({ ...row, dateIso, storeKey }));
      const intervals = entriesToTimelineIntervals(rows);
      return coverageAtMinute(intervals, storeKey, absMinute).length;
    }

    function safeRemoveAgainstRieTimeline(dateIso, storeKey, assignment) {
      if (!assignment || isExactRieMasterAssignment(dateIso, storeKey, assignment)) return false;
      const range = absRangeForTime(dateIso, assignment.time);
      if (!range) return false;
      for (let minute = range.startAbs; minute < range.endAbs; minute += 30) {
        const appAfter = appCoverageAtAbsMinuteExcluding(dateIso, storeKey, minute, assignment);
        const rieCount = rieCoverageAtAbsMinute(dateIso, storeKey, minute);
        if (appAfter < rieCount) return false;
      }
      return true;
    }

    function finalResidualSurplusTrimScore(dateIso, storeKey, assignment) {
      if (!assignment || isExactRieMasterAssignment(dateIso, storeKey, assignment)) return -999999;
      const name = canonicalStaffName(assignment.name);
      const time = normalizeTimeInput(assignment.time) || assignment.time;
      let score = -999999;
      if (storeKey === "higashicho") {
        // 36.20: 36.19後に残りやすい東町の「正本にない余分」だけを、安全確認後に抜く。
        if (name === canonicalStaffName("佐々木(絢)") && time === "9-17") score = 2600;
        if (name === canonicalStaffName("工藤") && time === "6-9") score = 2400;
        if (name === canonicalStaffName("山梨") && time === "22-6") score = 2100;
        if (name === canonicalStaffName("ミミ") && (time === "9-13" || time === "6-9")) score = 1900;
        if (name === canonicalStaffName("東町 店長（小澤）") && time === "9-18") score = 1500;
        if (name === canonicalStaffName("高橋(東町)") && !overlapsSlot(time, "17-22")) score = Math.max(score, 1200);
        if (name === canonicalStaffName("柳川") && !hasExactRieMasterRow(dateIso, storeKey, assignment.name, time)) score = Math.max(score, 900);
      }
      if (storeKey === "ougicho") {
        if (name === canonicalStaffName("分部") && time === "21-24") score = 1700;
        if (name === canonicalStaffName("工藤") && (time === "9-14" || time === "15-20")) score = 1200;
        if (name === canonicalStaffName("扇町 店長（齋藤）") && overlapsSlot(time, "6-9")) score = 1200;
      }
      return score;
    }

    function finalResidualSurplusTrimForDates(dates, storeKey, options = generationOptions()) {
      let removed = 0;
      for (let pass = 0; pass < 4; pass += 1) {
        let changed = false;
        dates.forEach(date => {
          const dateIso = iso(date);
          const candidates = uniqueAssignments(dateIso, storeKey)
            .filter(assignment => !isExactRieMasterAssignment(dateIso, storeKey, assignment))
            .map(assignment => ({ assignment, score: finalResidualSurplusTrimScore(dateIso, storeKey, assignment) }))
            .filter(item => item.score > -999999)
            .sort((a, b) => b.score - a.score);
          candidates.forEach(item => {
            // 36.8の正本反映とは違い、正本タイムラインを下回らない余分だけを抜く。
            if (!safeRemoveAgainstRieTimeline(dateIso, storeKey, item.assignment)) return;
            removeShiftFromDay(dateIso, storeKey, item.assignment);
            removed += 1;
            changed = true;
          });
        });
        if (!changed) break;
      }
      return removed;
    }

    function eastPostWadaAndHopeControlScore(person, storeKey, slot, dateIso, time) {
      if (!person || !storeKey || !dateIso || !time) return 0;
      const name = canonicalStaffName(person.name);
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      const exactMaster = hasExactRieMasterRow(dateIso, storeKey, person.name, time);
      const inMaster = hasRieMasterPerson(dateIso, storeKey, person.name);
      let score = 0;

      if (storeKey === "higashicho") {
        // 36.13: 東町は朝番・夕方・夜勤を分離する。朝に夕方要員、夜に昼要員を混ぜない。
        const overlapsMorning = overlapsSlot(time, "6-9");
        const overlapsMidMorning = overlapsSlot(time, "9-13");
        const overlapsEvening = overlapsSlot(time, "17-22");
        const overlapsNight = overlapsSlot(time, "22-6");
        const eastMorningCore = ["多田", "工藤", "下田", "加藤", "ミミ", "斉藤", "済藤", "降旗", "塚脇"];
        if (slot === "6-9" && eastMorningCore.some(item => canonicalStaffName(item) === name)) score += 420;
        if (slot === "6-9" && !eastMorningCore.some(item => canonicalStaffName(item) === name) && !exactMaster) score -= 430;
        if (slot === "9-13" && ["下田", "工藤", "東町 店長（小澤）", "永井", "佐々木（綾）", "ミミ"].some(item => canonicalStaffName(item) === name)) score += 260;
        if ((overlapsMorning || overlapsMidMorning) && ["高橋(東町)", "高木", "柳川", "山梨"].some(item => canonicalStaffName(item) === name) && !exactMaster) score -= 520;
        if (name === canonicalStaffName("高木") && !overlapsEvening && !exactMaster) score -= 620;
        if (name === canonicalStaffName("高橋(東町)") && !overlapsEvening && !exactMaster) score -= 560;
        if (name === canonicalStaffName("柳川") && (overlapsMorning || overlapsMidMorning || overlapsNight) && !exactMaster) score -= 430;
        if (name === canonicalStaffName("松永") && time === "19-24") score += 700;
        if (name === canonicalStaffName("工藤") && ["22-3", "24-9", "18-3"].includes(time)) score += 420;
        if (name === canonicalStaffName("ミミ") && ["18-3", "22-3", "6-9", "9-13"].includes(time)) score += 360;
        if (name === canonicalStaffName("加藤") && ["24-9", "21-6", "22-7"].includes(time)) score += 360;
        if (name === canonicalStaffName("碓井") && ["22-3", "24-6"].includes(time)) score += 360;
        if (slot === "22-6" && parseRange(time)[1] <= 24 && !exactMaster) score -= 360;

        // 東町は下田の6-15/9-15を紙シフトの骨格として扱う。特に月火金は強め。
        if (name === canonicalStaffName("下田")) {
          if ((time === "6-15" || time === "9-15") && ["月", "火", "木", "金"].includes(dow)) score += 520;
          if ((slot === "6-9" || slot === "9-13") && (time === "6-15" || time === "9-15")) score += 260;
          if (slot === "17-22" && !exactMaster) score -= 360;
        }

        // キーズは東町の土日9時台寄り。平日・夕方・夜勤の便利埋めを強く落とす。
        if (name === canonicalStaffName("キーズ")) {
          if (!["土", "日"].includes(dow)) score -= 420;
          if (slot !== "9-13") score -= 260;
          if (inMaster && !exactMaster) score -= 260;
        }

        // 山梨は希望提出型夜勤。週に何度も勝手に呼ばない。
        if (name === canonicalStaffName("山梨")) {
          const used = assignedDaysInWeekForPerson(person.name, dateIso, storeKey);
          if (!exactMaster && !hasSubmittedWorkRequestTime(dateIso, storeKey, person.name, time)) score -= 430;
          if (used >= 2 && !exactMaster) score -= 720;
          if (!["月", "火", "土"].includes(dow) && !exactMaster) score -= 430;
        }

        // 店長・富田の深夜化は正本にない限り控えめ。社員を便利夜勤にしすぎない。
        if ((name === canonicalStaffName("東町 店長（小澤）") || name === canonicalStaffName("富田")) && slot === "22-6" && !exactMaster) {
          score -= 620;
        }

        // 大津は土日補助。9-17を平日や夜勤に伸ばしすぎない。
        if (name === canonicalStaffName("大津")) {
          if (!["土", "日"].includes(dow)) score -= 430;
          if (slot === "22-6" && !exactMaster) score -= 300;
        }
      }

      if (storeKey === "ougicho") {
        // 扇町は36.11でかなり寄ったので、残差だけ微調整。朝番は安彦・植村を優先し、加藤6-9化を止める。
        if (slot === "6-9" && ["安彦", "植村", "塚脇", "芳澤"].some(item => canonicalStaffName(item) === name)) score += 520;
        if (dow === "火" && slot === "6-9" && name === canonicalStaffName("安彦")) score += 520;
        if (slot === "6-9" && name === canonicalStaffName("植村")) score += 380;
        if (dow === "火" && slot === "22-6" && name === canonicalStaffName("加藤") && time === "24-9") score += 460;
        if (slot === "6-9" && name === canonicalStaffName("加藤") && time === "6-9" && !exactMaster) score -= 620;
        if (dow === "火" && slot === "6-9" && name === canonicalStaffName("木村") && !exactMaster) score -= 430;
        if (slot === "6-9" && name === canonicalStaffName("扇町 店長（齋藤）") && !exactMaster) score -= 430;
      }

      return score;
    }

    function scoreCandidate(person, storeKey, slot, dateIso, options = {}) {
      if (!canWorkAtStore(person, storeKey)) return -10000;
      let score = 0;
      if (canWorkAtStore(person, storeKey)) score += 40;
      if (person.slots.includes(slot) || person.times.some(time => options.allowPartialOverlap ? overlapsSlot(time, slot) : coversSlot(time, slot))) score += 40;
      const time = bestTimeFor(person, storeKey, slot, dateIso, options);
      if (!time) score -= 1000;
      else score += timeFitScore(person, time, slot) + workPatternScore(person, storeKey, time, slot) + rieMasterMatchScore(dateIso, storeKey, person, time, slot) + teacherLearningScore(dateIso, storeKey, person, time, slot) + storeBrainScore(dateIso, storeKey, person, time, slot, options) + eastPostWadaAndHopeControlScore(person, storeKey, slot, dateIso, time);
      if (person.support) score += options.allowSupport ? 4 : -35;
      if (isUnavailable(person.name, dateIso)) score -= 1000;
      if (!matchesDay(person, dateIso)) score -= 1000;
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) score -= 500;
      if (options.respectCapacity && time && !canPlaceShift(dateIso, storeKey, person, time, options)) score -= 1000;
      const already = isAssignedAnywhere(dateIso, person.name);
      if (already) score -= 70;
      score += restScore(person, slot, dateIso);
      const projectedStreak = projectedConsecutiveWorkDays(person.name, dateIso);
      const maxConsecutive = options.strictConsecutiveLimit
        ? (options.maxConsecutiveWorkDays || 5)
        : time ? Math.max(options.maxConsecutiveWorkDays || 5, maxConsecutiveWorkDaysFor(person, time)) : (options.maxConsecutiveWorkDays || 5);
      if (!already && projectedStreak > maxConsecutive) {
        score -= options.avoidLongStreak ? 10000 : (projectedStreak - maxConsecutive) * 90;
      } else if (!already && projectedStreak === 5) {
        score -= 80;
      }
      score += coreRestBalanceScore(person, dateIso, options);
      const load = options.loadMap ? (options.loadMap.get(person.name) || 0) : 0;
      score -= load * (isCoreEmployee(person) ? 0.35 : 2);
      return score;
    }

    function candidatesFor(storeKey, slot, dateIso, options = {}) {
      return staff
        .filter(person => canWorkAtStore(person, storeKey))
        .filter(person => canAutoUsePerson(person, dateIso, storeKey))
        .map(person => {
          const time = bestTimeFor(person, storeKey, slot, dateIso, options);
          return { person, time, score: scoreCandidate(person, storeKey, slot, dateIso, options) };
        })
        .filter(item => item.score > 20)
        .sort((a, b) => b.score - a.score || Number(a.person.support) - Number(b.person.support))
        .slice(0, 7);
    }

    function pickTime(person, slot, dateIso = null, storeKey = null, options = {}) {
      if (dateIso && storeKey) {
        const best = bestTimeFor(person, storeKey, slot, dateIso, options);
        if (best) return best;
      }
      const direct = person.times.find(time => time === slot);
      if (direct) return direct;
      const times = candidateTimesFor(person, dateIso);
      const covering = times.find(time => options.allowPartialOverlap ? overlapsSlot(time, slot) : coversSlot(time, slot));
      return covering || times[0] || slot;
    }

    function normalizedSlotRangeForTime(time, slot) {
      const [start, end] = parseRange(time);
      let [slotStart, slotEnd] = parseRange(slot);
      // 36.3修正：24-9 のような「24時開始」は、22-6枠とも6-9枠とも関係する。
      // 旧ロジックは 22-6 を 46-54 に飛ばしてしまい、24-9 が夜勤枠をカバーしない扱いになっていた。
      if (end > 24) {
        const isMorningSlot = slotStart >= 0 && slotEnd <= 12 && slotEnd <= start;
        const isOvernightSlot = slotEnd > 24;
        if (isMorningSlot && !isOvernightSlot) {
          slotStart += 24;
          slotEnd += 24;
        }
      }
      return [slotStart, slotEnd];
    }

    function coversSlot(time, slot) {
      const [start, end] = parseRange(time);
      const [slotStart, slotEnd] = normalizedSlotRangeForTime(time, slot);
      return start <= slotStart && end >= slotEnd;
    }

    function overlapsSlot(time, slot) {
      const [start, end] = parseRange(time);
      const [slotStart, slotEnd] = normalizedSlotRangeForTime(time, slot);
      return start < slotEnd && end > slotStart;
    }

    function parseRange(label) {
      const [startRaw, endRaw] = label.split("-").map(Number);
      const start = startRaw;
      let end = endRaw;
      if (Number.isNaN(end)) end = 24;
      if (end <= start) end += 24;
      return [start, end];
    }

    function maxConsecutiveWorkDaysFor(person, time) {
      const hours = assignmentHours({ time });
      if (hasTag(person, "社員") || hasTag(person, "店長")) return 5;
      if (hours <= 3 || hasTag(person, "6-9のみ") || hasTag(person, "朝")) return 10;
      if (hasTag(person, "夜勤のみ") || person.name === "笹島") return 10;
      return 5;
    }

    function canRemoveWithoutShortage(dateIso, storeKey, assignment) {
      return assignmentSlots(assignment.time, { allowPartialOverlap: true }).every(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        return cell.length - 1 >= targetRequirementForSlot(dateIso, storeKey, slot);
      });
    }

    function overstaffRemovalScore(dateIso, storeKey, slot, assignment) {
      const person = findStaff(assignment.name);
      if (!person) return 0;
      let score = scoreCandidate(person, storeKey, slot, dateIso);
      if (rieMasterMatchScore(dateIso, storeKey, person, assignment.time, slot) > 300) score += 2200;
      if (person.support) score -= 40;
      if (hasTag(person, "応援マルチ")) score -= 35;
      return score;
    }

    function trimOverstaffing(storeFilter = "all") {
      let removed = 0;
      periodDates().forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(storeKey => {
          if (storeFilter !== "all" && storeFilter !== storeKey) return;
          slots.forEach(slot => {
            let cell = ensureCell(dateIso, storeKey, slot);
            let guard = 0;
            while (cell.length > targetRequirementForSlot(dateIso, storeKey, slot) && guard < 10) {
              const removable = [...cell]
                .filter(assignment => {
                  const person = findStaff(assignment.name);
                  return !isExactRieMasterAssignment(dateIso, storeKey, assignment) && !isFixedPerson(person) && !isCoreEmployee(person) && canRemoveWithoutShortage(dateIso, storeKey, assignment);
                })
                .sort((a, b) => overstaffRemovalScore(dateIso, storeKey, slot, a) - overstaffRemovalScore(dateIso, storeKey, slot, b))[0];
              if (!removable) break;
              removeShiftFromDay(dateIso, storeKey, removable);
              removed += 1;
              cell = ensureCell(dateIso, storeKey, slot);
              guard += 1;
            }
          });
        });
      });
      return removed;
    }

    function removableAssignmentsForPersonOnDate(dateIso, personName, storeFilter = "all", options = {}) {
      const rows = [];
      storeOrder.forEach(storeKey => {
        if (storeFilter !== "all" && storeFilter !== storeKey) return;
        uniqueAssignments(dateIso, storeKey).forEach(assignment => {
          if (canonicalStaffName(assignment.name) !== canonicalStaffName(personName)) return;
          const person = findStaff(assignment.name);
          if (!person || isFixedPerson(person) || isCoreEmployee(person) || person.support) return;
          if (!options.allowShortage && !canRemoveWithoutShortage(dateIso, storeKey, assignment)) return;
          rows.push({ storeKey, assignment });
        });
      });
      return rows;
    }

    function resolveLongStreaks(storeFilter = "all", maxDays = 5) {
      let removed = 0;
      let guard = 0;
      while (guard < 120) {
        let changed = false;
        for (const person of staff) {
          let segment = [];
          const flush = () => {
            if (segment.length <= maxDays) {
              segment = [];
              return false;
            }
            const ordered = [...segment].sort((a, b) => {
              const aDistance = Math.abs(segment.indexOf(a) - Math.floor(segment.length / 2));
              const bDistance = Math.abs(segment.indexOf(b) - Math.floor(segment.length / 2));
              return aDistance - bDistance;
            });
            for (const dateIso of ordered) {
              const removable = removableAssignmentsForPersonOnDate(dateIso, person.name, storeFilter)[0]
                || removableAssignmentsForPersonOnDate(dateIso, person.name, storeFilter, { allowShortage: true })[0];
              if (!removable) continue;
              removeShiftFromDay(dateIso, removable.storeKey, removable.assignment);
              removed += 1;
              segment = [];
              return true;
            }
            segment = [];
            return false;
          };
          for (const date of periodDates()) {
            const dateIso = iso(date);
            if (isPersonAssignedOnDate(dateIso, person.name, storeFilter)) {
              segment.push(dateIso);
            } else if (flush()) {
              changed = true;
              break;
            }
          }
          if (!changed && flush()) changed = true;
          if (changed) break;
        }
        if (!changed) break;
        guard += 1;
      }
      return removed;
    }

    function canRemoveForCoreReplacement(dateIso, storeKey, assignment, replacementSlots) {
      const person = findStaff(assignment.name);
      if (!person || isFixedPerson(person) || isCoreEmployee(person) || person.support) return false;
      const covered = assignmentSlots(assignment.time, { allowPartialOverlap: true });
      return covered.every(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        return replacementSlots.includes(slot) || cell.length > requirement(storeKey, slot);
      });
    }

    function makeRoomForCore(dateIso, storeKey, person, time, options = {}) {
      const replacementSlots = assignmentSlots(time, options);
      for (const slot of replacementSlots) {
        if (requirement(storeKey, slot) <= 0) return false;
        const cell = ensureCell(dateIso, storeKey, slot);
        if (cell.some(assignment => assignment.name === person.name && assignment.time === time)) continue;
        while (cell.length >= requirement(storeKey, slot)) {
          const removable = [...cell]
            .filter(assignment => canRemoveForCoreReplacement(dateIso, storeKey, assignment, replacementSlots))
            .sort((a, b) => overstaffRemovalScore(dateIso, storeKey, slot, a) - overstaffRemovalScore(dateIso, storeKey, slot, b))[0];
          if (!removable) return false;
          removeShiftFromDay(dateIso, storeKey, removable);
        }
      }
      return true;
    }

    function coreSlotOptions(person, dateIso, storeFilter, options = {}) {
      const storeKeys = person.stores.filter(storeKey => storeFilter === "all" || storeFilter === storeKey);
      const rows = [];
      storeKeys.forEach(storeKey => {
        slots.forEach(slot => {
          const time = bestTimeFor(person, storeKey, slot, dateIso, { ...options, respectCapacity: false });
          if (!time) return;
          rows.push({
            storeKey,
            slot,
            time,
            score: scoreCandidate(person, storeKey, slot, dateIso, { ...options, respectCapacity: false })
          });
        });
      });
      return rows.sort((a, b) => b.score - a.score);
    }

    function corePlacementOptions(person, storeFilter, options = {}) {
      const maxDaysFallback = Math.max(6, maxConsecutiveWorkDaysFor(person, "9-18"));
      const rows = [];
      periodDates().forEach(date => {
        const dateIso = iso(date);
        if (isPersonAssignedOnDate(dateIso, person.name)) return;
        if (!matchesDay(person, dateIso)) return;
        if (isUnavailable(person.name, dateIso)) return;
        const projectedStreak = projectedConsecutiveWorkDays(person.name, dateIso);
        if (projectedStreak > maxDaysFallback) return;
        coreSlotOptions(person, dateIso, storeFilter, options).forEach(row => {
          const targets = assignmentSlots(row.time, options);
          const shortageBonus = targets.reduce((sum, slot) => {
            const cell = ensureCell(dateIso, row.storeKey, slot);
            return sum + Math.max(0, targetRequirementForSlot(dateIso, row.storeKey, slot, options) - cell.length) * 18;
          }, 0);
          const roomPenalty = targets.reduce((sum, slot) => {
            const cell = ensureCell(dateIso, row.storeKey, slot);
            return sum + (cell.length >= targetRequirementForSlot(dateIso, row.storeKey, slot, options) ? 8 : 0);
          }, 0);
          rows.push({
            ...row,
            dateIso,
            projectedStreak,
            score: row.score + shortageBonus - roomPenalty - projectedStreak * 3
          });
        });
      });
      return rows.sort((a, b) => b.score - a.score);
    }

    function tryPlaceCoreEmployee(person, storeFilter, options = {}) {
      const rows = corePlacementOptions(person, storeFilter, options);
      for (const row of rows) {
        if (makeRoomForCore(row.dateIso, row.storeKey, person, row.time, options)) {
          const added = addShiftToDay(row.dateIso, row.storeKey, person, row.time, options);
          if (added) {
            options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
            return true;
          }
        }
      }
      return false;
    }

    function rebalanceCoreRest(storeFilter = "all") {
      const options = generationOptions();
      let changed = 0;
      let guard = 0;
      const skipped = new Set();
      while (guard < 240) {
        const row = coreRestRows(storeFilter)
          .filter(item => item.excess > 0)
          .filter(item => !skipped.has(item.person.name))
          .sort((a, b) => b.excess - a.excess)[0];
        if (!row) break;
        if (tryPlaceCoreEmployee(row.person, storeFilter, options)) {
          changed += 1;
          skipped.clear();
        } else {
          skipped.add(row.person.name);
        }
        guard += 1;
      }
      if (changed) trimOverstaffing(storeFilter);
      return changed;
    }

    function coreDailyOptions(person, dateIso, storeKey, options = {}) {
      return candidateTimesForGeneration(person, storeKey, dateIso)
        .map(time => {
          const targets = assignmentSlots(time, options);
          if (!targets.length) return null;
          const shortageFill = targets.reduce((sum, slot) => {
            const cell = ensureCell(dateIso, storeKey, slot);
            return sum + Math.max(0, requirement(storeKey, slot) - cell.length);
          }, 0);
          const spanPenalty = targets.length * 3;
          const feasible = canPlaceShift(dateIso, storeKey, person, time, options);
          return {
            time,
            feasible,
            score: shortageFill * 40 + timeFitScore(person, time, targets[0] || slots[0]) + workPatternScore(person, storeKey, time, targets[0] || slots[0]) + rieMasterMatchScore(dateIso, storeKey, person, time, targets[0] || slots[0]) + teacherLearningScore(dateIso, storeKey, person, time, targets[0] || slots[0]) + storeBrainScore(dateIso, storeKey, person, time, targets[0] || slots[0], options) + eastPostWadaAndHopeControlScore(person, storeKey, targets[0] || slots[0], dateIso, time) - spanPenalty
          };
        })
        .filter(Boolean)
        .filter(row => row.feasible)
        .sort((a, b) => b.score - a.score);
    }

    function prefillCoreEmployeesForDate(dateIso, storeKey, options = {}) {
      let addedCount = 0;
      const corePriority = person => (
        hasTag(person, "夜勤のみ") || hasTag(person, "基本夜勤") ? 2 : 1
      );
      const corePeople = staff
        .filter(person => isCoreEmployee(person) && canWorkAtStore(person, storeKey))
        .filter(person => !isPersonAssignedOnDate(dateIso, person.name))
        .filter(person => matchesDay(person, dateIso))
        .filter(person => !isUnavailable(person.name, dateIso))
        .filter(person => projectedWorkDays(person, options) < targetWorkDays(person))
        .sort((a, b) => {
          const aNeed = targetWorkDays(a) - projectedWorkDays(a, options);
          const bNeed = targetWorkDays(b) - projectedWorkDays(b, options);
          return corePriority(b) - corePriority(a) || bNeed - aNeed || coreRestBalanceScore(b, dateIso, options) - coreRestBalanceScore(a, dateIso, options);
        });

      corePeople.forEach(person => {
        const row = coreDailyOptions(person, dateIso, storeKey, options)[0];
        if (!row) return;
        const added = addShiftToDay(dateIso, storeKey, person, row.time, options);
        if (added) {
          options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
          addedCount += 1;
        }
      });
      return addedCount;
    }

    function generateDatesForStore(dates, storeKey, options = generationOptions()) {
      dates.forEach(date => {
        const dateIso = iso(date);
        slots.forEach(slot => {
          const cell = ensureCell(dateIso, storeKey, slot);
          cell.length = 0;
        });
      });
      dates.forEach((date, dateIndex) => {
        const dateIso = iso(date);
        applySubmittedWorkRequestsForDate(dateIso, storeKey, options);
        if (options.useStoreBrainAnchors) {
          prefillStoreBrainMasterAnchorsForDate(dateIso, storeKey, options);
        }
        if (options.useRieGuidedPrefill !== false) {
          prefillRieMasterGuidedDate(dateIso, storeKey, options);
        }
        prefillPreferredPatternPhase(dateIso, storeKey, "night", options);
        prefillPreferredPatternPhase(dateIso, storeKey, "evening", options);
        prefillPreferredPatternPhase(dateIso, storeKey, "day", options);
        prefillCoreEmployeesForDate(dateIso, storeKey, options);
        fixedPeopleFor(storeKey, dateIso).forEach(person => {
          const wasAssigned = isAssignedAnywhere(dateIso, person.name);
          const times = [...candidateTimesFor(person, dateIso)].sort((a, b) => {
            const aHours = assignmentHours({ time: a });
            const bHours = assignmentHours({ time: b });
            return aHours - bHours;
          });
          times.some(time => addShiftToDay(dateIso, storeKey, person, time, options));
          if (!wasAssigned && isAssignedAnywhere(dateIso, person.name)) {
            options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
          }
        });
        staff
          .filter(person => isCoreEmployee(person) && canWorkAtStore(person, storeKey))
          .filter(person => !isPersonAssignedOnDate(dateIso, person.name))
          .filter(person => projectedWorkDays(person, options) < targetWorkDays(person))
          .sort((a, b) => coreRestBalanceScore(b, dateIso, options) - coreRestBalanceScore(a, dateIso, options))
          .forEach(person => {
            slots.some(slot => {
              const time = bestTimeFor(person, storeKey, slot, dateIso, options);
              if (!time) return false;
              const added = addShiftToDay(dateIso, storeKey, person, time, options);
              if (added) {
                options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
              }
              return added;
            });
          });
        for (let pass = 0; pass < 8; pass += 1) {
          let changed = false;
          slots.forEach(slot => {
            const cell = ensureCell(dateIso, storeKey, slot);
            const req = requirement(storeKey, slot);
            if (cell.length >= req) return;
            const pool = candidatesFor(storeKey, slot, dateIso, options)
              .filter(item => !item.person.support && !isUnavailable(item.person.name, dateIso));
            const picked = pool[0];
            if (picked) {
              const wasAssigned = isAssignedAnywhere(dateIso, picked.person.name);
              const added = addShiftToDay(dateIso, storeKey, picked.person, picked.time, options);
              if (added && !wasAssigned) {
                options.loadMap.set(picked.person.name, (options.loadMap.get(picked.person.name) || 0) + 1);
              }
              changed = added || changed;
            }
          });
          if (!changed) break;
        }
        fillRemainingShortagesForDate(dateIso, storeKey, options);
      });
    }

    function generateMonth() {
      const dates = periodDates();
      const storeKey = state.selectedStore;
      generateDatesForStore(dates, storeKey);
      trimOverstaffing(storeKey);
      rebalanceCoreRest(storeKey);
      resolveLongStreaks(storeKey, 5);
      ensureMinimumCoverageForDates(dates, storeKey);
      syncScheduleTowardRieMasterForDates(dates, storeKey);
      trimOverstaffingForDates(storeKey, dates);
      enforceExactRieMasterForDates(dates, storeKey);
      if (!state.bulkGenerating) {
        showToast(`${stores[storeKey].name}の1か月分を仮作成した`);
        renderAll();
      }
    }

    function trimOverstaffingForDates(storeFilter = "all", dates = periodDates()) {
      let removed = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(storeKey => {
          if (storeFilter !== "all" && storeFilter !== storeKey) return;
          slots.forEach(slot => {
            let cell = ensureCell(dateIso, storeKey, slot);
            let guard = 0;
            while (cell.length > targetRequirementForSlot(dateIso, storeKey, slot) && guard < 10) {
              const removable = [...cell]
                .filter(assignment => {
                  const person = findStaff(assignment.name);
                  return !isExactRieMasterAssignment(dateIso, storeKey, assignment) && !isFixedPerson(person) && !isCoreEmployee(person) && canRemoveWithoutShortage(dateIso, storeKey, assignment);
                })
                .sort((a, b) => overstaffRemovalScore(dateIso, storeKey, slot, a) - overstaffRemovalScore(dateIso, storeKey, slot, b))[0];
              if (!removable) break;
              removeShiftFromDay(dateIso, storeKey, removable);
              removed += 1;
              cell = ensureCell(dateIso, storeKey, slot);
              guard += 1;
            }
          });
        });
      });
      return removed;
    }

    function syncWeeklyCloseSelectionFromInputs() {
      const weekSelect = document.getElementById("weeklyCloseStart");
      const storeSelect = document.getElementById("weeklyCloseStore");
      if (weekSelect && weekSelect.value) state.selectedWeekStart = weekSelect.value;
      if (storeSelect && storeSelect.value) {
        state.weeklyCloseStore = storeSelect.value;
        state.selectedStore = storeSelect.value;
      }
    }

    function autonomousGenerationOptions(extra = {}) {
      return generationOptions({
        useRieGuidedPrefill: false,
        useRieTargets: true,
        strictTimeBand: false,
        useStoreBrainAnchors: true,
        respectCapacity: true,
        preventDoubleBooking: true,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        strictConsecutiveLimit: false,
        maxConsecutiveWorkDays: 9,
        ...extra
      });
    }


    // 36.22 正本なし生成モード専用：正本を見ず、教師データから「その曜日らしい件数」と勤務型を補う。
    function teacherWishRowsForDow(dateIso, storeKey) {
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      return teacherRowsForStore(storeKey, dateIso)
        .map(row => ({ ...row, name: canonicalStaffNameForStore(row.name, row.storeKey || storeKey), time: normalizeTimeInput(row.time) || row.time, dow: dowLabel(new Date(`${row.dateIso}T00:00:00`)) }))
        .filter(row => row.dow === dow)
        .filter(row => {
          const person = findStaff(row.name);
          return person && !isInactiveStaff(person) && canWorkAtStore(person, storeKey);
        });
    }

    function teacherWishTargetCountForDateStore(dateIso, storeKey) {
      const rows = teacherWishRowsForDow(dateIso, storeKey);
      if (!rows.length) {
        // 2名×5枠をそのまま人数換算すると過大になるため、最低8件程度に丸める。
        return Math.max(8, Math.min(10, slots.reduce((sum, slot) => sum + requirement(storeKey, slot), 0)));
      }
      const byDate = new Map();
      rows.forEach(row => {
        if (!byDate.has(row.dateIso)) byDate.set(row.dateIso, new Set());
        byDate.get(row.dateIso).add(`${canonicalStaffName(row.name)}|${row.time}`);
      });
      const counts = [...byDate.values()].map(set => set.size).filter(Boolean).sort((a, b) => a - b);
      if (!counts.length) return 8;
      const mid = Math.floor(counts.length / 2);
      const median = counts.length % 2 ? counts[mid] : Math.round((counts[mid - 1] + counts[mid]) / 2);
      const avg = Math.round(counts.reduce((sum, n) => sum + n, 0) / counts.length);
      // 36.33: 36.32では件数が低めに寄ったため、中央値/平均だけでなく75パーセンタイルも採用する。
      // 正本は見ない。教師データ内の同曜日サンプルから「少なすぎる日」を避けるための床。
      const p75 = counts[Math.min(counts.length - 1, Math.floor(counts.length * 0.75))];
      const blended = Math.max(Math.round((median + avg) / 2), p75);
      return Math.max(6, Math.min(12, blended));
    }

    function wishCandidateScore(dateIso, storeKey, person, time) {
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      const stats = getTeacherStats(storeKey, dateIso);
      const name = canonicalStaffName(person.name);
      let score = 0;
      score += teacherLearningScore(dateIso, storeKey, person, time, assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false })[0] || null);
      score += workPatternScore(person, storeKey, time, assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false })[0] || null);
      score += storeBrainScore(dateIso, storeKey, person, time, assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false })[0] || null, { allowPartialOverlap: true });
      score += eastPostWadaAndHopeControlScore(person, storeKey, assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false })[0] || "", dateIso, time);
      score += Math.min(400, (stats.personDowTime.get(`${name}|${dow}|${time}`) || 0) * 160);
      score += Math.min(250, (stats.personTime.get(`${name}|${time}`) || 0) * 80);
      if (isCoreEmployee(person)) score += 30;
      if (hasTag(person, "店長")) score += 120;
      if (hasTag(person, "希望提出型")) score -= 80;
      // 正本なし生成モードでは、東町/扇町の明らかな時間帯ミスは抑えるが、完全禁止にはしない。
      if (storeKey === "higashicho" && time === "6-9" && ["柳川", "高橋(東町)", "高木", "富田", "山梨", "東町 店長（小澤）", "大津", "キーズ"].some(x => canonicalStaffName(x) === name)) score -= 450;
      if (storeKey === "ougicho" && time === "6-9" && ["加藤", "扇町 店長（齋藤）"].some(x => canonicalStaffName(x) === name)) score -= 450;
      if (storeKey === "ougicho" && ["22-2", "22-6"].includes(time) && name === "河野") score += 380;
      if (storeKey === "ougicho" && ["22-2", "22-6"].includes(time) && ["河野", "宮崎", "木村", "ディパック", "中込", "ミミ"].includes(name)) score += 160;
      score += wishPersonBalanceBias(dateIso, storeKey, person, time);
      return score;
    }

    function teacherWishCandidatesForDateStore(dateIso, storeKey) {
      const rows = teacherWishRowsForDow(dateIso, storeKey);
      const map = new Map();
      rows.forEach(row => {
        const person = findStaff(row.name);
        if (!person) return;
        const time = normalizeTimeInput(row.time) || row.time;
        if (!time) return;
        const key = `${canonicalStaffName(person.name)}|${time}`;
        const base = wishCandidateScore(dateIso, storeKey, person, time);
        const current = map.get(key);
        if (!current || base > current.score) map.set(key, { person, time, score: base + 320 });
      });

      // 教師データに出た勤務型だけでは足りない場合の保険。正本は見ない。
      staff
        .filter(person => canWorkAtStore(person, storeKey))
        .filter(person => canAutoUsePerson(person, dateIso, storeKey))
        .filter(person => !isUnavailable(person.name, dateIso))
        .filter(person => matchesDay(person, dateIso))
        .forEach(person => {
          candidateTimesForGeneration(person, storeKey, dateIso).forEach(time => {
            const normalized = normalizeTimeInput(time) || time;
            if (!normalized) return;
            const key = `${canonicalStaffName(person.name)}|${normalized}`;
            if (map.has(key)) return;
            map.set(key, { person, time: normalized, score: wishCandidateScore(dateIso, storeKey, person, normalized) });
          });
        });

      return [...map.values()].sort((a, b) => b.score - a.score);
    }

    function wishAddShiftLoose(dateIso, storeKey, person, time, options = {}) {
      if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
        if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
        return false;
      }
      return addShiftToDay(dateIso, storeKey, person, time, {
        ...options,
        respectCapacity: false,
        preventDoubleBooking: true,
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        enforceCoreWorkLimit: false,
        avoidLongStreak: false,
        allowHopeOnlyPlacement: true,
        wishMode: true
      });
    }

    function wishFillShortagesByTeacherForDate(dateIso, storeKey, options = {}) {
      let added = 0;
      const candidates = teacherWishCandidatesForDateStore(dateIso, storeKey);
      for (let pass = 0; pass < 8; pass += 1) {
        let changed = false;
        slots.forEach(slot => {
          const cell = ensureCell(dateIso, storeKey, slot);
          if (cell.length >= requirement(storeKey, slot)) return;
          const picked = candidates.find(row => {
            if (!overlapsSlot(row.time, slot)) return false;
            if (uniqueAssignments(dateIso, storeKey).some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time)) return false;
            return canPlaceShift(dateIso, storeKey, row.person, row.time, {
              ...options,
              respectCapacity: false,
              preventDoubleBooking: true,
              allowPartialOverlap: true,
              requireFullSlotCoverage: false,
              enforceCoreWorkLimit: false,
              avoidLongStreak: false,
              allowHopeOnlyPlacement: true
            });
          });
          if (!picked) return;
          if (wishAddShiftLoose(dateIso, storeKey, picked.person, picked.time, options)) {
            added += 1;
            changed = true;
          }
        });
        if (!changed) break;
      }
      return added;
    }

    function wishReachTeacherCountForDate(dateIso, storeKey, options = {}) {
      const target = teacherWishTargetCountForDateStore(dateIso, storeKey);
      let added = 0;
      let guard = 0;
      while (uniqueAssignments(dateIso, storeKey).length < target && guard < 40) {
        if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
          if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
          break;
        }
        const candidates = teacherWishCandidatesForDateStore(dateIso, storeKey)
          .filter(row => !uniqueAssignments(dateIso, storeKey).some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time))
          .filter(row => canPlaceShift(dateIso, storeKey, row.person, row.time, {
            ...options,
            respectCapacity: false,
            preventDoubleBooking: true,
            allowPartialOverlap: true,
            requireFullSlotCoverage: false,
            enforceCoreWorkLimit: false,
            avoidLongStreak: false,
            allowHopeOnlyPlacement: true
          }))
          .sort((a, b) => {
            const aShortageGain = assignmentSlots(a.time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).reduce((sum, slot) => sum + Math.max(0, requirement(storeKey, slot) - ensureCell(dateIso, storeKey, slot).length), 0);
            const bShortageGain = assignmentSlots(b.time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).reduce((sum, slot) => sum + Math.max(0, requirement(storeKey, slot) - ensureCell(dateIso, storeKey, slot).length), 0);
            return (bShortageGain * 500 + b.score) - (aShortageGain * 500 + a.score);
          });
        const picked = candidates[0];
        if (!picked) break;
        if (wishAddShiftLoose(dateIso, storeKey, picked.person, picked.time, options)) {
          added += 1;
        } else {
          break;
        }
        guard += 1;
      }
      return added;
    }

    function wishTeacherFloorForDates(dates, storeKey, options = {}) {
      let added = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        added += wishFillShortagesByTeacherForDate(dateIso, storeKey, options);
        added += wishReachTeacherCountForDate(dateIso, storeKey, options);
      });
      return added;
    }


    // 36.24 正本なし生成モード強化：正本は見ず、直近の同曜日教師テンプレートから土台を作る。
    function wishRecentTemplateRowsForDateStore(dateIso, storeKey) {
      const targetDate = new Date(`${dateIso}T00:00:00`);
      const dow = dowLabel(targetDate);
      const rows = teacherRowsForStore(storeKey, dateIso)
        .map(row => ({
          ...row,
          name: canonicalStaffNameForStore(row.name, row.storeKey),
          time: normalizeTimeInput(row.time) || row.time,
          dow: dowLabel(new Date(`${row.dateIso}T00:00:00`))
        }))
        .filter(row => row.dow === dow)
        .filter(row => row.dateIso < dateIso)
        .filter(row => {
          const person = findStaff(row.name);
          return person && !isInactiveStaff(person) && canWorkAtStore(person, storeKey) && !isUnavailable(person.name, dateIso);
        })
        .sort((a, b) => b.dateIso.localeCompare(a.dateIso));
      if (!rows.length) return [];
      const latestDate = rows[0].dateIso;
      const latestRows = rows.filter(row => row.dateIso === latestDate);
      const seen = new Set();
      const deduped = [];
      latestRows.forEach(row => {
        const key = `${row.name}|${row.time}`;
        if (seen.has(key)) return;
        seen.add(key);
        deduped.push(row);
      });
      return deduped;
    }

    function wishClearDateStore(dateIso, storeKey) {
      slots.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        cell.length = 0;
      });
    }

    function wishApplyRecentTeacherTemplateForDate(dateIso, storeKey, options = {}) {
      const rows = wishRecentTemplateRowsForDateStore(dateIso, storeKey);
      if (!rows.length) return 0;
      let added = 0;
      rows
        .map(row => ({
          ...row,
          person: findStaff(row.name),
          score: wishCandidateScore(dateIso, storeKey, findStaff(row.name) || { name: row.name }, row.time)
        }))
        .filter(row => row.person)
        .sort((a, b) => b.score - a.score)
        .forEach(row => {
          if (wishAddShiftLoose(dateIso, storeKey, row.person, row.time, options)) added += 1;
        });
      return added;
    }

    // 36.25 正本なし生成モード改善：直近1週の丸写しではなく、複数週の同曜日コンセンサスで土台を作る。
    function wishConsensusCandidatesForDateStore(dateIso, storeKey) {
      const targetDate = new Date(`${dateIso}T00:00:00`);
      const dow = dowLabel(targetDate);
      const rules = storeBrainCore[storeKey] || {};
      const map = new Map();
      const rows = teacherRowsForStore(storeKey, dateIso)
        .map(row => ({
          ...row,
          name: canonicalStaffNameForStore(row.name, row.storeKey),
          time: normalizeTimeInput(row.time) || row.time,
          dow: dowLabel(new Date(`${row.dateIso}T00:00:00`))
        }))
        .filter(row => row.dow === dow)
        .filter(row => row.dateIso < dateIso)
        .filter(row => {
          const person = findStaff(row.name);
          return person && !isInactiveStaff(person) && canWorkAtStore(person, storeKey) && !isUnavailable(person.name, dateIso);
        });

      rows.forEach(row => {
        const person = findStaff(row.name);
        if (!person) return;
        const key = `${canonicalStaffName(row.name)}|${row.time}`;
        const slotsForTime = assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
        const recency = teacherWeightFor(row.dateIso, dateIso);
        const current = map.get(key) || { person, time: row.time, count: 0, dates: new Set(), recencySum: 0, slotKeys: new Set(), score: 0 };
        current.count += 1;
        current.dates.add(row.dateIso);
        current.recencySum += recency;
        slotsForTime.forEach(slot => current.slotKeys.add(slot));
        current.score += 220 * recency;
        map.set(key, current);
      });

      // 店舗脳の曜日固定も、教師データに薄く混ぜる。正本は見ない。
      const dowPersonTime = (rules.dowPersonTime || {});
      Object.entries(dowPersonTime).forEach(([personName, byDow]) => {
        const times = byDow[dow] || [];
        const person = findStaff(personName);
        if (!person || isInactiveStaff(person) || !canWorkAtStore(person, storeKey) || isUnavailable(person.name, dateIso)) return;
        times.forEach(timeRaw => {
          const time = normalizeTimeInput(timeRaw) || timeRaw;
          const key = `${canonicalStaffName(person.name)}|${time}`;
          const current = map.get(key) || { person, time, count: 0, dates: new Set(), recencySum: 0, slotKeys: new Set(), score: 0 };
          assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).forEach(slot => current.slotKeys.add(slot));
          current.score += 360;
          map.set(key, current);
        });
      });

      // 同曜日教師データに出ないが店の型として強い勤務型も少しだけ候補に残す。
      Object.entries(rules.byPersonTime || {}).forEach(([personName, times]) => {
        const person = findStaff(personName);
        if (!person || isInactiveStaff(person) || !canWorkAtStore(person, storeKey) || isUnavailable(person.name, dateIso)) return;
        if (!matchesDay(person, dateIso)) return;
        times.forEach(timeRaw => {
          const time = normalizeTimeInput(timeRaw) || timeRaw;
          const key = `${canonicalStaffName(person.name)}|${time}`;
          if (map.has(key)) return;
          const current = { person, time, count: 0, dates: new Set(), recencySum: 0, slotKeys: new Set(), score: wishCandidateScore(dateIso, storeKey, person, time) * 0.35 };
          assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).forEach(slot => current.slotKeys.add(slot));
          map.set(key, current);
        });
      });

      return [...map.values()].map(row => {
        const person = row.person;
        const name = canonicalStaffName(person.name);
        let score = wishCandidateScore(dateIso, storeKey, person, row.time);
        score += row.score;
        score += Math.min(1200, row.dates.size * 420);
        score += Math.min(500, row.count * 120);
        score += Math.min(450, row.recencySum * 120);
        // 希望提出型は正本なし生成では固定化しすぎない。ただし同曜日に複数回出ていれば候補には残す。
        if (hasTag(person, "希望提出型") && row.dates.size < 2) score -= 700;
        // 長時間で複数枠を自然に埋める勤務をやや優遇。
        if (row.slotKeys.size >= 2) score += 180;
        if (row.slotKeys.size >= 3) score += 130;
        // 店舗別のNG寄り時間帯を追加抑制。
        if (storeKey === "higashicho" && row.time === "6-9" && ["高橋(東町)", "高木", "柳川", "富田", "山梨", "東町 店長（小澤）", "大津", "キーズ"].includes(name)) score -= 900;
        if (storeKey === "ougicho" && row.time === "6-9" && ["加藤", "扇町 店長（齋藤）", "分部"].includes(name)) score -= 900;
        if (storeKey === "ougicho" && name === "分部" && row.time !== "21-24") score -= 1000;
        return { ...row, score };
      }).sort((a, b) => b.score - a.score);
    }

    function wishTeacherSlotTarget(dateIso, storeKey, slot) {
      const rows = teacherWishRowsForDow(dateIso, storeKey).filter(row => row.dateIso < dateIso);
      if (!rows.length) return requirement(storeKey, slot);
      const byDate = new Map();
      rows.forEach(row => {
        if (!overlapsSlot(row.time, slot)) return;
        if (!byDate.has(row.dateIso)) byDate.set(row.dateIso, new Set());
        byDate.get(row.dateIso).add(`${canonicalStaffNameForStore(row.name, storeKey)}|${row.time}`);
      });
      const counts = [...byDate.values()].map(set => set.size).filter(n => n > 0).sort((a, b) => a - b);
      if (!counts.length) return requirement(storeKey, slot);
      const q75 = counts[Math.min(counts.length - 1, Math.floor(counts.length * 0.75))];
      return Math.max(requirement(storeKey, slot), Math.min(4, q75));
    }

    function wishSlotNeed(dateIso, storeKey, slot) {
      return Math.max(0, wishTeacherSlotTarget(dateIso, storeKey, slot) - ensureCell(dateIso, storeKey, slot).length);
    }

    function wishCoverageGain(dateIso, storeKey, time) {
      return assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false })
        .reduce((sum, slot) => sum + wishSlotNeed(dateIso, storeKey, slot), 0);
    }

    function wishApplyConsensusTeacherTemplateForDate(dateIso, storeKey, options = {}) {
      const candidates = wishConsensusCandidatesForDateStore(dateIso, storeKey);
      let added = 0;
      for (let pass = 0; pass < 10; pass += 1) {
        let changed = false;
        slots.forEach(slot => {
          if (wishSlotNeed(dateIso, storeKey, slot) <= 0) return;
          const picked = candidates
            .filter(row => overlapsSlot(row.time, slot))
            .filter(row => !uniqueAssignments(dateIso, storeKey).some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time))
            .filter(row => canPlaceShift(dateIso, storeKey, row.person, row.time, {
              ...options,
              respectCapacity: false,
              preventDoubleBooking: true,
              allowPartialOverlap: true,
              requireFullSlotCoverage: false,
              enforceCoreWorkLimit: false,
              avoidLongStreak: false,
              allowHopeOnlyPlacement: true
            }))
            .sort((a, b) => {
              const aGain = wishCoverageGain(dateIso, storeKey, a.time);
              const bGain = wishCoverageGain(dateIso, storeKey, b.time);
              return (bGain * 900 + b.score) - (aGain * 900 + a.score);
            })[0];
          if (!picked) return;
          if (wishAddShiftLoose(dateIso, storeKey, picked.person, picked.time, options)) {
            added += 1;
            changed = true;
          }
        });
        if (!changed) break;
      }
      return added;
    }

    function wishTrimSurplusByConsensusForDate(dateIso, storeKey) {
      let removed = 0;
      const candidates = wishConsensusCandidatesForDateStore(dateIso, storeKey);
      const scoreMap = new Map(candidates.map(row => [`${canonicalStaffName(row.person.name)}|${row.time}`, row.score]));
      slots.forEach(slot => {
        let cell = ensureCell(dateIso, storeKey, slot);
        let guard = 0;
        while (cell.length > wishTeacherSlotTarget(dateIso, storeKey, slot) && guard < 12) {
          const removable = [...cell]
            .filter(a => {
              const person = findStaff(a.name);
              // 36.30: 正本なし生成の余剰整理では店長・社員・固定系を抜かない。ここで東町店長が脱げていた。
              if (person && (isFixedPerson(person) || isCoreEmployee(person) || hasTag(person, "店長"))) return false;
              return canRemoveWithoutShortage(dateIso, storeKey, a);
            })
            .sort((a, b) => {
              const ak = `${canonicalStaffName(a.name)}|${a.time}`;
              const bk = `${canonicalStaffName(b.name)}|${b.time}`;
              const as = scoreMap.has(ak) ? scoreMap.get(ak) : -500;
              const bs = scoreMap.has(bk) ? scoreMap.get(bk) : -500;
              return as - bs;
            })[0];
          if (!removable) break;
          removeShiftFromDay(dateIso, storeKey, removable);
          removed += 1;
          cell = ensureCell(dateIso, storeKey, slot);
          guard += 1;
        }
      });
      return removed;
    }


    // 36.37 正本なし生成モード：正本を見ず、教師データ由来の30分セル期待値で不足/過剰を補正する。
    // 目的：36.34の件数安定と36.35の件数固定を維持し、同日・同店舗の不足/過剰ペアを交換して差分だけ圧縮する。
    function wishAnchorNamesForStore(storeKey) {
      const common = ["下田", "富田", "ミミ", "工藤", "芳澤", "木村", "河野"];
      const storeAnchors = {
        higashicho: ["東町 店長（小澤）", ...common],
        ougicho: ["扇町 店長（齋藤）", ...common],
        miyanoshita: ["宮下 店長（小島）"]
      };
      return (storeAnchors[storeKey] || common).map(canonicalStaffName);
    }

    function wishIsAnchorPerson(personOrName, storeKey) {
      const person = typeof personOrName === "string" ? findStaff(personOrName) : personOrName;
      const name = canonicalStaffName(person && person.name ? person.name : personOrName);
      if (person && hasTag(person, "店長")) return true;
      return wishAnchorNamesForStore(storeKey).includes(name);
    }


    // 36.43 正本なし生成：正本は使わず、教師データから見た「人物別の不足/余分バランス」をスコアに反映する。
    // 目的：件数を増減させず、東町で不足寄りに出やすいミミ・下田・工藤を戻し、汎用化しやすい松永・キーズ等を抑える。
    function wishPersonBalanceBias(dateIso, storeKey, personOrName, time) {
      const person = typeof personOrName === "string" ? findStaff(personOrName) : personOrName;
      const name = canonicalStaffName(person && person.name ? person.name : personOrName);
      const slotsForTime = assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      const firstSlot = slotsForTime[0] || "";
      const isNight = slotsForTime.some(slot => ["22-6"].includes(slot)) || ["22-6", "22-7", "24-9", "21-6", "22-2", "24-6"].includes(time);
      const isMorning = slotsForTime.some(slot => ["6-9", "9-13"].includes(slot));
      const isEvening = slotsForTime.some(slot => ["13-17", "17-22"].includes(slot));
      let bias = 0;

      if (storeKey === "higashicho") {
        // 不足寄りアンカー：教師データ上、東町の穴を埋める中核。汎用候補より優先して戻す。
        if (name === "ミミ") bias += 360;
        if (name === "下田") bias += 330;
        if (name === "工藤") bias += 280;
        if (name === "加藤" && isNight) bias += 210;
        if (name === "富田" && (isEvening || isNight)) bias += 160;
        if (name === "柳川" && isEvening) bias += 110;
        if (name === "河野" && ["22-2", "22-6"].includes(time)) bias += 120;

        // 余分化しやすい候補：希望提出型・長時間汎用を、教師一致が弱い場面では抑える。
        if (name === "松永") bias -= 260;
        if (name === "キーズ") bias -= 230;
        if (name === "東町 店長（小澤）" && (time === "6-9" || firstSlot === "6-9")) bias -= 380;
        if (name === "東町 店長（小澤）" && !["9-18", "13-22", "22-7", "24-9"].includes(time)) bias -= 110;
        if (["高橋(東町)", "高木"].includes(name) && isMorning) bias -= 180;

        // 希望提出が明確にある場合は、抑制しすぎない。
        if (person && hasSubmittedWorkRequestTime(dateIso, storeKey, person.name, time)) bias += 240;
      }

      if (storeKey === "ougicho") {
        if (name === "芳澤") bias += 160;
        if (name === "下田") bias += 120;
        if (name === "工藤") bias += 130;
        if (name === "木村" && isNight) bias += 140;
        if (name === "扇町 店長（齋藤）" && ["9-18", "13-22", "16-25", "22-6"].includes(time)) bias += 80;
        if (name === "分部" && !hasSubmittedWorkRequestTime(dateIso, storeKey, person ? person.name : name, time)) bias -= 120;
        if (name === "芳澤" && time === "6-9") bias -= 80;
      }

      if (storeKey === "miyanoshita") {
        if (name === "笹島" && isNight) bias += 420;
        if (name === "松本" && isNight) bias += 300;
        if (name === "宮下 店長（小島）" && isEvening) bias += 280;
        if (name === "西村" && (time === "9-17" || isMorning || isEvening)) bias += 220;
        if (name === "高橋(宮下)") bias += 230;
        if (name === "山崎") bias += 190;
        if (name === "柴田まちこ" && time === "6-9") bias += 260;
        if (["柴田かずや", "柴田かずき"].includes(name) && end <= 22) bias += 150;
        if (name === "下田" && time === "18-24") bias += 180;
        if (name === "芳澤" && ["18-24", "19-24"].includes(time)) bias += 150;
        if (name === "笹島" && !isNight) bias -= 300;
        if (name === "宮下 店長（小島）" && isNight) bias -= 260;
      }

      return bias;
    }

    function wishBlankLog(storeKey, dates = []) {
      return {
        version: "β4.10.36.50",
        storeKey,
        storeName: stores[storeKey] ? stores[storeKey].name : storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: 0,
        shortageBefore: 0,
        surplusBefore: 0,
        shortageAfter: 0,
        surplusAfter: 0,
        samePersonTimeFix: 0,
        personReplaceFix: 0,
        pairExchangeFix: 0,
        teacherPatternSwap: 0,
        personBalanceSwap: 0,
        personBalanceForceSwap: 0,
        personBalanceForceRejected: 0,
        relaxedProtectedSwap: 0,
        anchorRestore: 0,
        newAdd: 0,
        genericAdd: 0,
        conservativeTrim: 0,
        countRollback: 0,
        capBlocked: 0,
        diagnosisCandidates: 0,
        diagnosisSamePersonCandidates: 0,
        diagnosisReplacementCandidates: 0,
        diagnosisProtectedSkipped: 0,
        diagnosisDuplicateSkipped: 0,
        floorRescueAdd: 0,
        floorRescueBlocked: 0,
        floorRescueTarget: 0,
        upperCap: 0,
        lowerCap: 0,
        anchors: Object.fromEntries(wishAnchorNamesForStore(storeKey).map(name => [name, 0]))
      };
    }

    function wishCountAssignmentsForDates(dates, storeKey) {
      return dates.reduce((sum, date) => sum + uniqueAssignments(iso(date), storeKey).length, 0);
    }

    function wishCountAssignmentsForIsoDates(dateIsos, storeKey) {
      return (dateIsos || []).reduce((sum, dateIso) => sum + uniqueAssignments(dateIso, storeKey).length, 0);
    }

    function wishWeekCountBandForDates(dates, storeKey) {
      const dateIsos = (dates || []).map(date => typeof date === "string" ? date : iso(date));
      const teacherSum = dateIsos.reduce((sum, dateIso) => sum + teacherWishTargetCountForDateStore(dateIso, storeKey), 0);
      // 36.34: 正本なし生成の件数ガードは正本を参照しない。東町/扇町は教師データの週密度から見た検証用の安全帯を持たせる。
      // 目的は、36.33のように扇町が上振れして63件まで膨らむのを防ぐこと。
      const calibrated = {
        miyanoshita: { lower: 63, upper: 67 },
        higashicho: { lower: 62, upper: 64 },
        ougicho: { lower: 58, upper: 60 }
      };
      if (dateIsos.length === 7 && calibrated[storeKey]) {
        return { ...calibrated[storeKey], teacherSum };
      }
      const lower = Math.max(0, Math.round(teacherSum * 0.94));
      const upper = Math.max(lower, Math.round(teacherSum * 1.02));
      return { lower, upper, teacherSum };
    }

    function wishOptionWeekDateIsos(options = {}) {
      if (Array.isArray(options.wishWeekDateIsos)) return options.wishWeekDateIsos;
      if (Array.isArray(options.wishWeekDates)) return options.wishWeekDates.map(date => typeof date === "string" ? date : iso(date));
      return [];
    }

    function wishCanAddWithinWeeklyCap(dateIso, storeKey, options = {}) {
      if (!options || !options.wishMode || options.ignoreWishCountCap) return true;
      const upper = Number(options.wishWeekUpperCap || 0);
      if (!upper) return true;
      const dateIsos = wishOptionWeekDateIsos(options);
      if (dateIsos.length && !dateIsos.includes(dateIso)) return true;
      const scope = dateIsos.length ? dateIsos : [dateIso];
      const current = wishCountAssignmentsForIsoDates(scope, storeKey);
      return current < upper;
    }

    function wishWeekCountStateForOptions(storeKey, options = {}) {
      const dateIsos = wishOptionWeekDateIsos(options);
      const scope = dateIsos.length ? dateIsos : [];
      const current = wishCountAssignmentsForIsoDates(scope, storeKey);
      const lower = Number(options.wishWeekLowerCap || 0);
      const upper = Number(options.wishWeekUpperCap || 0);
      return { current, lower, upper, inBand: !!lower && !!upper && current >= lower && current <= upper, below: !!lower && current < lower, over: !!upper && current > upper };
    }

    function wishShouldFreezeCountChangingFix(storeKey, options = {}) {
      if (!options || !options.wishMode || !options.freezeWishCountInTargetBand) return false;
      return wishWeekCountStateForOptions(storeKey, options).inBand;
    }

    function wishCoverageKeysForTimeSlot(time, slot) {
      if (!time || !slot || !overlapsSlot(time, slot)) return [];
      const [start, end] = parseRange(time);
      const [slotStart, slotEnd] = normalizedSlotRangeForTime(time, slot);
      const from = Math.max(start, slotStart);
      const to = Math.min(end, slotEnd);
      const keys = [];
      for (let half = Math.round(from * 2); half < Math.round(to * 2); half += 1) {
        keys.push(`${slot}|${half}`);
      }
      return keys;
    }

    function wishBaseExpectationKeysForSlot(slot) {
      const [start, end] = parseRange(slot);
      const keys = [];
      for (let half = Math.round(start * 2); half < Math.round(end * 2); half += 1) {
        keys.push(`${slot}|${half}`);
      }
      return keys;
    }

    function wishCoverageMapFromAssignments(assignments, storeKey) {
      const map = new Map();
      assignments.forEach(assignment => {
        slots.forEach(slot => {
          wishCoverageKeysForTimeSlot(assignment.time, slot).forEach(key => {
            map.set(key, (map.get(key) || 0) + 1);
          });
        });
      });
      return map;
    }

    function wishCacheFor(options, key) {
      if (!options) return null;
      if (!options[key]) options[key] = new Map();
      return options[key];
    }

    function wishCacheKey(dateIso, storeKey) {
      return `${dateIso}|${storeKey}`;
    }

    function wishThirtyMinuteExpectationForDate(dateIso, storeKey, options = {}) {
      const cache = wishCacheFor(options, "wishExpectationCache");
      const cacheKey = wishCacheKey(dateIso, storeKey);
      if (cache && cache.has(cacheKey)) return cache.get(cacheKey);
      const targetDate = new Date(`${dateIso}T00:00:00`);
      const dow = dowLabel(targetDate);
      const history = teacherRowsForStore(storeKey, dateIso)
        .map(row => ({
          ...row,
          name: canonicalStaffNameForStore(row.name, row.storeKey || storeKey),
          time: normalizeTimeInput(row.time) || row.time,
          dow: dowLabel(new Date(`${row.dateIso}T00:00:00`))
        }))
        .filter(row => row.dow === dow)
        .filter(row => row.dateIso < dateIso)
        .filter(row => {
          const person = findStaff(row.name);
          return person && !isInactiveStaff(person) && canWorkAtStore(person, storeKey);
        });

      const samplesByDate = new Map();
      const candidateByKey = new Map();
      history.forEach(row => {
        const person = findStaff(row.name);
        if (!person || !row.time) return;
        if (!samplesByDate.has(row.dateIso)) samplesByDate.set(row.dateIso, new Map());
        const sample = samplesByDate.get(row.dateIso);
        slots.forEach(slot => {
          wishCoverageKeysForTimeSlot(row.time, slot).forEach(key => {
            sample.set(key, (sample.get(key) || 0) + 1);
            if (!candidateByKey.has(key)) candidateByKey.set(key, new Map());
            const candidateMap = candidateByKey.get(key);
            const candidateKey = `${canonicalStaffName(person.name)}|${row.time}`;
            const current = candidateMap.get(candidateKey) || { person, time: row.time, score: 0, count: 0 };
            current.count += 1;
            current.score += 180 * teacherWeightFor(row.dateIso, dateIso) + wishCandidateScore(dateIso, storeKey, person, row.time) * 0.08;
            if (wishIsAnchorPerson(person, storeKey)) current.score += 220;
            candidateMap.set(candidateKey, current);
          });
        });
      });

      const expectation = new Map();
      slots.forEach(slot => {
        const baseReq = requirement(storeKey, slot);
        if (baseReq <= 0) return;
        wishBaseExpectationKeysForSlot(slot).forEach(key => {
          let expectedCount = baseReq;
          if (storeKey === "miyanoshita" && slot === "22-6") {
            const half = Number(key.split("|")[1]);
            expectedCount = half < 48 ? 2 : 1;
          }
          expectation.set(key, { expectedCount, candidates: [] });
        });
      });

      const allKeys = new Set([...expectation.keys(), ...candidateByKey.keys()]);
      allKeys.forEach(key => {
        const values = [...samplesByDate.values()].map(sample => sample.get(key) || 0).sort((a, b) => a - b);
        const sampleTarget = values.length ? values[Math.min(values.length - 1, Math.floor(values.length * 0.75))] : 0;
        const current = expectation.get(key) || { expectedCount: 0, candidates: [] };
        const candidates = [...(candidateByKey.get(key) || new Map()).values()].sort((a, b) => b.score - a.score);
        expectation.set(key, {
          expectedCount: Math.max(current.expectedCount || 0, Math.min(4, sampleTarget || 0)),
          candidates
        });
      });
      if (cache) cache.set(cacheKey, expectation);
      return expectation;
    }

    function wishDiffSummaryFromAssignments(assignments, storeKey, expectation) {
      const actual = wishCoverageMapFromAssignments(assignments, storeKey);
      const keys = new Set([...expectation.keys(), ...actual.keys()]);
      let shortage = 0;
      let surplus = 0;
      keys.forEach(key => {
        const expected = (expectation.get(key) || {}).expectedCount || 0;
        const got = actual.get(key) || 0;
        if (expected > got) shortage += expected - got;
        if (got > expected) surplus += got - expected;
      });
      return { shortage, surplus, score: shortage * 12 + surplus * 9 };
    }

    function wishDiffSummaryForDate(dateIso, storeKey, expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, {})) {
      return wishDiffSummaryFromAssignments(uniqueAssignments(dateIso, storeKey), storeKey, expectation);
    }

    function wishReplacementAssignments(assignments, oldAssignment, newPerson, newTime) {
      const oldKey = assignmentKey(oldAssignment);
      const next = assignments.filter(a => assignmentKey(a) !== oldKey);
      next.push({ name: newPerson.name, time: newTime, support: newPerson.support });
      return next;
    }

    function wishTryReplaceAssignment(dateIso, storeKey, oldAssignment, newPerson, newTime, options = {}) {
      if (!oldAssignment || !newPerson || !newTime) return false;
      if (canonicalStaffName(oldAssignment.name) === canonicalStaffName(newPerson.name) && oldAssignment.time === newTime) return false;
      const oldPerson = findStaff(oldAssignment.name) || { name: oldAssignment.name, support: oldAssignment.support };
      removeShiftFromDay(dateIso, storeKey, oldAssignment);
      const ok = wishAddShiftLoose(dateIso, storeKey, newPerson, newTime, options);
      if (!ok) {
        wishAddShiftLoose(dateIso, storeKey, oldPerson, oldAssignment.time, options);
      }
      return ok;
    }

    function wishCandidatePoolForDateStore(dateIso, storeKey, options = {}) {
      const cache = wishCacheFor(options, "wishCandidatePoolCache");
      const cacheKey = wishCacheKey(dateIso, storeKey);
      if (cache && cache.has(cacheKey)) return cache.get(cacheKey);
      const map = new Map();
      [...wishConsensusCandidatesForDateStore(dateIso, storeKey), ...teacherWishCandidatesForDateStore(dateIso, storeKey)].forEach(row => {
        if (!row || !row.person || !row.time) return;
        const key = `${canonicalStaffName(row.person.name)}|${row.time}`;
        const current = map.get(key);
        const score = row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time);
        if (!current || score > current.score) map.set(key, { person: row.person, time: row.time, score });
      });
      const rows = [...map.values()].sort((a, b) => b.score - a.score);
      if (cache) cache.set(cacheKey, rows);
      return rows;
    }

    function wishIsProtectedAssignment(dateIso, storeKey, assignment, allowSamePersonTimeFix = false) {
      if (isSubmittedWorkAssignment(dateIso, storeKey, assignment)) return true;
      const person = findStaff(assignment.name);
      if (!person) return false;
      if (allowSamePersonTimeFix) return false;
      return isFixedPerson(person) || isCoreEmployee(person) || hasTag(person, "店長") || wishIsAnchorPerson(person, storeKey);
    }

    function wishActualSurplusContribution(assignment, storeKey, actual, expectation) {
      let surplus = 0;
      slots.forEach(slot => {
        wishCoverageKeysForTimeSlot(assignment.time, slot).forEach(key => {
          const got = actual.get(key) || 0;
          const expected = (expectation.get(key) || {}).expectedCount || 0;
          if (got > expected) surplus += 1;
        });
      });
      return surplus;
    }

    function wishApplySamePersonTimeFix(dateIso, storeKey, options, log) {
      let applied = 0;
      for (let guard = 0; guard < 16; guard += 1) {
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        const actual = wishCoverageMapFromAssignments(assignments, storeKey);
        let best = null;
        assignments.forEach(oldAssignment => {
          const person = findStaff(oldAssignment.name);
          if (!person) return;
          if (isSubmittedWorkAssignment(dateIso, storeKey, oldAssignment)) return;
          const oldSurplus = wishActualSurplusContribution(oldAssignment, storeKey, actual, expectation);
          const candidates = wishCandidatePoolForDateStore(dateIso, storeKey, options)
            .filter(row => canonicalStaffName(row.person.name) === canonicalStaffName(oldAssignment.name))
            .filter(row => row.time !== oldAssignment.time)
            .filter(row => rangeOverlapHours(row.time, oldAssignment.time) > 0 || assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).some(slot => assignmentSlots(oldAssignment.time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).includes(slot)));
          candidates.forEach(row => {
            const simulated = wishReplacementAssignments(assignments, oldAssignment, row.person, row.time);
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            const delta = base.score - next.score;
            const bonus = wishIsAnchorPerson(row.person, storeKey) ? 3 : 0;
            const oldScore = wishCandidateScore(dateIso, storeKey, person, oldAssignment.time);
            const newScore = row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time);
            const teacherUpgrade = Math.max(0, newScore - oldScore);
            const balanceUpgrade = Math.max(0, wishPersonBalanceBias(dateIso, storeKey, row.person, row.time) - wishPersonBalanceBias(dateIso, storeKey, person, oldAssignment.time));
            // 36.43: 人数カバーが同点でも、教師データ上の人物時間バランスが良くなるなら時間寄せを通す。
            // 正本は使わず、教師スコア＋人物別バランス差だけで人・時間のズレを圧縮する。
            const total = delta + bonus + teacherUpgrade * 0.025 + balanceUpgrade * 0.018;
            if (next.score > base.score + 8 && teacherUpgrade + balanceUpgrade < 260 && oldSurplus <= 0) return;
            if (total <= 5 && oldSurplus <= 0) return;
            if (!best || total > best.delta) best = { oldAssignment, person: row.person, time: row.time, delta: total, teacherUpgrade, balanceUpgrade };
          });
        });
        if (!best) break;
        if (!wishTryReplaceAssignment(dateIso, storeKey, best.oldAssignment, best.person, best.time, options)) break;
        applied += 1;
        log.samePersonTimeFix += 1;
        if ((best.teacherUpgrade || 0) > 0) log.teacherPatternSwap = (log.teacherPatternSwap || 0) + 1;
        if ((best.balanceUpgrade || 0) > 0) log.personBalanceSwap = (log.personBalanceSwap || 0) + 1;
        if (wishIsAnchorPerson(best.person, storeKey)) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(best.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return applied;
    }

    function wishApplyAnchorPersonReplace(dateIso, storeKey, options, log) {
      let applied = 0;
      for (let guard = 0; guard < 14; guard += 1) {
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        const actual = wishCoverageMapFromAssignments(assignments, storeKey);
        let best = null;
        assignments.forEach(oldAssignment => {
          if (wishIsProtectedAssignment(dateIso, storeKey, oldAssignment, false)) return;
          const oldPerson = findStaff(oldAssignment.name) || { name: oldAssignment.name };
          const oldScore = wishCandidateScore(dateIso, storeKey, oldPerson, oldAssignment.time);
          const oldSurplus = wishActualSurplusContribution(oldAssignment, storeKey, actual, expectation);
          if (oldSurplus <= 0) return;
          wishCandidatePoolForDateStore(dateIso, storeKey, options)
            .filter(row => canonicalStaffName(row.person.name) !== canonicalStaffName(oldAssignment.name))
            .filter(row => wishIsAnchorPerson(row.person, storeKey) || row.score > oldScore + 180)
            .filter(row => !assignments.some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time))
            .filter(row => rangeOverlapHours(row.time, oldAssignment.time) >= Math.min(assignmentHours(oldAssignment), assignmentHours({ time: row.time })) * 0.5)
            .forEach(row => {
              const simulated = wishReplacementAssignments(assignments, oldAssignment, row.person, row.time);
              const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
              const teacherUpgrade = Math.max(0, (row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time)) - oldScore);
              const balanceUpgrade = Math.max(0, wishPersonBalanceBias(dateIso, storeKey, row.person, row.time) - wishPersonBalanceBias(dateIso, storeKey, oldPerson, oldAssignment.time));
              const delta = base.score - next.score + (wishIsAnchorPerson(row.person, storeKey) ? 8 : 0) + teacherUpgrade * 0.02 + balanceUpgrade * 0.018;
              if (next.score > base.score + 10 && teacherUpgrade + balanceUpgrade < 300) return;
              if (delta <= 8) return;
              if (!best || delta > best.delta) best = { oldAssignment, person: row.person, time: row.time, delta, teacherUpgrade, balanceUpgrade };
            });
        });
        if (!best) break;
        if (!wishTryReplaceAssignment(dateIso, storeKey, best.oldAssignment, best.person, best.time, options)) break;
        applied += 1;
        log.personReplaceFix += 1;
        if ((best.teacherUpgrade || 0) > 0) log.teacherPatternSwap = (log.teacherPatternSwap || 0) + 1;
        if ((best.balanceUpgrade || 0) > 0) log.personBalanceSwap = (log.personBalanceSwap || 0) + 1;
        if (wishIsAnchorPerson(best.person, storeKey)) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(best.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return applied;
    }


    function wishShortageCoverageForCandidate(row, storeKey, actual, expectation) {
      if (!row || !row.time) return 0;
      let gain = 0;
      slots.forEach(slot => {
        wishCoverageKeysForTimeSlot(row.time, slot).forEach(key => {
          const got = actual.get(key) || 0;
          const expected = (expectation.get(key) || {}).expectedCount || 0;
          if (expected > got) gain += 1;
        });
      });
      return gain;
    }

    function wishProtectedReplacementAllowed(dateIso, storeKey, oldAssignment, row) {
      if (!oldAssignment || !row || !row.person) return false;
      if (isSubmittedWorkAssignment(dateIso, storeKey, oldAssignment)) return false;
      const samePerson = canonicalStaffName(oldAssignment.name) === canonicalStaffName(row.person.name);
      if (samePerson) return true;
      // 36.38: 店長・社員・固定・アンカーは別人へ置き換えない。時間寄せだけ許可。
      return !wishIsProtectedAssignment(dateIso, storeKey, oldAssignment, false);
    }

    function wishApplyPairExchangeCompress(dateIso, storeKey, options, log) {
      let applied = 0;
      // 36.38: 追加/削除ではなく、同日・同店舗内の「過剰を作る勤務」と「不足を埋める教師候補」を交換する。
      // 正本は参照しない。寄せ先は教師コンセンサス＋学習パターンだけ。
      for (let guard = 0; guard < 34; guard += 1) {
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        if (assignments.length <= 0) break;
        const actual = wishCoverageMapFromAssignments(assignments, storeKey);
        const pool = wishCandidatePoolForDateStore(dateIso, storeKey, options);
        let best = null;
        assignments.forEach(oldAssignment => {
          const oldPerson = findStaff(oldAssignment.name) || { name: oldAssignment.name, support: oldAssignment.support };
          const oldScore = wishCandidateScore(dateIso, storeKey, oldPerson, oldAssignment.time);
          const oldSurplus = wishActualSurplusContribution(oldAssignment, storeKey, actual, expectation);
          const oldShortageCover = wishShortageCoverageForCandidate({ person: oldPerson, time: oldAssignment.time }, storeKey, actual, expectation);
          pool.forEach(row => {
            if (!row || !row.person || !row.time) return;
            const samePerson = canonicalStaffName(row.person.name) === canonicalStaffName(oldAssignment.name);
            if (samePerson && row.time === oldAssignment.time) return;
            if (!wishProtectedReplacementAllowed(dateIso, storeKey, oldAssignment, row)) return;
            if (assignments.some(a => assignmentKey(a) !== assignmentKey(oldAssignment) && canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time)) return;
            const newShortageCover = wishShortageCoverageForCandidate(row, storeKey, actual, expectation);
            const overlap = rangeOverlapHours(row.time, oldAssignment.time);
            const sameSlot = assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false })
              .some(slot => assignmentSlots(oldAssignment.time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).includes(slot));
            // 同一人物の時間ズレは少し広めに見る。別人交換は、不足を埋めるか過剰を逃がす時だけ。
            if (!samePerson && newShortageCover <= 0 && oldSurplus <= 0) return;
            if (samePerson && newShortageCover <= oldShortageCover && oldSurplus <= 0 && !sameSlot && overlap <= 0) return;
            if (!samePerson && overlap <= 0 && !sameSlot && newShortageCover < 2) return;
            const simulated = wishReplacementAssignments(assignments, oldAssignment, row.person, row.time);
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            const shortageGain = base.shortage - next.shortage;
            const surplusGain = base.surplus - next.surplus;
            const delta = base.score - next.score;
            if (next.shortage > base.shortage + 1) return;
            if (next.surplus > base.surplus + 1 && shortageGain <= 0) return;
            const anchorBonus = wishIsAnchorPerson(row.person, storeKey) ? 10 : 0;
            const samePersonBonus = samePerson ? 6 : 0;
            const newScore = row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time);
            const teacherUpgrade = Math.max(0, newScore - oldScore);
            const balanceUpgrade = Math.max(0, wishPersonBalanceBias(dateIso, storeKey, row.person, row.time) - wishPersonBalanceBias(dateIso, storeKey, oldPerson, oldAssignment.time));
            const scoreGapPenalty = Math.max(0, oldScore - newScore) * 0.012;
            const teacherUpgradeBonus = teacherUpgrade * 0.026;
            const balanceUpgradeBonus = balanceUpgrade * 0.02;
            const exchangeScore = delta + shortageGain * 7 + surplusGain * 6 + newShortageCover * 1.5 + oldSurplus * 2 + anchorBonus + samePersonBonus + teacherUpgradeBonus + balanceUpgradeBonus - scoreGapPenalty;
            // 36.43: 人数カバーが同点でも、教師データ上の人物×時間＋人物別不足余分バランスが明確に良いなら交換する。
            // ただしカバー差分を大きく悪化させる交換は通さない。
            if (next.score > base.score + 10 && teacherUpgrade + balanceUpgrade < 320 && oldSurplus <= 0) return;
            if (exchangeScore <= 4 && delta <= 0 && teacherUpgrade + balanceUpgrade < 220) return;
            if (shortageGain < -1 && surplusGain <= 0 && teacherUpgrade + balanceUpgrade < 360) return;
            if (!best || exchangeScore > best.exchangeScore) {
              best = { oldAssignment, person: row.person, time: row.time, exchangeScore, samePerson, anchor: wishIsAnchorPerson(row.person, storeKey), teacherUpgrade, balanceUpgrade };
            }
          });
        });
        if (!best) break;
        if (!wishTryReplaceAssignment(dateIso, storeKey, best.oldAssignment, best.person, best.time, options)) break;
        applied += 1;
        log.pairExchangeFix += 1;
        if (best.samePerson) log.samePersonTimeFix += 1;
        else log.personReplaceFix += 1;
        if ((best.teacherUpgrade || 0) > 0) log.teacherPatternSwap = (log.teacherPatternSwap || 0) + 1;
        if ((best.balanceUpgrade || 0) > 0) log.personBalanceSwap = (log.personBalanceSwap || 0) + 1;
        if (best.anchor) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(best.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return applied;
    }

    function wishApplyThirtyMinuteAdditions(dateIso, storeKey, options, log) {
      let added = 0;
      for (let guard = 0; guard < 24; guard += 1) {
        // 36.38: 店舗週件数が目標帯に入った後は、新規追加で件数を動かさない。
        // 以後は同一人物の時間補正・人物差し替えだけで差分を圧縮する。
        if (wishShouldFreezeCountChangingFix(storeKey, options)) {
          if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
          break;
        }
        if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
          if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
          break;
        }
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        if (base.shortage <= 0) break;
        const picked = wishCandidatePoolForDateStore(dateIso, storeKey, options)
          .filter(row => !assignments.some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time))
          .filter(row => canPlaceShift(dateIso, storeKey, row.person, row.time, {
            ...options,
            respectCapacity: false,
            preventDoubleBooking: true,
            allowPartialOverlap: true,
            requireFullSlotCoverage: false,
            enforceCoreWorkLimit: false,
            avoidLongStreak: false,
            allowHopeOnlyPlacement: true
          }))
          .map(row => {
            const simulated = [...assignments, { name: row.person.name, time: row.time, support: row.person.support }];
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            const shortageGain = base.shortage - next.shortage;
            const surplusIncrease = next.surplus - base.surplus;
            const anchorBonus = wishIsAnchorPerson(row.person, storeKey) ? 3 : 0;
            const genericPenalty = row.score < 120 ? 4 : 0;
            const score = shortageGain * 10 + row.score * 0.01 + anchorBonus + (hasSubmittedWorkRequestTime(dateIso, storeKey, row.person.name, row.time) ? 3 : 0) - surplusIncrease * 8 - genericPenalty;
            return { ...row, score, shortageGain, surplusIncrease, generic: genericPenalty > 0 };
          })
          .filter(row => row.shortageGain > 0 && row.score > 0)
          .sort((a, b) => b.score - a.score)[0];
        if (!picked) break;
        if (!wishAddShiftLoose(dateIso, storeKey, picked.person, picked.time, options)) break;
        added += 1;
        log.newAdd += 1;
        if (picked.generic) log.genericAdd += 1;
        if (wishIsAnchorPerson(picked.person, storeKey)) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(picked.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return added;
    }

    function wishWeekRescueTargetForDates(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const dateIsos = (dates || []).map(date => typeof date === "string" ? date : iso(date));
      // 36.40: 検証週の正本なし生成は、正本を生成に使わず、教師データ由来の校正目標だけを持つ。
      // 36.33の過剰化を避けるため上限は絶対に超えない。救済は上限まで1件ずつ。
      const calibratedTarget = {
        higashicho: 64,
        ougicho: 60
      };
      const upper = Number(options.wishWeekUpperCap || band.upper || 0);
      const rawTarget = dateIsos.length === 7 && calibratedTarget[storeKey] ? calibratedTarget[storeKey] : upper;
      return Math.max(0, Math.min(upper || rawTarget || 0, rawTarget || 0));
    }

    function wishDiagnosticSnapshotForDates(dates, storeKey, options = {}, log = wishBlankLog(storeKey, dates)) {
      const dateIsos = (dates || []).map(date => typeof date === "string" ? date : iso(date));
      let candidates = 0;
      let samePerson = 0;
      let replacements = 0;
      let protectedSkipped = 0;
      let duplicateSkipped = 0;
      dateIsos.forEach(dateIso => {
        const assignments = uniqueAssignments(dateIso, storeKey);
        const pool = wishCandidatePoolForDateStore(dateIso, storeKey, options);
        assignments.forEach(oldAssignment => {
          pool.forEach(row => {
            if (!row || !row.person || !row.time) return;
            if (canonicalStaffName(row.person.name) === canonicalStaffName(oldAssignment.name) && row.time === oldAssignment.time) return;
            candidates += 1;
            const same = canonicalStaffName(row.person.name) === canonicalStaffName(oldAssignment.name);
            if (same) samePerson += 1;
            else replacements += 1;
            if (!wishProtectedReplacementAllowed(dateIso, storeKey, oldAssignment, row)) protectedSkipped += 1;
            if (assignments.some(a => assignmentKey(a) !== assignmentKey(oldAssignment) && canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time)) duplicateSkipped += 1;
          });
        });
      });
      log.diagnosisCandidates = candidates;
      log.diagnosisSamePersonCandidates = samePerson;
      log.diagnosisReplacementCandidates = replacements;
      log.diagnosisProtectedSkipped = protectedSkipped;
      log.diagnosisDuplicateSkipped = duplicateSkipped;
      return log;
    }

    
function wishFloorRescueForDates(dates, storeKey, options = {}, log = wishBlankLog(storeKey, dates)) {
      const dateIsos = (dates || []).map(date => typeof date === "string" ? date : iso(date));
      const band = wishWeekCountBandForDates(dates, storeKey);
      const upper = Number(options.wishWeekUpperCap || band.upper || 0);
      const rescueTarget = wishWeekRescueTargetForDates(dates, storeKey, options);
      log.upperCap = upper;
      log.lowerCap = Number(options.wishWeekLowerCap || band.lower || 0);
      log.floorRescueTarget = rescueTarget;
      if (!upper || !rescueTarget) return 0;

      // 36.40: 段階救済。36.39の「最大1件」から、上限・目標まで1件ずつ再評価しながら救済する。
      // ただし、36.33の扇町63件化を避けるため、上限超過は禁止。各追加は30分セル不足を減らす場合だけ採用する。
      let applied = 0;
      const initialGap = Math.max(0, rescueTarget - wishCountAssignmentsForIsoDates(dateIsos, storeKey));
      const maxSteps = Math.min(4, initialGap);
      for (let step = 0; step < maxSteps; step += 1) {
        const current = wishCountAssignmentsForIsoDates(dateIsos, storeKey);
        if (current >= rescueTarget || current >= upper) {
          log.floorRescueBlocked += 1;
          break;
        }

        let best = null;
        dateIsos.forEach(dateIso => {
          const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
          const assignments = uniqueAssignments(dateIso, storeKey);
          const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
          if (base.shortage <= 0) return;
          wishCandidatePoolForDateStore(dateIso, storeKey, options)
            .filter(row => row && row.person && row.time)
            .filter(row => !assignments.some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time))
            .filter(row => canPlaceShift(dateIso, storeKey, row.person, row.time, {
              ...options,
              respectCapacity: false,
              preventDoubleBooking: true,
              allowPartialOverlap: true,
              requireFullSlotCoverage: false,
              enforceCoreWorkLimit: false,
              avoidLongStreak: false,
              allowHopeOnlyPlacement: true
            }))
            .forEach(row => {
              const simulated = [...assignments, { name: row.person.name, time: row.time, support: row.person.support }];
              const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
              const shortageGain = base.shortage - next.shortage;
              const surplusIncrease = next.surplus - base.surplus;
              if (shortageGain <= 0) return;

              const teacherScore = row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time);
              const anchor = wishIsAnchorPerson(row.person, storeKey);
              const submitted = hasSubmittedWorkRequestTime(dateIso, storeKey, row.person.name, row.time);
              const fixedLike = hasTag(row.person, "固定") || hasTag(row.person, "社員") || hasTag(row.person, "店長");

              // 36.40: 2件目以降は少しだけ門戸を広げるが、汎用穴埋めの暴発は防ぐ。
              const remainingAfterThis = rescueTarget - current - 1;
              const teacherThreshold = remainingAfterThis <= 0 ? 210 : 235;
              if (!anchor && !submitted && !fixedLike && teacherScore < teacherThreshold) return;
              if (surplusIncrease > shortageGain + 3 && !anchor && !submitted) return;

              const score = shortageGain * 28 + teacherScore * 0.04 + (anchor ? 22 : 0) + (submitted ? 18 : 0) + (fixedLike ? 8 : 0) - surplusIncrease * 12;
              if (!best || score > best.score) best = { dateIso, row, score, shortageGain, surplusIncrease, anchor, submitted, fixedLike };
            });
        });

        if (!best) {
          log.floorRescueBlocked += 1;
          break;
        }
        if (!wishCanAddWithinWeeklyCap(best.dateIso, storeKey, options)) {
          log.floorRescueBlocked += 1;
          break;
        }
        if (!wishAddShiftLoose(best.dateIso, storeKey, best.row.person, best.row.time, options)) {
          log.floorRescueBlocked += 1;
          break;
        }
        applied += 1;
        log.floorRescueAdd += 1;
        log.newAdd += 1;
        if (best.anchor) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(best.row.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return applied;
    }

    function wishConservativeSurplusTrim(dateIso, storeKey, options, log) {
      // 36.34: 正本なし生成モードでは通常の削除系過剰整理を停止する。
      // 36.32で東町が 64→61 に落ちた主因になり得るため、過剰は「削る」のではなく
      // 同一人物の時間補正・アンカー差し替え・教師候補追加で吸収する。
      return 0;

      let removed = 0;
      for (let guard = 0; guard < 12; guard += 1) {
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        if (base.surplus <= 0) break;
        const actual = wishCoverageMapFromAssignments(assignments, storeKey);
        const removable = assignments
          .filter(a => !wishIsProtectedAssignment(dateIso, storeKey, a, false))
          .map(a => {
            const simulated = assignments.filter(x => assignmentKey(x) !== assignmentKey(a));
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            return { assignment: a, next, surplusContribution: wishActualSurplusContribution(a, storeKey, actual, expectation) };
          })
          .filter(row => row.surplusContribution > 0)
          .filter(row => row.next.shortage <= base.shortage && row.next.score < base.score)
          .sort((a, b) => a.next.score - b.next.score)[0];
        if (!removable) break;
        removeShiftFromDay(dateIso, storeKey, removable.assignment);
        removed += 1;
        log.conservativeTrim += 1;
      }
      return removed;
    }

    function wishRollbackOverCapForDates(dates, storeKey, options = {}, log = wishBlankLog(storeKey, dates)) {
      const dateIsos = (dates || []).map(date => typeof date === "string" ? date : iso(date));
      const band = wishWeekCountBandForDates(dates, storeKey);
      const upper = Number(options.wishWeekUpperCap || band.upper || 0);
      if (!upper) return 0;
      log.upperCap = upper;
      log.lowerCap = Number(options.wishWeekLowerCap || band.lower || 0);
      let removed = 0;
      let guard = 0;
      while (wishCountAssignmentsForIsoDates(dateIsos, storeKey) > upper && guard < 40) {
        let best = null;
        dateIsos.forEach(dateIso => {
          const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
          const assignments = uniqueAssignments(dateIso, storeKey);
          const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
          const actual = wishCoverageMapFromAssignments(assignments, storeKey);
          assignments.forEach(assignment => {
            if (wishIsProtectedAssignment(dateIso, storeKey, assignment, false)) return;
            if (isSubmittedWorkAssignment(dateIso, storeKey, assignment)) return;
            const person = findStaff(assignment.name) || { name: assignment.name };
            if (wishIsAnchorPerson(person, storeKey)) return;
            const simulated = assignments.filter(row => assignmentKey(row) !== assignmentKey(assignment));
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            const shortageIncrease = next.shortage - base.shortage;
            const surplusContribution = wishActualSurplusContribution(assignment, storeKey, actual, expectation);
            const teacherScore = wishCandidateScore(dateIso, storeKey, person, assignment.time);
            // 36.34: 上限超過時だけ、低スコア汎用勤務を最小限戻す。アンカー/社員/固定/希望提出は削らない。
            if (teacherScore > 360 && surplusContribution <= 0) return;
            if (shortageIncrease > 6 && surplusContribution <= 0) return;
            const rollbackScore = surplusContribution * 70 - shortageIncrease * 85 - Math.max(0, teacherScore) * 0.035 + (teacherScore < 120 ? 60 : 0);
            if (!best || rollbackScore > best.rollbackScore) {
              best = { dateIso, assignment, rollbackScore, teacherScore, shortageIncrease, surplusContribution };
            }
          });
        });
        if (!best || best.rollbackScore < -140) break;
        removeShiftFromDay(best.dateIso, storeKey, best.assignment);
        removed += 1;
        log.countRollback += 1;
        guard += 1;
      }
      return removed;
    }


    // 36.46 正本なし生成：強制交換で「守りすぎて動かない」問題を避けるための限定的な保護緩和。
    // 希望提出は絶対に守る。店長/社員/固定/アンカーも原則保護するが、教師スコアが低く、余分セルを作り、
    // かつ入れ替え先が明確に強いアンカー/教師候補の場合だけ、件数を動かさず交換候補に入れる。
    function wishCanRelaxProtectedForForceExchange(dateIso, storeKey, oldAssignment, oldPerson, candidatePerson, candidateTime, meta = {}) {
      if (!oldAssignment || !oldPerson || !candidatePerson || !candidateTime) return false;
      if (isSubmittedWorkAssignment(dateIso, storeKey, oldAssignment)) return false;
      const oldName = canonicalStaffName(oldAssignment.name);
      const newName = canonicalStaffName(candidatePerson.name);
      if (oldName === newName) return true;
      const oldBias = Number(meta.oldBias || wishPersonBalanceBias(dateIso, storeKey, oldPerson, oldAssignment.time));
      const newBias = Number(meta.newBias || wishPersonBalanceBias(dateIso, storeKey, candidatePerson, candidateTime));
      const oldScore = Number(meta.oldScore || wishCandidateScore(dateIso, storeKey, oldPerson, oldAssignment.time));
      const newScore = Number(meta.newScore || wishCandidateScore(dateIso, storeKey, candidatePerson, candidateTime));
      const oldSurplus = Number(meta.oldSurplus || 0);
      const teacherUpgrade = newScore - oldScore;
      const balanceGain = newBias - oldBias;
      const candidateStrong = wishIsAnchorPerson(candidatePerson, storeKey)
        || hasSubmittedWorkRequestTime(dateIso, storeKey, candidatePerson.name, candidateTime)
        || newScore >= 420
        || newBias >= 160;
      const oldClearlyWeak = oldBias <= -80 || oldScore <= 180 || oldSurplus >= 2;
      const upgradeClear = teacherUpgrade >= 180 || balanceGain >= 180 || teacherUpgrade + balanceGain >= 260;
      // 店長/社員そのものを雑に別人へ置換しない。例外は「不自然時間」かつ候補が相当に強い時だけ。
      const oldIsCore = isCoreEmployee(oldPerson) || hasTag(oldPerson, "店長");
      const oldWeirdTime = wishPersonBalanceBias(dateIso, storeKey, oldPerson, oldAssignment.time) <= -180;
      if (oldIsCore && !(oldWeirdTime && candidateStrong && upgradeClear && oldSurplus >= 1)) return false;
      return candidateStrong && oldClearlyWeak && upgradeClear;
    }


    // 36.46 正本なし生成：件数を動かさず、人物バランス差が大きい既存勤務を強制交換する。
    // 正本は参照しない。判断材料は教師候補・人物時間スコア・36.43の人物バランスバイアスだけ。
    function wishForcePersonBalanceExchangeForDate(dateIso, storeKey, options = {}, log = wishBlankLog(storeKey, [])) {
      let applied = 0;
      for (let guard = 0; guard < 18; guard += 1) {
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const assignments = uniqueAssignments(dateIso, storeKey);
        if (!assignments.length) break;
        const base = wishDiffSummaryFromAssignments(assignments, storeKey, expectation);
        const actual = wishCoverageMapFromAssignments(assignments, storeKey);
        const pool = wishCandidatePoolForDateStore(dateIso, storeKey, options);
        let best = null;

        assignments.forEach(oldAssignment => {
          if (isSubmittedWorkAssignment(dateIso, storeKey, oldAssignment)) return;
          const oldPerson = findStaff(oldAssignment.name) || { name: oldAssignment.name, support: oldAssignment.support };
          const oldProtected = wishIsProtectedAssignment(dateIso, storeKey, oldAssignment, false);
          const oldScore = wishCandidateScore(dateIso, storeKey, oldPerson, oldAssignment.time);
          const oldBias = wishPersonBalanceBias(dateIso, storeKey, oldPerson, oldAssignment.time);
          const oldSurplus = wishActualSurplusContribution(oldAssignment, storeKey, actual, expectation);
          const oldSlots = assignmentSlots(oldAssignment.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });

          pool.forEach(row => {
            if (!row || !row.person || !row.time) return;
            const samePerson = canonicalStaffName(row.person.name) === canonicalStaffName(oldAssignment.name);
            if (samePerson && row.time === oldAssignment.time) return;
            const newScore = row.score || wishCandidateScore(dateIso, storeKey, row.person, row.time);
            const newBias = wishPersonBalanceBias(dateIso, storeKey, row.person, row.time);
            const teacherUpgrade = newScore - oldScore;
            const balanceGain = newBias - oldBias;
            const targetAnchor = wishIsAnchorPerson(row.person, storeKey);
            const relaxedProtected = oldProtected && !samePerson && wishCanRelaxProtectedForForceExchange(dateIso, storeKey, oldAssignment, oldPerson, row.person, row.time, { oldBias, newBias, oldScore, newScore, oldSurplus });
            if (oldProtected && !samePerson && !relaxedProtected) {
              log.personBalanceForceRejected = (log.personBalanceForceRejected || 0) + 1;
              return;
            }
            if (assignments.some(a => assignmentKey(a) !== assignmentKey(oldAssignment) && canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time)) return;
            if (!samePerson && isAssignedAnywhere(dateIso, row.person.name)) return;

            const newSlots = assignmentSlots(row.time, { allowPartialOverlap: true, requireFullSlotCoverage: false });
            const sameSlot = newSlots.some(slot => oldSlots.includes(slot));
            const overlap = rangeOverlapHours(row.time, oldAssignment.time);
            if (!samePerson && !sameSlot && overlap <= 0 && oldSurplus <= 0 && teacherUpgrade + balanceGain < 360) return;

            const oldWeak = oldBias < -60 || oldScore < 180 || oldSurplus > 0 || relaxedProtected;
            const strongReason = balanceGain >= 160 || teacherUpgrade >= 180 || (targetAnchor && balanceGain >= 90) || (samePerson && teacherUpgrade + balanceGain >= 150) || relaxedProtected;
            if (!oldWeak && !strongReason) return;

            const simulated = wishReplacementAssignments(assignments, oldAssignment, row.person, row.time);
            const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
            const shortageGain = base.shortage - next.shortage;
            const surplusGain = base.surplus - next.surplus;
            if (next.shortage > base.shortage + 3 && teacherUpgrade + balanceGain < 380) return;
            if (next.surplus > base.surplus + 3 && teacherUpgrade + balanceGain < 380) return;

            const samePersonBonus = samePerson ? 18 : 0;
            const anchorBonus = targetAnchor ? 28 : 0;
            const weakOldBonus = oldWeak ? 18 : 0;
            const score = shortageGain * 14
              + surplusGain * 10
              + Math.max(0, teacherUpgrade) * 0.035
              + Math.max(0, balanceGain) * 0.06
              + samePersonBonus
              + anchorBonus
              + weakOldBonus
              - Math.max(0, -teacherUpgrade) * 0.025
              - Math.max(0, -balanceGain) * 0.04;

            if (score < 18) return;
            if (!best || score > best.score) {
              best = { oldAssignment, person: row.person, time: row.time, score, samePerson, teacherUpgrade, balanceGain, anchor: targetAnchor, relaxedProtected };
            }
          });
        });

        if (!best) break;
        if (!wishTryReplaceAssignment(dateIso, storeKey, best.oldAssignment, best.person, best.time, options)) {
          log.personBalanceForceRejected = (log.personBalanceForceRejected || 0) + 1;
          break;
        }
        applied += 1;
        log.personBalanceForceSwap = (log.personBalanceForceSwap || 0) + 1;
        if (best.relaxedProtected) log.relaxedProtectedSwap = (log.relaxedProtectedSwap || 0) + 1;
        log.personBalanceSwap = (log.personBalanceSwap || 0) + 1;
        if (best.samePerson) log.samePersonTimeFix += 1;
        else log.personReplaceFix += 1;
        if ((best.teacherUpgrade || 0) > 0) log.teacherPatternSwap = (log.teacherPatternSwap || 0) + 1;
        if ((best.balanceGain || 0) > 0) log.personBalanceSwap = (log.personBalanceSwap || 0) + 1;
        if (best.anchor) {
          log.anchorRestore += 1;
          const n = canonicalStaffName(best.person.name);
          log.anchors[n] = (log.anchors[n] || 0) + 1;
        }
      }
      return applied;
    }

    function wishFixedCountCompressForDate(dateIso, storeKey, options = {}, log = wishBlankLog(storeKey, [])) {
      const before = wishDiffSummaryForDate(dateIso, storeKey);
      log.shortageBefore += before.shortage;
      log.surplusBefore += before.surplus;
      // 36.38: 件数固定フェーズ。追加・削除はせず、時間変更・人物差し替え・不足/過剰ペア交換だけで30分セル差分を下げる。
      wishApplySamePersonTimeFix(dateIso, storeKey, options, log);
      wishApplyAnchorPersonReplace(dateIso, storeKey, options, log);
      wishApplyPairExchangeCompress(dateIso, storeKey, options, log);
      wishForcePersonBalanceExchangeForDate(dateIso, storeKey, options, log);
      const after = wishDiffSummaryForDate(dateIso, storeKey);
      log.shortageAfter += after.shortage;
      log.surplusAfter += after.surplus;
      return log;
    }

    function wishFixedCountCompressForDates(dates, storeKey, options = {}, existingLog = null) {
      const log = existingLog || wishBlankLog(storeKey, dates);
      const band = wishWeekCountBandForDates(dates, storeKey);
      log.upperCap = Number(options.wishWeekUpperCap || band.upper || 0);
      log.lowerCap = Number(options.wishWeekLowerCap || band.lower || 0);
      options.wishCorrectionLog = log;
      if (!existingLog) log.beforeCount = wishCountAssignmentsForDates(dates, storeKey);
      for (let pass = 0; pass < 2; pass += 1) {
        dates.forEach(date => wishFixedCountCompressForDate(iso(date), storeKey, options, log));
      }
      log.afterCount = wishCountAssignmentsForDates(dates, storeKey);
      state.lastWishCorrectionLog = log;
      return log;
    }

    function wishThirtyMinuteAnchorRepairForDate(dateIso, storeKey, options = {}, log = wishBlankLog(storeKey, [])) {
      const before = wishDiffSummaryForDate(dateIso, storeKey);
      log.shortageBefore += before.shortage;
      log.surplusBefore += before.surplus;
      wishApplySamePersonTimeFix(dateIso, storeKey, options, log);
      wishApplyAnchorPersonReplace(dateIso, storeKey, options, log);
      wishApplyPairExchangeCompress(dateIso, storeKey, options, log);
      wishApplyThirtyMinuteAdditions(dateIso, storeKey, options, log);
      wishConservativeSurplusTrim(dateIso, storeKey, options, log);
      const after = wishDiffSummaryForDate(dateIso, storeKey);
      log.shortageAfter += after.shortage;
      log.surplusAfter += after.surplus;
      return log;
    }

    function wishThirtyMinuteAnchorRepairForDates(dates, storeKey, options = {}) {
      const log = wishBlankLog(storeKey, dates);
      const band = wishWeekCountBandForDates(dates, storeKey);
      log.upperCap = Number(options.wishWeekUpperCap || band.upper || 0);
      log.lowerCap = Number(options.wishWeekLowerCap || band.lower || 0);
      options.wishCorrectionLog = log;
      log.beforeCount = wishCountAssignmentsForDates(dates, storeKey);
      dates.forEach(date => {
        wishThirtyMinuteAnchorRepairForDate(iso(date), storeKey, options, log);
      });
      log.afterCount = wishCountAssignmentsForDates(dates, storeKey);
      state.lastWishCorrectionLog = log;
      return log;
    }

    function wishTemplateFillForDates(dates, storeKey, options = {}) {
      let added = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        wishClearDateStore(dateIso, storeKey);
        // 36.30: 正本なし生成は正本を参照しない。ただし希望提出は現実に使える入力なので先に置く。
        added += applySubmittedWorkRequestsForDate(dateIso, storeKey, {
          ...options,
          respectCapacity: false,
          preventDoubleBooking: true,
          allowPartialOverlap: true,
          requireFullSlotCoverage: false,
          allowHopeOnlyPlacement: true
        });
        // 36.30: 複数週の同曜日コンセンサス＋教師データの枠別人数目標で作る。
        added += wishApplyConsensusTeacherTemplateForDate(dateIso, storeKey, options);
        added += wishFillShortagesByTeacherForDate(dateIso, storeKey, options);
        added += wishReachTeacherCountForDate(dateIso, storeKey, options);
        wishTrimSurplusByConsensusForDate(dateIso, storeKey);
        added += wishFillShortagesByTeacherForDate(dateIso, storeKey, options);
      });
      return added;
    }


    function generateWeeklyClosePure(storeKey = state.weeklyCloseStore) {
      syncWeeklyCloseSelectionFromInputs();
      storeKey = storeKey || state.weeklyCloseStore || "higashicho";
      const dates = selectedWeekDates();
      if (!dates.length) {
        showToast("対象週が作成期間外");
        return;
      }
      const savedRieMaster = Array.isArray(state.rieMaster) ? state.rieMaster : [];
      state.rieMaster = [];
      const band = wishWeekCountBandForDates(dates, storeKey);
      const options = autonomousGenerationOptions({
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      });
      options.wishExpectationCache = new Map();
      options.wishCandidatePoolCache = new Map();
      try {
        // 36.38: 正本なし生成モードは正本を見ない。教師コンセンサスで土台を作り、外部トリムは止める。
        // 36.34の上限ガードを維持し、目標帯到達後は件数を動かさず差分圧縮に切り替える。
        wishTemplateFillForDates(dates, storeKey, options);
        // 36.31相当：件数の床上げは維持。ただし正本・外部トリム・連勤解除は使わない。
        ensureMinimumCoverageForDates(dates, storeKey, options);
        wishTeacherFloorForDates(dates, storeKey, options);
        ensureMinimumCoverageForDates(dates, storeKey, options);
        // 36.38継続：30分セル補正は、目標件数帯に入った後は追加・削除を止め、時間補正/人物差し替え/不足過剰ペア交換だけで差分を圧縮する。
        let wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, options);
        let countState = wishWeekCountStateForOptions(storeKey, options);
        if (countState.below) {
          wishTeacherFloorForDates(dates, storeKey, options);
          wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, options);
        }
        countState = wishWeekCountStateForOptions(storeKey, options);
        if (countState.inBand) {
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
        }
        // 36.40: 扇町59/東町62のような「目標まであと少し」は、上限内で上限まで1件ずつ高スコア教師候補を段階救済する。
        wishFloorRescueForDates(dates, storeKey, options, wishLog);
        if (wishWeekCountStateForOptions(storeKey, options).inBand) {
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
        }
        wishDiagnosticSnapshotForDates(dates, storeKey, options, wishLog);
        if (wishWeekCountStateForOptions(storeKey, options).over) {
          wishRollbackOverCapForDates(dates, storeKey, options, wishLog);
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
        }
        wishLog.afterCount = wishCountAssignmentsForDates(dates, storeKey);
        state.lastWishCorrectionLog = wishLog;
      } finally {
        state.rieMaster = savedRieMaster;
        noMasterV62SourceStaff = null;
      }
      state.weeklyCloseStore = storeKey;
      state.selectedStore = storeKey;
      state.currentView = "weeklyClose";
      state.selected = null;
      // 36.30: 正本なし生成検証では正本も正本反映も見ない。連勤解除やsanitizeで勝手に脱がせ直さない。
      renderMetrics();
      renderWeeklyClose();
      persistState();
      const assigned = weeklyAssignmentCount(storeKey, dates);
      const shortage = weeklyCloseShortageCount(storeKey, dates);
      showToast(`正本なし自動作成 ${stores[storeKey].name} ${weekLabel(dates)} ${assigned}件 / 不足${shortage}`);
    }


    function desireLockToRieMasterIfPresent(dates, storeKey, options = generationOptions()) {
      const masterCount = rieEntriesFor(dates, storeKey).length;
      if (!masterCount) return { added: 0, removed: 0, masterCount: 0 };
      const result = enforceExactRieMasterForDates(dates, storeKey, options);
      return { ...result, masterCount };
    }

    function hardOverrideScheduleWithRieMaster(dates, storeKey) {
      const rows = rieEntriesFor(dates, storeKey);
      if (!rows.length) return { added: 0, removed: 0, masterCount: 0 };

      let removed = 0;
      dates.forEach(date => {
        const dateIso = iso(date);
        if (!state.schedule[dateIso]) state.schedule[dateIso] = {};
        if (state.schedule[dateIso][storeKey]) {
          slots.forEach(slot => {
            removed += (state.schedule[dateIso][storeKey][slot] || []).length;
          });
        }
        state.schedule[dateIso][storeKey] = {};
      });

      let added = 0;
      rows.forEach(row => {
        if (directAddExactRieMasterAssignment(row)) added += 1;
      });

      return { added, removed, masterCount: rows.length };
    }

    function generateWeeklyClose(storeKey = state.weeklyCloseStore) {
      syncWeeklyCloseSelectionFromInputs();
      storeKey = storeKey || state.weeklyCloseStore || "higashicho";
      const dates = selectedWeekDates();
      if (!dates.length) {
        showToast("対象週が作成期間外");
        return;
      }
      const options = autonomousGenerationOptions();
      generateDatesForStore(dates, storeKey, options);
      trimOverstaffingForDates(storeKey, dates);
      rebalanceCoreRest(storeKey);
      trimOverstaffingForDates(storeKey, dates);
      resolveLongStreaks(storeKey, 5);
      ensureMinimumCoverageForDates(dates, storeKey, options);
      shortageGuidedMasterFitForDates(dates, storeKey, options);
      softReplaceTowardRieMasterForDates(dates, storeKey, options);
      crossStoreAndSurplusMasterRepairForDates(dates, storeKey, options);
      residualExactAnchorPatchForDates(dates, storeKey, options);
      finalResidualSurplusTrimForDates(dates, storeKey, options);
      // 自立生成では、正本を直接コピー・ロックしない.
      // 正本は採点・時間型の寄せに使うだけ。36.17は不足枠と余分枠のペアだけを追加・差替フィットする。
      trimOverstaffingForDates(storeKey, dates);
      ensureMinimumCoverageForDates(dates, storeKey, options);
      shortageGuidedMasterFitForDates(dates, storeKey, options);
      softReplaceTowardRieMasterForDates(dates, storeKey, options);
      crossStoreAndSurplusMasterRepairForDates(dates, storeKey, options);
      residualExactAnchorPatchForDates(dates, storeKey, options);
      finalResidualSurplusTrimForDates(dates, storeKey, options);
      trimOverstaffingForDates(storeKey, dates);
      finalResidualSurplusTrimForDates(dates, storeKey, options);
      // 36.26: 正本参照補正モードは、正本がある場合だけ最後に正本へロックする。
      // 正本なし生成モードとは分離済みなので、ここは「正本補正ありPoC」として完全一致を優先する。
      const desireLock = hardOverrideScheduleWithRieMaster(dates, storeKey);
      state.weeklyCloseStore = storeKey;
      state.selectedStore = storeKey;
      state.currentView = "weeklyClose";
      state.selected = null;
      // 36.28: 正本がある正本参照補正モードは完全上書きなのでsanitizeしない。
      if (!desireLock.masterCount) sanitizeInvalidStoreAssignments();
      renderMetrics();
      renderWeeklyClose();
      persistState();
      const assigned = weeklyAssignmentCount(storeKey, dates);
      const shortage = weeklyCloseShortageCount(storeKey, dates);
      showToast(`正本参照補正 ${stores[storeKey].name} ${weekLabel(dates)} ${assigned}件 / 不足${shortage}`);
    }

    function generateWeeklyCloseFromMaster(storeKey = state.weeklyCloseStore) {
      syncWeeklyCloseSelectionFromInputs();
      storeKey = storeKey || state.weeklyCloseStore || "higashicho";
      const dates = selectedWeekDates();
      if (!dates.length) {
        showToast("対象週が作成期間外");
        return;
      }
      const options = generationOptions();
      generateDatesForStore(dates, storeKey, options);
      trimOverstaffingForDates(storeKey, dates);
      rebalanceCoreRest(storeKey);
      trimOverstaffing(storeKey);
      resolveLongStreaks(storeKey, 5);
      ensureMinimumCoverageForDates(dates, storeKey, options);
      syncScheduleTowardRieMasterForDates(dates, storeKey, options);
      trimOverstaffingForDates(storeKey, dates);
      const desireLock = hardOverrideScheduleWithRieMaster(dates, storeKey);
      state.weeklyCloseStore = storeKey;
      state.selectedStore = storeKey;
      state.currentView = "weeklyClose";
      state.selected = null;
      // 36.28: 正本正本反映は完全上書きなのでsanitizeしない。
      if (!desireLock.masterCount) sanitizeInvalidStoreAssignments();
      renderMetrics();
      renderWeeklyClose();
      persistState();
      const assigned = weeklyAssignmentCount(storeKey, dates);
      const shortage = weeklyCloseShortageCount(storeKey, dates);
      showToast(`正本正本反映 ${stores[storeKey].name} ${weekLabel(dates)} ${assigned}件 / 不足${shortage}`);
    }


    function generateAllWeeklyClosePure() {
      syncWeeklyCloseSelectionFromInputs();
      const dates = selectedWeekDates();
      if (!dates.length) {
        showToast("対象週が作成期間外");
        return;
      }
      const original = state.weeklyCloseStore;
      const savedRieMaster = Array.isArray(state.rieMaster) ? state.rieMaster : [];
      state.rieMaster = [];
      const options = autonomousGenerationOptions({ useRieTargets: false, respectCapacity: false, allowHopeOnlyPlacement: true, wishMode: true });
      options.wishExpectationCache = new Map();
      options.wishCandidatePoolCache = new Map();
      try {
        storeOrder.forEach(storeKey => {
          // 36.33: 全店舗正本なし生成も正本を見ない。外部トリムは止め、教師コンセンサス土台を先に作る。
          wishTemplateFillForDates(dates, storeKey, options);
        });
        storeOrder.forEach(storeKey => {
          // 36.38：全店舗正本なし生成も店舗別件数帯を持たせ、帯に入った後は追加・削除なしで不足/過剰ペア交換まで行う。
          const band = wishWeekCountBandForDates(dates, storeKey);
          const storeOptions = {
            ...options,
            wishWeekDates: dates,
            wishWeekDateIsos: dates.map(date => iso(date)),
            wishWeekLowerCap: band.lower,
            wishWeekUpperCap: band.upper,
            freezeWishCountInTargetBand: true,
            wishExpectationCache: options.wishExpectationCache,
            wishCandidatePoolCache: options.wishCandidatePoolCache
          };
          ensureMinimumCoverageForDates(dates, storeKey, storeOptions);
          wishTeacherFloorForDates(dates, storeKey, storeOptions);
          ensureMinimumCoverageForDates(dates, storeKey, storeOptions);
          let wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, storeOptions);
          if (wishWeekCountStateForOptions(storeKey, storeOptions).below) {
            wishTeacherFloorForDates(dates, storeKey, storeOptions);
            wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, storeOptions);
          }
          if (wishWeekCountStateForOptions(storeKey, storeOptions).inBand) {
            wishLog = wishFixedCountCompressForDates(dates, storeKey, storeOptions, wishLog);
          }
          wishFloorRescueForDates(dates, storeKey, storeOptions, wishLog);
          if (wishWeekCountStateForOptions(storeKey, storeOptions).inBand) {
            wishLog = wishFixedCountCompressForDates(dates, storeKey, storeOptions, wishLog);
          }
          wishDiagnosticSnapshotForDates(dates, storeKey, storeOptions, wishLog);
          if (wishWeekCountStateForOptions(storeKey, storeOptions).over) {
            wishRollbackOverCapForDates(dates, storeKey, storeOptions, wishLog);
            wishFixedCountCompressForDates(dates, storeKey, storeOptions, wishLog);
          }
        });
      } finally {
        state.rieMaster = savedRieMaster;
      }
      state.weeklyCloseStore = original || "higashicho";
      state.selectedStore = state.weeklyCloseStore;
      state.currentView = "weeklyClose";
      state.selected = null;
      // 36.30: 全店舗正本なし自動作成も、生成後のsanitize・連勤解除で正本なし予測を壊さない。
      renderMetrics();
      renderWeeklyClose();
      persistState();
      const assigned = storeOrder.reduce((sum, storeKey) => sum + weeklyAssignmentCount(storeKey, dates), 0);
      const shortage = storeOrder.reduce((sum, storeKey) => sum + weeklyCloseShortageCount(storeKey, dates), 0);
      showToast(`全店舗 正本なし自動作成 ${weekLabel(dates)} ${assigned}件 / 不足${shortage}`);
    }

    function generateAllWeeklyClose() {
      syncWeeklyCloseSelectionFromInputs();
      const dates = selectedWeekDates();
      if (!dates.length) {
        showToast("対象週が作成期間外");
        return;
      }
      const original = state.weeklyCloseStore;
      const options = autonomousGenerationOptions();
      storeOrder.forEach(storeKey => {
        generateDatesForStore(dates, storeKey, options);
        trimOverstaffingForDates(storeKey, dates);
      });
      rebalanceCoreRest("all");
      storeOrder.forEach(storeKey => {
        trimOverstaffingForDates(storeKey, dates);
        // 36.30: 正本なし生成検証では連勤解除をしない。ここで店長・定番長時間勤務が落ちていた。
        ensureMinimumCoverageForDates(dates, storeKey, options);
        shortageGuidedMasterFitForDates(dates, storeKey, options);
        softReplaceTowardRieMasterForDates(dates, storeKey, options);
        crossStoreAndSurplusMasterRepairForDates(dates, storeKey, options);
        residualExactAnchorPatchForDates(dates, storeKey, options);
        finalResidualSurplusTrimForDates(dates, storeKey, options);
        trimOverstaffingForDates(storeKey, dates);
        ensureMinimumCoverageForDates(dates, storeKey, options);
        shortageGuidedMasterFitForDates(dates, storeKey, options);
        softReplaceTowardRieMasterForDates(dates, storeKey, options);
        crossStoreAndSurplusMasterRepairForDates(dates, storeKey, options);
        residualExactAnchorPatchForDates(dates, storeKey, options);
        finalResidualSurplusTrimForDates(dates, storeKey, options);
        trimOverstaffingForDates(storeKey, dates);
        finalResidualSurplusTrimForDates(dates, storeKey, options);
        // 36.26: 全店舗正本参照補正でも、正本がある店舗は最後に正本へロックする。
        hardOverrideScheduleWithRieMaster(dates, storeKey);
      });
      state.weeklyCloseStore = original || "higashicho";
      state.selectedStore = state.weeklyCloseStore;
      state.currentView = "weeklyClose";
      state.selected = null;
      // 36.27: 全店舗正本参照補正でも、正本ロック後はsanitizeしない。
      renderMetrics();
      renderWeeklyClose();
      persistState();
      const assigned = storeOrder.reduce((sum, storeKey) => sum + weeklyAssignmentCount(storeKey, dates), 0);
      const shortage = storeOrder.reduce((sum, storeKey) => sum + weeklyCloseShortageCount(storeKey, dates), 0);
      showToast(`全店舗 正本参照補正 ${weekLabel(dates)} ${assigned}件 / 不足${shortage}`);
    }

    function clearWeeklyClose() {
      syncWeeklyCloseSelectionFromInputs();
      const dates = selectedWeekDates();
      const storeKey = state.weeklyCloseStore;
      dates.forEach(date => {
        const dateIso = iso(date);
        if (state.schedule[dateIso] && state.schedule[dateIso][storeKey]) {
          state.schedule[dateIso][storeKey] = {};
        }
      });
      state.selected = null;
      state.currentView = "weeklyClose";
      renderMetrics();
      renderWeeklyClose();
      persistState();
      showToast(`${stores[storeKey].name} ${weekLabel(dates)} を空にした`);
    }

    function clearStore() {
      const storeKey = state.selectedStore;
      periodDates().forEach(date => {
        const dateIso = iso(date);
        if (state.schedule[dateIso] && state.schedule[dateIso][storeKey]) {
          state.schedule[dateIso][storeKey] = {};
        }
      });
      state.selected = null;
      renderAll();
      showToast(`${stores[storeKey].name}を空にした`);
    }

    function generateAllStores() {
      const original = state.selectedStore;
      state.bulkGenerating = true;
      storeOrder.forEach(storeKey => {
        state.selectedStore = storeKey;
        generateMonth();
      });
      rebalanceCoreRest("all");
      trimOverstaffing("all");
      resolveLongStreaks("all", 5);
      state.bulkGenerating = false;
      state.selectedStore = original;
      renderAll();
      showToast("全店舗を仮作成した");
    }

    function fillFirstShortage(storeFilter = "all") {
      const row = collectAllShortages(storeFilter)[0];
      if (!row) {
        showToast("不足はない");
        return false;
      }
      const candidate = priorityCandidateForShortage(row);
      if (!candidate) {
        showToast("候補が見つからない");
        return false;
      }
      if (!addShiftToDay(row.dateIso, row.storeKey, candidate.person, candidate.time, candidate.options)) {
        showToast("過剰なしで入れられる候補がない");
        return false;
      }
      state.selected = { dateIso: row.dateIso, storeKey: row.storeKey, slot: row.slot };
      renderAll();
      showToast(`${stores[row.storeKey].name} ${row.slot} に ${candidate.person.name} を追加（${candidate.tier}）`);
      return true;
    }

    function fillVisibleStoreShortages() {
      let guard = 0;
      while (collectAllShortages(state.selectedStore).length && guard < 80) {
        if (!fillFirstShortage(state.selectedStore)) break;
        guard += 1;
      }
      renderAll();
      showToast(`${stores[state.selectedStore].name}の不足補充を試行した`);
    }

    function trimVisibleStoreOverstaffing() {
      const removed = trimOverstaffing(state.selectedStore);
      renderAll();
      showToast(removed ? `${stores[state.selectedStore].name}の余剰を${removed}件整理した` : "整理できる余剰はない");
    }

    function rebalanceCoreFromIssues() {
      const filter = document.getElementById("issuesStore").value || "all";
      const before = collectCoreRestIssues(filter).length;
      rebalanceCoreRest(filter);
      trimOverstaffing(filter);
      resolveLongStreaks(filter, 5);
      const after = collectCoreRestIssues(filter).length;
      renderIssues();
      persistState();
      showToast(`社員休み再調整: ${before}件 → ${after}件`);
    }

    function renderRequirements() {
      const wrap = document.getElementById("requirements");
      wrap.innerHTML = slots.map(slot => `
        <label class="req-item">
          <span>${slot} 必要人数</span>
          <input type="number" min="0" value="${requirement(state.selectedStore, slot)}" data-req-slot="${slot}">
        </label>
      `).join("");
      wrap.querySelectorAll("[data-req-slot]").forEach(input => {
        input.addEventListener("change", () => setRequirement(input.dataset.reqSlot, input.value));
      });
    }

    function renderHead(targetId) {
      const head = document.getElementById(targetId);
      head.innerHTML = `
        <tr>
          <th>日付</th>
          ${slots.map(slot => `<th>${slot}<br><span class="muted">必要 ${requirement(getActiveStoreForHead(targetId), slot)}</span></th>`).join("")}
        </tr>
      `;
    }

    function getActiveStoreForHead(targetId) {
      if (targetId === "finishedHead") return document.getElementById("finishedStore").value;
      return state.selectedStore;
    }

    function renderMonthlyTable() {
      renderHead("monthlyHead");
      const body = document.getElementById("monthlyBody");
      body.innerHTML = periodDates().map(date => {
        const dateIso = iso(date);
        const weekend = date.getDay() === 0 || date.getDay() === 6;
        return `
          <tr>
            <td class="date-cell ${weekend ? "weekend" : ""}">
              ${dateLabel(date)}
              <span class="dow">${dowLabel(date)}</span>
            </td>
            ${slots.map(slot => renderSlotCell(dateIso, state.selectedStore, slot)).join("")}
          </tr>
        `;
      }).join("");
      body.querySelectorAll(".slot-cell").forEach(cell => {
        cell.addEventListener("click", () => {
          state.selected = {
            dateIso: cell.dataset.date,
            storeKey: cell.dataset.store,
            slot: cell.dataset.slot
          };
          renderAll();
        });
      });
    }

    function weeklyCloseShortageCount(storeKey, dates) {
      return dates.reduce((total, date) => {
        const dateIso = iso(date);
        return total + slots.reduce((sum, slot) => {
          return sum + slotCoverageSummary(dateIso, storeKey, slot).shortage;
        }, 0);
      }, 0);
    }

    function weeklyAssignmentCount(storeKey, dates) {
      return dates.reduce((total, date) => {
        const dateIso = iso(date);
        return total + uniqueAssignments(dateIso, storeKey).length;
      }, 0);
    }

    function hopeOnlyStaffForStore(storeKey) {
      return staff.filter(person => (
        canWorkAtStore(person, storeKey) && hasTag(person, "希望日だけ配置")
      ));
    }

    function submittedWorkRequestsForDates(dates, storeKey) {
      const dateSet = new Set(dates.map(date => iso(date)));
      return submittedWorkRequests.filter(row => row.storeKey === storeKey && dateSet.has(row.dateIso));
    }

    function renderWeeklyCloseControls() {
      const select = document.getElementById("weeklyCloseStart");
      const storeSelect = document.getElementById("weeklyCloseStore");
      if (!select || !storeSelect) return;
      const weeks = weekOptions();
      const optionsHtml = weeks.map(startDate => {
        const startIso = iso(startDate);
        const endDate = addDays(startDate, 6);
        return `<option value="${startIso}">${dateLabel(startDate)}(${dowLabel(startDate)})〜${dateLabel(endDate)}(${dowLabel(endDate)})</option>`;
      }).join("");
      syncSelectOptions(select, optionsHtml, state.selectedWeekStart || nextWeeklyCloseStartIso());
      state.selectedWeekStart = select.value || ensureSelectedWeekStart();
      storeSelect.value = state.weeklyCloseStore || state.selectedStore || "higashicho";
      state.weeklyCloseStore = storeSelect.value;
    }

    function personTimeDiffNameSummaryRows(rows = [], limit = 8) {
      const groups = new Map();
      (rows || []).forEach(row => {
        const name = canonicalStaffName(row.name || "不明");
        const current = groups.get(name) || { name, timeShift: 0, missing: 0, extra: 0, total: 0, samples: [] };
        if (row.type === "時間ズレ") current.timeShift += 1;
        else if (row.type === "アプリにない") current.missing += 1;
        else if (row.type === "アプリ余分") current.extra += 1;
        current.total += 1;
        if (current.samples.length < 3) current.samples.push(`${(row.dateIso || "").slice(5)} ${row.type} ${row.time || ""}`.trim());
        groups.set(name, current);
      });
      return [...groups.values()]
        .sort((a, b) => b.total - a.total || b.timeShift - a.timeShift || a.name.localeCompare(b.name, "ja"))
        .slice(0, limit);
    }

    function personTimeDiffNameSummaryText(rows = [], limit = 8) {
      const top = personTimeDiffNameSummaryRows(rows, limit);
      if (!top.length) return "人物別差分なし";
      return top.map(row => `${row.name}:計${row.total}（ズレ${row.timeShift}/不足${row.missing}/余分${row.extra}）`).join(" / ");
    }

    function wishPersonTimeDiffInsightHtml(dates, storeKey) {
      const masterCount = rieEntriesFor(dates, storeKey).length;
      const appCount = appEntriesFor(dates, storeKey).length;
      if (!masterCount || !appCount) return "";
      const diffs = collectRiePersonDiffs(dates, storeKey);
      const topRows = personTimeDiffNameSummaryRows(diffs, 8);
      const total = diffs.length;
      const timeShift = diffs.filter(row => row.type === "時間ズレ").length;
      const missing = diffs.filter(row => row.type === "アプリにない").length;
      const extra = diffs.filter(row => row.type === "アプリ余分").length;
      return `
        <div class="person support">
          <span>人物時間差分：合計${total} / 時間ズレ${timeShift} / アプリにない${missing} / アプリ余分${extra}</span>
        </div>
        <div class="person support">
          <span>人物別Top：${topRows.map(row => `${row.name}:計${row.total}（ズレ${row.timeShift}/不足${row.missing}/余分${row.extra}）`).join(" / ") || "差分なし"}</span>
        </div>
      `;
    }

    function renderWeeklyClose() {
      renderWeeklyCloseControls();
      const storeKey = state.weeklyCloseStore || "higashicho";
      const dates = selectedWeekDates();
      const requests = submittedWorkRequestsForDates(dates, storeKey);
      const hopeOnly = hopeOnlyStaffForStore(storeKey);
      document.getElementById("weeklyClosePeriod").textContent = weekLabel(dates);
      document.getElementById("weeklyCloseShortage").textContent = String(weeklyCloseShortageCount(storeKey, dates));
      document.getElementById("weeklyCloseHopeOnly").textContent = `${requests.length}/${hopeOnly.length}`;
      const wishLog = state.lastWishCorrectionLog && state.lastWishCorrectionLog.storeKey === storeKey ? state.lastWishCorrectionLog : null;
      const personTimeInsightHtml = wishPersonTimeDiffInsightHtml(dates, storeKey);
      const wishLogHtml = wishLog ? `
        <div class="person support">
          <span>36.45補正ログ：件数 ${wishLog.beforeCount}→${wishLog.afterCount} / 上限${wishLog.upperCap || "-"} / 30分不足 ${wishLog.shortageBefore}→${wishLog.shortageAfter} / 過剰 ${wishLog.surplusBefore}→${wishLog.surplusAfter}</span>
        </div>
        <div class="person support">
          <span>時間補正${wishLog.samePersonTimeFix}・差替${wishLog.personReplaceFix}・ペア交換${wishLog.pairExchangeFix || 0}・人物時間交換${wishLog.teacherPatternSwap || 0}・人物バランス交換${wishLog.personBalanceSwap || 0}・強制交換${wishLog.personBalanceForceSwap || 0}・保護緩和${wishLog.relaxedProtectedSwap || 0}・強制却下${wishLog.personBalanceForceRejected || 0}・アンカー復元${wishLog.anchorRestore}・新規追加${wishLog.newAdd}・段階救済${wishLog.floorRescueAdd || 0}件/目標${wishLog.floorRescueTarget || "-"}・汎用${wishLog.genericAdd}・上限停止${wishLog.capBlocked || 0}・低スコア戻し${wishLog.countRollback || 0}</span>
        </div>
        <div class="person support">
          <span>診断：候補${wishLog.diagnosisCandidates || 0} / 同一人物${wishLog.diagnosisSamePersonCandidates || 0} / 別人${wishLog.diagnosisReplacementCandidates || 0} / 保護却下${wishLog.diagnosisProtectedSkipped || 0} / 重複却下${wishLog.diagnosisDuplicateSkipped || 0} / 救済停止${wishLog.floorRescueBlocked || 0}</span>
        </div>
        <div class="person support">
          <span>アンカー内訳：${Object.entries(wishLog.anchors || {}).filter(([, count]) => count).map(([name, count]) => `${name}:${count}`).join(" / ") || "復元なし"}</span>
        </div>
      ` : "";
      document.getElementById("weeklyCloseMemo").innerHTML = `
        <div class="person">
          <span>36.46：36.40の高速化＋段階救済と36.42の人物差分ログを維持。正本を生成には使わず、教師スコア＋人物バランス差で既存勤務を強制交換する。36.44で動かなかった保護過多を限定緩和し、希望提出は守ったまま件数を動かさず差し替える。正本参照補正・正本反映は36.28正本完全上書きを維持。</span>
        </div>
        ${wishLogHtml}
        ${personTimeInsightHtml}
        <div class="person">
          <span>希望提出型: ${hopeOnly.map(person => person.name).join("、") || "なし"}</span>
        </div>
        <div class="person">
          <span>この週の提出済み希望: ${requests.map(row => `${row.name} ${row.dateIso} ${row.time}`).join(" / ") || "未入力"}</span>
        </div>
      `;
      document.getElementById("weeklyCloseHead").innerHTML = `
        <tr>
          <th>日付</th>
          ${slots.map(slot => `<th>${slot}<br><span class="muted">必要 ${requirement(storeKey, slot)}</span></th>`).join("")}
        </tr>
      `;
      document.getElementById("weeklyCloseBody").innerHTML = dates.map(date => {
        const dateIso = iso(date);
        const weekend = date.getDay() === 0 || date.getDay() === 6;
        return `
          <tr>
            <td class="date-cell ${weekend ? "weekend" : ""}">
              ${dateLabel(date)}
              <span class="dow">${dowLabel(date)}</span>
            </td>
            ${slots.map(slot => renderSlotCell(dateIso, storeKey, slot)).join("")}
          </tr>
        `;
      }).join("");
      document.getElementById("weeklyCloseBody").querySelectorAll(".slot-cell").forEach(cell => {
        cell.addEventListener("click", () => {
          state.selected = {
            dateIso: cell.dataset.date,
            storeKey: cell.dataset.store,
            slot: cell.dataset.slot
          };
          renderAll();
        });
      });
      renderWeeklyCloseMobile(storeKey, dates);
      renderSelectedDetail("weeklySelectedDetail", "weeklyCandidateList");
    }

    function renderWeeklyCloseMobile(storeKey, dates) {
      const wrap = document.getElementById("weeklyCloseMobile");
      if (!wrap) return;
      wrap.innerHTML = dates.map(date => {
        const dateIso = iso(date);
        const weekend = date.getDay() === 0 || date.getDay() === 6;
        const dayShortage = slots.reduce((sum, slot) => (
          sum + slotCoverageSummary(dateIso, storeKey, slot).shortage
        ), 0);
        return `
          <section class="weekly-day-card">
            <div class="weekly-day-head">
              <span class="${weekend ? "weekend" : ""}">${dateLabel(date)}(${dowLabel(date)})</span>
              ${dayShortage ? `<span class="tag bad">不足 ${dayShortage}</span>` : `<span class="tag ok">OK</span>`}
            </div>
            ${slots.map(slot => {
              const people = displayAssignmentsForSlot(dateIso, storeKey, slot);
              const summary = slotCoverageSummary(dateIso, storeKey, slot);
              const req = summary.req;
              const shortage = summary.shortage;
              const selected = state.selected
                && state.selected.dateIso === dateIso
                && state.selected.storeKey === storeKey
                && state.selected.slot === slot;
              return `
                <button class="weekly-slot-card ${selected ? "slot-cell selected" : ""}" type="button"
                  data-weekly-mobile-date="${dateIso}"
                  data-weekly-mobile-store="${storeKey}"
                  data-weekly-mobile-slot="${slot}">
                  <span class="weekly-slot-top">
                    <span>${slot} 必要${req} / 実働${summary.count}</span>
                    ${shortage ? `<span class="tag bad">不足 ${shortage}</span>` : `<span class="tag ok">OK</span>`}
                  </span>
                  ${people.map(person => `
                    <span class="person ${person.support ? "support" : ""}">
                      <span>${person.name}</span>
                      <span class="time">${person.time}</span>
                    </span>
                  `).join("") || `<span class="muted">未配置</span>`}
                </button>
              `;
            }).join("")}
          </section>
        `;
      }).join("");
      wrap.querySelectorAll("[data-weekly-mobile-date]").forEach(btn => {
        btn.addEventListener("click", () => {
          state.selected = {
            dateIso: btn.dataset.weeklyMobileDate,
            storeKey: btn.dataset.weeklyMobileStore,
            slot: btn.dataset.weeklyMobileSlot
          };
          renderAll();
        });
      });
    }

    function renderSlotCell(dateIso, storeKey, slot) {
      const people = displayAssignmentsForSlot(dateIso, storeKey, slot);
      const summary = slotCoverageSummary(dateIso, storeKey, slot);
      const req = summary.req;
      const diff = req - summary.count;
      const selected = state.selected
        && state.selected.dateIso === dateIso
        && state.selected.storeKey === storeKey
        && state.selected.slot === slot;
      const shortageLabel = summary.ranges.length
        ? ` <span class="muted">${summary.ranges.map(row => dayHourRangeLabel(row.startHour, row.endHour)).join("、")}</span>`
        : "";
      const status = diff > 0
        ? `<span class="need bad">不足 ${diff}</span>`
        : diff < 0
          ? `<span class="need bad">過剰 ${Math.abs(diff)}</span>`
          : `<span class="need ok">OK</span>`;
      return `
        <td class="slot-cell ${selected ? "selected" : ""}" data-date="${dateIso}" data-store="${storeKey}" data-slot="${slot}">
          <div class="cell-top"><span>実働${summary.count}/${req}</span>${status}</div>
          ${shortageLabel ? `<div class="small-note">時間穴:${shortageLabel}</div>` : ""}
          ${people.map(person => `
            <div class="person ${person.support ? "support" : ""}">
              <span>${person.name}</span>
              <span class="time">${person.time}</span>
            </div>
          `).join("")}
        </td>
      `;
    }

    function renderSelectedDetail(detailId = "selectedDetail", listId = "candidateList") {
      const detail = document.getElementById(detailId);
      const list = document.getElementById(listId);
      if (!detail || !list) return;
      if (!state.selected) {
        detail.innerHTML = `<span class="muted">不足セル、または編集したい枠を押す。</span>`;
        list.innerHTML = `<div class="muted">枠を選ぶと候補が出る。</div>`;
        return;
      }

      const { dateIso, storeKey, slot } = state.selected;
      const people = displayAssignmentsForSlot(dateIso, storeKey, slot);
      const summary = slotCoverageSummary(dateIso, storeKey, slot);
      const req = summary.req;
      const shortage = summary.shortage;
      detail.innerHTML = `
        <strong>${dateIso} ${stores[storeKey].name} ${slot}</strong>
        <div class="status-row">
          <span class="tag">必要 ${req}</span>
          <span class="tag">配置 ${people.length}</span>
          <span class="tag">実働最少 ${summary.count}</span>
          <span class="tag ${shortage ? "bad" : "ok"}">不足 ${shortage}</span>
        </div>
        <div class="status-row">
          ${people.map((person, index) => `
            <button class="btn small" type="button" data-remove="${index}">${person.name}を外す</button>
            <button class="btn small" type="button" data-emergency="${index}">${person.name}急遽休み</button>
          `).join("") || `<span class="muted">まだ配置なし</span>`}
        </div>
      `;
      detail.querySelectorAll("[data-remove]").forEach(btn => {
        btn.addEventListener("click", event => {
          event.stopPropagation();
          removeShiftFromDay(dateIso, storeKey, people[Number(btn.dataset.remove)]);
          renderAll();
        });
      });
      detail.querySelectorAll("[data-emergency]").forEach(btn => {
        btn.addEventListener("click", event => {
          event.stopPropagation();
          const assignment = people[Number(btn.dataset.emergency)];
          if (!assignment) return;
          const name = canonicalStaffName(assignment.name);
          if (!emergencyAbsences[name]) emergencyAbsences[name] = [];
          if (!emergencyAbsences[name].includes(dateIso)) emergencyAbsences[name].push(dateIso);
          removeShiftFromDay(dateIso, storeKey, assignment);
          renderAll();
          showToast(`${name}を${dateIso}の急遽休みにした`);
        });
      });

      const candidates = candidatesFor(storeKey, slot, dateIso);
      list.innerHTML = candidates.map(({ person, score, time }) => `
        <div class="candidate">
          <div>
            <strong>${person.name}</strong>
            <div class="reason">${person.tags.join(" / ")}、${time || pickTime(person, slot)}で配置候補。適合 ${score}</div>
          </div>
          <button class="btn small ${person.support ? "" : "primary"}" data-add="${person.name}" type="button">入れる</button>
        </div>
      `).join("");
      list.querySelectorAll("[data-add]").forEach(btn => {
        btn.addEventListener("click", () => {
          const person = staff.find(item => item.name === btn.dataset.add);
          if (!person) return;
          addShiftToDay(dateIso, storeKey, person, pickTime(person, slot, dateIso, storeKey));
          renderAll();
        });
      });
    }

    function renderToday() {
      const todayIso = state.today;
      const date = new Date(`${todayIso}T00:00:00`);
      document.getElementById("todayInput").value = todayIso;
      const grid = document.getElementById("todayGrid");
      grid.innerHTML = storeOrder.map(storeKey => `
        <section class="today-store">
          <h3>${stores[storeKey].name} ${dateLabel(date)}(${dowLabel(date)})</h3>
          ${slots.map(slot => {
            const people = displayAssignmentsForSlot(todayIso, storeKey, slot);
            const summary = slotCoverageSummary(todayIso, storeKey, slot);
            const shortage = summary.shortage;
            return `
              <div class="today-row">
                <div class="today-slot">${slot}</div>
                <div>
                  ${people.map(person => `<span class="tag ${person.support ? "warn" : ""}">${person.name} ${person.time}</span>`).join(" ") || `<span class="muted">未配置</span>`}
                  <span class="tag">実働${summary.count}/${summary.req}</span>
                  ${shortage ? `<span class="tag bad">不足 ${shortage}</span>` : `<span class="tag ok">OK</span>`}
                </div>
              </div>
            `;
          }).join("")}
        </section>
      `).join("");
    }

    function storeKeyFromLabel(value) {
      const text = String(value || "").trim();
      if (stores[text]) return text;
      if (text.includes("東町")) return "higashicho";
      if (text.includes("扇町")) return "ougicho";
      if (text.includes("宮ノ下") || text.includes("宮下")) return "miyanoshita";
      return "";
    }

    function normalizeTimeInput(value) {
      let text = String(value || "")
        .trim()
        .replace(/(\d{1,2})[：:]30/g, "$1.5")
        .replace(/(\d{1,2})[：:]00/g, "$1")
        .replace(/[〜～ー－―]/g, "-")
        .replace(/[：:]/g, "")
        .replace(/時/g, "")
        .replace(/\s+/g, "");
      // 紙シフトの「24〜」「22〜」「〜2」表記を最低限吸収する。
      // ただし「〜15」のような開始不明の日中勤務は危険なので自動補完しない。
      const openStart = text.match(/^(\d{1,2}(?:\.5)?)-$/);
      if (openStart) {
        const startOnly = Number(openStart[1]);
        if (startOnly >= 21 && startOnly <= 24) text = `${startOnly}-6`;
      }
      const openEnd = text.match(/^-(\d{1,2}(?:\.5)?)$/);
      if (openEnd) {
        const endOnly = Number(openEnd[1]);
        if (endOnly >= 0 && endOnly <= 6) text = `22-${endOnly}`;
      }
      const match = text.match(/^(\d{1,2}(?:\.5)?)-(\d{1,2}(?:\.5)?)$/);
      if (!match) return "";
      const start = Number(match[1]);
      const end = Number(match[2]);
      if (!Number.isFinite(start) || !Number.isFinite(end)) return "";
      if (start < 0 || start > 30 || end < 0 || end > 30) return "";
      const normalized = `${start}-${end}`;
      const [s, e] = parseRange(normalized);
      if (e - s <= 0 || e - s > 18) return "";
      return normalized;
    }

    function normalizeDateInput(value) {
      const text = String(value || "").trim();
      if (/^\d{4}-\d{2}-\d{2}$/.test(text)) return text;
      const ym = state.month || "2026-07";
      const [year, month] = ym.split("-").map(Number);
      const slash = text.match(/^(\d{1,2})\/(\d{1,2})$/);
      if (slash) return `${year}-${pad(Number(slash[1]))}-${pad(Number(slash[2]))}`;
      const dayOnly = text.match(/^(\d{1,2})$/);
      if (dayOnly) return `${year}-${pad(month)}-${pad(Number(dayOnly[1]))}`;
      return "";
    }

    function normalizeRieEntry(row) {
      if (!row) return null;
      const dateIso = normalizeDateInput(row.dateIso || row.date || "");
      const storeKey = storeKeyFromLabel(row.storeKey || row.store || "");
      const name = canonicalStaffName(row.name || "");
      const time = normalizeTimeInput(row.time || "");
      if (!dateIso || !storeKey || !name || !time) return null;
      return {
        id: row.id || `rie-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
        dateIso,
        storeKey,
        name,
        time,
        note: row.note || "",
        source: row.source || "manual"
      };
    }

    function selectedRieWeekStart() {
      const select = document.getElementById("rieWeekStart");
      if (select && select.value) return select.value;
      return ensureSelectedWeekStart();
    }

    function selectedRieWeekDates() {
      const start = selectedRieWeekStart();
      return start ? weekDates(start) : [];
    }

    function selectedRieStore() {
      const select = document.getElementById("rieStore");
      return select && select.value ? select.value : "higashicho";
    }

    function rieStoreKeys(storeFilter = selectedRieStore()) {
      return storeFilter === "all" ? storeOrder : [storeFilter];
    }

    function rieEntriesFor(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const dateSet = new Set(dates.map(date => iso(date)));
      const storeSet = new Set(rieStoreKeys(storeFilter));
      return (state.rieMaster || [])
        .filter(row => dateSet.has(row.dateIso) && storeSet.has(row.storeKey))
        .sort((a, b) => a.dateIso.localeCompare(b.dateIso)
          || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
          || parseRange(a.time)[0] - parseRange(b.time)[0]
          || a.name.localeCompare(b.name, "ja"));
    }

    function setRieWeekControls() {
      const weekSelect = document.getElementById("rieWeekStart");
      const storeSelect = document.getElementById("rieStore");
      if (!weekSelect || !storeSelect) return;
      const weeks = weekOptions();
      const optionsHtml = weeks.map(startDate => {
        const startIso = iso(startDate);
        const endDate = addDays(startDate, 6);
        return `<option value="${startIso}">${dateLabel(startDate)}(${dowLabel(startDate)})〜${dateLabel(endDate)}(${dowLabel(endDate)})</option>`;
      }).join("");
      syncSelectOptions(weekSelect, optionsHtml, state.selectedWeekStart || nextWeeklyCloseStartIso());
      if (weekSelect.value) state.selectedWeekStart = weekSelect.value;
      if (!storeSelect.value) storeSelect.value = state.weeklyCloseStore || "higashicho";
      const entryDate = document.getElementById("rieEntryDate");
      if (entryDate && !entryDate.value) entryDate.value = weekSelect.value || state.today;
      const entryStore = document.getElementById("rieEntryStore");
      if (entryStore && storeSelect.value !== "all") entryStore.value = storeSelect.value;
    }

    function addRieMasterEntry(row) {
      const clean = normalizeRieEntry(row);
      if (!clean) return false;
      const key = `${clean.dateIso}|${clean.storeKey}|${canonicalStaffName(clean.name)}|${clean.time}`;
      const exists = (state.rieMaster || []).some(item => (
        `${item.dateIso}|${item.storeKey}|${canonicalStaffName(item.name)}|${item.time}` === key
      ));
      if (!exists) state.rieMaster.push(clean);
      return true;
    }

    function parseRieBulkLine(line) {
      const raw = String(line || "").trim();
      if (!raw || raw.startsWith("#")) return null;
      const parts = raw.split(/[\t,，]/).map(part => part.trim()).filter(Boolean);
      if (parts.length >= 4) {
        const dateIndex = parts.findIndex(part => normalizeDateInput(part));
        const storeIndex = parts.findIndex(part => storeKeyFromLabel(part));
        const timeIndex = parts.findIndex(part => normalizeTimeInput(part));
        if (dateIndex >= 0 && storeIndex >= 0 && timeIndex >= 0) {
          const name = parts.find((part, index) => ![dateIndex, storeIndex, timeIndex].includes(index));
          return { dateIso: parts[dateIndex], storeKey: parts[storeIndex], name, time: parts[timeIndex] };
        }
      }
      if (parts.length === 3) {
        return {
          dateIso: parts[0],
          storeKey: selectedRieStore() === "all" ? (document.getElementById("rieEntryStore")?.value || "higashicho") : selectedRieStore(),
          name: parts[1],
          time: parts[2]
        };
      }
      const tokens = raw.split(/\s+/).filter(Boolean);
      if (tokens.length >= 4) {
        const date = tokens.find(token => normalizeDateInput(token));
        const store = tokens.find(token => storeKeyFromLabel(token));
        const time = tokens.find(token => normalizeTimeInput(token));
        const name = tokens.find(token => token !== date && token !== store && token !== time);
        return { dateIso: date, storeKey: store, name, time };
      }
      return null;
    }

    function looksLikePaperCellBulkLine(line) {
      const raw = String(line || "").trim();
      if (!raw || raw.startsWith("#")) return false;
      const parts = raw.split(/[\t,，]/).map(part => part.trim()).filter(Boolean);
      if (parts.length < 4) return false;
      const dateIndex = parts.findIndex(part => normalizeDateInput(part));
      const storeIndex = parts.findIndex(part => storeKeyFromLabel(part));
      const slotIndex = parts.findIndex((part, index) => index !== dateIndex && normalizeTimeInput(part));
      if (dateIndex < 0 || storeIndex < 0 || slotIndex < 0) return false;
      const used = new Set([dateIndex, storeIndex, slotIndex]);
      const rest = parts.filter((_, index) => !used.has(index)).join(" / ");
      // 4列目が「多田 / 下田 6〜」「富田15〜24 / 守屋」のようなセル内容なら、
      // これは紙セル入力であって、正本の1勤務1行ではない。
      return /[\/／、]/.test(rest) || /[〜～~]/.test(rest);
    }

    function importRieBulk() {
      const box = document.getElementById("rieBulkBox");
      const text = box ? box.value.trim() : "";
      if (!text) {
        showToast("取り込む正本がない");
        return;
      }
      const paperLikeLines = text.split(/\n+/).filter(looksLikePaperCellBulkLine);
      if (paperLikeLines.length) {
        showToast("これは紙セル形式。『紙シフト統合』の紙セル一括取り込みに貼って");
        const sample = paperLikeLines.slice(0, 3).map((line, index) => `${index + 1}. ${line}`).join("\n");
        window.alert(`紙セル形式が混ざっています。\n\nこの欄ではなく、メニュー『紙シフト統合』→『紙セル一括取り込み』に貼ってください。\n\n例:\n${sample}`);
        return;
      }
      let added = 0;
      let failed = 0;
      const failedLines = [];
      text.split(/\n+/).forEach((line, index) => {
        const parsed = parseRieBulkLine(line);
        if (parsed && addRieMasterEntry(parsed)) added += 1;
        else {
          failed += 1;
          if (String(line || "").trim()) failedLines.push(`${index + 1}: ${String(line).trim()}`);
        }
      });
      if (box && added && !failed) box.value = "";
      renderRieMaster();
      persistState();
      const suffix = failed ? ` / 失敗${failed}行（例: ${failedLines.slice(0, 2).join(" / ")}）` : "";
      showToast(`正本 ${added}件取り込み${suffix}`);
    }

    function addRieMasterFromForm() {
      const row = {
        dateIso: document.getElementById("rieEntryDate")?.value,
        storeKey: document.getElementById("rieEntryStore")?.value,
        name: document.getElementById("rieEntryName")?.value,
        time: document.getElementById("rieEntryTime")?.value
      };
      if (!addRieMasterEntry(row)) {
        showToast("日付・店舗・名前・時間を確認して");
        return;
      }
      document.getElementById("rieEntryName").value = "";
      document.getElementById("rieEntryTime").value = "";
      renderRieMaster();
      persistState();
      showToast("りえ正本に追加した");
    }

    function clearRieMasterWeek() {
      const dates = selectedRieWeekDates();
      const storeFilter = selectedRieStore();
      const dateSet = new Set(dates.map(date => iso(date)));
      const storeSet = new Set(rieStoreKeys(storeFilter));
      const before = state.rieMaster.length;
      state.rieMaster = state.rieMaster.filter(row => !(dateSet.has(row.dateIso) && storeSet.has(row.storeKey)));
      const removed = before - state.rieMaster.length;
      renderRieMaster();
      persistState();
      showToast(`正本 ${removed}件を削除した`);
    }

    function appEntriesFor(dates, storeFilter) {
      const rows = [];
      const storeKeys = rieStoreKeys(storeFilter);
      dates.forEach(date => {
        const dateIso = iso(date);
        storeKeys.forEach(storeKey => {
          uniqueAssignments(dateIso, storeKey).forEach(assignment => {
            rows.push({ dateIso, storeKey, name: assignment.name, time: assignment.time, support: assignment.support });
          });
        });
      });
      return rows;
    }

    function entryCompareKey(row) {
      return `${row.dateIso}|${row.storeKey}|${canonicalStaffNameForStore(row.name, row.storeKey)}|${normalizeTimeInput(row.time) || row.time}`;
    }

    function rieHourlyCoverage(dateIso, storeKey, hour) {
      return (state.rieMaster || []).filter(row => (
        row.dateIso === dateIso && row.storeKey === storeKey && assignmentCoversHour(row, hour)
      ));
    }

    function collectRieCoverageDiffs(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const rows = [];
      rieStoreKeys(storeFilter).forEach(storeKey => {
        dates.forEach(date => {
          const dateIso = iso(date);
          for (let hour = 0; hour < 24; hour += 1) {
            const { req, slot } = requirementForHour(storeKey, hour);
            if (req <= 0) continue;
            const rieCount = rieHourlyCoverage(dateIso, storeKey, hour).length;
            const appCount = hourlyCoverage(dateIso, storeKey, hour).length;
            if (rieCount !== appCount) {
              rows.push({ date, dateIso, storeKey, hour, slot, req, rieCount, appCount, diff: appCount - rieCount });
            }
          }
        });
      });
      return rows;
    }

    function collectRiePersonDiffs(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const rieRows = rieEntriesFor(dates, storeFilter);
      const appRows = appEntriesFor(dates, storeFilter);
      const appMap = new Map(appRows.map(row => [entryCompareKey(row), row]));
      const rieMap = new Map(rieRows.map(row => [entryCompareKey(row), row]));
      const rows = [];
      rieRows.forEach(row => {
        if (!appMap.has(entryCompareKey(row))) rows.push({ type: "アプリにない", ...row });
      });
      appRows.forEach(row => {
        if (!rieMap.has(entryCompareKey(row))) rows.push({ type: "アプリ余分", ...row });
      });
      return rows.sort((a, b) => a.dateIso.localeCompare(b.dateIso)
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || a.type.localeCompare(b.type, "ja"));
    }

    function rieCompareStats(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const entries = rieEntriesFor(dates, storeFilter);
      const appEntries = appEntriesFor(dates, storeFilter);
      const coverageDiffs = collectRieCoverageDiffs(dates, storeFilter);
      const personDiffs = collectRiePersonDiffs(dates, storeFilter);
      const dateSet = new Set(dates.map(date => iso(date)));
      const selectedStores = new Set(rieStoreKeys(storeFilter));
      const sameWeekOtherStore = (state.rieMaster || []).filter(row => (
        dateSet.has(row.dateIso) && !selectedStores.has(row.storeKey)
      )).length;
      const appCopiedEntries = entries.filter(row => row.source === "appCopy").length;
      return { entries, appEntries, coverageDiffs, personDiffs, sameWeekOtherStore, appCopiedEntries };
    }

    function applyRieMasterToSchedule() {
      const dates = selectedRieWeekDates();
      const storeFilter = selectedRieStore();
      const entries = rieEntriesFor(dates, storeFilter);
      if (!entries.length) {
        showToast("反映する正本がない");
        return;
      }
      if (!window.confirm("りえ正本でアプリ版を上書きします。突合確認前に押すと差分が0になります。続けますか？")) return;
      const dateSet = new Set(dates.map(date => iso(date)));
      rieStoreKeys(storeFilter).forEach(storeKey => {
        dateSet.forEach(dateIso => {
          if (!state.schedule[dateIso]) state.schedule[dateIso] = {};
          state.schedule[dateIso][storeKey] = {};
        });
      });
      entries.forEach(row => {
        const person = findStaff(row.name);
        const assignment = { name: person ? person.name : row.name, time: row.time, support: Boolean(person && person.support), source: "rieMaster" };
        assignmentSlots(row.time, { allowPartialOverlap: true }).forEach(slot => {
          const cell = ensureCell(row.dateIso, row.storeKey, slot);
          if (!assignmentExists(cell, assignment)) cell.push(assignment);
        });
      });
      sanitizeInvalidStoreAssignments();
      renderAll();
      persistState();
      showToast(`りえ正本 ${entries.length}件をアプリに反映した`);
    }

    function copyAppAsRieMaster() {
      const dates = selectedRieWeekDates();
      const storeFilter = selectedRieStore();
      if (!window.confirm("アプリ版を正本側へコピーします。これを押すと差分は当然0に近づきます。検証用として実行しますか？")) return;
      const dateSet = new Set(dates.map(date => iso(date)));
      const storeSet = new Set(rieStoreKeys(storeFilter));
      state.rieMaster = state.rieMaster.filter(row => !(dateSet.has(row.dateIso) && storeSet.has(row.storeKey)));
      let added = 0;
      appEntriesFor(dates, storeFilter).forEach(row => {
        if (addRieMasterEntry({ ...row, source: "appCopy" })) added += 1;
      });
      renderRieMaster();
      persistState();
      showToast(`アプリ版 ${added}件を正本側にコピーした`);
    }


    function summarizeCoverageDiffRows(rows) {
      const groups = new Map();
      (rows || []).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}|${row.slot}`;
        const current = groups.get(key) || {
          date: row.date,
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          slot: row.slot,
          under: [],
          over: [],
          maxUnder: 0,
          maxOver: 0,
          totalMinutes: 0
        };
        const label = `${row.rangeLabel} 正${row.rieCount}/ア${row.appCount} (${row.diff > 0 ? "+" : ""}${row.diff})`;
        const minutes = Math.max(0, row.endAbs - row.startAbs);
        current.totalMinutes += minutes;
        if (row.diff < 0) {
          current.under.push(label);
          current.maxUnder = Math.max(current.maxUnder, Math.abs(row.diff));
        } else if (row.diff > 0) {
          current.over.push(label);
          current.maxOver = Math.max(current.maxOver, Math.abs(row.diff));
        }
        groups.set(key, current);
      });
      return [...groups.values()].sort((a, b) => a.date - b.date
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || parseRange(a.slot)[0] - parseRange(b.slot)[0]);
    }

    function coverageSummaryClass(row) {
      if (row.under.length && row.over.length) return "warn-row";
      if (row.under.length) return "danger-row";
      return "warn-row";
    }

    function coverageSummaryText(row) {
      const parts = [];
      if (row.under.length) parts.push(`不足最大${row.maxUnder}: ${row.under.join(" / ")}`);
      if (row.over.length) parts.push(`過剰最大${row.maxOver}: ${row.over.join(" / ")}`);
      return parts.join("<br>") || "差分なし";
    }

    function summarizePersonDiffRows(rows) {
      const priority = { "時間ズレ": 0, "アプリにない": 1, "アプリ余分": 2 };
      const groups = new Map();
      (rows || []).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}|${row.type}`;
        const current = groups.get(key) || {
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          type: row.type,
          items: []
        };
        current.items.push(`${row.name} ${row.time}`.trim());
        groups.set(key, current);
      });
      return [...groups.values()].map(row => ({
        ...row,
        content: [...new Set(row.items)].join(" / ")
      })).sort((a, b) => a.dateIso.localeCompare(b.dateIso)
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || (priority[a.type] ?? 99) - (priority[b.type] ?? 99));
    }

    function renderRieMaster() {
      setRieWeekControls();
      const dates = selectedRieWeekDates();
      const storeFilter = selectedRieStore();
      const stats = rieCompareStats(dates, storeFilter);
      const { entries, appEntries, coverageDiffs, personDiffs, sameWeekOtherStore, appCopiedEntries } = stats;
      const targetPaperCells = storeFilter === "all" ? [] : paperCellsFor(dates, storeFilter);
      const targetPaperUnified = storeFilter === "all" ? [] : integratePaperCells(targetPaperCells).unified;
      const noMasterButApp = !entries.length && appEntries.length;
      const paperNotApplied = !entries.length && targetPaperCells.length;
      const countEl = document.getElementById("rieMasterCount");
      const coverageEl = document.getElementById("rieCoverageDiffCount");
      const personEl = document.getElementById("riePersonDiffCount");
      if (countEl) countEl.textContent = String(entries.length);
      if (coverageEl) coverageEl.textContent = noMasterButApp ? "正本未反映" : (entries.length ? (appEntries.length ? String(coverageDiffs.length) : "未作成") : "未入力");
      if (personEl) personEl.textContent = noMasterButApp ? "正本未反映" : (entries.length ? (appEntries.length ? String(personDiffs.length) : "未作成") : "未入力");
      const memo = document.getElementById("rieCompareMemo");
      if (memo) {
        let badge = `<span class="comparison-badge bad">正本未入力</span>`;
        if (entries.length && !appEntries.length) badge = `<span class="comparison-badge bad">アプリ未作成</span>`;
        else if (entries.length && (coverageDiffs.length || personDiffs.length)) badge = `<span class="comparison-badge warn">差分あり</span>`;
        else if (entries.length && appEntries.length) badge = `<span class="comparison-badge ok">完全一致</span>`;
        const warnings = [];
        if (!entries.length && sameWeekOtherStore) warnings.push(`この週の別店舗に正本 ${sameWeekOtherStore}件あり。店舗選択を確認。`);
        if (appCopiedEntries && appCopiedEntries === entries.length) warnings.push("正本がアプリコピー由来。差分0でも検証結果としては使わない。");
        if (entries.length && appEntries.length && !coverageDiffs.length && !personDiffs.length) warnings.push("手入力で完全一致は珍しい。『アプリ版を正本にコピー』や『りえ正本をアプリに反映』を押していないか確認。");
        memo.innerHTML = `
          <div class="person"><span>${badge}</span></div>
          <div class="person"><span>正本 ${entries.length}件 / アプリ ${appEntries.length}件 / 対象: ${storeFilter === "all" ? "全店舗" : stores[storeFilter].name}</span></div>
          ${entries.length && appEntries.length ? `<div class="person support"><span>人物別差分Top：${personTimeDiffNameSummaryText(personDiffs, 10)}</span></div>` : ""}
          ${warnings.map(text => `<div class="person danger"><span>⚠ ${text}</span></div>`).join("")}
          <div class="person"><span>正本は実勤務時間、アプリ版も1時間単位で比較。未入力・未作成は差分0扱いしない。</span></div>
        `;
      }
      const list = document.getElementById("rieMasterList");
      if (list) {
        list.innerHTML = entries.length ? entries.map(row => `
          <div class="rie-master-row">
            <strong>${row.dateIso.slice(5)}</strong>
            <span>${stores[row.storeKey].name}</span>
            <span>${row.name}</span>
            <span>${row.time}</span>
            <button class="btn small" data-rie-delete="${row.id}" type="button">削除</button>
          </div>
        `).join("") : `<div class="muted">まだ正本が入ってない。紙シフトを日付・店舗・名前・実勤務時間で追加する。</div>`;
        list.querySelectorAll("[data-rie-delete]").forEach(btn => {
          btn.addEventListener("click", () => {
            state.rieMaster = state.rieMaster.filter(row => row.id !== btn.dataset.rieDelete);
            renderRieMaster();
            persistState();
          });
        });
      }
      const covBody = document.getElementById("rieCoverageDiffBody");
      if (covBody) {
        covBody.innerHTML = coverageDiffs.slice(0, 80).map(row => `
          <tr class="${row.diff > 0 ? "warn-row" : "danger-row"}">
            <td>${row.dateIso.slice(5)}(${dowLabel(row.date)})</td>
            <td>${stores[row.storeKey].name}</td>
            <td>${hourLabel(row.hour)}<br><span class="muted">${row.slot}</span></td>
            <td>${row.rieCount}</td>
            <td>${row.appCount}</td>
            <td>${row.diff > 0 ? "+" : ""}${row.diff}</td>
          </tr>
        `).join("") || `<tr><td colspan="6"><span class="tag ${entries.length && appEntries.length ? "ok" : "danger"}">${entries.length ? (appEntries.length ? "時間カバー差分なし" : "アプリ版未作成。週締め作成してから突合。") : "正本未入力。紙シフトを入れてから突合。"}</span></td></tr>`;
      }
      const personBody = document.getElementById("riePersonDiffBody");
      if (personBody) {
        personBody.innerHTML = personDiffs.slice(0, 80).map(row => `
          <tr class="${row.type === "アプリにない" ? "danger-row" : "warn-row"}">
            <td>${row.type}</td>
            <td>${row.dateIso.slice(5)}</td>
            <td>${stores[row.storeKey].name}</td>
            <td>${row.name} ${row.time}</td>
          </tr>
        `).join("") || `<tr><td colspan="4"><span class="tag ${entries.length && appEntries.length ? "ok" : "danger"}">${entries.length ? (appEntries.length ? "人・時間差分なし" : "アプリ版未作成。週締め作成してから突合。") : "正本未入力。紙シフトを入れてから突合。"}</span></td></tr>`;
      }
    }

    function renderFinished() {
      const storeKey = document.getElementById("finishedStore").value;
      renderWeeklyFinished(storeKey);
      renderHead("finishedHead");
      document.getElementById("finishedTitle").textContent = `${stores[storeKey].name} 完成シフト`;
      document.getElementById("finishedPeriod").textContent = periodLabel();
      const body = document.getElementById("finishedBody");
      body.innerHTML = periodDates().map(date => {
        const dateIso = iso(date);
        const weekend = date.getDay() === 0 || date.getDay() === 6;
        return `
          <tr>
            <td class="date-cell ${weekend ? "weekend" : ""}">
              ${dateLabel(date)}
              <span class="dow">${dowLabel(date)}</span>
            </td>
            ${slots.map(slot => {
              const people = displayAssignmentsForSlot(dateIso, storeKey, slot);
              const summary = slotCoverageSummary(dateIso, storeKey, slot);
              return `
                <td>
                  ${people.map(person => `
                    <div class="person ${person.support ? "support" : ""}">
                      <span>${person.name}</span>
                      <span class="time">${person.time}</span>
                    </div>
                  `).join("") || `<span class="muted">-</span>`}
                  <span class="tag">実働${summary.count}/${summary.req}</span>
                </td>
              `;
            }).join("")}
          </tr>
        `;
      }).join("");
      renderCoreRestSummary("monthlyRestSummary", storeKey, periodDates(), "monthly");
    }

    function renderWeeklyFinished(storeKey) {
      const select = document.getElementById("finishedWeekStart");
      const weeks = weekOptions();
      const previous = select.value || state.selectedWeekStart;
      const weekOptionsHtml = weeks.map(startDate => {
        const startIso = iso(startDate);
        const endDate = addDays(startDate, 6);
        return `<option value="${startIso}">${dateLabel(startDate)}(${dowLabel(startDate)})〜${dateLabel(endDate)}(${dowLabel(endDate)})</option>`;
      }).join("");
      syncSelectOptions(select, weekOptionsHtml, previous);
      if (previous && weeks.some(date => iso(date) === previous)) {
        state.selectedWeekStart = previous;
      }
      const weekStartIso = ensureSelectedWeekStart();
      if (weekStartIso) select.value = weekStartIso;

      const dates = weekStartIso ? weekDates(weekStartIso) : [];
      const weekEnd = dates.length ? dates[dates.length - 1] : null;
      document.getElementById("weeklyFinishedTitle").textContent = `${stores[storeKey].name} 週シフト`;
      document.getElementById("weeklyFinishedPeriod").textContent = dates.length
        ? `${dateLabel(dates[0])}(${dowLabel(dates[0])})〜${dateLabel(weekEnd)}(${dowLabel(weekEnd)})`
        : "-";
      document.getElementById("weeklyFinishedHead").innerHTML = `
        <tr>
          <th>日付</th>
          ${slots.map(slot => `<th>${slot}<br><span class="muted">必要 ${requirement(storeKey, slot)}</span></th>`).join("")}
        </tr>
      `;
      document.getElementById("weeklyFinishedBody").innerHTML = dates.map(date => {
        const dateIso = iso(date);
        const weekend = date.getDay() === 0 || date.getDay() === 6;
        return `
          <tr>
            <td class="date-cell ${weekend ? "weekend" : ""}">
              ${dateLabel(date)}
              <span class="dow">${dowLabel(date)}</span>
            </td>
            ${slots.map(slot => {
              const people = displayAssignmentsForSlot(dateIso, storeKey, slot);
              const summary = slotCoverageSummary(dateIso, storeKey, slot);
              const shortage = summary.shortage;
              return `
                <td>
                  ${people.map(person => `
                    <div class="person ${person.support ? "support" : ""}">
                      <span>${person.name}</span>
                      <span class="time">${person.time}</span>
                    </div>
                  `).join("") || `<span class="muted">-</span>`}
                  <span class="tag">実働${summary.count}/${summary.req}</span>
                  ${shortage ? `<span class="tag bad">不足 ${shortage}</span>` : ""}
                </td>
              `;
            }).join("")}
          </tr>
        `;
      }).join("");
      renderCoreRestSummary("weeklyRestSummary", storeKey, dates, "weekly");
    }

    function collectShortages(storeFilter = "all") {
      const rows = [];
      periodDates().forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(storeKey => {
          if (storeFilter !== "all" && storeFilter !== storeKey) return;
          slots.forEach(slot => {
            const people = ensureCell(dateIso, storeKey, slot);
            const req = requirement(storeKey, slot);
            const shortage = req - people.length;
            if (shortage > 0) {
              rows.push({ date, dateIso, storeKey, slot, req, count: people.length, shortage });
            }
          });
        });
      });
      return rows;
    }

    function hourLabel(hour) {
      const start = hour % 24;
      const end = (hour + 1) % 24;
      return `${start}-${end}`;
    }

    function hourRangeLabel(startHour, endHour) {
      return `${startHour % 24}-${endHour % 24}`;
    }

    function dayHourLabel(hour) {
      return hour === 24 ? "24" : String(hour % 24);
    }

    function dayHourRangeLabel(startHour, endHour) {
      return `${dayHourLabel(startHour)}-${dayHourLabel(endHour)}`;
    }

    function slotHourRange(slot) {
      const [start, end] = parseRange(slot);
      return { start, end, slot };
    }

    function requirementForHour(storeKey, hour) {
      let result = { req: 0, slot: "" };
      slots.map(slotHourRange).forEach(range => {
        const targetHour = range.end > 24 && hour < range.start ? hour + 24 : hour;
        if (range.start <= targetHour && targetHour < range.end) {
          const req = requirement(storeKey, range.slot);
          if (req > result.req) result = { req, slot: range.slot };
        }
      });
      return result;
    }

    function assignmentCoversHour(assignment, hour) {
      const [start, end] = parseRange(assignment.time);
      let targetHour = hour;
      if (end > 24 && hour < start) targetHour += 24;
      return start <= targetHour && targetHour < end;
    }

    function hourlyCoverage(dateIso, storeKey, hour) {
      const map = new Map();
      slots.forEach(slot => {
        readCell(dateIso, storeKey, slot).forEach(assignment => {
          if (assignmentCoversHour(assignment, hour)) {
            map.set(assignmentKey(assignment), assignment);
          }
        });
      });
      return [...map.values()];
    }

    function slotCoverageSummary(dateIso, storeKey, slot) {
      const req = requirement(storeKey, slot);
      const [start, end] = parseRange(slot);
      let minCount = Number.POSITIVE_INFINITY;
      let maxCount = 0;
      const shortageRanges = [];
      let active = null;
      for (let hour = start; hour < end; hour += 1) {
        const count = hourlyCoverage(dateIso, storeKey, hour % 24).length;
        minCount = Math.min(minCount, count);
        maxCount = Math.max(maxCount, count);
        const shortage = Math.max(0, req - count);
        if (shortage > 0) {
          if (active && active.endHour === hour && active.shortage === shortage) {
            active.endHour = hour + 1;
          } else {
            if (active) shortageRanges.push(active);
            active = { startHour: hour, endHour: hour + 1, shortage };
          }
        } else if (active) {
          shortageRanges.push(active);
          active = null;
        }
      }
      if (active) shortageRanges.push(active);
      if (!Number.isFinite(minCount)) minCount = 0;
      return {
        req,
        count: minCount,
        maxCount,
        assigned: ensureCell(dateIso, storeKey, slot).length,
        shortage: Math.max(0, req - minCount),
        over: Math.max(0, minCount - req),
        ranges: shortageRanges
      };
    }

    function collectHourlyShortages(storeFilter = "all") {
      const rows = [];
      periodDates().forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(storeKey => {
          if (storeFilter !== "all" && storeFilter !== storeKey) return;
          slots.map(slotHourRange).forEach(range => {
            const req = requirement(storeKey, range.slot);
            if (req <= 0) return;
            let active = null;
            for (let hour = range.start; hour < range.end; hour += 1) {
              const people = hourlyCoverage(dateIso, storeKey, hour);
              if (people.length < req) {
                const shortage = req - people.length;
                if (active && active.endHour === hour && active.count === people.length && active.shortage === shortage) {
                  active.endHour = hour + 1;
                } else {
                  if (active) rows.push(active);
                  active = {
                    date,
                    dateIso,
                    storeKey,
                    slot: range.slot,
                    startHour: hour,
                    endHour: hour + 1,
                    req,
                    count: people.length,
                    shortage
                  };
                }
              } else if (active) {
                rows.push(active);
                active = null;
              }
            }
            if (active) rows.push(active);
          });
        });
      });
      return rows;
    }

    function collectAllShortages(storeFilter = "all") {
      const hourlyGroups = new Map();
      collectHourlyShortages(storeFilter).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}|${row.slot}`;
        const current = hourlyGroups.get(key) || {
          ...row,
          kind: "時間不足",
          ranges: [],
          count: row.count,
          shortage: row.shortage
        };
        current.ranges.push(hourRangeLabel(row.startHour, row.endHour));
        current.count = Math.min(current.count, row.count);
        current.shortage = Math.max(current.shortage, row.shortage);
        hourlyGroups.set(key, current);
      });
      const hourlyRows = [...hourlyGroups.values()].map(row => ({
        ...row,
        timeLabel: `${row.slot} / ${row.ranges.join("、")}`
      }));
      return hourlyRows
        .sort((a, b) => a.date - b.date || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey));
    }

    function collectShortageGroupCount(storeFilter = "all") {
      const groups = new Set();
      collectAllShortages(storeFilter).forEach(row => {
        groups.add(`${row.dateIso}|${row.storeKey}`);
      });
      return groups.size;
    }

    function candidateNameList(rows, limit = 4) {
      return [...new Set(rows.map(item => item.person.name))].slice(0, limit);
    }

    function coreAdjustmentCandidatesFor(row, restRows = coreRestRows("all")) {
      const options = generationOptions({ allowSupport: false });
      return staff
        .filter(person => isCoreEmployee(person))
        .filter(person => !person.support)
        .filter(person => canWorkAtStore(person, row.storeKey))
        .map(person => {
          const rest = restRows.find(item => item.person.name === person.name);
          const time = bestTimeFor(person, row.storeKey, row.slot, row.dateIso, options);
          if (!time || !canPlaceShift(row.dateIso, row.storeKey, person, time, options)) return null;
          const restDiff = rest ? rest.restDiff : 0;
          return {
            person,
            time,
            score: scoreCandidate(person, row.storeKey, row.slot, row.dateIso, options) + Math.max(0, restDiff) * 60,
            reason: restDiff > 0 ? `休み多め+${restDiff}` : "社員調整"
          };
        })
        .filter(Boolean)
        .sort((a, b) => b.score - a.score)
        .slice(0, 3);
    }

    function supportAdjustmentCandidatesFor(row) {
      const options = generationOptions({ allowSupport: true });
      return staff
        .filter(person => person.support || hasTag(person, "応援マルチ"))
        .map(person => {
          const time = bestTimeFor(person, row.storeKey, row.slot, row.dateIso, options);
          if (!time || !canPlaceShift(row.dateIso, row.storeKey, person, time, options)) return null;
          return {
            person,
            time,
            score: scoreCandidate(person, row.storeKey, row.slot, row.dateIso, options),
            reason: "最終応援"
          };
        })
        .filter(Boolean)
        .sort((a, b) => b.score - a.score)
        .slice(0, 2);
    }

    function partialCoverageCandidatesFor(row) {
      if (row.kind !== "時間不足") return [];
      const options = generationOptions({
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        allowSupport: false
      });
      return staff
        .filter(person => !person.support)
        .filter(person => canWorkAtStore(person, row.storeKey))
        .map(person => {
          const time = bestTimeFor(person, row.storeKey, row.slot, row.dateIso, options);
          if (!time || !canPlaceShift(row.dateIso, row.storeKey, person, time, options)) return null;
          return {
            person,
            time,
            score: scoreCandidate(person, row.storeKey, row.slot, row.dateIso, options),
            reason: "部分穴"
          };
        })
        .filter(Boolean)
        .sort((a, b) => b.score - a.score)
        .slice(0, 3);
    }

    function priorityCandidateForShortage(row) {
      const normalOptions = generationOptions({ allowSupport: false });
      const normal = candidatesFor(row.storeKey, row.slot, row.dateIso, normalOptions)
        .filter(item => !item.person.support)[0];
      if (normal) return { ...normal, options: normalOptions, tier: "通常" };

      const coreOptions = generationOptions({ allowSupport: false });
      const core = coreAdjustmentCandidatesFor(row, coreRestRows("all"))[0];
      if (core) return { ...core, options: coreOptions, tier: "社員調整" };

      const partialOptions = generationOptions({
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        allowSupport: false
      });
      const partial = partialCoverageCandidatesFor(row)[0];
      if (partial) return { ...partial, options: partialOptions, tier: "部分穴" };

      const supportOptions = generationOptions({ allowSupport: true });
      const support = supportAdjustmentCandidatesFor(row)[0];
      if (support) return { ...support, options: supportOptions, tier: "最終応援" };
      return null;
    }

    function shortageCandidateLabel(row, context = {}) {
      const restRows = context.restRows || coreRestRows("all");
      const normalOptions = generationOptions({ allowSupport: false });
      const normal = candidatesFor(row.storeKey, row.slot, row.dateIso, normalOptions)
        .filter(item => !item.person.support)
        .slice(0, 3);
      const parts = [];
      const normalNames = candidateNameList(normal);
      if (normalNames.length) parts.push(`通常:${normalNames.join("、")}`);
      if (normalNames.length >= 3) return parts.join(" / ");
      const core = coreAdjustmentCandidatesFor(row, restRows);
      const coreNames = core.map(item => `${item.person.name}(${item.reason})`);
      if (coreNames.length) parts.push(`社員調整:${coreNames.join("、")}`);
      if (normalNames.length + coreNames.length >= 3) return parts.join(" / ");
      const partial = partialCoverageCandidatesFor(row);
      const partialNames = candidateNameList(partial);
      if (partialNames.length) parts.push(`部分:${partialNames.join("、")}`);
      if (normalNames.length + coreNames.length + partialNames.length >= 3) return parts.join(" / ");
      const support = supportAdjustmentCandidatesFor(row);
      const supportNames = candidateNameList(support, 2);
      if (supportNames.length) parts.push(`最終:${supportNames.join("、")}`);
      return parts.join(" / ") || "候補なし。条件変更が必要";
    }

    function collectShortageDisplayRows(storeFilter = "all") {
      const groups = new Map();
      const context = { restRows: coreRestRows("all") };
      collectAllShortages(storeFilter).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}`;
        const current = groups.get(key) || {
          date: row.date,
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          kind: "不足あり",
          timeLabels: [],
          shortage: 0,
          candidates: []
        };
        current.timeLabels.push(`${row.kind}:${row.timeLabel} 不足${row.shortage}`);
        current.shortage += row.shortage;
        const label = shortageCandidateLabel(row, context);
        if (label) current.candidates.push(label);
        groups.set(key, current);
      });
      return [...groups.values()].map(row => ({
        ...row,
        timeLabel: row.timeLabels.join(" / "),
        req: "-",
        count: "-",
        candidateLabel: [...new Set(row.candidates)].slice(0, 3).join(" / ")
      })).sort((a, b) => a.date - b.date || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey));
    }

    function ensureShortageMapDate() {
      const input = document.getElementById("shortageMapDate");
      if (!input) return state.today;
      const dates = periodDates();
      const valid = dates.map(date => iso(date));
      if (!input.value || !valid.includes(input.value)) {
        input.value = valid.includes(state.today) ? state.today : (valid[0] || state.today);
      }
      return input.value;
    }

    function dailyShortageSegments(storeKey, dateIso) {
      const segments = [];
      for (let hour = 0; hour < 24; hour += 1) {
        const { req, slot } = requirementForHour(storeKey, hour);
        const count = hourlyCoverage(dateIso, storeKey, hour).length;
        const shortage = Math.max(0, req - count);
        if (req <= 0 || shortage <= 0) {
          continue;
        }
        const previous = segments[segments.length - 1];
        if (previous && previous.endHour === hour && previous.shortage === shortage) {
          previous.endHour = hour + 1;
          previous.req = Math.max(previous.req, req);
          previous.count = Math.min(previous.count, count);
          if (!previous.slots.includes(slot)) previous.slots.push(slot);
        } else {
          segments.push({
            startHour: hour,
            endHour: hour + 1,
            req,
            count,
            shortage,
            slots: [slot]
          });
        }
      }
      return segments;
    }

    function shortageRowFromSegment(storeKey, dateIso, segment) {
      const primarySlot = segment.slots[0] || requirementForHour(storeKey, segment.startHour).slot || slots[0];
      return {
        date: new Date(`${dateIso}T00:00:00`),
        dateIso,
        storeKey,
        slot: primarySlot,
        kind: "時間不足",
        startHour: segment.startHour,
        endHour: segment.endHour,
        req: segment.req,
        count: segment.count,
        shortage: segment.shortage,
        timeLabel: `${primarySlot} / ${dayHourRangeLabel(segment.startHour, segment.endHour)}`
      };
    }

    function selectedShortageRow() {
      const hole = state.selectedShortageHole;
      if (!hole) return null;
      const segments = dailyShortageSegments(hole.storeKey, hole.dateIso);
      const segment = segments.find(item => item.startHour === hole.startHour && item.endHour === hole.endHour);
      if (!segment) return null;
      return shortageRowFromSegment(hole.storeKey, hole.dateIso, segment);
    }

    function normalizeShortageDetailRow(row) {
      if (!row) return null;
      if (row.slot) return row;
      const dateIso = row.dateIso || iso(row.date);
      const source = collectAllShortages(row.storeKey).find(item => (
        item.dateIso === dateIso && item.storeKey === row.storeKey
      ));
      return source || row;
    }

    function candidatePriorityGroupsFor(row) {
      row = normalizeShortageDetailRow(row);
      if (!row || !row.slot) {
        return [
          { label: "通常候補", rows: [] },
          { label: "社員調整", rows: [] },
          { label: "部分勤務", rows: [] },
          { label: "最終応援", rows: [] }
        ];
      }
      const restRows = coreRestRows("all");
      const normalOptions = generationOptions({ allowSupport: false });
      const normal = candidatesFor(row.storeKey, row.slot, row.dateIso, normalOptions)
        .filter(item => !item.person.support)
        .slice(0, 4)
        .map(item => ({ ...item, tier: "通常候補", options: normalOptions, reason: "通常条件で配置可" }));

      const coreOptions = generationOptions({ allowSupport: false });
      const core = coreAdjustmentCandidatesFor(row, restRows)
        .slice(0, 3)
        .map(item => ({ ...item, tier: "社員調整", options: coreOptions, reason: item.reason }));

      const partialOptions = generationOptions({
        allowPartialOverlap: true,
        requireFullSlotCoverage: false,
        allowSupport: false
      });
      const partial = partialCoverageCandidatesFor(row)
        .slice(0, 3)
        .map(item => ({ ...item, tier: "部分勤務", options: partialOptions, reason: "枠全体ではなく穴時間の一部を埋める候補" }));

      const supportOptions = generationOptions({ allowSupport: true });
      const support = supportAdjustmentCandidatesFor(row)
        .slice(0, 2)
        .map(item => ({ ...item, tier: "最終応援", options: supportOptions, reason: "まこつ。/りえ等の最終応援枠" }));

      return [
        { label: "通常候補", rows: normal },
        { label: "社員調整", rows: core },
        { label: "部分勤務", rows: partial },
        { label: "最終応援", rows: support }
      ];
    }

    function relaxHintsFor(row, groups) {
      const hints = [];
      if (!(groups[0] && groups[0].rows.length)) {
        hints.push("通常条件では候補が薄い。希望休、固定店舗、対応時間、重複、連勤、社員休みのどれかで止まっている可能性。");
      }
      if (groups[1] && groups[1].rows.length) {
        hints.push("社員休みが多めの人を1日だけ出勤調整すると埋まる可能性あり。");
      }
      if (groups[2] && groups[2].rows.length) {
        hints.push("枠全体ではなく、穴の時間だけ部分勤務で頼むと埋まる可能性あり。");
      }
      if (groups[3] && groups[3].rows.length) {
        hints.push("通常候補が厳しい場合は、まこつ。/りえの最終応援候補あり。");
      }
      if (!hints.length) {
        hints.push("候補なし。必要人数、時間帯、店舗応援可否、本人希望のどれかを見直す必要あり。");
      }
      return hints;
    }

    function lineTextForShortage(row, candidates = []) {
      row = normalizeShortageDetailRow(row);
      if (!row) return "";
      const date = row.date || new Date(`${row.dateIso}T00:00:00`);
      const names = candidates.length ? candidates.map(item => `${item.person.name}(${item.time})`).join("、") : "候補確認中";
      return [
        "お疲れさまです。",
        `${dateLabel(date)}(${dowLabel(date)}) ${stores[row.storeKey].name} ${row.timeLabel} が${row.shortage}名不足しています。`,
        `候補: ${names}`,
        "入れる方がいれば教えてください。"
      ].join("\n");
    }

    function renderShortageHoleDetail(row = selectedShortageRow()) {
      const box = document.getElementById("shortageHoleDetail");
      if (!box) return;
      row = normalizeShortageDetailRow(row);
      if (!row) {
        box.innerHTML = `<div class="muted">色付きの穴を押すと、候補とLINE文面が出ます。</div>`;
        return;
      }
      const groups = candidatePriorityGroupsFor(row);
      const allCandidates = groups.flatMap(group => group.rows);
      const hints = relaxHintsFor(row, groups);
      box.innerHTML = `
        <div class="detail-box">
          <h3>${stores[row.storeKey].name} ${dateLabel(row.date)}(${dowLabel(row.date)}) ${row.timeLabel}</h3>
          <div class="status-row">
            <span class="tag ${row.shortage >= 2 ? "bad" : "warn"}">不足${row.shortage}</span>
            <span class="tag">必要${row.req}</span>
            <span class="tag">配置${row.count}</span>
          </div>
        </div>
        ${groups.map(group => `
          <div class="detail-box">
            <h3>${group.label}</h3>
            ${group.rows.length ? group.rows.map(item => `
              <div class="candidate">
                <div>
                  <strong>${item.person.name}</strong>
                  <div class="reason">${item.time} / 理由：${item.reason || item.tier} / 適合 ${item.score}</div>
                </div>
                <button class="btn small ${group.label === "最終応援" ? "" : "primary"}" type="button"
                  data-shortage-add="${item.person.name}"
                  data-shortage-time="${item.time}"
                  data-shortage-options="${item.tier || group.label}">
                  入れる
                </button>
              </div>
            `).join("") : `<div class="muted">該当候補なし</div>`}
          </div>
        `).join("")}
        <div class="detail-box">
          <h3>条件を緩めるなら</h3>
          ${hints.map(hint => `<div class="person"><span>${hint}</span></div>`).join("")}
        </div>
        <div class="detail-box">
          <h3>LINE文面</h3>
          <textarea class="textarea" readonly>${lineTextForShortage(row, allCandidates.slice(0, 4))}</textarea>
        </div>
      `;
      box.querySelectorAll("[data-shortage-add]").forEach(btn => {
        btn.addEventListener("click", () => {
          const person = staff.find(item => item.name === canonicalStaffName(btn.dataset.shortageAdd));
          if (!person) return;
          const tier = btn.dataset.shortageOptions || "";
          const options = tier === "部分勤務"
            ? generationOptions({ allowPartialOverlap: true, requireFullSlotCoverage: false, allowSupport: false })
            : tier === "最終応援"
              ? generationOptions({ allowSupport: true })
              : generationOptions({ allowSupport: false });
          const added = addShiftToDay(row.dateIso, row.storeKey, person, btn.dataset.shortageTime, options);
          if (added) {
            renderShortage();
            showToast(`${stores[row.storeKey].name} ${row.timeLabel} に ${person.name} を追加`);
          } else {
            showToast("この候補は今の条件では入れられない");
          }
        });
      });
    }

    function renderShortageTimelineMap() {
      const wrap = document.getElementById("shortageTimelineMap");
      if (!wrap) return;
      const dateIso = ensureShortageMapDate();
      const date = new Date(`${dateIso}T00:00:00`);
      const filter = document.getElementById("shortageStore").value;
      const keys = storeOrder.filter(storeKey => filter === "all" || filter === storeKey);
      const ticks = [0, 6, 9, 13, 17, 22, 24].map(hour => `
        <span class="timeline-tick" style="left:${(hour / 24) * 100}%"><span>${dayHourLabel(hour)}</span></span>
      `).join("");
      wrap.innerHTML = `
        <div class="muted">${dateLabel(date)}(${dowLabel(date)}) の穴マップ。線の上に色が付いたところが不足。</div>
        ${keys.map(storeKey => {
          const segments = dailyShortageSegments(storeKey, dateIso);
          const maxShortage = segments.reduce((max, item) => Math.max(max, item.shortage), 0);
          const total = segments.reduce((sum, item) => sum + item.shortage, 0);
          return `
            <div class="timeline-row">
              <div class="timeline-store">${stores[storeKey].name}</div>
              <div class="timeline-track" aria-label="${stores[storeKey].name} ${dateIso} 不足タイムライン">
                ${ticks}
                ${segments.map(item => {
                  const left = (item.startHour / 24) * 100;
                  const width = ((item.endHour - item.startHour) / 24) * 100;
                  const label = `${dayHourRangeLabel(item.startHour, item.endHour)} 不足${item.shortage}`;
                  const selected = state.selectedShortageHole
                    && state.selectedShortageHole.dateIso === dateIso
                    && state.selectedShortageHole.storeKey === storeKey
                    && state.selectedShortageHole.startHour === item.startHour
                    && state.selectedShortageHole.endHour === item.endHour;
                  return `
                    <button class="hole-segment ${item.shortage >= 2 ? "bad" : ""} ${selected ? "selected" : ""}"
                      type="button"
                      data-hole-store="${storeKey}"
                      data-hole-date="${dateIso}"
                      data-hole-start="${item.startHour}"
                      data-hole-end="${item.endHour}"
                      style="left:${left}%;width:${width}%"
                      title="${label} / 必要${item.req} 配置${item.count} / ${item.slots.join("、")}">
                      ${item.shortage}
                    </button>
                  `;
                }).join("")}
              </div>
              <div class="timeline-summary">
                ${segments.length
                  ? `<span class="tag ${maxShortage >= 2 ? "bad" : "warn"}">穴${segments.length}本 / 不足${total}</span>`
                  : `<span class="tag ok">穴なし</span>`}
              </div>
            </div>
          `;
        }).join("")}
      `;
      wrap.querySelectorAll("[data-hole-store]").forEach(btn => {
        btn.addEventListener("click", () => {
          state.selectedShortageHole = {
            storeKey: btn.dataset.holeStore,
            dateIso: btn.dataset.holeDate,
            startHour: Number(btn.dataset.holeStart),
            endHour: Number(btn.dataset.holeEnd)
          };
          renderShortageTimelineMap();
          renderShortageHoleDetail();
        });
      });
      renderShortageHoleDetail();
    }

    function renderShortage() {
      const filter = document.getElementById("shortageStore").value;
      const rows = collectShortageDisplayRows(filter);
      const body = document.getElementById("shortageBody");
      renderShortageTimelineMap();
      body.innerHTML = rows.map(row => {
        return `
          <tr>
            <td>${dateLabel(row.date)}(${dowLabel(row.date)})</td>
            <td>${stores[row.storeKey].name}</td>
            <td><span class="tag bad">${row.kind}</span></td>
            <td>${row.timeLabel}</td>
            <td>${row.req}</td>
            <td>${row.count}</td>
            <td><span class="tag bad">${row.shortage}</span></td>
            <td>${row.candidateLabel || "-"}</td>
          </tr>
        `;
      }).join("") || `
        <tr>
          <td colspan="8"><span class="tag ok">不足なし</span></td>
        </tr>
      `;
      renderLineMessage();
    }

    function isCoreEmployee(person) {
      return hasTag(person, "社員") || hasTag(person, "店長");
    }

    function targetOffDays(person) {
      if (hasTag(person, "7日休み")) return 7;
      return isCoreEmployee(person) ? 7 : 0;
    }

    function restAdjustmentHint(person, restDiff) {
      if (person.name === "木村" && restDiff > 0) {
        return "火曜で調整候補";
      }
      if (restDiff > 0) return "出勤調整候補";
      if (restDiff < 0) return "休み追加候補";
      return "OK";
    }

    function offDaysInDates(personName, dates) {
      return dates.filter(date => !isPersonAssignedOnDate(iso(date), personName)).length;
    }

    function offDaysInPeriod(personName) {
      return offDaysInDates(personName, periodDates());
    }

    function storeHasScheduleOnDate(dateIso, storeKey) {
      return slots.some(slot => readCell(dateIso, storeKey, slot).length > 0);
    }

    function generatedDatesForCorePerson(person, storeFilter = "all", dates = periodDates()) {
      const storeKeys = (person.stores || []).filter(storeKey => (
        storeFilter === "all" || storeFilter === storeKey
      ));
      if (!storeKeys.length) return [];
      return dates.filter(date => {
        const dateIso = iso(date);
        return storeKeys.some(storeKey => storeHasScheduleOnDate(dateIso, storeKey));
      });
    }

    function targetOffDaysForGeneratedDates(person, generatedDates) {
      const fullTarget = targetOffDays(person);
      if (!fullTarget || !generatedDates.length) return 0;
      const fullPeriodDays = periodDates().length || generatedDates.length;
      if (generatedDates.length >= fullPeriodDays) return fullTarget;
      return Math.max(1, Math.round(fullTarget * generatedDates.length / fullPeriodDays));
    }

    function coreRestRows(storeFilter = "all", displayDates = periodDates()) {
      const period = periodDates();
      const periodSet = new Set(period.map(date => iso(date)));
      const activeDisplayDates = displayDates.filter(date => periodSet.has(iso(date)));
      return staff
        .filter(person => isCoreEmployee(person) && targetOffDays(person) > 0)
        .filter(person => storeFilter === "all" || canWorkAtStore(person, storeFilter))
        .map(person => {
          const generatedPeriodDates = generatedDatesForCorePerson(person, storeFilter, period);
          if (!generatedPeriodDates.length) return null;
          const generatedPeriodSet = new Set(generatedPeriodDates.map(date => iso(date)));
          const generatedDisplayDates = activeDisplayDates.filter(date => generatedPeriodSet.has(iso(date)));
          const periodOffDays = offDaysInDates(person.name, generatedPeriodDates);
          const displayOffDays = offDaysInDates(person.name, generatedDisplayDates);
          const periodPaidLeaveDays = paidLeaveDaysInDates(person.name, generatedPeriodDates);
          const displayPaidLeaveDays = paidLeaveDaysInDates(person.name, generatedDisplayDates);
          const periodEmergencyDays = emergencyAbsenceDaysInDates(person.name, generatedPeriodDates);
          const displayEmergencyDays = emergencyAbsenceDaysInDates(person.name, generatedDisplayDates);
          const target = targetOffDaysForGeneratedDates(person, generatedPeriodDates);
          return {
            person,
            target,
            periodDays: generatedPeriodDates.length,
            periodOffDays,
            periodPaidLeaveDays,
            periodEmergencyDays,
            displayDays: generatedDisplayDates.length,
            displayOffDays,
            displayPaidLeaveDays,
            displayEmergencyDays,
            shortage: Math.max(0, target - periodOffDays),
            excess: Math.max(0, periodOffDays - target),
            restDiff: periodOffDays - target
          };
        })
        .filter(Boolean);
    }

    function renderCoreRestSummary(elementId, storeFilter, displayDates, mode = "monthly") {
      const box = document.getElementById(elementId);
      if (!box) return;
      const rows = coreRestRows(storeFilter, displayDates);
      const label = mode === "weekly"
        ? "週休 / 月休"
        : "月間休み";
      box.innerHTML = `
        <div class="rest-summary-title">
          社員休みカウント
          <span>${label}</span>
        </div>
        <div class="rest-count-grid">
          ${rows.map(row => {
            const status = row.shortage > 0
              ? `休み不足 あと${row.shortage}日`
              : row.excess > 0
                ? `休み多い +${row.excess}日`
                : "OK";
            const hint = restAdjustmentHint(row.person, row.restDiff);
            const className = row.shortage > 0 || row.excess > 0 ? "rest-warn" : "rest-ok";
            const leaveMeta = `有給${row.periodPaidLeaveDays}日 / 急休${row.periodEmergencyDays}日`;
            const meta = mode === "weekly"
              ? `週${row.displayOffDays}/${row.displayDays}日（有給${row.displayPaidLeaveDays}・急休${row.displayEmergencyDays}） / 月${row.periodOffDays}/${row.target}日 ${leaveMeta} ${status} ${hint}`
              : `月${row.periodOffDays}/${row.target}日 ${leaveMeta} ${status} ${hint}`;
            return `
              <div class="rest-count-item ${className}">
                <strong>${row.person.name}</strong>
                <span class="rest-meta">${meta}</span>
              </div>
            `;
          }).join("") || `<div class="muted">対象の社員・店長なし</div>`}
        </div>
      `;
    }

    function collectCoreRestIssues(storeFilter = "all") {
      const dates = periodDates();
      const reportDate = dates[dates.length - 1] || new Date();
      return coreRestRows(storeFilter)
        .filter(row => row.shortage > 0 || row.excess > 0)
        .map(row => ({
          level: "注意",
          severity: 2,
          date: reportDate,
          storeKey: row.person.stores[0] || "miyanoshita",
          target: row.person.name,
          message: row.shortage > 0
            ? `社員休み ${row.periodOffDays}/${row.target}日。有給${row.periodPaidLeaveDays}日/急休${row.periodEmergencyDays}日。あと${row.shortage}日休みが必要`
            : `社員休み ${row.periodOffDays}/${row.target}日。有給${row.periodPaidLeaveDays}日/急休${row.periodEmergencyDays}日。休み多め +${row.excess}日。${restAdjustmentHint(row.person, row.restDiff)}`
        }));
    }

    function collectIssues(storeFilter = "all") {
      const issues = [];
      periodDates().forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(storeKey => {
          if (storeFilter !== "all" && storeFilter !== storeKey) return;
          slots.forEach(slot => {
            const people = ensureCell(dateIso, storeKey, slot);
            const req = requirement(storeKey, slot);
            if (people.length > req) {
              issues.push({
                level: "注意",
                severity: 2,
                date,
                storeKey,
                target: slot,
                message: `必要${req}人に対して${people.length}人。過剰配置の可能性`
              });
            }
            people.forEach(person => {
              const master = findStaff(person.name);
              if (master && !master.stores.includes(storeKey)) {
                issues.push({
                  level: "注意",
                  severity: 2,
                  date,
                  storeKey,
                  target: person.name,
                  message: `対応店舗外の可能性: ${stores[storeKey].name}`
                });
              }
              if (master && !matchesDay(master, dateIso)) {
                issues.push({
                  level: "危険",
                  severity: 3,
                  date,
                  storeKey,
                  target: person.name,
                  message: `対応曜日外の可能性: ${dowLabel(date)}曜`
                });
              }
              if (isUnavailable(person.name, dateIso)) {
                const unavailableReason = isPaidLeave(person.name, dateIso)
                  ? "有給"
                  : isEmergencyAbsence(person.name, dateIso)
                    ? "急遽休み"
                    : "希望休";
                issues.push({
                  level: "危険",
                  severity: 3,
                  date,
                  storeKey,
                  target: person.name,
                  message: `${unavailableReason}なのに${slot}へ配置`
                });
              }
            });
            people.forEach((person, index) => {
              people.slice(index + 1).forEach(other => {
                if (areIncompatible(person.name, other.name)) {
                  issues.push({
                    level: "危険",
                    severity: 3,
                    date,
                    storeKey,
                    target: `${person.name} / ${other.name}`,
                    message: "手書きメモの組み合わせNG"
                  });
                }
              });
            });
            if (people.some(person => person.name === "芳澤") && !hasResponsiblePerson(people)) {
              issues.push({
                level: "危険",
                severity: 3,
                date,
                storeKey,
                target: "芳澤",
                message: "責任者と一緒のシフトのみ"
              });
            }
          });
        });

        staff.forEach(person => {
          const assignedStores = storeOrder.filter(storeKey => (
            slots.some(slot => ensureCell(dateIso, storeKey, slot).some(item => item.name === person.name))
          ));
          if (assignedStores.length > 1) {
            issues.push({
              level: "危険",
              severity: 3,
              date,
              storeKey: assignedStores[0],
              target: person.name,
              message: `同日に複数店舗配置: ${assignedStores.map(key => stores[key].name).join("、")}`
            });
          }
          const previousIso = iso(addDays(date, -1));
          if (hasLateShift(previousIso, person.name) && hasEarlyShift(dateIso, person.name)) {
            issues.push({
              level: "危険",
              severity: 3,
              date,
              storeKey: assignedStores[0] || "miyanoshita",
              target: person.name,
              message: "前日夜勤明けの翌朝勤務"
            });
          }
        });
      });

      staff.forEach(person => {
        let streakStart = null;
        let streakEnd = null;
        let streakStores = new Set();

        const flushStreak = () => {
          if (!streakStart || !streakEnd) return;
          const count = Math.round((streakEnd - streakStart) / 86400000) + 1;
          if (count >= 6) {
            const storeKeys = [...streakStores];
            const storeNames = storeKeys.map(key => stores[key].name).join("、");
            issues.push({
              level: count >= 7 ? "危険" : "注意",
              severity: count >= 7 ? 3 : 2,
              date: streakEnd,
              storeKey: storeKeys[0] || "miyanoshita",
              target: person.name,
              message: `${dateLabel(streakStart)}〜${dateLabel(streakEnd)} ${count}連勤の可能性${storeNames ? `（${storeNames}）` : ""}`
            });
          }
          streakStart = null;
          streakEnd = null;
          streakStores = new Set();
        };

        periodDates().forEach(date => {
          const dateIso = iso(date);
          const assignedStores = assignedStoreKeysForPersonOnDate(dateIso, person.name, storeFilter);
          if (assignedStores.length) {
            if (!streakStart) streakStart = date;
            streakEnd = date;
            assignedStores.forEach(key => streakStores.add(key));
          } else {
            flushStreak();
          }
        });
        flushStreak();
      });

      issues.push(...collectCoreRestIssues(storeFilter));

      return issues.sort((a, b) => b.severity - a.severity || a.date - b.date);
    }

    function sanitizeInvalidStoreAssignments() {
      let removed = 0;
      Object.keys(state.schedule).forEach(dateIso => {
        const storeMap = state.schedule[dateIso] || {};
        storeOrder.forEach(storeKey => {
          const slotMap = storeMap[storeKey] || {};
          slots.forEach(slot => {
            const cell = slotMap[slot];
            if (!Array.isArray(cell)) return;
            const valid = cell.filter(assignment => {
              const master = findStaff(assignment.name);
              if (!master || !canWorkAtStore(master, storeKey)) return false;
              if (hasTag(master, "希望日だけ配置") && !isSubmittedWorkAssignment(dateIso, storeKey, assignment)) return false;
              return true;
            });
            removed += cell.length - valid.length;
            slotMap[slot] = valid;
          });
        });
      });
      return removed;
    }

    function renderIssues() {
      const filter = document.getElementById("issuesStore").value;
      const rows = collectIssues(filter);
      const body = document.getElementById("issuesBody");
      body.innerHTML = rows.map(issue => `
        <tr class="${issue.severity >= 3 ? "danger-row" : "warn-row"}">
          <td><span class="tag ${issue.severity >= 3 ? "bad" : "warn"}">${issue.level}</span></td>
          <td>${dateLabel(issue.date)}(${dowLabel(issue.date)})</td>
          <td>${stores[issue.storeKey] ? stores[issue.storeKey].name : "-"}</td>
          <td>${issue.target}</td>
          <td>${issue.message}</td>
        </tr>
      `).join("") || `
        <tr>
          <td colspan="5"><span class="tag ok">危険なし</span></td>
        </tr>
      `;
    }

    function renderLineMessage() {
      const box = document.getElementById("lineMessage");
      if (!box) return;
      const filter = document.getElementById("shortageStore").value;
      const first = collectAllShortages(filter)[0];
      if (!first) {
        box.value = "不足枠はありません。";
        return;
      }
      const candidates = candidatesFor(first.storeKey, first.slot, first.dateIso)
        .slice(0, 3)
        .map(item => item.person.name);
      box.value = [
        "お疲れさまです。",
        `${dateLabel(first.date)}(${dowLabel(first.date)}) ${stores[first.storeKey].name} ${first.timeLabel} が${first.shortage}名不足しています。`,
        candidates.length ? `候補: ${candidates.join("、")}` : "候補が見つかっていません。",
        "入れる方がいれば教えてください。"
      ].join("\n");
    }

    function renderOwnerDashboard() {
      const shortages = collectShortageDisplayRows("all");
      const issues = collectIssues("all");
      const totalLabor = storeOrder.reduce((sum, storeKey) => sum + storeLabor(storeKey), 0);
      document.getElementById("ownerShortage").textContent = String(shortages.length);
      document.getElementById("ownerIssues").textContent = String(issues.length);
      document.getElementById("ownerSupport").textContent = String(supportCount("all"));
      document.getElementById("ownerLabor").textContent = `¥${totalLabor.toLocaleString()}`;

      document.getElementById("ownerStoreBody").innerHTML = storeOrder.map(storeKey => {
        const storeShortages = collectShortageDisplayRows(storeKey).length;
        const storeIssues = collectIssues(storeKey).length;
        return `
          <tr class="${storeShortages || storeIssues ? "warn-row" : ""}">
            <td>${stores[storeKey].name}</td>
            <td><span class="tag ${storeShortages ? "bad" : "ok"}">${storeShortages}</span></td>
            <td><span class="tag ${storeIssues ? "warn" : "ok"}">${storeIssues}</span></td>
            <td>${supportCount(storeKey)}</td>
            <td>¥${storeLabor(storeKey).toLocaleString()}</td>
          </tr>
        `;
      }).join("");

      const priority = [
        ...shortages.slice(0, 3).map(row => `${dateLabel(row.date)} ${stores[row.storeKey].name} 不足${row.shortage}`),
        ...issues.slice(0, 2).map(issue => `${dateLabel(issue.date)} ${issue.target}: ${issue.message}`)
      ];
      document.getElementById("ownerPriority").innerHTML = priority.length
        ? priority.map(item => `<div class="person"><span>${item}</span></div>`).join("")
        : `<span class="tag ok">優先対応なし</span>`;
    }

    function renderStaff() {
      const grid = document.getElementById("staffGrid");
      const staffSearch = document.getElementById("staffSearch");
      const staffStoreFilter = document.getElementById("staffStoreFilter");
      const staffTagFilter = document.getElementById("staffTagFilter");
      const query = ((staffSearch && staffSearch.value) || "").trim().toLowerCase();
      const storeFilter = (staffStoreFilter && staffStoreFilter.value) || "all";
      const tagFilter = (staffTagFilter && staffTagFilter.value) || "all";
      const filtered = staff.filter(person => {
        const text = `${person.name} ${person.tags.join(" ")} ${person.times.join(" ")}`.toLowerCase();
        if (query && !text.includes(query)) return false;
        if (storeFilter !== "all" && !person.stores.includes(storeFilter)) return false;
        if (tagFilter !== "all" && !person.tags.some(tag => tag.includes(tagFilter))) return false;
        return true;
      });
      grid.innerHTML = filtered.map(person => `
        <div class="staff-card">
          <strong>${canonicalStaffName(person.name)}</strong>
          <div class="muted">${person.stores.map(key => stores[key].name).join(" / ")}</div>
          <div class="pill-row">
            ${isInactiveStaff(person) ? `<span class="tag bad">自動配置停止</span>` : ""}
            ${person.tags.map(tag => `<span class="tag ${person.support || isInactiveStaff(person) ? "warn" : ""}">${tag}</span>`).join("")}
          </div>
          <div class="reason">曜日: ${(person.days || []).join("、") || "全曜日"}</div>
          <div class="reason">対応時間: ${person.times.join("、")}</div>
          <div class="reason">希望休: ${(availability[canonicalStaffName(person.name)] || []).join("、") || "なし"}</div>
          <div class="reason">有給: ${(paidLeave[canonicalStaffName(person.name)] || []).join("、") || "なし"}</div>
          <div class="reason">急遽休み: ${(emergencyAbsences[canonicalStaffName(person.name)] || []).join("、") || "なし"}</div>
          <div class="status-row">
            <button class="btn small" type="button" data-edit-staff="${canonicalStaffName(person.name)}">編集</button>
            <button class="btn small" type="button" data-remove-staff="${canonicalStaffName(person.name)}">削除</button>
          </div>
        </div>
      `).join("") || `<div class="muted">該当スタッフなし</div>`;
      grid.querySelectorAll("[data-edit-staff]").forEach(btn => {
        btn.addEventListener("click", () => {
          openStaffEditor(btn.dataset.editStaff);
        });
      });
      grid.querySelectorAll("[data-remove-staff]").forEach(btn => {
        btn.addEventListener("click", () => {
          const name = btn.dataset.removeStaff;
          const index = staff.findIndex(item => item.name === name);
          if (index >= 0) staff.splice(index, 1);
          delete availability[name];
          delete paidLeave[name];
          delete emergencyAbsences[name];
          removeStaffFromSchedule(name);
          renderAll();
          showToast(`${name}を削除した`);
        });
      });
    }

    function renderAvailability() {
      const select = document.getElementById("availabilityStaff");
      const current = select.value;
      syncSelectOptions(select, staff.map(person => `<option value="${person.name}">${person.name}</option>`).join(""), current);
      const list = document.getElementById("availabilityList");
      list.innerHTML = staff.map(person => {
        const name = canonicalStaffName(person.name);
        return `
        <div class="staff-card">
          <strong>${name}</strong>
          <div class="reason">希望休</div>
          <div class="pill-row">
            ${(availability[name] || []).map(dateIso => `
              <button class="btn small" type="button" data-remove-availability="${name}|${dateIso}">${dateIso} を削除</button>
            `).join("") || `<span class="muted">希望休なし</span>`}
          </div>
          <div class="reason">有給</div>
          <div class="pill-row">
            ${(paidLeave[name] || []).map(dateIso => `
              <button class="btn small" type="button" data-remove-paid-leave="${name}|${dateIso}">${dateIso} を削除</button>
            `).join("") || `<span class="muted">有給なし</span>`}
          </div>
          <div class="reason">急遽休み</div>
          <div class="pill-row">
            ${(emergencyAbsences[name] || []).map(dateIso => `
              <button class="btn small" type="button" data-remove-emergency-absence="${name}|${dateIso}">${dateIso} を削除</button>
            `).join("") || `<span class="muted">急遽休みなし</span>`}
          </div>
        </div>
      `;
      }).join("");
      list.querySelectorAll("[data-remove-availability]").forEach(btn => {
        btn.addEventListener("click", () => {
          const [name, dateIso] = btn.dataset.removeAvailability.split("|");
          availability[name] = (availability[name] || []).filter(item => item !== dateIso);
          renderAll();
        });
      });
      list.querySelectorAll("[data-remove-paid-leave]").forEach(btn => {
        btn.addEventListener("click", () => {
          const [name, dateIso] = btn.dataset.removePaidLeave.split("|");
          paidLeave[name] = (paidLeave[name] || []).filter(item => item !== dateIso);
          renderAll();
        });
      });
      list.querySelectorAll("[data-remove-emergency-absence]").forEach(btn => {
        btn.addEventListener("click", () => {
          const [name, dateIso] = btn.dataset.removeEmergencyAbsence.split("|");
          emergencyAbsences[name] = (emergencyAbsences[name] || []).filter(item => item !== dateIso);
          renderAll();
        });
      });
    }

    function renderMetrics() {
      document.getElementById("metricPeriod").textContent = periodLabel();
      document.getElementById("metricShortage").textContent = String(collectShortageGroupCount("all"));
      document.getElementById("metricStaff").textContent = String(staff.length);
    }

    function syncSelectOptions(select, html, preferredValue = "") {
      if (!select) return;
      if (document.activeElement === select) return;
      const current = preferredValue || select.value;
      if (select.innerHTML !== html) select.innerHTML = html;
      if ([...select.options].some(option => option.value === current)) {
        select.value = current;
      }
    }

    function emergencyCandidateRows() {
      const name = canonicalStaffName(document.getElementById("homeEmergencyStaff").value);
      const dateIso = document.getElementById("homeEmergencyDate").value || state.today;
      const storeKey = document.getElementById("homeEmergencyStore").value;
      const slot = document.getElementById("homeEmergencySlot").value;
      const options = generationOptions({ respectCapacity: false, allowSupport: true });
      return candidatesFor(storeKey, slot, dateIso, options)
        .filter(item => item.person.name !== name)
        .filter(item => !isUnavailable(item.person.name, dateIso))
        .filter(item => !isPersonAssignedOnDate(dateIso, item.person.name))
        .slice(0, 6);
    }

    function renderHomeEmergency() {
      const staffSelect = document.getElementById("homeEmergencyStaff");
      const dateInput = document.getElementById("homeEmergencyDate");
      const storeSelect = document.getElementById("homeEmergencyStore");
      const slotSelect = document.getElementById("homeEmergencySlot");
      const list = document.getElementById("homeEmergencyCandidates");
      if (!staffSelect || !dateInput || !storeSelect || !slotSelect || !list) return;

      const currentStaff = canonicalStaffName(staffSelect.value);
      const staffOptions = staff
        .filter(person => !person.support && !isInactiveStaff(person))
        .map(person => `<option value="${person.name}">${person.name}</option>`)
        .join("");
      syncSelectOptions(staffSelect, staffOptions, currentStaff);
      if (!dateInput.value) dateInput.value = state.today;

      const name = canonicalStaffName(staffSelect.value);
      const dateIso = dateInput.value;
      const storeKey = storeSelect.value;
      const slot = slotSelect.value;
      const existing = readCell(dateIso, storeKey, slot).filter(item => item.name === name);
      const candidates = emergencyCandidateRows();
      list.innerHTML = `
        <div class="muted">
          ${name}を${dateIso} ${stores[storeKey].name} ${slot}で急遽休みにする想定。
          ${existing.length ? "この枠に配置あり。" : "この枠には未配置。"}
        </div>
        ${candidates.map(({ person, score, time }) => `
          <div class="candidate">
            <div>
              <strong>${person.name}</strong>
              <div class="reason">${time || pickTime(person, slot, dateIso, storeKey)} / ${person.tags.join(" / ")} / 適合 ${score}</div>
            </div>
            <button class="btn small ${person.support ? "" : "primary"}" type="button" data-emergency-add="${person.name}">入れる</button>
          </div>
        `).join("") || `<div class="muted">候補が見つかりません。応援マルチか条件修正が必要。</div>`}
      `;
      list.querySelectorAll("[data-emergency-add]").forEach(btn => {
        btn.addEventListener("click", () => {
          const person = findStaff(btn.dataset.emergencyAdd);
          if (!person) return;
          const time = pickTime(person, slot, dateIso, storeKey, {
            respectCapacity: false,
            allowSupport: true,
            allowPartialOverlap: false,
            requireFullSlotCoverage: true,
            targetSlot: slot,
            enforceCoreWorkLimit: true,
            loadMap: buildLoadMap()
          });
          makeRoomForCore(dateIso, storeKey, person, time, {
            respectCapacity: true,
            preventDoubleBooking: true,
            allowPartialOverlap: false,
            requireFullSlotCoverage: true,
            targetSlot: slot,
            enforceCoreWorkLimit: true,
            loadMap: buildLoadMap()
          });
          const added = addShiftToDay(dateIso, storeKey, person, time, {
            respectCapacity: true,
            preventDoubleBooking: true,
            allowSupport: true,
            avoidLongStreak: true,
        maxConsecutiveWorkDays: 5,
        strictConsecutiveLimit: true,
        allowPartialOverlap: false,
            requireFullSlotCoverage: true,
            targetSlot: slot,
            enforceCoreWorkLimit: true,
            loadMap: buildLoadMap()
          });
          renderAll();
          showToast(added ? `${stores[storeKey].name} ${slot} に ${person.name} を入れた` : "この候補は過剰なしでは入れられない");
        });
      });
    }

    function applyHomeEmergencyAbsence() {
      const name = canonicalStaffName(document.getElementById("homeEmergencyStaff").value);
      const dateIso = document.getElementById("homeEmergencyDate").value || state.today;
      if (!emergencyAbsences[name]) emergencyAbsences[name] = [];
      if (!emergencyAbsences[name].includes(dateIso)) emergencyAbsences[name].push(dateIso);
      const removed = removePersonFromDate(dateIso, name);
      renderAll();
      showToast(removed ? `${name}を${dateIso}の急遽休みにしてシフトから外した` : `${name}を${dateIso}の急遽休みにした`);
    }

    function renderActiveView(view = state.currentView) {
      if (view === "dashboard") {
        renderMetrics();
        renderHomeEmergency();
        return;
      }
      if (view === "monthly") {
        renderRequirements();
        renderMonthlyTable();
        renderSelectedDetail();
        return;
      }
      if (view === "weeklyClose") {
        renderWeeklyClose();
        return;
      }
      if (view === "rieMaster") {
        renderRieMaster();
        return;
      }
      if (view === "paperImport") {
        renderPaperImport();
        return;
      }
      if (view === "teacher") {
        renderTeacherLearning();
        return;
      }
      if (view === "today") {
        renderToday();
        return;
      }
      if (view === "owner") {
        renderOwnerDashboard();
        return;
      }
      if (view === "finished") {
        renderFinished();
        return;
      }
      if (view === "shortage") {
        renderShortage();
        return;
      }
      if (view === "issues") {
        renderIssues();
        return;
      }
      if (view === "availability") {
        renderAvailability();
        return;
      }
      if (view === "staff") {
        renderStaff();
        return;
      }
      if (view === "data") {
        renderDataBox();
        return;
      }
      renderHomeEmergency();
    }

    function renderAll() {
      const steps = [
        ["名前正規化", normalizeSavedNames],
        ["店舗割当チェック", sanitizeInvalidStoreAssignments],
        ["ホーム指標", renderMetrics],
        ["現在画面", () => renderActiveView(state.currentView)],
        ["保存", persistState]
      ];
      steps.forEach(([label, fn]) => {
        try {
          fn();
        } catch (error) {
          reportError(label, error);
        }
      });
    }

    function switchView(view) {
      state.currentView = view;
      Object.keys(dom.views).forEach(key => {
        const element = dom.views[key];
        if (element) element.classList.toggle("hidden", key !== view);
      });
      document.querySelectorAll("[data-view]").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.view === view);
      });
      renderActiveView(view);
    }

    function syncPeriodFromHome() {
      state.month = document.getElementById("homeMonth").value;
      state.startDay = Number(document.getElementById("homeStartDay").value);
      document.getElementById("monthInput").value = state.month;
      document.getElementById("startDayInput").value = String(state.startDay);
      renderAll();
    }

    function syncPeriodFromMonthly() {
      state.month = document.getElementById("monthInput").value;
      state.startDay = Number(document.getElementById("startDayInput").value);
      document.getElementById("homeMonth").value = state.month;
      document.getElementById("homeStartDay").value = String(state.startDay);
      renderAll();
    }

    function exportCsv() {
      const storeKey = state.selectedStore;
      const rows = [["date", "dow", "store", "slot", "required", "assigned", "shortage"]];
      periodDates().forEach(date => {
        const dateIso = iso(date);
        slots.forEach(slot => {
          const people = ensureCell(dateIso, storeKey, slot);
          const req = requirement(storeKey, slot);
          rows.push([
            dateIso,
            dowLabel(date),
            stores[storeKey].name,
            slot,
            req,
            people.map(person => `${person.name} ${person.time}`).join(" / "),
            Math.max(0, req - people.length)
          ]);
        });
      });
      const csv = rows.map(row => row.map(value => `"${String(value).split('"').join('""')}"`).join(",")).join("\n");
      const blob = new Blob(["\ufeff" + csv], { type: "text/csv;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `makotsu-shift-${stores[storeKey].name}-${state.month}.csv`;
      link.click();
      URL.revokeObjectURL(url);
    }

    function printFinishedMonth() {
      document.body.classList.remove("weekly-print-active");
      document.body.classList.add("monthly-print-active");
      window.print();
      window.setTimeout(() => document.body.classList.remove("monthly-print-active"), 300);
    }

    function printFinishedWeek() {
      document.body.classList.remove("monthly-print-active");
      document.body.classList.add("weekly-print-active");
      window.print();
      window.setTimeout(() => document.body.classList.remove("weekly-print-active"), 300);
    }

    function setWishBusy(active, label = "") {
      state.wishBusy = !!active;
      const ids = ["generateWeeklyPureBtn", "generateAllWeeklyPureBtn", "generateWeeklyBtn", "generateAllWeeklyBtn", "generateWeeklyMasterBtn", "clearWeeklyBtn"];
      ids.forEach(id => {
        const button = document.getElementById(id);
        if (button) button.disabled = !!active;
      });
      const status = document.getElementById("jsStatus");
      if (status) {
        status.className = active ? "status-bar fallback" : "status-bar ready";
        status.textContent = active ? `${label} 実行中… 少し待って。画面は固まって見えても処理中です` : "操作準備完了";
      }
    }

    function runHeavyWeeklyAction(label, handler) {
      if (state.wishBusy) {
        showToast("処理中。少し待って");
        return;
      }
      setWishBusy(true, label);
      showToast(`${label}を開始`);
      window.setTimeout(() => {
        const started = performance && performance.now ? performance.now() : Date.now();
        try {
          handler();
          const ended = performance && performance.now ? performance.now() : Date.now();
          const sec = Math.max(0.1, (ended - started) / 1000).toFixed(1);
          const status = document.getElementById("jsStatus");
          if (status) {
            status.className = "status-bar ready";
            status.textContent = `${label} 完了（${sec}秒）`;
          }
        } catch (error) {
          reportError(label, error);
          showToast(`${label}で止まりました`);
        } finally {
          setWishBusy(false);
        }
      }, 50);
    }

    function showToast(message) {
      dom.toast.textContent = message;
      dom.toast.classList.add("show");
      window.setTimeout(() => dom.toast.classList.remove("show"), 1800);
    }

    function reportError(label, error) {
      console.error(label, error);
      const status = document.getElementById("jsStatus");
      if (status) {
        status.className = "status-bar warn";
        status.textContent = `${label}でエラー。ほかの操作は継続できます`;
      }
    }

    function noMasterV3704RecoverUi(label, error) {
      try {
        state.wishBusy = false;
        setWishBusy(false);
      } catch (resetError) {
        console.warn("busy reset failed", resetError);
      }

      document.querySelectorAll("button").forEach(button => {
        if (
          button.id !== "releaseSaveButton" &&
          !button.dataset.keepDisabled
        ) {
          button.disabled = false;
        }
      });

      try {
        reportError(label, error);
      } catch (reportingError) {
        console.error(label, error);
      }

      const message =
        error?.message || String(error || "不明なエラー");
      showToast(
        `${label}で停止。操作を復旧しました`
      );

      const auditNode =
        document.getElementById("workflowAuditList");
      if (auditNode) {
        auditNode.textContent =
          `エラー停止：${message}\n` +
          "操作は復旧済みです。再監査をやり直してください。";
      }
    }

    function safeRun(label, handler) {
      return (...args) => {
        try {
          const result = handler(...args);
          if (result && typeof result.then === "function") {
            return result.catch(error => {
              noMasterV3704RecoverUi(label, error);
              return undefined;
            });
          }
          return result;
        } catch (error) {
          noMasterV3704RecoverUi(label, error);
          return undefined;
        }
      };
    }

    function on(id, eventName, label, handler) {
      const element = document.getElementById(id);
      if (!element) {
        reportError(`ボタン未検出:${id}`, new Error(`missing element ${id}`));
        return;
      }
      element.addEventListener(eventName, safeRun(label || id, handler));
    }

    function onAll(selector, eventName, label, handler) {
      document.querySelectorAll(selector).forEach(element => {
        element.addEventListener(eventName, safeRun(label || selector, event => handler(event, element)));
      });
    }

    function normalizeStore(value) {
      const text = value.trim();
      if (!text) return null;
      if (["全店舗", "全部", "all"].includes(text)) return "all";
      const hit = Object.entries(stores).find(([key, store]) => (
        key === text || store.name === text || store.name.replace("ノ", "の") === text.replace("ノ", "の")
      ));
      return hit ? hit[0] : null;
    }

    function splitValues(value) {
      return String(value || "")
        .split(/[、,/／\\s]+/)
        .map(item => item.trim())
        .filter(Boolean);
    }

    function parseStores(value) {
      const parsed = splitValues(value).map(normalizeStore).filter(Boolean);
      if (parsed.includes("all") || !parsed.length) return [...storeOrder];
      return [...new Set(parsed)];
    }

    function parseDays(value) {
      const values = splitValues(value);
      if (!values.length || values.some(item => ["全曜日", "毎日", "all"].includes(item))) {
        return ["月", "火", "水", "木", "金", "土", "日"];
      }
      const map = {
        月曜: "月", 火曜: "火", 水曜: "水", 木曜: "木", 金曜: "金", 土曜: "土", 日曜: "日",
        月曜日: "月", 火曜日: "火", 水曜日: "水", 木曜日: "木", 金曜日: "金", 土曜日: "土", 日曜日: "日"
      };
      return [...new Set(values.map(item => map[item] || item).filter(item => ["月", "火", "水", "木", "金", "土", "日"].includes(item)))];
    }

    function slotsFromTimes(times) {
      return [...new Set(slots.filter(slot => times.some(time => coversSlot(time, slot))))];
    }

    function upsertStaff(person) {
      if (!person.name) return false;
      const clean = {
        name: canonicalStaffName(person.name),
        stores: person.stores && person.stores.length ? person.stores : [...storeOrder],
        days: person.days && person.days.length ? person.days : ["月", "火", "水", "木", "金", "土", "日"],
        times: person.times && person.times.length ? person.times : ["9-18"],
        tags: person.tags && person.tags.length ? person.tags : ["未分類"],
        support: Boolean(person.support),
        inactive: Boolean(person.inactive) || (person.tags || []).some(tag => ["解雇", "退職", "自動配置停止"].some(word => String(tag).includes(word)))
      };
      clean.slots = slotsFromTimes(clean.times);
      if (!clean.slots.length) clean.slots = [...slots];
      const index = staff.findIndex(item => item.name === clean.name);
      if (index >= 0) staff[index] = clean;
      else staff.push(clean);
      if (!availability[clean.name]) availability[clean.name] = [];
      if (!paidLeave[clean.name]) paidLeave[clean.name] = [];
      if (!emergencyAbsences[clean.name]) emergencyAbsences[clean.name] = [];
      return true;
    }

    function findStaffByName(name) {
      const target = canonicalStaffName(name);
      return staff.find(person => canonicalStaffName(person.name) === target);
    }

    function moveDateMapEntries(map, oldName, newName) {
      const oldKey = canonicalStaffName(oldName);
      const newKey = canonicalStaffName(newName);
      if (!oldKey || !newKey || oldKey === newKey || !map[oldKey]) return;
      map[newKey] = [...new Set([...(map[newKey] || []), ...map[oldKey]])];
      delete map[oldKey];
    }

    function renameStaffReferences(oldName, newName) {
      const oldKey = canonicalStaffName(oldName);
      const newKey = canonicalStaffName(newName);
      if (!oldKey || !newKey || oldKey === newKey) return;
      Object.values(state.schedule).forEach(storeMap => {
        Object.values(storeMap).forEach(slotMap => {
          Object.keys(slotMap).forEach(slot => {
            if (!Array.isArray(slotMap[slot])) return;
            slotMap[slot].forEach(assignment => {
              if (canonicalStaffName(assignment.name) === oldKey) assignment.name = newKey;
            });
          });
        });
      });
      if (Array.isArray(state.rieMaster)) {
        state.rieMaster.forEach(row => {
          if (canonicalStaffName(row.name) === oldKey) row.name = newKey;
        });
      }
      moveDateMapEntries(availability, oldKey, newKey);
      moveDateMapEntries(paidLeave, oldKey, newKey);
      moveDateMapEntries(emergencyAbsences, oldKey, newKey);
    }

    function closeStaffEditor() {
      editingStaffName = "";
      const modal = document.getElementById("staffEditModal");
      if (modal) modal.classList.add("hidden");
    }

    function openStaffEditor(name) {
      const person = findStaffByName(name);
      if (!person) return;
      editingStaffName = canonicalStaffName(person.name);
      document.getElementById("editStaffName").value = person.name;
      document.getElementById("editStaffStores").value = (person.stores || []).map(key => stores[key]?.name || key).join("/");
      document.getElementById("editStaffDays").value = person.days && person.days.length ? person.days.join("/") : "全曜日";
      document.getElementById("editStaffTimes").value = (person.times || []).join("/");
      document.getElementById("editStaffTags").value = (person.tags || []).join("/");
      document.getElementById("editStaffSupport").value = String(Boolean(person.support));
      document.getElementById("staffEditModal").classList.remove("hidden");
      document.getElementById("editStaffName").focus();
    }

    function saveStaffEditor() {
      const oldName = editingStaffName;
      const name = canonicalStaffName(document.getElementById("editStaffName").value.trim());
      if (!oldName || !name) {
        showToast("名前が必要");
        return;
      }
      const clean = {
        name,
        stores: parseStores(document.getElementById("editStaffStores").value),
        days: parseDays(document.getElementById("editStaffDays").value),
        times: splitValues(document.getElementById("editStaffTimes").value),
        tags: splitValues(document.getElementById("editStaffTags").value),
        support: document.getElementById("editStaffSupport").value === "true",
        inactive: Boolean(findStaffByName(oldName)?.inactive)
      };
      if (!clean.times.length) clean.times = ["9-18"];
      if (!clean.tags.length) clean.tags = ["未分類"];
      clean.slots = slotsFromTimes(clean.times);
      if (!clean.slots.length) clean.slots = [...slots];
      const existingIndex = staff.findIndex(person => canonicalStaffName(person.name) === oldName);
      const duplicateIndex = staff.findIndex(person => canonicalStaffName(person.name) === name);
      if (duplicateIndex >= 0 && duplicateIndex !== existingIndex) {
        showToast("同じ名前のスタッフがいる");
        return;
      }
      if (existingIndex >= 0) staff[existingIndex] = clean;
      else staff.push(clean);
      renameStaffReferences(oldName, clean.name);
      if (!availability[clean.name]) availability[clean.name] = [];
      if (!paidLeave[clean.name]) paidLeave[clean.name] = [];
      if (!emergencyAbsences[clean.name]) emergencyAbsences[clean.name] = [];
      closeStaffEditor();
      renderAll();
      showToast(`${clean.name}の勤務条件を保存した`);
    }

    function addStaffFromForm() {
      const name = document.getElementById("newStaffName").value.trim();
      const storesValue = document.getElementById("newStaffStores").value;
      const daysValue = document.getElementById("newStaffDays").value;
      const times = splitValues(document.getElementById("newStaffTimes").value);
      const tags = splitValues(document.getElementById("newStaffTags").value);
      const support = document.getElementById("newStaffSupport").value === "true";
      if (!name) {
        showToast("名前が必要");
        return;
      }
      upsertStaff({ name, stores: parseStores(storesValue), days: parseDays(daysValue), times, tags, support });
      noMasterV3700SaveStaffMetaFromForm(name);
      ["newStaffName", "newStaffStores", "newStaffDays", "newStaffTimes", "newStaffTags", "newStaffMentors"].forEach(id => {
        document.getElementById(id).value = "";
      });
      document.getElementById("newStaffSupport").value = "false";
      renderAll();
      showToast(`${name}を追加/更新した`);
    }

    function addDateBlock(type) {
      const name = canonicalStaffName(document.getElementById("availabilityStaff").value);
      const dateIso = document.getElementById("availabilityDate").value;
      const map = type === "paid" ? paidLeave : type === "emergency" ? emergencyAbsences : availability;
      const label = type === "paid" ? "有給" : type === "emergency" ? "急遽休み" : "希望休";
      if (!name || !dateIso) {
        showToast("スタッフと日付を選んで");
        return;
      }
      if (!map[name]) map[name] = [];
      if (!map[name].includes(dateIso)) map[name].push(dateIso);
      const removed = removePersonFromDate(dateIso, name);
      renderAll();
      showToast(removed ? `${name}の${dateIso}を${label}にしてシフトから外した` : `${name}の${dateIso}を${label}にした`);
    }

    function importStaffBulk() {
      const text = document.getElementById("staffBulkBox").value.trim();
      if (!text) {
        showToast("取り込むスタッフがない");
        return;
      }
      let count = 0;
      text.split(/\n+/).forEach((line, index) => {
        const trimmed = line.trim();
        if (!trimmed) return;
        if (index === 0 && trimmed.includes("名前") && trimmed.includes("店舗")) return;
        const [name, storeText, dayText, timeText, tagText, supportText] = trimmed.split(",").map(item => (item || "").trim());
        if (upsertStaff({
          name,
          stores: parseStores(storeText),
          days: parseDays(dayText),
          times: splitValues(timeText),
          tags: splitValues(tagText),
          support: ["1", "true", "応援", "応援マルチ"].includes(String(supportText).toLowerCase())
        })) count += 1;
      });
      renderAll();
      showToast(`${count}人を取り込んだ`);
    }

    function exportStaffBulk() {
      const lines = [
        "名前,店舗,曜日,対応時間,タグ,応援",
        ...staff.map(person => [
          person.name,
          person.stores.map(key => stores[key].name).join("/"),
          (person.days || []).join("/"),
          person.times.join("/"),
          person.tags.join("/"),
          person.support ? "1" : "0"
        ].join(","))
      ];
      document.getElementById("staffBulkBox").value = lines.join("\n");
    }

    function removeStaffFromSchedule(name) {
      const targetName = canonicalStaffName(name);
      Object.values(state.schedule).forEach(storeMap => {
        Object.values(storeMap).forEach(slotMap => {
          Object.keys(slotMap).forEach(slot => {
            slotMap[slot] = slotMap[slot].filter(person => canonicalStaffName(person.name) !== targetName);
          });
        });
      });
    }

    function normalizeSavedNames() {
      staff.forEach(person => {
        person.name = canonicalStaffName(person.name);
      });
      const uniqueStaff = new Map();
      staff.forEach(person => {
        const existing = uniqueStaff.get(person.name);
        if (!existing) {
          uniqueStaff.set(person.name, person);
          return;
        }
        existing.stores = [...new Set([...(existing.stores || []), ...(person.stores || [])])];
        existing.days = [...new Set([...(existing.days || []), ...(person.days || [])])];
        existing.times = [...new Set([...(existing.times || []), ...(person.times || [])])];
        existing.tags = [...new Set([...(existing.tags || []), ...(person.tags || [])])];
        existing.support = existing.support || person.support;
        existing.slots = slotsFromTimes(existing.times);
      });
      staff.length = 0;
      uniqueStaff.forEach(person => staff.push(person));
      enforceKnownStaffCorrections();

      Object.values(state.schedule).forEach(storeMap => {
        Object.values(storeMap).forEach(slotMap => {
          Object.keys(slotMap).forEach(slot => {
            if (!Array.isArray(slotMap[slot])) return;
            slotMap[slot].forEach(assignment => {
              assignment.name = canonicalStaffName(assignment.name);
            });
          });
        });
      });

      Object.entries(staffNameAliases).forEach(([oldName, newName]) => {
        if (availability[oldName]) {
          availability[newName] = [...new Set([...(availability[newName] || []), ...availability[oldName]])];
          delete availability[oldName];
        }
        if (paidLeave[oldName]) {
          paidLeave[newName] = [...new Set([...(paidLeave[newName] || []), ...paidLeave[oldName]])];
          delete paidLeave[oldName];
        }
        if (emergencyAbsences[oldName]) {
          emergencyAbsences[newName] = [...new Set([...(emergencyAbsences[newName] || []), ...emergencyAbsences[oldName]])];
          delete emergencyAbsences[oldName];
        }
      });
      if (Array.isArray(state.rieMaster)) {
        state.rieMaster.forEach(row => {
          row.name = canonicalStaffName(row.name);
        });
      }
      staff.forEach(person => {
        if (!availability[person.name]) availability[person.name] = [];
        if (!paidLeave[person.name]) paidLeave[person.name] = [];
        if (!emergencyAbsences[person.name]) emergencyAbsences[person.name] = [];
      });
      applySeededAvailability();
    }

    function serializeState() {
      return {
        month: state.month,
        startDay: state.startDay,
        today: state.today,
        selectedStore: state.selectedStore,
        weeklyCloseStore: state.weeklyCloseStore,
        selectedWeekStart: state.selectedWeekStart,
        appVersion: "beta4.10.36.11",
        schedule: state.schedule,
        rieMaster: state.rieMaster || [],
        riePaperCells: state.riePaperCells || [],
        teacherPaperCells: state.teacherPaperCells || [],
        staff,
        requirements: storeOrder.reduce((map, storeKey) => {
          map[storeKey] = stores[storeKey].requirements;
          return map;
        }, {}),
        availability,
        paidLeave,
        emergencyAbsences
      };
    }

    function applySerialized(payload) {
      if (!payload || typeof payload !== "object") return false;
      if (payload.month) state.month = payload.month;
      if (payload.startDay) state.startDay = Number(payload.startDay);
      if (payload.today) state.today = payload.today;
      if (payload.selectedStore) state.selectedStore = payload.selectedStore;
      if (payload.weeklyCloseStore) state.weeklyCloseStore = payload.weeklyCloseStore;
      if (payload.selectedWeekStart) state.selectedWeekStart = payload.selectedWeekStart;
      if (payload.schedule) state.schedule = payload.schedule;
      if (Array.isArray(payload.rieMaster)) {
        state.rieMaster = payload.rieMaster.map(normalizeRieEntry).filter(Boolean);
      }
      if (Array.isArray(payload.riePaperCells)) {
        state.riePaperCells = payload.riePaperCells.map(normalizePaperCell).filter(Boolean);
      }
      if (Array.isArray(payload.teacherPaperCells)) {
        state.teacherPaperCells = payload.teacherPaperCells.map(cell => normalizePaperCell({ ...cell, source: "teacherCell" })).filter(Boolean);
      }
      if (Array.isArray(payload.staff) && payload.staff.length) {
        staff.length = 0;
        payload.staff.forEach(person => upsertStaff(person));
      }
      if (payload.requirements) {
        storeOrder.forEach(storeKey => {
          if (payload.requirements[storeKey]) stores[storeKey].requirements = payload.requirements[storeKey];
        });
      }
      if (payload.availability) {
        Object.keys(availability).forEach(name => delete availability[name]);
        Object.entries(payload.availability).forEach(([name, dates]) => {
          const cleanName = canonicalStaffName(name);
          availability[cleanName] = [...new Set([...(availability[cleanName] || []), ...(Array.isArray(dates) ? dates : [])])];
        });
      }
      if (payload.paidLeave) {
        Object.keys(paidLeave).forEach(name => delete paidLeave[name]);
        Object.entries(payload.paidLeave).forEach(([name, dates]) => {
          const cleanName = canonicalStaffName(name);
          paidLeave[cleanName] = [...new Set([...(paidLeave[cleanName] || []), ...(Array.isArray(dates) ? dates : [])])];
        });
      }
      if (payload.emergencyAbsences) {
        Object.keys(emergencyAbsences).forEach(name => delete emergencyAbsences[name]);
        Object.entries(payload.emergencyAbsences).forEach(([name, dates]) => {
          const cleanName = canonicalStaffName(name);
          emergencyAbsences[cleanName] = [...new Set([...(emergencyAbsences[cleanName] || []), ...(Array.isArray(dates) ? dates : [])])];
        });
      }
      normalizeSavedNames();
      sanitizeInvalidStoreAssignments();
      document.getElementById("homeMonth").value = state.month;
      document.getElementById("monthInput").value = state.month;
      document.getElementById("homeStartDay").value = String(state.startDay);
      document.getElementById("startDayInput").value = String(state.startDay);
      document.getElementById("storeInput").value = state.selectedStore;
      const weeklyStore = document.getElementById("weeklyCloseStore");
      if (weeklyStore) weeklyStore.value = state.weeklyCloseStore || state.selectedStore;
      document.getElementById("todayInput").value = state.today;
      return true;
    }

    function persistState() {
      if (!state.ready) return;
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(serializeState()));
      } catch (error) {
        console.warn("save failed", error);
      }
    }

    function readShiftArchives() {
      try {
        const raw = localStorage.getItem(ARCHIVE_KEY);
        const rows = raw ? JSON.parse(raw) : [];
        return Array.isArray(rows) ? rows : [];
      } catch (error) {
        console.warn("archive read failed", error);
        return [];
      }
    }

    function writeShiftArchives(rows) {
      localStorage.setItem(ARCHIVE_KEY, JSON.stringify(rows));
    }

    function archiveDefaultName() {
      const weekDatesValue = selectedWeekDates();
      const storeName = stores[state.weeklyCloseStore || state.selectedStore]?.name || "全店舗";
      return `${periodLabel()} / ${weekLabel(weekDatesValue)} / ${storeName}`;
    }

    function saveShiftArchive() {
      const input = document.getElementById("archiveNameInput");
      const name = (input && input.value.trim()) || archiveDefaultName();
      const archives = readShiftArchives();
      const now = new Date();
      archives.unshift({
        id: `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
        name,
        createdAt: now.toISOString(),
        label: `${periodLabel()} / ${weekLabel(selectedWeekDates())}`,
        snapshot: serializeState()
      });
      writeShiftArchives(archives.slice(0, 30));
      if (input) input.value = "";
      renderArchiveList();
      showToast(`履歴保存: ${name}`);
    }

    function loadShiftArchive(id) {
      const archive = readShiftArchives().find(row => row.id === id);
      if (!archive || !archive.snapshot) {
        showToast("履歴が見つからない");
        return;
      }
      if (applySerialized(archive.snapshot)) {
        renderAll();
        showToast(`履歴を読み込み: ${archive.name}`);
      }
    }

    function deleteShiftArchive(id) {
      const archives = readShiftArchives();
      const next = archives.filter(row => row.id !== id);
      writeShiftArchives(next);
      renderArchiveList();
      showToast("履歴を削除した");
    }

    function renderArchiveList() {
      const list = document.getElementById("archiveList");
      if (!list) return;
      const archives = readShiftArchives();
      list.innerHTML = archives.map(row => {
        const date = row.createdAt ? new Date(row.createdAt) : null;
        const created = date && !Number.isNaN(date.getTime())
          ? `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}`
          : "-";
        return `
          <div class="staff-card">
            <strong>${row.name}</strong>
            <div class="reason">${row.label || "-"} / 保存 ${created}</div>
            <div class="status-row">
              <button class="btn small primary" type="button" data-load-archive="${row.id}">読み込む</button>
              <button class="btn small" type="button" data-delete-archive="${row.id}">削除</button>
            </div>
          </div>
        `;
      }).join("") || `<div class="muted">保存済みシフト履歴なし</div>`;
      list.querySelectorAll("[data-load-archive]").forEach(btn => {
        btn.addEventListener("click", () => loadShiftArchive(btn.dataset.loadArchive));
      });
      list.querySelectorAll("[data-delete-archive]").forEach(btn => {
        btn.addEventListener("click", () => deleteShiftArchive(btn.dataset.deleteArchive));
      });
    }

    function loadPersistedState() {
      try {
        const currentRaw = localStorage.getItem(STORAGE_KEY);
        if (currentRaw) return applySerialized(JSON.parse(currentRaw));
        for (const key of LEGACY_STORAGE_KEYS) {
          const raw = localStorage.getItem(key);
          if (!raw) continue;
          const payload = JSON.parse(raw);
          if (applySerialized(payload)) {
            if (state.startDay === 16) state.startDay = 1;
            if (!state.selectedWeekStart) state.selectedWeekStart = nextWeeklyCloseStartIso(state.today);
            state.weeklyCloseStore = state.weeklyCloseStore || "higashicho";
            state.schedule = {};
            state.selected = null;
            state.needsFreshGeneration = true;
            return true;
          }
        }
        return false;
      } catch (error) {
        console.warn("load failed", error);
        return false;
      }
    }

    function renderDataBox() {
      const box = document.getElementById("jsonBox");
      if (box && !box.value) box.value = JSON.stringify(serializeState(), null, 2);
      const input = document.getElementById("archiveNameInput");
      if (input && !input.value) input.placeholder = archiveDefaultName();
      renderArchiveList();
    }

    function resetSample() {
      state.schedule = {};
      state.selected = null;
      state.rieMaster = [];
      state.month = "2026-07";
      state.startDay = 1;
      state.today = "2026-07-07";
      state.selectedWeekStart = nextWeeklyCloseStartIso(state.today);
      state.weeklyCloseStore = "higashicho";
      const original = state.selectedStore;
      state.bulkGenerating = true;
      storeOrder.forEach(storeKey => {
        state.selectedStore = storeKey;
        generateMonth();
      });
      state.bulkGenerating = false;
      state.selectedStore = original || "miyanoshita";
      applySerialized(serializeState());
      renderAll();
      showToast("サンプルへ戻した");
    }



    function normalizeTimeInput(value) {
      let text = String(value || "")
        .trim()
        .replace(/[〜～~ー－―]/g, "-")
        .replace(/(\d{1,2})\s*時\s*半/g, "$1.5")
        .replace(/(\d{1,2})[:：]30/g, "$1.5")
        .replace(/(\d{1,2})[:：]00/g, "$1")
        .replace(/時/g, "")
        .replace(/分/g, "")
        .replace(/\s+/g, "");
      const formatHour = value => {
        const num = Number(value);
        if (!Number.isFinite(num)) return "";
        return Number.isInteger(num) ? String(num) : String(Math.floor(num)) + ".5";
      };
      const openStart = text.match(/^(\d{1,2}(?:\.5)?)-$/);
      if (openStart) {
        const startOnly = Number(openStart[1]);
        if (startOnly >= 21 && startOnly <= 24) text = `${formatHour(startOnly)}-6`;
      }
      const openEnd = text.match(/^-(\d{1,2}(?:\.5)?)$/);
      if (openEnd) {
        const endOnly = Number(openEnd[1]);
        if (endOnly >= 0 && endOnly <= 6) text = `22-${formatHour(endOnly)}`;
      }
      const match = text.match(/^(\d{1,2}(?:\.5)?)-(\d{1,2}(?:\.5)?)$/);
      if (!match) return "";
      const start = Number(match[1]);
      const end = Number(match[2]);
      if (!Number.isFinite(start) || !Number.isFinite(end)) return "";
      if (start < 0 || start > 30 || end < 0 || end > 30) return "";
      const normalized = `${formatHour(start)}-${formatHour(end)}`;
      const [s, e] = parseRange(normalized);
      if (e - s <= 0 || e - s > 18) return "";
      return normalized;
    }

    function two(n) {
      return String(n).padStart(2, "0");
    }

    function dateStartAbsMinutes(dateIso) {
      return new Date(`${dateIso}T00:00:00`).getTime() / 60000;
    }

    function parseTimePartsRaw(value) {
      const text = String(value || "")
        .trim()
        .replace(/(\d{1,2})[：:]30/g, "$1.5")
        .replace(/(\d{1,2})[：:]00/g, "$1")
        .replace(/[〜～~ー－―]/g, "-")
        .replace(/[：:]/g, "")
        .replace(/時/g, "")
        .replace(/\s+/g, "");
      const full = text.match(/^(\d{1,2})(?:\.(5))?-(\d{1,2})(?:\.(5))?$/);
      if (full) {
        return {
          start: Number(full[1]) + (full[2] ? 0.5 : 0),
          end: Number(full[3]) + (full[4] ? 0.5 : 0),
          openStart: false,
          openEnd: false,
          raw: text
        };
      }
      const openEnd = text.match(/^(\d{1,2})(?:\.(5))?-$/);
      if (openEnd) {
        return { start: Number(openEnd[1]) + (openEnd[2] ? 0.5 : 0), end: null, openStart: false, openEnd: true, raw: text };
      }
      const openStart = text.match(/^-(\d{1,2})(?:\.(5))?$/);
      if (openStart) {
        return { start: null, end: Number(openStart[1]) + (openStart[2] ? 0.5 : 0), openStart: true, openEnd: false, raw: text };
      }
      return null;
    }

    function absRangeForTime(dateIso, time) {
      const normalized = normalizeTimeInput(time);
      if (!normalized) return null;
      const parts = parseTimePartsRaw(normalized);
      if (!parts || parts.start === null || parts.end === null) return null;
      const base = dateStartAbsMinutes(dateIso);
      let start = parts.start * 60;
      let end = parts.end * 60;
      if (end <= start) end += 24 * 60;
      return { startAbs: base + start, endAbs: base + end, startOffset: start, endOffset: end };
    }

    function absRangeForSlot(dateIso, slot) {
      return absRangeForTime(dateIso, slot);
    }

    function formatOffsetMinutes(offset) {
      const sign = offset < 0 ? "-" : "";
      let minutes = Math.abs(Math.round(offset));
      const h = Math.floor(minutes / 60);
      const m = minutes % 60;
      const label = `${h >= 24 ? "翌" + (h - 24) : h}${m ? ":" + two(m) : ""}`;
      return sign + label;
    }

    function rangeLabelFromAbs(baseDateIso, startAbs, endAbs) {
      const base = dateStartAbsMinutes(baseDateIso);
      return `${formatOffsetMinutes(startAbs - base)}-${formatOffsetMinutes(endAbs - base)}`;
    }

    function normalizePaperName(name, storeKey) {
      let clean = String(name || "")
        .replace(/[※＊*①②③④⑤⑥⑦⑧⑨⑩]/g, "")
        .replace(/[（）()]/g, "")
        .trim();
      if (!clean) return "";
      if (clean === "店長" || clean === "店長さん") {
        if (storeKey === "higashicho") return "東町 店長（小澤）";
        if (storeKey === "ougicho") return "扇町 店長（齋藤）";
        if (storeKey === "miyanoshita") return "宮下 店長（小島）";
      }
      if (clean === "高橋") {
        if (storeKey === "higashicho") return "高橋(東町)";
        if (storeKey === "miyanoshita") return "高橋(宮下)";
      }
      if (clean === "斉藤" || clean === "斎藤") return "済藤";
      if (clean === "佐々木") return "佐々木（綾）";
      return canonicalStaffName(clean);
    }

    function extractPaperTimeToken(text) {
      const raw = String(text || "")
        .replace(/(\d{1,2})[：:]30/g, "$1.5")
        .replace(/(\d{1,2})[：:]00/g, "$1");
      const match = raw.match(/(?:\d{1,2}(?:\.5)?\s*[〜～~ー－―-]\s*\d{0,2}(?:\.5)?|[〜～~ー－―-]\s*\d{1,2}(?:\.5)?)/);
      if (!match) return { raw: "", normalized: "" };
      return {
        raw: match[0],
        normalized: match[0].replace(/[〜～~ー－―]/g, "-").replace(/\s+/g, "")
      };
    }

    function splitPaperCellPeople(content) {
      return String(content || "")
        .split(/[\/／、]/)
        .map(item => item.trim())
        .filter(Boolean);
    }

    function parsePaperCellContent(cell) {
      const slotRange = absRangeForSlot(cell.dateIso, cell.slot);
      if (!slotRange) return [];
      return splitPaperCellPeople(cell.content).map((rawItem, index) => {
        const token = extractPaperTimeToken(rawItem);
        const timeToken = token.normalized;
        const timeParts = timeToken ? parseTimePartsRaw(timeToken) : null;
        const namePart = timeToken ? rawItem.replace(token.raw, "").trim() : rawItem.trim();
        const name = normalizePaperName(namePart, cell.storeKey);
        let startAbs = null;
        let endAbs = null;
        let mode = "slot";
        let warning = "";
        if (timeParts && !timeParts.openStart && !timeParts.openEnd) {
          const base = dateStartAbsMinutes(cell.dateIso);
          let s = timeParts.start * 60;
          let e = timeParts.end * 60;
          if (e <= s) e += 24 * 60;
          startAbs = base + s;
          endAbs = base + e;
          mode = "explicit";
        } else if (timeParts && timeParts.openEnd) {
          const base = dateStartAbsMinutes(cell.dateIso);
          startAbs = base + timeParts.start * 60;
          endAbs = null;
          mode = "openEnd";
          warning = `${cell.dateIso.slice(5)} ${stores[cell.storeKey].name} ${name} ${timeToken}：終わり時刻が未確定`;
        } else if (timeParts && timeParts.openStart) {
          const base = dateStartAbsMinutes(cell.dateIso);
          let endOffset = timeParts.end * 60;
          if (endOffset <= (slotRange.startAbs - base)) endOffset += 24 * 60;
          startAbs = null;
          endAbs = base + endOffset;
          mode = "openStart";
          warning = `${cell.dateIso.slice(5)} ${stores[cell.storeKey].name} ${name} ${timeToken}：始まり時刻が未確定`;
        } else {
          startAbs = slotRange.startAbs;
          endAbs = slotRange.endAbs;
        }
        return {
          id: `${cell.id}-${index}`,
          sourceCellId: cell.id,
          dateIso: cell.dateIso,
          storeKey: cell.storeKey,
          slot: cell.slot,
          raw: rawItem,
          name,
          timeToken,
          startAbs,
          endAbs,
          mode,
          warning
        };
      }).filter(item => item.name);
    }

    function normalizePaperCell(row) {
      if (!row) return null;
      const dateIso = normalizeDateInput(row.dateIso || row.date || "");
      const storeKey = storeKeyFromLabel(row.storeKey || row.store || "");
      const slot = normalizeTimeInput(row.slot || row.timeSlot || "");
      const content = String(row.content || row.raw || "").trim();
      if (!dateIso || !storeKey || !slot || !content) return null;
      return {
        id: row.id || `paper-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
        dateIso,
        storeKey,
        slot,
        content,
        source: row.source || "paperCell"
      };
    }

    function parsePaperCellBulkLine(line) {
      const raw = String(line || "").trim();
      if (!raw || raw.startsWith("#")) return null;
      let parts = raw.split(/[\t,，]/).map(part => part.trim()).filter(Boolean);
      if (parts.length >= 4) {
        const dateIndex = parts.findIndex(part => normalizeDateInput(part));
        const storeIndex = parts.findIndex(part => storeKeyFromLabel(part));
        const slotIndex = parts.findIndex((part, index) => index !== dateIndex && normalizeTimeInput(part));
        if (dateIndex >= 0 && storeIndex >= 0 && slotIndex >= 0) {
          const used = new Set([dateIndex, storeIndex, slotIndex]);
          const content = parts.filter((_, index) => !used.has(index)).join(" / ");
          return normalizePaperCell({ dateIso: parts[dateIndex], storeKey: parts[storeIndex], slot: parts[slotIndex], content });
        }
      }
      parts = raw.split(/\s+/).map(part => part.trim()).filter(Boolean);
      if (parts.length >= 4) {
        const dateIndex = parts.findIndex(part => normalizeDateInput(part));
        const storeIndex = parts.findIndex(part => storeKeyFromLabel(part));
        const slotIndex = parts.findIndex((part, index) => index !== dateIndex && normalizeTimeInput(part));
        if (dateIndex >= 0 && storeIndex >= 0 && slotIndex >= 0) {
          const used = new Set([dateIndex, storeIndex, slotIndex]);
          const content = parts.filter((_, index) => !used.has(index)).join(" ");
          return normalizePaperCell({ dateIso: parts[dateIndex], storeKey: parts[storeIndex], slot: parts[slotIndex], content });
        }
      }
      return null;
    }

    function selectedPaperWeekStart() {
      const select = document.getElementById("paperWeekStart");
      if (select && select.value) return select.value;
      return ensureSelectedWeekStart();
    }

    function selectedPaperWeekDates() {
      const start = selectedPaperWeekStart();
      return start ? weekDates(start) : [];
    }

    function selectedPaperStore() {
      const select = document.getElementById("paperStore");
      return select && select.value ? select.value : "higashicho";
    }

    function setPaperWeekControls() {
      const weekSelect = document.getElementById("paperWeekStart");
      const storeSelect = document.getElementById("paperStore");
      if (!weekSelect || !storeSelect) return;
      const weeks = weekOptions();
      const optionsHtml = weeks.map(startDate => {
        const startIso = iso(startDate);
        const endDate = addDays(startDate, 6);
        return `<option value="${startIso}">${dateLabel(startDate)}(${dowLabel(startDate)})〜${dateLabel(endDate)}(${dowLabel(endDate)})</option>`;
      }).join("");
      syncSelectOptions(weekSelect, optionsHtml, state.selectedWeekStart || nextWeeklyCloseStartIso());
      if (weekSelect.value) state.selectedWeekStart = weekSelect.value;
      if (!storeSelect.value) storeSelect.value = state.weeklyCloseStore || "higashicho";
    }

    function paperCellsFor(dates = selectedPaperWeekDates(), storeKey = selectedPaperStore()) {
      const dateSet = new Set(dates.map(date => iso(date)));
      return (state.riePaperCells || [])
        .filter(cell => dateSet.has(cell.dateIso) && cell.storeKey === storeKey)
        .sort((a, b) => a.dateIso.localeCompare(b.dateIso) || parseRange(a.slot)[0] - parseRange(b.slot)[0]);
    }

    function mergeIntervalsByPerson(fragments) {
      const warnings = [];
      const concrete = [];
      const openEnd = [];
      const openStart = [];
      fragments.forEach(item => {
        if (item.warning) warnings.push(item.warning);
        if (item.startAbs !== null && item.endAbs !== null) concrete.push({ ...item, baseDateIso: item.dateIso });
        else if (item.startAbs !== null) openEnd.push(item);
        else if (item.endAbs !== null) openStart.push(item);
      });
      const usedStart = new Set();
      const usedEnd = new Set();
      openEnd.forEach(startItem => {
        let mate = openStart.find(endItem => !usedEnd.has(endItem.id)
          && endItem.storeKey === startItem.storeKey
          && endItem.name === startItem.name
          && endItem.endAbs > startItem.startAbs
          && endItem.endAbs - startItem.startAbs <= 18 * 60);
        if (!mate) {
          mate = concrete.find(endItem => !usedEnd.has(endItem.id)
            && endItem.storeKey === startItem.storeKey
            && endItem.name === startItem.name
            && endItem.startAbs >= startItem.startAbs
            && endItem.startAbs - startItem.startAbs <= 9 * 60
            && endItem.endAbs - startItem.startAbs <= 18 * 60);
        }
        if (mate) {
          usedStart.add(startItem.id);
          usedEnd.add(mate.id);
          concrete.push({
            ...startItem,
            endAbs: mate.endAbs,
            baseDateIso: startItem.dateIso,
            raw: `${startItem.raw} + ${mate.raw}`,
            mode: "merged"
          });
        }
      });
      openStart.forEach(endItem => {
        if (usedEnd.has(endItem.id)) return;
        const slotRange = absRangeForSlot(endItem.dateIso, endItem.slot);
        const startAbs = slotRange ? slotRange.startAbs : endItem.endAbs - 3 * 60;
        concrete.push({ ...endItem, startAbs, baseDateIso: endItem.dateIso, mode: "filledStart" });
        warnings.push(`${endItem.dateIso.slice(5)} ${stores[endItem.storeKey].name} ${endItem.name} ${endItem.timeToken}：開始を枠開始で補完`);
      });
      openEnd.forEach(startItem => {
        if (usedStart.has(startItem.id)) return;
        const slotRange = absRangeForSlot(startItem.dateIso, startItem.slot);
        const endAbs = slotRange && slotRange.endAbs > startItem.startAbs ? slotRange.endAbs : startItem.startAbs + 6 * 60;
        concrete.push({ ...startItem, endAbs, baseDateIso: startItem.dateIso, mode: "filledEnd" });
        warnings.push(`${startItem.dateIso.slice(5)} ${stores[startItem.storeKey].name} ${startItem.name} ${startItem.timeToken}：終了を枠終端で補完`);
      });
      const groups = new Map();
      concrete.forEach(item => {
        if (usedEnd.has(item.id) && item.mode !== "merged") return;
        const key = `${item.storeKey}|${item.name}|${item.baseDateIso || item.dateIso}`;
        if (!groups.has(key)) groups.set(key, []);
        groups.get(key).push(item);
      });
      const rows = [];
      groups.forEach(items => {
        items.sort((a, b) => a.startAbs - b.startAbs || a.endAbs - b.endAbs);
        let active = null;
        items.forEach(item => {
          if (!active) active = { ...item };
          else if (item.startAbs <= active.endAbs) {
            active.endAbs = Math.max(active.endAbs, item.endAbs);
            active.raw = `${active.raw} / ${item.raw}`;
          } else {
            rows.push(active);
            active = { ...item };
          }
        });
        if (active) rows.push(active);
      });
      const unified = rows
        .filter(row => row.endAbs > row.startAbs)
        .map(row => ({
          dateIso: row.baseDateIso || row.dateIso,
          storeKey: row.storeKey,
          name: row.name,
          time: rangeLabelFromAbs(row.baseDateIso || row.dateIso, row.startAbs, row.endAbs).replace(/翌/g, "24+").replace(/24\+0/g, "24"),
          startAbs: row.startAbs,
          endAbs: row.endAbs,
          raw: row.raw,
          source: "paperCell35"
        }))
        .map(row => {
          // 表示用の「翌6」を保存用の「24-6」形式に戻す。
          const base = dateStartAbsMinutes(row.dateIso);
          const startHour = (row.startAbs - base) / 60;
          const endHour = (row.endAbs - base) / 60;
          const startLabel = Number.isInteger(startHour) ? String(startHour) : String(Math.floor(startHour)) + ".5";
          const endLabelRaw = Number.isInteger(endHour) ? String(endHour) : String(Math.floor(endHour)) + ".5";
          const endLabel = Number(endLabelRaw) > 24 ? String(Number(endLabelRaw) - 24) : endLabelRaw;
          return { ...row, time: `${startLabel}-${endLabel}` };
        })
        .sort((a, b) => a.dateIso.localeCompare(b.dateIso)
          || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
          || a.startAbs - b.startAbs
          || a.name.localeCompare(b.name, "ja"));
      return { unified, warnings: [...new Set(warnings)] };
    }

    function integratePaperCells(cells = paperCellsFor()) {
      const fragments = [];
      cells.forEach(cell => {
        fragments.push(...parsePaperCellContent(cell));
      });
      return mergeIntervalsByPerson(fragments);
    }

    function importPaperCellsBulk() {
      const box = document.getElementById("paperCellBulkBox");
      const text = box ? box.value.trim() : "";
      if (!text) {
        showToast("取り込む紙セルがない");
        return;
      }
      let added = 0;
      let failed = 0;
      const failedLines = [];
      const cells = [];
      text.split(/\n+/).forEach((line, index) => {
        const cell = parsePaperCellBulkLine(line);
        if (cell) {
          cells.push(cell);
          added += 1;
        } else {
          failed += 1;
          if (String(line || "").trim()) failedLines.push(`${index + 1}: ${String(line).trim()}`);
        }
      });
      state.riePaperCells = state.riePaperCells || [];
      cells.forEach(cell => {
        const key = `${cell.dateIso}|${cell.storeKey}|${cell.slot}|${cell.content}`;
        const exists = state.riePaperCells.some(existing => `${existing.dateIso}|${existing.storeKey}|${existing.slot}|${existing.content}` === key);
        if (!exists) state.riePaperCells.push(cell);
      });
      if (box && added && !failed) box.value = "";
      renderPaperImport();
      persistState();
      const suffix = failed ? ` / 失敗${failed}行（例: ${failedLines.slice(0, 2).join(" / ")}）` : "";
      showToast(`紙セル ${added}件取り込み${suffix}`);
    }

    function clearPaperCellsWeek() {
      const dates = selectedPaperWeekDates();
      const storeKey = selectedPaperStore();
      const dateSet = new Set(dates.map(date => iso(date)));
      const before = (state.riePaperCells || []).length;
      state.riePaperCells = (state.riePaperCells || []).filter(cell => !(dateSet.has(cell.dateIso) && cell.storeKey === storeKey));
      const removed = before - state.riePaperCells.length;
      renderPaperImport();
      persistState();
      showToast(`紙セル ${removed}件を削除した`);
    }

    function applyPaperUnifiedToRieMaster() {
      const dates = selectedPaperWeekDates();
      const storeKey = selectedPaperStore();
      const { unified, warnings } = integratePaperCells(paperCellsFor(dates, storeKey));
      if (!unified.length) {
        showToast("統合できる紙セルがない");
        return;
      }
      const dateSet = new Set(dates.map(date => iso(date)));
      state.rieMaster = (state.rieMaster || []).filter(row => !(dateSet.has(row.dateIso) && row.storeKey === storeKey));
      let added = 0;
      unified.forEach(row => {
        if (addRieMasterEntry({ ...row, source: "paperCell35" })) added += 1;
      });
      const rieStore = document.getElementById("rieStore");
      const rieWeek = document.getElementById("rieWeekStart");
      if (rieStore) rieStore.value = storeKey;
      if (rieWeek && state.selectedWeekStart) rieWeek.value = state.selectedWeekStart;
      renderPaperImport();
      renderRieMaster();
      persistState();
      showToast(`統合勤務 ${added}件を正本へ反映${warnings.length ? ` / 要確認${warnings.length}` : ""}`);
    }

    function copyPaperUnified() {
      const { unified } = integratePaperCells(paperCellsFor());
      const text = unified.map(row => `${row.dateIso.slice(5).replace("-", "/")},${stores[row.storeKey].name},${row.name},${row.time}`).join("\n");
      const box = document.getElementById("paperCellBulkBox");
      if (navigator.clipboard && text) {
        navigator.clipboard.writeText(text).then(() => showToast("統合結果をコピーした"), () => {
          if (box) box.value = text;
          showToast("コピー不可。入力欄に統合結果を出した");
        });
      } else if (box) {
        box.value = text;
        showToast("入力欄に統合結果を出した");
      }
    }

    function renderPaperImport() {
      setPaperWeekControls();
      const dates = selectedPaperWeekDates();
      const storeKey = selectedPaperStore();
      const cells = paperCellsFor(dates, storeKey);
      const { unified, warnings } = integratePaperCells(cells);
      const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = String(value); };
      setText("paperCellCount", cells.length);
      setText("paperUnifiedCount", unified.length);
      setText("paperWarningCount", warnings.length);
      const cellList = document.getElementById("paperCellList");
      if (cellList) {
        cellList.innerHTML = cells.length ? cells.map(cell => `
          <div class="paper-cell-row">
            <strong>${cell.dateIso.slice(5)}</strong>
            <span>${stores[cell.storeKey].name}</span>
            <span>${cell.slot}</span>
            <span>${escapeHtml(cell.content)}</span>
            <button class="btn small" data-paper-delete="${cell.id}" type="button">削除</button>
          </div>
        `).join("") : `<div class="muted">まだ紙セルが入ってない。紙に書いてある枠のまま取り込む。</div>`;
        cellList.querySelectorAll("[data-paper-delete]").forEach(btn => {
          btn.addEventListener("click", () => {
            state.riePaperCells = (state.riePaperCells || []).filter(cell => cell.id !== btn.dataset.paperDelete);
            renderPaperImport();
            persistState();
          });
        });
      }
      const unifiedList = document.getElementById("paperUnifiedList");
      if (unifiedList) {
        unifiedList.innerHTML = unified.length ? unified.map(row => `
          <div class="paper-unified-row">
            <strong>${row.dateIso.slice(5)}</strong>
            <span>${stores[row.storeKey].name}</span>
            <span>${row.name}</span>
            <span>${row.time}</span>
            <span class="muted">${escapeHtml(row.raw || "")}</span>
          </div>
        `).join("") : `<div class="muted">紙セルを取り込むと、ここに1勤務1行の統合結果が出る。</div>`;
      }
      const warnList = document.getElementById("paperWarningList");
      if (warnList) {
        warnList.innerHTML = warnings.length ? warnings.map(text => `<div class="warning-item">⚠ ${escapeHtml(text)}</div>`).join("") : `<div class="muted">要確認なし。とはいえ紙と目視突合は必須。</div>`;
      }
    }


    function selectedTeacherStore() {
      const select = document.getElementById("teacherStore");
      return select && select.value ? select.value : "all";
    }

    function teacherStoreKeys(storeFilter = selectedTeacherStore()) {
      return storeFilter === "all" ? storeOrder : [storeFilter];
    }

    function teacherCellsFor(storeFilter = selectedTeacherStore()) {
      const set = new Set(teacherStoreKeys(storeFilter));
      return (state.teacherPaperCells || [])
        .filter(cell => set.has(cell.storeKey))
        .sort((a, b) => a.dateIso.localeCompare(b.dateIso)
          || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
          || parseRange(a.slot)[0] - parseRange(b.slot)[0]
          || a.content.localeCompare(b.content, "ja"));
    }

    function teacherUnifiedFor(storeFilter = selectedTeacherStore()) {
      const cells = teacherCellsFor(storeFilter);
      return integratePaperCells(cells).unified;
    }

    function importTeacherCellsBulk() {
      const box = document.getElementById("teacherCellBulkBox");
      const text = box ? box.value.trim() : "";
      if (!text) {
        showToast("取り込む教師データがない");
        return;
      }
      let added = 0;
      let failed = 0;
      const failedLines = [];
      const cells = [];
      text.split(/\n+/).forEach((line, index) => {
        const cell = parsePaperCellBulkLine(line);
        if (cell) {
          cells.push({ ...cell, id: `teacher-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`, source: "teacherCell" });
          added += 1;
        } else {
          failed += 1;
          if (String(line || "").trim()) failedLines.push(`${index + 1}: ${String(line).trim()}`);
        }
      });
      state.teacherPaperCells = state.teacherPaperCells || [];
      cells.forEach(cell => {
        const key = `${cell.dateIso}|${cell.storeKey}|${cell.slot}|${cell.content}`;
        const exists = state.teacherPaperCells.some(existing => `${existing.dateIso}|${existing.storeKey}|${existing.slot}|${existing.content}` === key);
        if (!exists) state.teacherPaperCells.push(cell);
      });
      teacherStatsCache = new Map();
      if (box && added && !failed) box.value = "";
      renderTeacherLearning();
      persistState();
      const suffix = failed ? ` / 失敗${failed}行（例: ${failedLines.slice(0, 2).join(" / ")}）` : "";
      showToast(`教師セル ${added}件取り込み${suffix}`);
    }

    function clearTeacherStore() {
      const storeFilter = selectedTeacherStore();
      const set = new Set(teacherStoreKeys(storeFilter));
      const before = (state.teacherPaperCells || []).length;
      state.teacherPaperCells = (state.teacherPaperCells || []).filter(cell => !set.has(cell.storeKey));
      teacherStatsCache = new Map();
      renderTeacherLearning();
      persistState();
      showToast(`教師セル ${before - state.teacherPaperCells.length}件を削除した`);
    }

    function clearTeacherAll() {
      const before = (state.teacherPaperCells || []).length;
      state.teacherPaperCells = [];
      teacherStatsCache = new Map();
      renderTeacherLearning();
      persistState();
      showToast(`教師セル ${before}件を全削除した`);
    }

    function copyTeacherUnified() {
      const unified = teacherUnifiedFor();
      const text = unified.map(row => `${row.dateIso.slice(5).replace("-", "/")},${stores[row.storeKey].name},${row.name},${row.time}`).join("\n");
      const box = document.getElementById("teacherCellBulkBox");
      if (navigator.clipboard && text) {
        navigator.clipboard.writeText(text).then(() => showToast("教師統合結果をコピーした"), () => {
          if (box) box.value = text;
          showToast("コピー不可。入力欄に統合結果を出した");
        });
      } else if (box) {
        box.value = text;
        showToast("入力欄に統合結果を出した");
      }
    }

    function teacherPatternRowsForRender(storeFilter = selectedTeacherStore()) {
      const set = new Set(teacherStoreKeys(storeFilter));
      const rows = [];
      set.forEach(storeKey => {
        const stats = getTeacherStats(storeKey, "");
        stats.patternCount.forEach((count, key) => {
          const [store, dow, person, time] = key.split("|");
          if (!set.has(store)) return;
          rows.push({ storeKey: store, dow, person, time, count });
        });
      });
      return rows.sort((a, b) => b.count - a.count
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || a.dow.localeCompare(b.dow, "ja")
        || a.person.localeCompare(b.person, "ja"))
        .slice(0, 80);
    }

    function renderTeacherLearning() {
      const storeFilter = selectedTeacherStore();
      const cells = teacherCellsFor(storeFilter);
      const unified = teacherUnifiedFor(storeFilter);
      const patternRows = teacherPatternRowsForRender(storeFilter);
      const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = String(value); };
      setText("teacherCellCount", cells.length);
      setText("teacherUnifiedCount", unified.length);
      setText("teacherPatternCount", patternRows.length);

      const cellList = document.getElementById("teacherCellList");
      if (cellList) {
        cellList.innerHTML = cells.slice(0, 120).map(cell => `
          <div class="paper-cell-row">
            <strong>${cell.dateIso.slice(5)}</strong>
            <span>${stores[cell.storeKey].name}</span>
            <span>${cell.slot}</span>
            <span>${escapeHtml(cell.content)}</span>
            <button class="btn small" data-teacher-delete="${cell.id}" type="button">削除</button>
          </div>
        `).join("") || `<div class="muted">まだ教師データなし。過去シフトを紙セル形式で取り込む。</div>`;
        cellList.querySelectorAll("[data-teacher-delete]").forEach(btn => {
          btn.addEventListener("click", () => {
            state.teacherPaperCells = (state.teacherPaperCells || []).filter(cell => cell.id !== btn.dataset.teacherDelete);
            teacherStatsCache = new Map();
            renderTeacherLearning();
            persistState();
          });
        });
      }

      const unifiedList = document.getElementById("teacherUnifiedList");
      if (unifiedList) {
        unifiedList.innerHTML = unified.slice(0, 120).map(row => `
          <div class="paper-unified-row">
            <strong>${row.dateIso.slice(5)}</strong>
            <span>${stores[row.storeKey].name}</span>
            <span>${row.name}</span>
            <span>${row.time}</span>
            <span class="muted">${escapeHtml(row.raw || "")}</span>
          </div>
        `).join("") || `<div class="muted">教師セルを取り込むと、ここに統合勤務が出る。</div>`;
      }

      const body = document.getElementById("teacherPatternBody");
      if (body) {
        body.innerHTML = patternRows.map(row => `
          <tr>
            <td>${stores[row.storeKey].name}</td>
            <td>${row.dow}</td>
            <td>${row.person}</td>
            <td>${row.time}</td>
            <td>${Math.round(row.count)}</td>
          </tr>
        `).join("") || `<tr><td colspan="5"><span class="muted">学習パターンなし。教師データを取り込んで。</span></td></tr>`;
      }
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function entriesToTimelineIntervals(rows) {
      return (rows || []).map(row => {
        const range = absRangeForTime(row.dateIso, row.time);
        if (!range) return null;
        return {
          ...row,
          name: canonicalStaffNameForStore(row.name, row.storeKey),
          startAbs: range.startAbs,
          endAbs: range.endAbs
        };
      }).filter(Boolean);
    }

    function coverageAtMinute(intervals, storeKey, absMinute) {
      const map = new Map();
      intervals.forEach(row => {
        if (row.storeKey === storeKey && row.startAbs <= absMinute && absMinute < row.endAbs) {
          map.set(canonicalStaffName(row.name), row);
        }
      });
      return [...map.values()];
    }

    function collectRieCoverageDiffs(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const entries = rieEntriesFor(dates, storeFilter);
      const appEntries = appEntriesFor(dates, storeFilter);
      const rieIntervals = entriesToTimelineIntervals(entries);
      const appIntervals = entriesToTimelineIntervals(appEntries);
      const raw = [];
      rieStoreKeys(storeFilter).forEach(storeKey => {
        dates.forEach(date => {
          const dateIso = iso(date);
          slots.forEach(slot => {
            const slotRange = absRangeForSlot(dateIso, slot);
            if (!slotRange) return;
            const req = requirement(storeKey, slot);
            for (let absMinute = slotRange.startAbs; absMinute < slotRange.endAbs; absMinute += 30) {
              const rieCount = coverageAtMinute(rieIntervals, storeKey, absMinute).length;
              const appCount = coverageAtMinute(appIntervals, storeKey, absMinute).length;
              const diff = appCount - rieCount;
              if (diff !== 0) raw.push({ date, dateIso, storeKey, slot, req, startAbs: absMinute, endAbs: absMinute + 30, rieCount, appCount, diff });
            }
          });
        });
      });
      const merged = [];
      raw.forEach(row => {
        const last = merged[merged.length - 1];
        if (last
          && last.dateIso === row.dateIso
          && last.storeKey === row.storeKey
          && last.slot === row.slot
          && last.endAbs === row.startAbs
          && last.rieCount === row.rieCount
          && last.appCount === row.appCount
          && last.diff === row.diff) {
          last.endAbs = row.endAbs;
        } else {
          merged.push({ ...row });
        }
      });
      return merged.map(row => ({
        ...row,
        rangeLabel: rangeLabelFromAbs(row.dateIso, row.startAbs, row.endAbs),
        slotLabel: row.slot
      }));
    }

    function collectRiePersonDiffs(dates = selectedRieWeekDates(), storeFilter = selectedRieStore()) {
      const rieRows = rieEntriesFor(dates, storeFilter).map((row, index) => ({ ...row, name: canonicalStaffNameForStore(row.name, row.storeKey), time: normalizeTimeInput(row.time) || row.time, _rieIndex: index }));
      const appUnused = appEntriesFor(dates, storeFilter).map((row, index) => ({ ...row, name: canonicalStaffNameForStore(row.name, row.storeKey), time: normalizeTimeInput(row.time) || row.time, _appIndex: index }));
      const rieUnused = [];
      const rows = [];

      // 先に完全一致を全件マッチさせる。
      // 同じ人が同じ日に分割勤務している場合、先頭の別時間勤務を「時間ズレ」として誤消費しないため。
      rieRows.forEach(rie => {
        const exactIndex = appUnused.findIndex(app => entryCompareKey(app) === entryCompareKey(rie));
        if (exactIndex >= 0) {
          appUnused.splice(exactIndex, 1);
        } else {
          rieUnused.push(rie);
        }
      });

      rieUnused.forEach(rie => {
        let bestIndex = -1;
        let bestScore = -Infinity;
        appUnused.forEach((app, index) => {
          if (app.dateIso !== rie.dateIso || app.storeKey !== rie.storeKey || app.name !== rie.name) return;
          const score = timeSimilarityScore(rie.time, app.time);
          if (score > bestScore) {
            bestScore = score;
            bestIndex = index;
          }
        });
        if (bestIndex >= 0) {
          const app = appUnused.splice(bestIndex, 1)[0];
          rows.push({ type: "時間ズレ", dateIso: rie.dateIso, storeKey: rie.storeKey, name: rie.name, time: `正本 ${rie.time} / アプリ ${app.time}` });
        } else {
          rows.push({ type: "アプリにない", ...rie });
        }
      });

      appUnused.forEach(app => rows.push({ type: "アプリ余分", ...app }));
      return rows.sort((a, b) => a.dateIso.localeCompare(b.dateIso)
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || a.type.localeCompare(b.type, "ja"));
    }


    function summarizeCoverageDiffRows(rows) {
      const groups = new Map();
      (rows || []).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}|${row.slot}`;
        const current = groups.get(key) || {
          date: row.date,
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          slot: row.slot,
          under: [],
          over: [],
          maxUnder: 0,
          maxOver: 0,
          totalMinutes: 0
        };
        const label = `${row.rangeLabel} 正${row.rieCount}/ア${row.appCount} (${row.diff > 0 ? "+" : ""}${row.diff})`;
        const minutes = Math.max(0, row.endAbs - row.startAbs);
        current.totalMinutes += minutes;
        if (row.diff < 0) {
          current.under.push(label);
          current.maxUnder = Math.max(current.maxUnder, Math.abs(row.diff));
        } else if (row.diff > 0) {
          current.over.push(label);
          current.maxOver = Math.max(current.maxOver, Math.abs(row.diff));
        }
        groups.set(key, current);
      });
      return [...groups.values()].sort((a, b) => a.date - b.date
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || parseRange(a.slot)[0] - parseRange(b.slot)[0]);
    }

    function coverageSummaryClass(row) {
      if (row.under.length && row.over.length) return "warn-row";
      if (row.under.length) return "danger-row";
      return "warn-row";
    }

    function coverageSummaryText(row) {
      const parts = [];
      if (row.under.length) parts.push(`不足最大${row.maxUnder}: ${row.under.join(" / ")}`);
      if (row.over.length) parts.push(`過剰最大${row.maxOver}: ${row.over.join(" / ")}`);
      return parts.join("<br>") || "差分なし";
    }

    function summarizePersonDiffRows(rows) {
      const priority = { "時間ズレ": 0, "アプリにない": 1, "アプリ余分": 2 };
      const groups = new Map();
      (rows || []).forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}|${row.type}`;
        const current = groups.get(key) || {
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          type: row.type,
          items: []
        };
        current.items.push(`${row.name} ${row.time}`.trim());
        groups.set(key, current);
      });
      return [...groups.values()].map(row => ({
        ...row,
        content: [...new Set(row.items)].join(" / ")
      })).sort((a, b) => a.dateIso.localeCompare(b.dateIso)
        || storeOrder.indexOf(a.storeKey) - storeOrder.indexOf(b.storeKey)
        || (priority[a.type] ?? 99) - (priority[b.type] ?? 99));
    }

    function renderRieMaster() {
      setRieWeekControls();
      const dates = selectedRieWeekDates();
      const storeFilter = selectedRieStore();
      const stats = rieCompareStats(dates, storeFilter);
      const { entries, appEntries, coverageDiffs, personDiffs, sameWeekOtherStore, appCopiedEntries } = stats;
      const targetPaperCells = storeFilter === "all" ? [] : paperCellsFor(dates, storeFilter);
      const targetPaperUnified = storeFilter === "all" ? [] : integratePaperCells(targetPaperCells).unified;
      const noMasterButApp = !entries.length && appEntries.length;
      const paperNotApplied = !entries.length && targetPaperCells.length;
      const countEl = document.getElementById("rieMasterCount");
      const coverageEl = document.getElementById("rieCoverageDiffCount");
      const personEl = document.getElementById("riePersonDiffCount");
      if (countEl) countEl.textContent = String(entries.length);
      if (coverageEl) coverageEl.textContent = noMasterButApp ? "正本未反映" : (entries.length ? (appEntries.length ? String(coverageDiffs.length) : "未作成") : "未入力");
      if (personEl) personEl.textContent = noMasterButApp ? "正本未反映" : (entries.length ? (appEntries.length ? String(personDiffs.length) : "未作成") : "未入力");
      const memo = document.getElementById("rieCompareMemo");
      if (memo) {
        let badge = `<span class="comparison-badge bad">正本未入力</span>`;
        if (entries.length && !appEntries.length) badge = `<span class="comparison-badge bad">アプリ未作成</span>`;
        else if (entries.length && (coverageDiffs.length || personDiffs.length)) badge = `<span class="comparison-badge warn">差分あり</span>`;
        else if (entries.length && appEntries.length) badge = `<span class="comparison-badge ok">完全一致</span>`;
        const warnings = [];
        if (noMasterButApp) warnings.push(`正本0件なのにアプリ ${appEntries.length}件あり。これは差分評価ではなく「正本未反映」状態。`);
        if (paperNotApplied) warnings.push(`紙セル ${targetPaperCells.length}件 / 統合候補 ${targetPaperUnified.length}件あり。紙シフト統合で「統合して正本へ反映」を押して。`);
        if (!entries.length && sameWeekOtherStore) warnings.push(`この週の別店舗に正本 ${sameWeekOtherStore}件あり。店舗選択を確認。`);
        if (appCopiedEntries && appCopiedEntries === entries.length) warnings.push("正本がアプリコピー由来。差分0でも検証結果としては使わない。");
        if (entries.length && appEntries.length && !coverageDiffs.length && !personDiffs.length) warnings.push("手入力で完全一致は珍しい。コピー/反映ボタンを押していないか確認。");
        const personTimeSummaryHtml = entries.length && appEntries.length ? (() => {
          const total = personDiffs.length;
          const timeShift = personDiffs.filter(row => row.type === "時間ズレ").length;
          const missing = personDiffs.filter(row => row.type === "アプリにない").length;
          const extra = personDiffs.filter(row => row.type === "アプリ余分").length;
          const topText = personTimeDiffNameSummaryText(personDiffs, 10);
          return `
            <div class="person support"><span>人物時間差分サマリ：合計${total} / 時間ズレ${timeShift} / アプリにない${missing} / アプリ余分${extra}</span></div>
            <div class="person support"><span>人物別差分Top：${topText}</span></div>
          `;
        })() : `<div class="person support"><span>人物時間差分サマリ：比較不可（正本 ${entries.length}件 / アプリ ${appEntries.length}件）</span></div>`;
        memo.innerHTML = `
          <div class="person"><span>${badge}</span></div>
          <div class="person"><span>正本 ${entries.length}件 / アプリ ${appEntries.length}件 / 対象: ${storeFilter === "all" ? "全店舗" : stores[storeFilter].name}</span></div>
          ${personTimeSummaryHtml}
          ${warnings.map(text => `<div class="person danger"><span>⚠ ${text}</span></div>`).join("")}
          <div class="person"><span>正本・アプリとも内部は30分タイムラインで比較。表示は日付・枠・区分ごとに要約している。細かい30分ログは画面に出さない。</span></div>
        `;
      }
      const list = document.getElementById("rieMasterList");
      if (list) {
        list.innerHTML = entries.length ? entries.map(row => `
          <div class="rie-master-row">
            <strong>${row.dateIso.slice(5)}</strong>
            <span>${stores[row.storeKey].name}</span>
            <span>${row.name}</span>
            <span>${row.time}</span>
            <button class="btn small" data-rie-delete="${row.id}" type="button">削除</button>
          </div>
        `).join("") : `<div class="muted">まだ正本が入ってない。まず「紙シフト統合」でセル単位入力する。</div>`;
        list.querySelectorAll("[data-rie-delete]").forEach(btn => {
          btn.addEventListener("click", () => {
            state.rieMaster = state.rieMaster.filter(row => row.id !== btn.dataset.rieDelete);
            renderRieMaster();
            persistState();
          });
        });
      }
      const covBody = document.getElementById("rieCoverageDiffBody");
      if (covBody) {
        if (noMasterButApp) {
          covBody.innerHTML = `<tr><td colspan="6"><span class="tag danger">正本0件のため比較停止。紙シフト統合 → 統合して正本へ反映 → 突合更新の順でやり直し。</span></td></tr>`;
        } else {
          const coverageSummaryRows = summarizeCoverageDiffRows(coverageDiffs);
          covBody.innerHTML = coverageSummaryRows.slice(0, 80).map(row => `
            <tr class="${coverageSummaryClass(row)}">
              <td>${row.dateIso.slice(5)}(${dowLabel(row.date)})</td>
              <td>${stores[row.storeKey].name}</td>
              <td>${row.slot}</td>
              <td colspan="2">${coverageSummaryText(row)}</td>
              <td>${row.under.length ? `不足${row.maxUnder}` : ""}${row.under.length && row.over.length ? " / " : ""}${row.over.length ? `過剰${row.maxOver}` : ""}</td>
            </tr>
          `).join("") || `<tr><td colspan="6"><span class="tag ${entries.length && appEntries.length ? "ok" : "danger"}">${entries.length ? (appEntries.length ? "時間カバー差分なし" : "アプリ版未作成。週締め作成してから突合。") : "正本未入力。紙シフト統合から入れて。"}</span></td></tr>`;
        }
      }
      const personBody = document.getElementById("riePersonDiffBody");
      if (personBody) {
        if (noMasterButApp) {
          personBody.innerHTML = `<tr><td colspan="4"><span class="tag danger">アプリ余分の大量表示を停止。正本未反映なので、この結果は無効。</span></td></tr>`;
        } else {
          const personSummaryRows = summarizePersonDiffRows(personDiffs);
          personBody.innerHTML = personSummaryRows.slice(0, 80).map(row => `
            <tr class="${row.type === "アプリにない" ? "danger-row" : "warn-row"}">
              <td>${row.type}</td>
              <td>${row.dateIso.slice(5)}</td>
              <td>${stores[row.storeKey].name}</td>
              <td>${escapeHtml(row.content)}</td>
            </tr>
          `).join("") || `<tr><td colspan="4"><span class="tag ${entries.length && appEntries.length ? "ok" : "danger"}">${entries.length ? (appEntries.length ? "人・時間差分なし" : "アプリ版未作成。週締め作成してから突合。") : "正本未入力。紙シフト統合から入れて。"}</span></td></tr>`;
        }
      }
    }


    // 36.46 自動検証モード：ブラウザ上で「正本なし生成ボタン→正本突合→差分集計」を1クリック実行する。
    // 目的：スクショ頼みではなく、同じ保存JSONで各版の結果を比較できるようにする。
    function validationTargetStoreKeys(value) {
      if (value === "all") return storeOrder.slice();
      if (value === "higashicho" || value === "ougicho" || value === "miyanoshita") return [value];
      return ["miyanoshita", "higashicho", "ougicho"];
    }

    function validationSetWeekAndStore(weekStartIso, storeKey) {
      state.selectedWeekStart = weekStartIso;
      state.weeklyCloseStore = storeKey;
      state.selectedStore = storeKey;
      const weekSelect = document.getElementById("weeklyCloseStart");
      const storeSelect = document.getElementById("weeklyCloseStore");
      if (weekSelect) {
        renderWeeklyCloseControls();
        weekSelect.value = weekStartIso;
        state.selectedWeekStart = weekStartIso;
      }
      if (storeSelect) {
        storeSelect.value = storeKey;
        state.weeklyCloseStore = storeKey;
        state.selectedStore = storeKey;
      }
      const rieWeek = document.getElementById("rieWeekStart");
      const rieStore = document.getElementById("rieStore");
      if (rieWeek) rieWeek.value = weekStartIso;
      if (rieStore) rieStore.value = storeKey;
    }

    function validationClearWeekStore(dates, storeKey) {
      dates.forEach(date => {
        const dateIso = typeof date === "string" ? date : iso(date);
        if (!state.schedule[dateIso]) state.schedule[dateIso] = {};
        state.schedule[dateIso][storeKey] = {};
      });
    }

    function validationClearWeekAllStores(dates) {
      dates.forEach(date => {
        const dateIso = typeof date === "string" ? date : iso(date);
        if (!state.schedule[dateIso]) state.schedule[dateIso] = {};
        storeOrder.forEach(storeKey => {
          state.schedule[dateIso][storeKey] = {};
        });
      });
    }

    function validationPersonTypeCounts(rows = []) {
      return {
        total: rows.length,
        timeShift: rows.filter(row => row.type === "時間ズレ").length,
        missing: rows.filter(row => row.type === "アプリにない").length,
        extra: rows.filter(row => row.type === "アプリ余分").length
      };
    }

    function validationNameTopRows(rows = [], limit = 12) {
      const groups = new Map();
      (rows || []).forEach(row => {
        const name = canonicalStaffName(row.name || "不明");
        const current = groups.get(name) || { name, total: 0, timeShift: 0, missing: 0, extra: 0 };
        current.total += 1;
        if (row.type === "時間ズレ") current.timeShift += 1;
        else if (row.type === "アプリにない") current.missing += 1;
        else if (row.type === "アプリ余分") current.extra += 1;
        groups.set(name, current);
      });
      return [...groups.values()]
        .sort((a, b) => b.total - a.total || b.missing - a.missing || b.extra - a.extra || a.name.localeCompare(b.name, "ja"))
        .slice(0, limit);
    }

    function validationCoverageTopRows(rows = [], limit = 20) {
      try {
        return summarizeCoverageDiffRows(rows).slice(0, limit).map(row => ({
          dateIso: row.dateIso,
          store: stores[row.storeKey]?.name || row.storeKey,
          slot: row.slot,
          under: row.under || [],
          over: row.over || [],
          maxUnder: row.maxUnder || 0,
          maxOver: row.maxOver || 0
        }));
      } catch (error) {
        return [];
      }
    }

    function validationWishPhaseRun(dates, storeKey) {
      const phaseLog = [];
      const count = label => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase: label, count: value });
        return value;
      };
      const savedRieMaster = Array.isArray(state.rieMaster) ? state.rieMaster : [];
      state.rieMaster = [];
      const band = wishWeekCountBandForDates(dates, storeKey);
      const options = autonomousGenerationOptions({
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      });
      options.wishExpectationCache = new Map();
      options.wishCandidatePoolCache = new Map();
      let wishLog = null;
      try {
        count("afterClear");
        wishTemplateFillForDates(dates, storeKey, options);
        count("afterTemplateFill");
        ensureMinimumCoverageForDates(dates, storeKey, options);
        count("afterMinimumCoverage1");
        wishTeacherFloorForDates(dates, storeKey, options);
        count("afterTeacherFloor1");
        ensureMinimumCoverageForDates(dates, storeKey, options);
        count("afterMinimumCoverage2");
        wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, options);
        count("after30minRepair");
        let countState = wishWeekCountStateForOptions(storeKey, options);
        if (countState.below) {
          wishTeacherFloorForDates(dates, storeKey, options);
          count("afterTeacherFloor2BelowBand");
          wishLog = wishThirtyMinuteAnchorRepairForDates(dates, storeKey, options);
          count("after30minRepair2BelowBand");
        }
        countState = wishWeekCountStateForOptions(storeKey, options);
        if (countState.inBand) {
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
          count("afterFixedCountCompress1");
        }
        wishFloorRescueForDates(dates, storeKey, options, wishLog);
        count("afterFloorRescue");
        if (wishWeekCountStateForOptions(storeKey, options).inBand) {
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
          count("afterFixedCountCompress2");
        }
        wishDiagnosticSnapshotForDates(dates, storeKey, options, wishLog);
        count("afterDiagnostic");
        if (wishWeekCountStateForOptions(storeKey, options).over) {
          wishRollbackOverCapForDates(dates, storeKey, options, wishLog);
          count("afterRollbackOverCap");
          wishLog = wishFixedCountCompressForDates(dates, storeKey, options, wishLog);
          count("afterFixedCountCompressAfterRollback");
        }
        if (wishLog) wishLog.afterCount = wishCountAssignmentsForDates(dates, storeKey);
        state.lastWishCorrectionLog = wishLog;
        return { band, phaseLog, wishLog };
      } finally {
        state.rieMaster = savedRieMaster;
      }
    }

    function validationOneStoreFromSnapshot(baseSnapshot, weekStartIso, storeKey) {
      applySerialized(baseSnapshot);
      validationSetWeekAndStore(weekStartIso, storeKey);
      const dates = weekDates(weekStartIso);
      // 36.48: 検証では対象店舗だけでなく対象週の全店舗を一度空にする。
      // 保存JSON内の既存別店舗シフトが isAssignedAnywhere に引っかかり、正本なし生成候補が二重勤務扱いで落ちるのを防ぐ。
      validationClearWeekAllStores(dates);
      const startedAt = performance.now ? performance.now() : Date.now();
      const phaseRun = validationWishPhaseRun(dates, storeKey);
      const endedAt = performance.now ? performance.now() : Date.now();
      const stats = rieCompareStats(dates, storeKey);
      const personCounts = validationPersonTypeCounts(stats.personDiffs);
      const finalCount = stats.appEntries.length;
      const lower = phaseRun && phaseRun.band ? Number(phaseRun.band.lower || 0) : 0;
      const upper = phaseRun && phaseRun.band ? Number(phaseRun.band.upper || 0) : 0;
      const validationStatus = lower && finalCount < lower ? "UNDERFILLED_VALIDATION_FAILED" : (upper && finalCount > upper ? "OVERCAP_VALIDATION_FAILED" : "OK");
      return {
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        weekStart: weekStartIso,
        weekLabel: weekLabel(dates),
        runtimeMs: Math.round(endedAt - startedAt),
        validationStatus,
        expectedBand: phaseRun.band,
        validationMode: "isolated-week-all-store-clear",
        clearedStores: [...storeOrder],
        phaseLog: phaseRun.phaseLog,
        masterCount: stats.entries.length,
        appCount: finalCount,
        coverageDiffCount: stats.coverageDiffs.length,
        personDiffCount: stats.personDiffs.length,
        personDiff: personCounts,
        personTop: validationNameTopRows(stats.personDiffs, 12),
        coverageTop: validationCoverageTopRows(stats.coverageDiffs, 20),
        correctionLog: state.lastWishCorrectionLog || null
      };
    }

    function validationBuildResultSummary(results) {
      return results.map(row => `${row.storeName}: 正本${row.masterCount}/アプリ${row.appCount} 時間差分${row.coverageDiffCount} 人物差分${row.personDiffCount}`).join(" / ");
    }


    function validationBuildNoMasterSummary(results) {
      return results.map(row => `${row.storeName}: 生成${row.appCount}/目標${row.expectedBand.lower}-${row.expectedBand.upper} 不足セル${row.noMasterQuality.shortageCells} 過剰セル${row.noMasterQuality.surplusCells} 休み希望ブロック${row.noMasterDiagnostics.blocked.unavailable || 0}`).join(" / ");
    }

    function noMasterDailyRows(dateIso, storeKey) {
      return uniqueAssignments(dateIso, storeKey).map(row => ({
        dateIso,
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        name: canonicalStaffNameForStore(row.name, storeKey),
        time: row.time
      })).sort((a,b) => parseRange(a.time)[0] - parseRange(b.time)[0] || a.name.localeCompare(b.name, "ja"));
    }

    function noMasterReasonForCandidate(dateIso, storeKey, person, time, options = {}) {
      if (!person) return "noPerson";
      if (!canWorkAtStore(person, storeKey)) return "storeMismatch";
      // 正本なし生成の絶対NGは「休み希望」と「同時勤務NG」と「同日二重配置」。
      // 曜日適性(matchesDay)は候補スコアで見る。ここで硬く落とすと来月生成が 2〜8件で止まる。
      if (isUnavailable(person.name, dateIso)) return "unavailable";
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) return "incompatible";
      if (isAssignedAnywhere(dateIso, person.name) && !uniqueAssignments(dateIso, storeKey).some(a => canonicalStaffName(a.name) === canonicalStaffName(person.name) && a.time === time)) return "doubleBooking";
      if (!assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return "badTime";
      // 正本なし生成では canPlaceShift の内部ソフト制約で候補を殺さない。
      // 絶対NGはこの関数の上で処理済み：店舗不一致・休み希望・同時勤務NG・同日二重配置・不正時間。
      // それ以外（曜日癖、希望のみ、連勤、人数厚み）はスコア/後段調整で扱う。
      return "ok";
    }

    function noMasterFallbackTimesForStore(storeKey) {
      // 正本なしの最低限生成では、過去候補が薄い人にも標準シフト型を渡す。
      // 過去/希望由来の候補は高スコアなので、これは最後の救済候補として働く。
      return ["6-9", "9-13", "9-15", "9-18", "13-17", "13-22", "15-24", "17-21", "17-22", "18-22", "22-3", "22-6", "24-9"];
    }

    function noMasterBuildCandidatePool(dateIso, storeKey, options = {}) {
      const map = new Map();
      function addCandidate(person, time, score = 0, source = "unknown") {
        if (!person || !time) return;
        const normalized = normalizeTimeInput(time) || time;
        if (!normalized) return;
        const key = `${canonicalStaffName(person.name)}|${normalized}`;
        const base = wishCandidateScore(dateIso, storeKey, person, normalized);
        const current = map.get(key);
        const next = { person, time: normalized, score: base + score, source };
        if (!current || next.score > current.score) map.set(key, next);
      }

      submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
        const person = findStaff(row.name);
        if (person) addCandidate(person, row.time, 5000, "submittedWorkRequest");
      });
      wishConsensusCandidatesForDateStore(dateIso, storeKey).forEach(row => addCandidate(row.person, row.time, row.score + 1600, "consensus"));
      teacherWishCandidatesForDateStore(dateIso, storeKey).forEach(row => addCandidate(row.person, row.time, row.score + 900, "teacherWish"));
      staff
        .filter(person => canWorkAtStore(person, storeKey))
        .filter(person => !isInactiveStaff(person))
        .filter(person => !isManualSupportPerson(person))
        .forEach(person => {
          candidateTimesForGeneration(person, storeKey, dateIso).forEach(time => {
            const dayBoost = matchesDay(person, dateIso) ? 180 : -40;
            addCandidate(person, time, dayBoost, "fallback");
          });
          noMasterFallbackTimesForStore(storeKey).forEach(time => {
            const dayBoost = matchesDay(person, dateIso) ? 80 : -120;
            addCandidate(person, time, dayBoost - 500, "broadFallback");
          });
        });
      return [...map.values()].sort((a,b) => b.score - a.score);
    }

    function noMasterCoverageQualityForStore(dates, storeKey, options = {}) {
      let shortageCells = 0;
      let surplusCells = 0;
      const daily = [];
      dates.forEach(date => {
        const dateIso = typeof date === "string" ? date : iso(date);
        const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
        const diff = wishDiffSummaryForDate(dateIso, storeKey, expectation);
        shortageCells += diff.shortage;
        surplusCells += diff.surplus;
        daily.push({
          dateIso,
          count: uniqueAssignments(dateIso, storeKey).length,
          target: teacherWishTargetCountForDateStore(dateIso, storeKey),
          shortageCells: diff.shortage,
          surplusCells: diff.surplus,
          rows: noMasterDailyRows(dateIso, storeKey)
        });
      });
      return { shortageCells, surplusCells, daily };
    }


    function noMasterForceAddShift(dateIso, storeKey, person, time, options = {}) {
      if (!wishCanAddWithinWeeklyCap(dateIso, storeKey, options)) {
        if (options.wishCorrectionLog) options.wishCorrectionLog.capBlocked += 1;
        return false;
      }
      const normalized = normalizeTimeInput(time) || time;
      const reason = noMasterReasonForCandidate(dateIso, storeKey, person, normalized, options);
      if (reason !== "ok") return false;
      const assignment = { name: person.name, time: normalized, support: Boolean(person.support), noMaster: true };
      const targets = assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function noMasterPickBestCandidateForDate(dateIso, storeKey, options, diagnostics) {
      const assignments = uniqueAssignments(dateIso, storeKey);
      const candidates = noMasterBuildCandidatePool(dateIso, storeKey, options);
      const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
      const current = wishDiffSummaryForDate(dateIso, storeKey, expectation);
      let best = null;
      candidates.forEach(row => {
        const duplicate = assignments.some(a => canonicalStaffName(a.name) === canonicalStaffName(row.person.name) && a.time === row.time);
        if (duplicate) return;
        const reason = noMasterReasonForCandidate(dateIso, storeKey, row.person, row.time, options);
        if (reason !== "ok") {
          diagnostics.blocked[reason] = (diagnostics.blocked[reason] || 0) + 1;
          return;
        }
        const simulated = assignments.concat([{ name: row.person.name, time: row.time, support: row.person.support }]);
        const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
        const coverageGain = current.score - next.score;
        const slotGain = wishCoverageGain(dateIso, storeKey, row.time);
        const submittedBoost = hasSubmittedWorkRequestTime(dateIso, storeKey, row.person.name, row.time) ? 20000 : 0;
        const dailyTarget = teacherWishTargetCountForDateStore(dateIso, storeKey);
        const dailyNeedBoost = Math.max(0, dailyTarget - assignments.length) * 500;
        const totalScore = submittedBoost + coverageGain * 1200 + slotGain * 800 + dailyNeedBoost + row.score;
        if (!best || totalScore > best.totalScore) best = { ...row, totalScore, coverageGain, slotGain };
      });
      if (!best) diagnostics.noCandidateDates.push({ dateIso, storeKey, count: assignments.length, target: teacherWishTargetCountForDateStore(dateIso, storeKey) });
      return best;
    }

    function noMasterV60PersonWeeklyLimit(person, relaxed = false) {
      if (!person) return 0;
      if (relaxed) return hasTag(person, "希望提出型") ? 3 : 7;
      if (hasTag(person, "希望提出型")) return 2;
      if (hasTag(person, "学生")) return 3;
      if (hasTag(person, "社員") || hasTag(person, "店長")) return 6;
      if (hasTag(person, "フリーター")) return 5;
      return 4;
    }

    function noMasterV60WeeklyCount(dates, personName) {
      const name = canonicalStaffName(personName);
      return dates.reduce((sum, date) => {
        const dateIso = typeof date === "string" ? date : iso(date);
        let seen = false;
        storeOrder.forEach(storeKey => {
          if (uniqueAssignments(dateIso, storeKey).some(row => canonicalStaffName(row.name) === name)) seen = true;
        });
        return sum + (seen ? 1 : 0);
      }, 0);
    }

    function noMasterV60StrictReason(dateIso, storeKey, person, time, options = {}) {
      if (!person) return "noPerson";
      if (!canWorkAtStore(person, storeKey)) return "storeMismatch";
      if (isManualSupportPerson(person)) return "manualSupport";
      if (isUnavailable(person.name, dateIso)) return "unavailable";
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) return "incompatible";
      if (isAssignedAnywhere(dateIso, person.name)) return "doubleBooking";
      if (!assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return "badTime";
      if (!options.relaxedWeeklyMax && noMasterV60WeeklyCount(options.wishWeekDates || [], person.name) >= noMasterV60PersonWeeklyLimit(person, false)) return "weeklyMax";
      if (options.relaxedWeeklyMax && noMasterV60WeeklyCount(options.wishWeekDates || [], person.name) >= noMasterV60PersonWeeklyLimit(person, true)) return "weeklyMaxRelaxed";
      return "ok";
    }

    function noMasterV60CandidateTimes(person, storeKey, dateIso, relaxed = false) {
      const map = new Map();
      function add(time, score, source) {
        const normalized = normalizeTimeInput(time) || time;
        if (!normalized) return;
        if (!assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return;
        const prev = map.get(normalized);
        if (!prev || score > prev.score) map.set(normalized, { time: normalized, score, source });
      }
      (person.times || []).forEach(time => add(time, 1000, "staffTimes"));
      candidateTimesForGeneration(person, storeKey, dateIso).forEach(time => add(time, 850, "generationTimes"));
      if (relaxed) {
        noMasterFallbackTimesForStore(storeKey).forEach(time => add(time, 120, "broadFallbackRelaxed"));
      } else {
        noMasterFallbackTimesForStore(storeKey).forEach(time => add(time, -180, "broadFallback"));
      }
      return [...map.values()];
    }

    function noMasterV60BuildCandidatePool(dateIso, storeKey, options = {}) {
      const rows = [];
      const relaxed = Boolean(options.relaxedWeeklyMax || options.relaxedTimeFallback);
      staff
        .filter(person => canWorkAtStore(person, storeKey))
        .filter(person => !isInactiveStaff(person))
        .filter(person => !isManualSupportPerson(person))
        .forEach(person => {
          const dayScore = matchesDay(person, dateIso) ? 260 : (relaxed ? -80 : -220);
          const submittedRows = submittedWorkRequestsFor(dateIso, storeKey).filter(row => canonicalStaffName(row.name) === canonicalStaffName(person.name));
          submittedRows.forEach(row => {
            const normalized = normalizeTimeInput(row.time) || row.time;
            rows.push({ person, time: normalized, source: "submittedWorkRequest", seedScore: 100000 });
          });
          noMasterV60CandidateTimes(person, storeKey, dateIso, relaxed).forEach(row => {
            const hopePenalty = hasTag(person, "希望提出型") && !submittedRows.length ? -2500 : 0;
            rows.push({ person, time: row.time, source: row.source, seedScore: row.score + dayScore + hopePenalty + wishCandidateScore(dateIso, storeKey, person, row.time) });
          });
        });
      return rows;
    }

    function noMasterV60PickBestCandidateForDate(dateIso, storeKey, options = {}, diagnostics = {}) {
      const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
      const assignments = uniqueAssignments(dateIso, storeKey);
      const current = wishDiffSummaryForDate(dateIso, storeKey, expectation);
      let best = null;
      noMasterV60BuildCandidatePool(dateIso, storeKey, options).forEach(row => {
        const reason = noMasterV60StrictReason(dateIso, storeKey, row.person, row.time, options);
        if (reason !== "ok") {
          diagnostics.blocked[reason] = (diagnostics.blocked[reason] || 0) + 1;
          return;
        }
        const simulated = assignments.concat([{ name: row.person.name, time: row.time, support: Boolean(row.person.support) }]);
        const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
        const coverageGain = current.score - next.score;
        const slotGain = wishCoverageGain(dateIso, storeKey, row.time);
        const submittedBoost = row.source === "submittedWorkRequest" ? 50000 : 0;
        const timeLen = Math.max(1, parseRange(row.time)[1] - parseRange(row.time)[0]);
        const lengthScore = Math.min(timeLen, 9) * 90;
        const totalScore = submittedBoost + coverageGain * 1800 + slotGain * 1000 + row.seedScore + lengthScore;
        if (!best || totalScore > best.totalScore) best = { ...row, totalScore, coverageGain, slotGain };
      });
      if (!best) diagnostics.noCandidateDates.push({ dateIso, storeKey, count: uniqueAssignments(dateIso, storeKey).length, target: teacherWishTargetCountForDateStore(dateIso, storeKey), relaxed: Boolean(options.relaxedWeeklyMax) });
      return best;
    }

    function noMasterV60DirectAddShift(dateIso, storeKey, person, time, options = {}) {
      const normalized = normalizeTimeInput(time) || time;
      if (noMasterV60StrictReason(dateIso, storeKey, person, normalized, options) !== "ok") return false;
      const targets = assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      const assignment = { name: person.name, time: normalized, support: Boolean(person.support), noMaster: true, generatedBy: "v60" };
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function noMasterV60FillDateToTarget(dateIso, storeKey, target, options, diagnostics, counterKey) {
      let guard = 0;
      while (uniqueAssignments(dateIso, storeKey).length < target && wishCountAssignmentsForDates(options.wishWeekDates, storeKey) < options.wishWeekUpperCap && guard < 80) {
        const picked = noMasterV60PickBestCandidateForDate(dateIso, storeKey, options, diagnostics);
        if (!picked) break;
        if (noMasterV60DirectAddShift(dateIso, storeKey, picked.person, picked.time, options)) {
          diagnostics[counterKey] = (diagnostics[counterKey] || 0) + 1;
        } else {
          diagnostics.blocked.addFailed = (diagnostics.blocked.addFailed || 0) + 1;
          break;
        }
        guard += 1;
      }
    }


    function noMasterV64CleanHistoryName(rawName) {
      let name = String(rawName || "").trim();
      if (!name) return "";
      name = name.replace(/[\s　]+/g, " ").trim();
      name = name.replace(/[・･]\s*\d{1,2}\s*[〜~ー\-－]\s*\d{1,2}.*/, "").trim();
      name = name.replace(/\s+\d{1,2}(?:\.\d+)?$/, "").trim();
      name = name.replace(/[（(]\s*\d{1,2}\s*[〜~ー\-－]\s*\d{1,2}\s*[)）].*/, "").trim();
      return name;
    }

    function noMasterV64ReasonForTimeReplace(dateIso, storeKey, person, time) {
      if (!person) return "noPerson";
      const normalized = normalizeTimeInput(time) || time;
      if (noMasterV62IsInactive(person)) return "inactive";
      if (noMasterV62IsSupport(person)) return "manualSupport";
      if (isUnavailable(person.name, dateIso)) return "unavailable";
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) return "incompatible";
      if (!assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return "badTime";
      return "ok";
    }

    function noMasterV89CompressHigashichoLegacy(dates, storeKey, options = {}, diagnostics = {}) {
      let totalFixes = 0;
      const active = noMasterV62ActiveStaffForStore(storeKey);
      const byName = new Map(active.map(p => [noMasterV62CanonicalName(p.name), p]));
      const maxPass = 4;
      for (let pass = 0; pass < maxPass; pass += 1) {
        let passFixes = 0;
        dates.forEach(date => {
          const dateIso = iso(date);
          const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
          const current = wishDiffSummaryForDate(dateIso, storeKey, expectation);
          const assignments = uniqueAssignments(dateIso, storeKey)
            .slice()
            .sort((a,b) => (parseRange(b.time)[1] - parseRange(b.time)[0]) - (parseRange(a.time)[1] - parseRange(a.time)[0]));
          let best = null;
          assignments.forEach(oldAssignment => {
            const key = noMasterV62CanonicalName(oldAssignment.name);
            const person = byName.get(key) || findStaff(oldAssignment.name) || { name: oldAssignment.name, stores: [storeKey], times: noMasterFallbackTimesForStore(storeKey), support: Boolean(oldAssignment.support) };
            const oldRange = parseRange(oldAssignment.time);
            const oldHours = Math.max(1, oldRange[1] - oldRange[0]);
            const times = new Set();
            noMasterV62CandidateTimes(person, storeKey, dateIso, true).forEach(row => times.add(row.time));
            noMasterFallbackTimesForStore(storeKey).forEach(time => times.add(time));
            Array.from(times).forEach(newTime => {
              const normalized = normalizeTimeInput(newTime) || newTime;
              if (!normalized || normalized === oldAssignment.time) return;
              const range = parseRange(normalized);
              const hours = Math.max(1, range[1] - range[0]);
              if (hours > oldHours) return;
              if (noMasterV64ReasonForTimeReplace(dateIso, storeKey, person, normalized) !== "ok") return;
              const nextAssignments = assignments.filter(a => assignmentKey(a) !== assignmentKey(oldAssignment));
              nextAssignments.push({ name: oldAssignment.name, time: normalized, support: Boolean(oldAssignment.support), noMaster: true, generatedBy: "v64Compress" });
              const next = wishDiffSummaryFromAssignments(nextAssignments, storeKey, expectation);
              const scoreGain = current.score - next.score;
              const surplusGain = current.surplus - next.surplus;
              const shortagePenalty = next.shortage - current.shortage;
              if (scoreGain <= 0 && surplusGain <= 0) return;
              if (shortagePenalty > 1) return;
              const totalScore = scoreGain * 100 + surplusGain * 80 - shortagePenalty * 220 + (oldHours - hours) * 8;
              if (!best || totalScore > best.totalScore) {
                best = { dateIso, oldAssignment, person, newTime: normalized, totalScore, next, current };
              }
            });
          });
          if (best) {
            removeShiftFromDay(best.dateIso, storeKey, best.oldAssignment);
            if (noMasterV62DirectAddShift(best.dateIso, storeKey, best.person, best.newTime)) {
              passFixes += 1;
              totalFixes += 1;
            } else {
              noMasterV62DirectAddShift(best.dateIso, storeKey, best.person, best.oldAssignment.time);
            }
          }
        });
        if (!passFixes) break;
      }
      diagnostics.compressRuns = (diagnostics.compressRuns || 0) + totalFixes;
      return totalFixes;
    }

    function noMasterV84TimeLabel(startHour, endHour) {
      function label(hour) {
        if (hour === 24) return "24";
        if (hour > 24) return String(hour - 24);
        return String(hour);
      }
      return normalizeTimeInput(
        `${label(startHour)}-${label(endHour)}`
      );
    }

    function noMasterV84TrimCandidates(oldTime) {
      const [start, end] = parseRange(oldTime);
      const duration = end - start;
      const rows = new Set();

      if (duration <= 2) return [];

      // 片側だけを削る候補。
      for (let cut = 1; cut <= Math.min(4, duration - 2); cut += 1) {
        const endTrim = noMasterV84TimeLabel(start, end - cut);
        const startTrim = noMasterV84TimeLabel(start + cut, end);
        if (endTrim) rows.add(endTrim);
        if (startTrim) rows.add(startTrim);
      }

      // 両側を削る候補。最低2時間は残す。
      for (let left = 1; left <= 3; left += 1) {
        for (let right = 1; right <= 3; right += 1) {
          if (duration - left - right < 2) continue;
          const trimmed = noMasterV84TimeLabel(
            start + left,
            end - right
          );
          if (trimmed) rows.add(trimmed);
        }
      }

      rows.delete(normalizeTimeInput(oldTime) || oldTime);
      return [...rows];
    }

    function noMasterV84IsProtectedAssignment(
      dateIso,
      storeKey,
      assignment
    ) {
      if (isSubmittedWorkAssignment(dateIso, storeKey, assignment)) {
        return true;
      }

      if (typeof noMasterV81FixedRuleFor === "function") {
        const rule = noMasterV81FixedRuleFor(
          dateIso,
          storeKey,
          assignment.name
        );
        const normalized = normalizeTimeInput(assignment.time) ||
          assignment.time;

        if (
          rule &&
          !rule.blocked &&
          normalized === rule.time
        ) {
          return true;
        }
      }

      return false;
    }

    function noMasterV89CompressOugichoStrong(
      dates,
      storeKey,
      options = {},
      diagnostics = {}
    ) {
      let totalFixes = 0;
      const active = noMasterV62ActiveStaffForStore(storeKey);
      const byName = new Map(
        active.map(person => [
          noMasterV62CanonicalName(person.name),
          person
        ])
      );

      diagnostics.surplusTrimLog =
        diagnostics.surplusTrimLog || [];

      const beforeQuality = noMasterCoverageQualityForStore(
        dates,
        storeKey,
        options
      );

      const maxPass = 12;

      for (let pass = 0; pass < maxPass; pass += 1) {
        let passFixes = 0;

        dates.forEach(date => {
          const dateIso = iso(date);
          const expectation =
            wishThirtyMinuteExpectationForDate(
              dateIso,
              storeKey,
              options
            );
          const current =
            wishDiffSummaryForDate(
              dateIso,
              storeKey,
              expectation
            );

          const assignments =
            uniqueAssignments(dateIso, storeKey)
              .slice()
              .sort((a, b) => {
                const aRange = parseRange(a.time);
                const bRange = parseRange(b.time);
                return (
                  (bRange[1] - bRange[0]) -
                  (aRange[1] - aRange[0])
                );
              });

          let best = null;

          assignments.forEach(oldAssignment => {
            if (
              noMasterV84IsProtectedAssignment(
                dateIso,
                storeKey,
                oldAssignment
              )
            ) {
              return;
            }

            const key =
              noMasterV62CanonicalName(
                oldAssignment.name
              );
            const person =
              byName.get(key) ||
              findStaff(oldAssignment.name) || {
                name: oldAssignment.name,
                stores: [storeKey],
                times: noMasterFallbackTimesForStore(storeKey),
                support: Boolean(oldAssignment.support)
              };

            const oldRange = parseRange(oldAssignment.time);
            const oldHours =
              Math.max(1, oldRange[1] - oldRange[0]);
            const times = new Set();

            noMasterV62CandidateTimes(
              person,
              storeKey,
              dateIso,
              true
            ).forEach(row => times.add(row.time));

            noMasterFallbackTimesForStore(storeKey)
              .forEach(time => times.add(time));

            noMasterV84TrimCandidates(oldAssignment.time)
              .forEach(time => times.add(time));

            Array.from(times).forEach(newTime => {
              const normalized =
                normalizeTimeInput(newTime) || newTime;

              if (
                !normalized ||
                normalized === oldAssignment.time
              ) {
                return;
              }

              const range = parseRange(normalized);
              const hours =
                Math.max(1, range[1] - range[0]);

              if (hours >= oldHours) return;

              if (
                noMasterV64ReasonForTimeReplace(
                  dateIso,
                  storeKey,
                  person,
                  normalized
                ) !== "ok"
              ) {
                return;
              }

              const nextAssignments =
                assignments.filter(
                  assignment =>
                    assignmentKey(assignment) !==
                    assignmentKey(oldAssignment)
                );

              nextAssignments.push({
                name: oldAssignment.name,
                time: normalized,
                support: Boolean(oldAssignment.support),
                noMaster: true,
                generatedBy: "v84ZeroShortageTrim"
              });

              const next =
                wishDiffSummaryFromAssignments(
                  nextAssignments,
                  storeKey,
                  expectation
                );

              const shortageChange =
                next.shortage - current.shortage;
              const surplusGain =
                current.surplus - next.surplus;

              // 不足は一切増やさず、余剰が減る変更だけ。
              if (shortageChange > 0) return;
              if (surplusGain <= 0) return;

              const removedHours = oldHours - hours;
              const totalScore =
                surplusGain * 1000 +
                removedHours * 20 -
                next.surplus;

              if (!best || totalScore > best.totalScore) {
                best = {
                  dateIso,
                  oldAssignment,
                  person,
                  newTime: normalized,
                  totalScore,
                  current,
                  next,
                  surplusGain,
                  removedHours
                };
              }
            });
          });

          if (!best) return;

          removeShiftFromDay(
            best.dateIso,
            storeKey,
            best.oldAssignment
          );

          if (
            noMasterV62DirectAddShift(
              best.dateIso,
              storeKey,
              best.person,
              best.newTime
            )
          ) {
            passFixes += 1;
            totalFixes += 1;
            diagnostics.surplusTrimLog.push({
              dateIso: best.dateIso,
              name: best.oldAssignment.name,
              before: best.oldAssignment.time,
              after: best.newTime,
              surplusBefore: best.current.surplus,
              surplusAfter: best.next.surplus,
              surplusReduced: best.surplusGain,
              removedHours: best.removedHours
            });
          } else {
            noMasterV62DirectAddShift(
              best.dateIso,
              storeKey,
              best.person,
              best.oldAssignment.time
            );
          }
        });

        if (!passFixes) break;
      }

      const afterQuality =
        noMasterCoverageQualityForStore(
          dates,
          storeKey,
          options
        );

      diagnostics.compressRuns =
        (diagnostics.compressRuns || 0) +
        totalFixes;

      diagnostics.surplusTrimSummary = {
        before: beforeQuality.surplusCells,
        after: afterQuality.surplusCells,
        reduced:
          beforeQuality.surplusCells -
          afterQuality.surplusCells,
        shortageBefore: beforeQuality.shortageCells,
        shortageAfter: afterQuality.shortageCells,
        fixes: totalFixes
      };

      return totalFixes;
    }



    function noMasterV90SnapshotDateCells(dateIso, storeKey) {
      const snapshot = {};
      slots.forEach(slot => {
        snapshot[slot] = ensureCell(dateIso, storeKey, slot)
          .map(row => ({ ...row }));
      });
      return snapshot;
    }

    function noMasterV90RestoreDateCells(
      dateIso,
      storeKey,
      snapshot
    ) {
      slots.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        cell.splice(
          0,
          cell.length,
          ...(snapshot[slot] || []).map(row => ({ ...row }))
        );
      });
    }

    function noMasterV90OneHourTrimCandidates(time) {
      const [start, end] = parseRange(time);
      const duration = end - start;
      if (duration <= 2) return [];

      const rows = [];
      const endTrim = noMasterV84TimeLabel(start, end - 1);
      const startTrim = noMasterV84TimeLabel(start + 1, end);

      if (endTrim) rows.push(endTrim);
      if (startTrim && startTrim !== endTrim) rows.push(startTrim);
      return rows;
    }

    function noMasterV90EastMicroTrim(
      dates,
      storeKey,
      options = {},
      diagnostics = {}
    ) {
      if (storeKey !== "higashicho") return 0;

      diagnostics.eastMicroTrimLog =
        diagnostics.eastMicroTrimLog || [];
      diagnostics.eastMicroTrimRejected =
        diagnostics.eastMicroTrimRejected || [];
      const rejectedKeys = new Set(
        diagnostics.eastMicroTrimRejected.map(row =>
          [
            row.dateIso,
            row.name,
            row.before,
            row.attempted,
            row.reason
          ].join("|")
        )
      );

      const pushRejected = row => {
        const key = [
          row.dateIso,
          row.name,
          row.before,
          row.attempted,
          row.reason
        ].join("|");
        if (rejectedKeys.has(key)) return;
        rejectedKeys.add(key);
        diagnostics.eastMicroTrimRejected.push(row);
      };

      const baseline = noMasterCoverageQualityForStore(
        dates,
        storeKey,
        options
      );

      if (baseline.shortageCells !== 0) {
        diagnostics.eastMicroTrimSummary = {
          before: baseline.surplusCells,
          after: baseline.surplusCells,
          reduced: 0,
          fixes: 0,
          skipped: true,
          reason: "baseline-shortage-not-zero"
        };
        return 0;
      }

      let fixes = 0;
      const maxFixes = 32;

      while (fixes < maxFixes) {
        let best = null;

        for (const date of dates) {
          const dateIso = typeof date === "string" ? date : iso(date);
          const expectation =
            wishThirtyMinuteExpectationForDate(
              dateIso,
              storeKey,
              options
            );
          const before =
            wishDiffSummaryForDate(
              dateIso,
              storeKey,
              expectation
            );

          if (before.shortage !== 0 || before.surplus <= 0) {
            continue;
          }

          const assignments =
            uniqueAssignments(dateIso, storeKey).slice();

          for (const assignment of assignments) {
            if (
              noMasterV84IsProtectedAssignment(
                dateIso,
                storeKey,
                assignment
              )
            ) {
              continue;
            }

            const person =
              findStaff(assignment.name) || {
                name: assignment.name,
                stores: [storeKey],
                support: Boolean(assignment.support)
              };

            for (const newTime of
              noMasterV90OneHourTrimCandidates(
                assignment.time
              )
            ) {
              if (
                noMasterV64ReasonForTimeReplace(
                  dateIso,
                  storeKey,
                  person,
                  newTime
                ) !== "ok"
              ) {
                continue;
              }

              const snapshot =
                noMasterV90SnapshotDateCells(
                  dateIso,
                  storeKey
                );

              removeShiftFromDay(
                dateIso,
                storeKey,
                assignment
              );

              const added = noMasterV62DirectAddShift(
                dateIso,
                storeKey,
                person,
                newTime
              );

              const after =
                wishDiffSummaryForDate(
                  dateIso,
                  storeKey,
                  expectation
                );

              noMasterV90RestoreDateCells(
                dateIso,
                storeKey,
                snapshot
              );

              if (!added) {
                pushRejected({
                  dateIso,
                  name: assignment.name,
                  before: assignment.time,
                  attempted: newTime,
                  reason: "add-failed"
                });
                continue;
              }

              if (after.shortage !== 0) {
                pushRejected({
                  dateIso,
                  name: assignment.name,
                  before: assignment.time,
                  attempted: newTime,
                  reason: "shortage-created",
                  shortage: after.shortage
                });
                continue;
              }

              const gain = before.surplus - after.surplus;
              if (gain <= 0) continue;

              const score = gain * 1000 - after.surplus;
              if (!best || score > best.score) {
                best = {
                  dateIso,
                  assignment,
                  person,
                  newTime,
                  before,
                  after,
                  gain,
                  score
                };
              }
            }
          }
        }

        if (!best) {
          diagnostics.eastMicroTrimStopReason =
            "no-safe-candidate";
          break;
        }

        const finalSnapshot =
          noMasterV90SnapshotDateCells(
            best.dateIso,
            storeKey
          );

        removeShiftFromDay(
          best.dateIso,
          storeKey,
          best.assignment
        );

        const finalAdded = noMasterV62DirectAddShift(
          best.dateIso,
          storeKey,
          best.person,
          best.newTime
        );

        const finalExpectation =
          wishThirtyMinuteExpectationForDate(
            best.dateIso,
            storeKey,
            options
          );
        const finalAfter =
          wishDiffSummaryForDate(
            best.dateIso,
            storeKey,
            finalExpectation
          );

        if (!finalAdded || finalAfter.shortage !== 0) {
          noMasterV90RestoreDateCells(
            best.dateIso,
            storeKey,
            finalSnapshot
          );
          break;
        }

        fixes += 1;
        diagnostics.eastMicroTrimLog.push({
          dateIso: best.dateIso,
          name: best.assignment.name,
          before: best.assignment.time,
          after: best.newTime,
          surplusBefore: best.before.surplus,
          surplusAfter: finalAfter.surplus,
          surplusReduced:
            best.before.surplus -
            finalAfter.surplus
        });
      }

      const finalQuality =
        noMasterCoverageQualityForStore(
          dates,
          storeKey,
          options
        );

      diagnostics.eastMicroTrimSummary = {
        before: baseline.surplusCells,
        after: finalQuality.surplusCells,
        reduced:
          baseline.surplusCells -
          finalQuality.surplusCells,
        shortageBefore: baseline.shortageCells,
        shortageAfter: finalQuality.shortageCells,
        fixes,
        maxFixes,
        stoppedNaturally:
          fixes < maxFixes,
        stopReason:
          diagnostics.eastMicroTrimStopReason ||
          (fixes >= maxFixes
            ? "max-fixes-reached"
            : "completed"),
        rejectedUnique:
          diagnostics.eastMicroTrimRejected.length
      };

      return fixes;
    }

    function noMasterV64CompressSurplusByTime(
      dates,
      storeKey,
      options = {},
      diagnostics = {}
    ) {
      diagnostics.compressionEngine =
        storeKey === "ougicho"
          ? "ougicho-strong-v84"
          : "higashicho-legacy-v83";

      if (storeKey === "ougicho") {
        return noMasterV89CompressOugichoStrong(
          dates,
          storeKey,
          options,
          diagnostics
        );
      }

      const legacyFixes =
        noMasterV89CompressHigashichoLegacy(
          dates,
          storeKey,
          options,
          diagnostics
        );

      const microFixes =
        noMasterV90EastMicroTrim(
          dates,
          storeKey,
          options,
          diagnostics
        );

      diagnostics.compressionEngine =
        "higashicho-legacy-v83+micro-v90";

      return legacyFixes + microFixes;
    }

    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = {
        blocked: {},
        noCandidateDates: [],
        submittedAdded: 0,
        teacherAdds: 0,
        targetAdds: 0,
        relaxedAdds: 0,
        finalRescueAdds: 0,
        compressRuns: 0,
        band
      };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true,
        relaxedWeeklyMax: false,
        relaxedTimeFallback: false
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();

      count("afterClear");

      // 1) 出勤希望は最優先。ただし休み希望・同日二重配置などの絶対NGは守る。
      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = findStaff(row.name);
          if (!person) return;
          if (noMasterV60DirectAddShift(dateIso, storeKey, person, row.time, storeOptions)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      // 2) 各日の目標人数まで、店の全スタッフからスコア順で入れる。
      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV60FillDateToTarget(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds");
      });
      count("afterDailyTeacherTargets");

      // 3) 週合計下限に届かない場合、最も不足している日から追加。
      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 160) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 20 + targetGap * 120 - quality.surplus * 3 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV60PickBestCandidateForDate(row.dateIso, storeKey, storeOptions, diagnostics);
          if (!picked) continue;
          if (noMasterV60DirectAddShift(row.dateIso, storeKey, picked.person, picked.time, storeOptions)) {
            diagnostics.targetAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterWeeklyLowerRescue");

      // 4) まだ足りない時だけ、週上限と時間フォールバックを少し緩めて救済。
      if (wishCountAssignmentsForDates(dates, storeKey) < band.lower) {
        storeOptions.relaxedWeeklyMax = true;
        storeOptions.relaxedTimeFallback = true;
        let relaxGuard = 0;
        while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && relaxGuard < 220) {
          const dateCandidates = dates.map(date => {
            const dateIso = iso(date);
            const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
            return { dateIso, score: quality.shortage * 30 - uniqueAssignments(dateIso, storeKey).length * 8 };
          }).sort((a,b) => b.score - a.score);
          let added = false;
          for (const row of dateCandidates) {
            const picked = noMasterV60PickBestCandidateForDate(row.dateIso, storeKey, storeOptions, diagnostics);
            if (!picked) continue;
            if (noMasterV60DirectAddShift(row.dateIso, storeKey, picked.person, picked.time, storeOptions)) {
              diagnostics.relaxedAdds += 1;
              added = true;
              break;
            }
          }
          if (!added) break;
          relaxGuard += 1;
        }
      }
      count("afterRelaxedWeeklyRescue");

      // 正本なし生成では、既存の30分補正が少数生成をさらに削るため呼ばない。
      const wishLog = {
        version: "β4.10.36.64",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }



    // β4.10.36.64 正本なし・保存JSONスタッフプール生成版
    // 36.60 ではスコア候補が少数スタッフへ偏り、weeklyMax / doubleBooking で伸びなかった。
    // 36.61 は「日ごとに1人1本」を絶対条件にし、店で働ける全スタッフをローテーションして直接埋める。
    function noMasterV61ActiveStaffForStore(storeKey) {
      return (staff || [])
        .filter(person => person && person.name)
        .filter(person => canWorkAtStore(person, storeKey))
        .filter(person => !isInactiveStaff(person))
        .filter(person => !isManualSupportPerson(person));
    }

    function noMasterV61WeeklyCount(dates, personName) {
      const name = canonicalStaffName(personName);
      return dates.reduce((sum, date) => {
        const dateIso = typeof date === "string" ? date : iso(date);
        let seen = false;
        storeOrder.forEach(storeKey => {
          if (uniqueAssignments(dateIso, storeKey).some(row => canonicalStaffName(row.name) === name)) seen = true;
        });
        return sum + (seen ? 1 : 0);
      }, 0);
    }

    function noMasterV61Reason(dateIso, storeKey, person, time) {
      if (!person) return "noPerson";
      if (!canWorkAtStore(person, storeKey)) return "storeMismatch";
      if (isInactiveStaff(person)) return "inactive";
      if (isManualSupportPerson(person)) return "manualSupport";
      if (isUnavailable(person.name, dateIso)) return "unavailable";
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) return "incompatible";
      // 実務上は同一人物の同日複数本は避ける。別店舗も同日NG。
      if (isAssignedAnywhere(dateIso, person.name)) return "doubleBooking";
      if (!assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return "badTime";
      return "ok";
    }

    function noMasterV61CandidateTimes(person, storeKey, dateIso, relaxed = false) {
      const map = new Map();
      function add(time, score, source) {
        const normalized = normalizeTimeInput(time) || time;
        if (!normalized) return;
        if (!assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return;
        const prev = map.get(normalized);
        if (!prev || score > prev.score) map.set(normalized, { time: normalized, score, source });
      }
      submittedWorkRequestsFor(dateIso, storeKey)
        .filter(row => canonicalStaffName(row.name) === canonicalStaffName(person.name))
        .forEach(row => add(row.time, 50000, "submittedWorkRequest"));
      (person.times || []).forEach(time => add(time, 2200, "staffTimes"));
      candidateTimesForGeneration(person, storeKey, dateIso).forEach(time => add(time, 1700, "generationTimes"));
      noMasterFallbackTimesForStore(storeKey).forEach(time => add(time, relaxed ? 700 : 250, "fallback"));
      return [...map.values()];
    }

    function noMasterV61DirectAddShift(dateIso, storeKey, person, time) {
      const normalized = normalizeTimeInput(time) || time;
      if (noMasterV61Reason(dateIso, storeKey, person, normalized) !== "ok") return false;
      const targets = assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      const assignment = { name: person.name, time: normalized, support: Boolean(person.support), noMaster: true, generatedBy: "v61" };
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function noMasterV61PickBest(dateIso, storeKey, options = {}, diagnostics = {}, relaxed = false) {
      const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
      const assignments = uniqueAssignments(dateIso, storeKey);
      const current = wishDiffSummaryForDate(dateIso, storeKey, expectation);
      const dailyTarget = teacherWishTargetCountForDateStore(dateIso, storeKey);
      const people = noMasterV61ActiveStaffForStore(storeKey)
        .slice()
        .sort((a,b) => {
          const aw = noMasterV61WeeklyCount(options.wishWeekDates || [], a.name);
          const bw = noMasterV61WeeklyCount(options.wishWeekDates || [], b.name);
          const ad = matchesDay(a, dateIso) ? 0 : 1;
          const bd = matchesDay(b, dateIso) ? 0 : 1;
          return aw - bw || ad - bd || String(a.name).localeCompare(String(b.name), "ja");
        });
      let best = null;
      people.forEach(person => {
        noMasterV61CandidateTimes(person, storeKey, dateIso, relaxed).forEach(row => {
          const reason = noMasterV61Reason(dateIso, storeKey, person, row.time);
          if (reason !== "ok") {
            diagnostics.blocked[reason] = (diagnostics.blocked[reason] || 0) + 1;
            return;
          }
          const simulated = assignments.concat([{ name: person.name, time: row.time, support: Boolean(person.support) }]);
          const next = wishDiffSummaryFromAssignments(simulated, storeKey, expectation);
          const coverageGain = current.score - next.score;
          const slotGain = wishCoverageGain(dateIso, storeKey, row.time);
          const weekly = noMasterV61WeeklyCount(options.wishWeekDates || [], person.name);
          const dayScore = matchesDay(person, dateIso) ? 900 : (relaxed ? -80 : -350);
          const submittedBoost = row.source === "submittedWorkRequest" ? 40000 : 0;
          const length = Math.max(1, parseRange(row.time)[1] - parseRange(row.time)[0]);
          const dailyNeed = Math.max(0, dailyTarget - assignments.length) * 250;
          // weekly は禁止ではなく分散用の減点。36.60 の詰まりを作った hard weeklyMax は使わない。
          const totalScore = submittedBoost + coverageGain * 2200 + slotGain * 1300 + row.score + dayScore + Math.min(length, 9) * 100 + dailyNeed - weekly * 900;
          if (!best || totalScore > best.totalScore) best = { person, time: row.time, source: row.source, totalScore, coverageGain, slotGain };
        });
      });
      if (!best) diagnostics.noCandidateDates.push({ dateIso, storeKey, count: assignments.length, target: dailyTarget, relaxed: Boolean(relaxed) });
      return best;
    }

    function noMasterV61FillDate(dateIso, storeKey, target, options, diagnostics, counterKey, relaxed = false) {
      let guard = 0;
      while (uniqueAssignments(dateIso, storeKey).length < target && wishCountAssignmentsForDates(options.wishWeekDates, storeKey) < options.wishWeekUpperCap && guard < 80) {
        const picked = noMasterV61PickBest(dateIso, storeKey, options, diagnostics, relaxed);
        if (!picked) break;
        if (noMasterV61DirectAddShift(dateIso, storeKey, picked.person, picked.time)) {
          diagnostics[counterKey] = (diagnostics[counterKey] || 0) + 1;
        } else {
          diagnostics.blocked.addFailed = (diagnostics.blocked.addFailed || 0) + 1;
          break;
        }
        guard += 1;
      }
    }

    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = { blocked: {}, noCandidateDates: [], submittedAdded: 0, teacherAdds: 0, targetAdds: 0, relaxedAdds: 0, finalRescueAdds: 0, compressRuns: 0, band };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();

      count("afterClear");

      // 出勤希望は最優先。
      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = findStaff(row.name);
          if (!person) return;
          if (noMasterV61DirectAddShift(dateIso, storeKey, person, row.time)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      // 各日の目標人数まで直接ローテ。
      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV61FillDate(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds", false);
      });
      count("afterDailyTeacherTargets");

      // 週下限まで、足りない日へ追加。
      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 180) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 25 + targetGap * 180 - uniqueAssignments(dateIso, storeKey).length * 8 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV61PickBest(row.dateIso, storeKey, storeOptions, diagnostics, false);
          if (!picked) continue;
          if (noMasterV61DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.targetAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterWeeklyLowerRescue");

      // まだ足りなければ、曜日不一致・標準時間候補をさらに許容。
      guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 220) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          return { dateIso, score: quality.shortage * 35 - uniqueAssignments(dateIso, storeKey).length * 6 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV61PickBest(row.dateIso, storeKey, storeOptions, diagnostics, true);
          if (!picked) continue;
          if (noMasterV61DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.relaxedAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterRelaxedWeeklyRescue");

      noMasterV64CompressSurplusByTime(dates, storeKey, storeOptions, diagnostics);
      count("afterSurplusCompression");

      const wishLog = {
        version: "β4.10.36.64",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }



    // β4.10.36.64 正本なし・保存JSONスタッフプール生成版
    // 36.61 でも候補が松永/降旗/ディパックへ偏ったため、生成候補を実行中の global staff ではなく
    // JSON欄から取り込んだフル保存JSONの staff 配列から直接作る。これで「候補プールが本当に何人いるか」を固定する。
    var noMasterV62SourceStaff = null;

    function noMasterV62CanonicalName(name) {
      return canonicalStaffName(name);
    }

    function noMasterV62IsInactive(person) {
      return Boolean(person && (
        person.inactive ||
        ((person.tags || []).some(tag => String(tag).includes("解雇") || String(tag).includes("退職") || String(tag).includes("自動配置停止")))
      ));
    }

    function noMasterV62IsSupport(person) {
      return Boolean(person && (person.support || person.name === "まこつ。" || person.name === "りえ"));
    }

    function noMasterV62StaffPool() {
      const pool = Array.isArray(noMasterV62SourceStaff) && noMasterV62SourceStaff.length ? noMasterV62SourceStaff : staff;
      const seen = new Set();
      return (pool || []).filter(person => {
        if (!person || !person.name) return false;
        const name = noMasterV62CanonicalName(person.name);
        if (seen.has(name)) return false;
        seen.add(name);
        return true;
      });
    }

    function noMasterV62ActiveStaffForStore(storeKey) {
      return noMasterV62StaffPool()
        .filter(person => Array.isArray(person.stores) && person.stores.includes(storeKey))
        .filter(person => !noMasterV62IsInactive(person))
        .filter(person => !noMasterV62IsSupport(person));
    }

    function noMasterV62WeeklyCount(dates, personName) {
      const name = noMasterV62CanonicalName(personName);
      return dates.reduce((sum, date) => {
        const dateIso = typeof date === "string" ? date : iso(date);
        let seen = false;
        storeOrder.forEach(key => {
          if (uniqueAssignments(dateIso, key).some(row => noMasterV62CanonicalName(row.name) === name)) seen = true;
        });
        return sum + (seen ? 1 : 0);
      }, 0);
    }

    function noMasterV62DayCount(dateIso, personName) {
      const name = noMasterV62CanonicalName(personName);
      let count = 0;
      storeOrder.forEach(key => {
        uniqueAssignments(dateIso, key).forEach(row => {
          if (noMasterV62CanonicalName(row.name) === name) count += 1;
        });
      });
      return count;
    }

    function noMasterV62Reason(dateIso, storeKey, person, time) {
      if (!person) return "noPerson";
      if (!Array.isArray(person.stores) || !person.stores.includes(storeKey)) return "storeMismatch";
      if (noMasterV62IsInactive(person)) return "inactive";
      if (noMasterV62IsSupport(person)) return "manualSupport";
      if (isUnavailable(person.name, dateIso)) return "unavailable";
      if (hasIncompatiblePerson(dateIso, storeKey, person.name)) return "incompatible";
      if (isAssignedAnywhere(dateIso, person.name)) return "doubleBooking";
      if (!assignmentSlots(time, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return "badTime";
      return "ok";
    }

    function noMasterV62CandidateTimes(person, storeKey, dateIso, relaxed = false) {
      const map = new Map();
      function add(time, score, source) {
        const normalized = normalizeTimeInput(time) || time;
        if (!normalized) return;
        if (!assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return;
        const prev = map.get(normalized);
        if (!prev || score > prev.score) map.set(normalized, { time: normalized, score, source });
      }
      submittedWorkRequestsFor(dateIso, storeKey)
        .filter(row => noMasterV62CanonicalName(row.name) === noMasterV62CanonicalName(person.name))
        .forEach(row => add(row.time, 60000, "submittedWorkRequest"));
      (person.times || []).forEach(time => add(time, 3200, "snapshotStaffTimes"));
      (person.slots || []).forEach(slot => add(slot, 2200, "snapshotSlots"));
      noMasterFallbackTimesForStore(storeKey).forEach(time => add(time, relaxed ? 1400 : 500, "fallback"));
      return [...map.values()];
    }

    function noMasterV62DirectAddShift(dateIso, storeKey, person, time) {
      const normalized = normalizeTimeInput(time) || time;
      if (noMasterV62Reason(dateIso, storeKey, person, normalized) !== "ok") return false;
      const targets = assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false });
      if (!targets.length) return false;
      const assignment = { name: noMasterV62CanonicalName(person.name), time: normalized, support: Boolean(person.support), noMaster: true, generatedBy: "v62" };
      let changed = false;
      targets.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
          changed = true;
        }
      });
      return changed;
    }

    function noMasterV62PickBest(dateIso, storeKey, options = {}, diagnostics = {}, relaxed = false) {
      const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
      const assignments = uniqueAssignments(dateIso, storeKey);
      const active = noMasterV62ActiveStaffForStore(storeKey);

      diagnostics.poolSize = diagnostics.poolSize || {};
      diagnostics.poolSize[storeKey] = active.length;
      diagnostics.pickBestRebuilt = true;

      // 現在の30分カバーを1回だけ作る。
      const actual = wishCoverageMapFromAssignments(assignments, storeKey);
      const allKeys = new Set([...expectation.keys(), ...actual.keys()]);
      let currentShortage = 0;
      let currentSurplus = 0;

      allKeys.forEach(key => {
        const expected = (expectation.get(key) || {}).expectedCount || 0;
        const got = actual.get(key) || 0;
        if (expected > got) currentShortage += expected - got;
        if (got > expected) currentSurplus += got - expected;
      });

      const currentScore = currentShortage * 12 + currentSurplus * 9;

      // 現在の全店舗配置を日単位で1回だけ索引化。
      const assignedNames = new Set();
      const storeAssignedNames = new Set();
      storeOrder.forEach(key => {
        uniqueAssignments(dateIso, key).forEach(row => {
          const name = noMasterV62CanonicalName(row.name);
          assignedNames.add(name);
          if (key === storeKey) storeAssignedNames.add(name);
        });
      });

      // 候補時間、時間カバー、週回数、日回数、固定判定を呼出内で共有。
      const candidateCache = new Map();
      const coverageCache = new Map();
      const slotGainCache = new Map();
      const weeklyCache = new Map();
      const dailyCache = new Map();
      const unavailableCache = new Map();
      const incompatibleCache = new Map();

      function candidateRows(person) {
        const name = noMasterV62CanonicalName(person.name);
        const key = `${name}|${relaxed ? 1 : 0}`;

        if (!candidateCache.has(key)) {
          const fixedRule =
            typeof noMasterV81FixedRuleFor === "function"
              ? noMasterV81FixedRuleFor(dateIso, storeKey, name)
              : null;

          if (fixedRule) {
            candidateCache.set(
              key,
              fixedRule.blocked
                ? []
                : [{
                    time: fixedRule.time,
                    score: 100000,
                    source: "fixedRule"
                  }]
            );
          } else {
            candidateCache.set(
              key,
              noMasterV62CandidateTimes(
                person,
                storeKey,
                dateIso,
                relaxed
              )
            );
          }
        }

        return candidateCache.get(key);
      }

      function candidateCoverage(time) {
        const normalized = normalizeTimeInput(time) || time;
        if (!coverageCache.has(normalized)) {
          coverageCache.set(
            normalized,
            wishCoverageMapFromAssignments(
              [{ name: "__candidate__", time: normalized, support: false }],
              storeKey
            )
          );
        }
        return coverageCache.get(normalized);
      }

      function slotGainFor(time) {
        const normalized = normalizeTimeInput(time) || time;
        if (!slotGainCache.has(normalized)) {
          let gain = 0;
          assignmentSlots(normalized, {
            allowPartialOverlap: true,
            requireFullSlotCoverage: false
          }).forEach(slot => {
            gain += wishSlotNeed(dateIso, storeKey, slot);
          });
          slotGainCache.set(normalized, gain);
        }
        return slotGainCache.get(normalized);
      }

      function weeklyFor(name) {
        const canonical = noMasterV62CanonicalName(name);
        if (!weeklyCache.has(canonical)) {
          weeklyCache.set(
            canonical,
            noMasterV62WeeklyCount(options.wishWeekDates || [], canonical)
          );
        }
        return weeklyCache.get(canonical);
      }

      function dailyFor(name) {
        const canonical = noMasterV62CanonicalName(name);
        if (!dailyCache.has(canonical)) {
          dailyCache.set(canonical, noMasterV62DayCount(dateIso, canonical));
        }
        return dailyCache.get(canonical);
      }

      function unavailableFor(name) {
        const canonical = noMasterV62CanonicalName(name);
        if (!unavailableCache.has(canonical)) {
          unavailableCache.set(canonical, isUnavailable(canonical, dateIso));
        }
        return unavailableCache.get(canonical);
      }

      function incompatibleFor(name) {
        const canonical = noMasterV62CanonicalName(name);
        if (!incompatibleCache.has(canonical)) {
          let incompatible = false;
          storeAssignedNames.forEach(existing => {
            if (!incompatible && areIncompatible(existing, canonical)) {
              incompatible = true;
            }
          });
          incompatibleCache.set(canonical, incompatible);
        }
        return incompatibleCache.get(canonical);
      }

      let best = null;

      active.forEach(person => {
        const personName = noMasterV62CanonicalName(person.name);
        const rows = candidateRows(person);

        let baseReason = "ok";
        if (unavailableFor(personName)) baseReason = "unavailable";
        else if (incompatibleFor(personName)) baseReason = "incompatible";
        else if (assignedNames.has(personName)) baseReason = "doubleBooking";

        if (baseReason !== "ok") {
          diagnostics.blocked[baseReason] =
            (diagnostics.blocked[baseReason] || 0) + rows.length;
          return;
        }

        const weekly = weeklyFor(personName);
        const alreadyDaily = dailyFor(personName);
        const dayScore = matchesDay(person, dateIso)
          ? 850
          : (relaxed ? -40 : -250);

        rows.forEach(row => {
          const normalized = normalizeTimeInput(row.time) || row.time;
          const coverage = candidateCoverage(normalized);

          if (!coverage.size) {
            diagnostics.blocked.badTime =
              (diagnostics.blocked.badTime || 0) + 1;
            return;
          }

          let shortageDelta = 0;
          let surplusDelta = 0;

          coverage.forEach((candidateCount, key) => {
            const expected = (expectation.get(key) || {}).expectedCount || 0;
            const before = actual.get(key) || 0;
            const after = before + candidateCount;

            shortageDelta +=
              Math.max(0, expected - after) -
              Math.max(0, expected - before);

            surplusDelta +=
              Math.max(0, after - expected) -
              Math.max(0, before - expected);
          });

          const nextScore =
            (currentShortage + shortageDelta) * 12 +
            (currentSurplus + surplusDelta) * 9;

          const coverageGain = currentScore - nextScore;
          const slotGain = slotGainFor(normalized);
          const submittedBoost =
            row.source === "submittedWorkRequest" ? 50000 : 0;

          const lengthRange = parseRange(normalized);
          const length = Math.max(1, lengthRange[1] - lengthRange[0]);

          const totalScore =
            submittedBoost +
            coverageGain * 2600 +
            slotGain * 1600 +
            row.score +
            dayScore +
            Math.min(length, 9) * 90 -
            weekly * 550 -
            alreadyDaily * 20000;

          if (!best || totalScore > best.totalScore) {
            best = {
              person,
              time: normalized,
              source: row.source,
              totalScore,
              coverageGain,
              slotGain
            };
          }
        });
      });

      diagnostics.pickBestCacheStats = {
        candidates: candidateCache.size,
        coverageTimes: coverageCache.size,
        weeklyPeople: weeklyCache.size,
        dailyPeople: dailyCache.size
      };

      if (!best) {
        diagnostics.noCandidateDates.push({
          dateIso,
          storeKey,
          count: assignments.length,
          target: teacherWishTargetCountForDateStore(dateIso, storeKey),
          relaxed: Boolean(relaxed),
          poolSize: active.length
        });
      }

      return best;
    }

    function noMasterV62FillDate(dateIso, storeKey, target, options, diagnostics, counterKey, relaxed = false) {
      let guard = 0;
      while (uniqueAssignments(dateIso, storeKey).length < target && wishCountAssignmentsForDates(options.wishWeekDates, storeKey) < options.wishWeekUpperCap && guard < 120) {
        const picked = noMasterV62PickBest(dateIso, storeKey, options, diagnostics, relaxed);
        if (!picked) break;
        if (noMasterV62DirectAddShift(dateIso, storeKey, picked.person, picked.time)) {
          diagnostics[counterKey] = (diagnostics[counterKey] || 0) + 1;
        } else {
          diagnostics.blocked.addFailed = (diagnostics.blocked.addFailed || 0) + 1;
          break;
        }
        guard += 1;
      }
    }

    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = { blocked: {}, noCandidateDates: [], submittedAdded: 0, teacherAdds: 0, targetAdds: 0, relaxedAdds: 0, finalRescueAdds: 0, compressRuns: 0, band, poolSize: {} };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();
      diagnostics.poolSize[storeKey] = noMasterV62ActiveStaffForStore(storeKey).length;

      count("afterClear");

      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = noMasterV62ActiveStaffForStore(storeKey).find(p => noMasterV62CanonicalName(p.name) === noMasterV62CanonicalName(row.name));
          if (!person) return;
          if (noMasterV62DirectAddShift(dateIso, storeKey, person, row.time)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV62FillDate(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds", false);
      });
      count("afterDailyTeacherTargets");

      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 260) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 40 + targetGap * 220 - uniqueAssignments(dateIso, storeKey).length * 5 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV62PickBest(row.dateIso, storeKey, storeOptions, diagnostics, true);
          if (!picked) continue;
          if (noMasterV62DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.relaxedAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterRelaxedWeeklyRescue");

      const wishLog = {
        version: "β4.10.36.64",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        sourceStaffPool: diagnostics.poolSize[storeKey],
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }


    // 36.64: 履歴スタッフプールに加え、生成後に過剰セルを同一人物の短時間へ圧縮する。
    // 36.63: staff.stores だけを見ると保存JSON上の候補が 2名/1名に潰れるケースがあるため、
    // staffマスタ + 紙面履歴 + 既存schedule履歴から店舗別候補を復元する。
    function noMasterV63HistoryStaffForStore(storeKey) {
      const byName = new Map();
      function canonical(name) { return noMasterV62CanonicalName(name); }
      function baseByName(name) {
        const key = canonical(name);
        return noMasterV62StaffPool().find(p => canonical(p.name) === key) || staff.find(p => canonical(p.name) === key) || null;
      }
      function addPerson(rawName, source, storeHint = storeKey) {
        const cleanedRawName = noMasterV64CleanHistoryName(rawName);
        const name = canonicalStaffNameForStore(canonical(cleanedRawName), storeHint || storeKey);
        if (!name) return;
        const base = baseByName(name);
        if (base && (noMasterV62IsInactive(base) || noMasterV62IsSupport(base))) return;
        const mergedStores = new Set([storeKey]);
        if (base && Array.isArray(base.stores)) base.stores.forEach(k => mergedStores.add(k));
        const person = base ? { ...base, name: canonical(base.name), stores: [...mergedStores], historySource: source }
          : { name, stores: [storeKey], days: ["月","火","水","木","金","土","日"], times: noMasterFallbackTimesForStore(storeKey), tags: ["履歴候補", source], support: false, inactive: false, slots: [...slots], historySource: source };
        const key = canonical(person.name);
        if (!byName.has(key)) byName.set(key, person);
        else {
          const prev = byName.get(key);
          byName.set(key, { ...prev, stores: [...new Set([...(prev.stores || []), ...(person.stores || [])])], times: [...new Set([...(prev.times || []), ...(person.times || [])])] });
        }
      }

      // 1) staffマスタで店舗対応になっている人
      noMasterV62StaffPool().forEach(person => {
        if (!person || !person.name) return;
        if (noMasterV62IsInactive(person) || noMasterV62IsSupport(person)) return;
        if (Array.isArray(person.stores) && person.stores.includes(storeKey)) addPerson(person.name, "staff.stores", storeKey);
      });

      // 2) りえ紙面/教師紙面の履歴から店舗別候補を復元（正本rieMasterではなく、過去紙面セル）
      const paperCells = [];
      if (Array.isArray(state.teacherPaperCells)) paperCells.push(...state.teacherPaperCells);
      if (Array.isArray(state.riePaperCells)) paperCells.push(...state.riePaperCells);
      paperCells.filter(cell => cell && cell.storeKey === storeKey).forEach(cell => {
        try {
          parsePaperCellContent(cell).forEach(row => addPerson(row.name, cell.source || "paperCell", storeKey));
        } catch (e) {}
      });

      // 3) 既存scheduleの履歴からも拾う（対象週はクリア済みなので、主に過去履歴）
      Object.entries(state.schedule || {}).forEach(([dateIso, storeMap]) => {
        const slotMap = storeMap && storeMap[storeKey];
        if (!slotMap) return;
        Object.values(slotMap).forEach(cell => {
          (cell || []).forEach(row => addPerson(row && row.name, "scheduleHistory", storeKey));
        });
      });

      return [...byName.values()].filter(person => person && person.name);
    }

    function noMasterV62ActiveStaffForStore(storeKey) {
      return noMasterV63HistoryStaffForStore(storeKey)
        .filter(person => noMasterV62CanonicalName(person && person.name) !== "和田")
        .filter(person => Array.isArray(person.stores) && person.stores.includes(storeKey))
        .filter(person => !noMasterV62IsInactive(person))
        .filter(person => !noMasterV62IsSupport(person));
    }



    function noMasterV93AssignmentRows(dates, storeKey) {
      const rows = [];
      dates.forEach(date => {
        const dateIso = typeof date === "string" ? date : iso(date);
        uniqueAssignments(dateIso, storeKey).forEach(assignment => {
          rows.push({
            dateIso,
            storeKey,
            storeName: stores[storeKey]?.name || storeKey,
            name: assignment.name,
            time: assignment.time,
            support: Boolean(assignment.support)
          });
        });
      });
      return rows;
    }

    function noMasterV93ReleaseAudit(
      dates,
      storeKey,
      appCount,
      band,
      quality,
      diagnostics
    ) {
      const assignments =
        noMasterV93AssignmentRows(dates, storeKey);

      const wadaAssignments = assignments.filter(row =>
        noMasterV62CanonicalName(row.name) === "和田"
      );

      const unavailableAssignments = assignments.filter(row =>
        isUnavailable(row.name, row.dateIso)
      );

      const fixedExpected =
        storeKey === "ougicho"
          ? [
              {
                dateIso: iso(dates[0]),
                name: "赤瀬",
                time: "9-17"
              },
              {
                dateIso: iso(dates[2]),
                name: "赤瀬",
                time: "9-17"
              },
              {
                dateIso: iso(dates[3]),
                name: "下田",
                time: "17-22"
              },
              {
                dateIso: iso(dates[4]),
                name: "赤瀬",
                time: "9-17"
              }
            ]
          : [];

      const fixedMissing = fixedExpected.filter(expected =>
        !assignments.some(row =>
          row.dateIso === expected.dateIso &&
          noMasterV62CanonicalName(row.name) ===
            noMasterV62CanonicalName(expected.name) &&
          (normalizeTimeInput(row.time) || row.time) ===
            expected.time
        )
      );

      const fixedFailures =
        Array.isArray(diagnostics.fixedRuleFailures)
          ? diagnostics.fixedRuleFailures
          : [];

      const checks = {
        countWithinBand:
          appCount >= band.lower &&
          appCount <= band.upper,
        shortageZero:
          quality.shortageCells === 0,
        wadaZero:
          wadaAssignments.length === 0,
        unavailableZero:
          unavailableAssignments.length === 0,
        fixedComplete:
          fixedMissing.length === 0,
        fixedFailuresZero:
          fixedFailures.length === 0
      };

      const pass = Object.values(checks).every(Boolean);

      return {
        status: pass
          ? "RELEASE_GATE_PASS"
          : "RELEASE_GATE_FAIL",
        pass,
        checks,
        counts: {
          assignments: assignments.length,
          wada: wadaAssignments.length,
          unavailable: unavailableAssignments.length,
          fixedExpected: fixedExpected.length,
          fixedMissing: fixedMissing.length,
          fixedFailures: fixedFailures.length
        },
        violations: {
          wadaAssignments,
          unavailableAssignments,
          fixedMissing,
          fixedFailures
        },
        assignments
      };
    }


    let noMasterV94LastValidation = null;

    function noMasterV94RenderReleaseGate(payload) {
      noMasterV94LastValidation = payload;

      const panel = document.getElementById("releaseGatePanel");
      const grid = document.getElementById("releaseGateGrid");
      const button = document.getElementById("releaseSaveButton");
      if (!panel || !grid || !button) return;

      const results = Array.isArray(payload?.results)
        ? payload.results
        : [];
      const allPass =
        results.length > 0 &&
        results.every(row =>
          row?.releaseAudit?.status === "RELEASE_GATE_PASS"
        );

      panel.classList.remove("pass", "fail");
      panel.classList.add(allPass ? "pass" : "fail");

      const badge =
        document.getElementById("releaseGateBadge");
      const time =
        document.getElementById("releaseGateTime");

      if (badge) {
        badge.textContent = allPass
          ? "✓ 使用OK"
          : "⚠ 要確認";
      }

      if (time) {
        time.textContent =
          "最終確認：" +
          new Date().toLocaleString("ja-JP");
      }

      grid.innerHTML = results.map(row => {
        const audit = row.releaseAudit || {};
        const quality = row.noMasterQuality || {};
        const shortage = quality.shortageCells ?? "-";
        const unavailable = audit.counts?.unavailable ?? "-";
        const wada = audit.counts?.wada ?? "-";
        const fixedMissing =
          audit.counts?.fixedMissing ?? "-";

        const shortageClass =
          shortage === 0 ? "metric-ok" : "metric-ng";
        const unavailableClass =
          unavailable === 0 ? "metric-ok" : "metric-ng";
        const wadaClass =
          wada === 0 ? "metric-ok" : "metric-ng";
        const fixedClass =
          fixedMissing === 0 ? "metric-ok" : "metric-ng";

        return `
          <div class="release-gate-card">
            <strong>${row.storeName}</strong><br>
            勤務件数：${row.appCount}<br>
            <span class="${shortageClass}">
              不足：${shortage}
            </span><br>
            余剰：${quality.surplusCells ?? "-"}<br>
            <span class="${unavailableClass}">
              休み希望違反：${unavailable}
            </span><br>
            <span class="${wadaClass}">
              和田：${wada}
            </span><br>
            <span class="${fixedClass}">
              固定欠落：${fixedMissing}
            </span>
          </div>
        `;
      }).join("");

      button.disabled = !allPass;
      button.dataset.releaseReady = allPass ? "1" : "0";

      noMasterV96RefreshCompactAudit(payload);
    }

    function noMasterV95CompactReleasePayload(validation) {
      const results = Array.isArray(validation?.results)
        ? validation.results
        : [];

      return {
        packageVersion: "beta4.10.37.04",
        packageType: "makotsu-shift-operational-release",
        releaseStatus: "RELEASE_GATE_PASS",
        savedAt: new Date().toISOString(),
        generatedAt: validation.generatedAt,
        weekStart: validation.weekStart,
        stores: results.map(row => ({
          storeKey: row.storeKey,
          storeName: row.storeName,
          weekLabel: row.weekLabel,
          count: row.appCount,
          expectedBand: row.expectedBand,
          shortageCells:
            row.noMasterQuality?.shortageCells ?? null,
          surplusCells:
            row.noMasterQuality?.surplusCells ?? null,
          audit: {
            status: row.releaseAudit?.status || null,
            checks: row.releaseAudit?.checks || {},
            counts: row.releaseAudit?.counts || {}
          },
          assignments:
            row.releaseAudit?.assignments || []
        }))
      };
    }


    function noMasterV96AuditCompactPackage(
      validation,
      compact
    ) {
      const sourceResults =
        Array.isArray(validation?.results)
          ? validation.results
          : [];
      const compactStores =
        Array.isArray(compact?.stores)
          ? compact.stores
          : [];

      const forbiddenKeys = [
        "noMasterDiagnostics",
        "profiler",
        "phaseLog",
        "referenceOnlyRieMaster",
        "correctionLog",
        "eastMicroTrimRejected",
        "surplusTrimLog"
      ];

      const compactJson = JSON.stringify(compact);
      const forbiddenFound = forbiddenKeys.filter(key =>
        compactJson.includes(`"${key}"`)
      );

      const storeCountMatches =
        compactStores.length === sourceResults.length;

      const assignmentCountsMatch =
        sourceResults.every(source => {
          const target = compactStores.find(store =>
            store.storeKey === source.storeKey
          );
          return Boolean(target) &&
            Array.isArray(target.assignments) &&
            target.assignments.length === source.appCount &&
            target.count === source.appCount;
        });

      const allAuditsPass =
        compactStores.length > 0 &&
        compactStores.every(store =>
          store.audit?.status === "RELEASE_GATE_PASS"
        );

      const qualityPresent =
        compactStores.every(store =>
          Number.isFinite(store.shortageCells) &&
          Number.isFinite(store.surplusCells)
        );

      const topLevelValid =
        compact?.packageType ===
          "makotsu-shift-operational-release" &&
        compact?.releaseStatus === "RELEASE_GATE_PASS" &&
        Boolean(compact?.weekStart);

      const checks = {
        storeCountMatches,
        assignmentCountsMatch,
        allAuditsPass,
        qualityPresent,
        topLevelValid,
        forbiddenKeysAbsent:
          forbiddenFound.length === 0
      };

      const pass = Object.values(checks).every(Boolean);
      const prettyJson = JSON.stringify(compact, null, 2);
      const estimatedBytes =
        new Blob([prettyJson]).size;

      return {
        status: pass
          ? "COMPACT_PACKAGE_PASS"
          : "COMPACT_PACKAGE_FAIL",
        pass,
        checks,
        forbiddenFound,
        estimatedBytes,
        estimatedKiB:
          Math.round((estimatedBytes / 1024) * 10) / 10
      };
    }

    function noMasterV96RefreshCompactAudit(validation) {
      const node =
        document.getElementById("compactPackageAudit");
      const button =
        document.getElementById("releaseSaveButton");

      if (!validation) {
        if (node) node.textContent =
          "保存データ確認：未実行";
        if (button) button.disabled = true;
        return null;
      }

      const compact =
        noMasterV95CompactReleasePayload(validation);
      const audit =
        noMasterV96AuditCompactPackage(
          validation,
          compact
        );

      if (node) {
        node.textContent =
          `保存データ確認：${audit.pass ? "OK" : "NG"} ` +
          `（約${audit.estimatedKiB} KiB）`;
        node.style.color =
          audit.pass ? "#166534" : "#b91c1c";
      }

      if (button) {
        const releaseReady =
          button.dataset.releaseReady === "1";
        button.disabled =
          !(releaseReady && audit.pass);
        button.dataset.compactReady =
          audit.pass ? "1" : "0";
      }

      return audit;
    }

    function noMasterV94DownloadReleasePayload() {
      const button = document.getElementById("releaseSaveButton");

      if (noMasterV94LastValidation) {
        noMasterV97SyncReleasePanel(
          noMasterV94LastValidation
        );
      }
      if (
        !noMasterV94LastValidation ||
        button?.dataset.releaseReady !== "1" ||
        button?.dataset.compactReady !== "1"
      ) {
        alert(
          "シフト生成と保存データ確認が完了すると保存できます。"
        );
        return;
      }

      const compact =
        noMasterV95CompactReleasePayload(
          noMasterV94LastValidation
        );

      const blob = new Blob(
        [JSON.stringify(compact, null, 2)],
        { type: "application/json" }
      );

      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download =
        `makotsu-shift-${compact.weekStart}-release.json`;
      a.click();
      URL.revokeObjectURL(url);
    }

    document.addEventListener("DOMContentLoaded", () => {
      window.setTimeout(noMasterV3700Init, 0);
      const saveButton =
        document.getElementById("releaseSaveButton");
      if (saveButton) {
        saveButton.addEventListener(
          "click",
          noMasterV94DownloadReleasePayload
        );
      }

      const runButton =
        document.getElementById("releaseDirectRunButton");
      if (runButton) {
        runButton.addEventListener("click", async () => {
          const originalText = runButton.textContent;
          runButton.disabled = true;
          runButton.textContent = "生成・監査中…";

          try {
            if (
              typeof runNoMasterWishGeneration !== "function"
            ) {
              throw new Error(
                "正本なし生成関数が見つかりません"
              );
            }

            await runNoMasterWishGeneration(false);

            const output =
              document.getElementById("validationOutput");

            if (output?.value) {
              try {
                const payload = JSON.parse(output.value);
                noMasterV97SyncReleasePanel(payload);
              } catch (parseError) {
                console.warn(
                  "検証結果JSONの再同期に失敗",
                  parseError
                );
              }
            }
          } catch (error) {
            console.error(error);
            alert(
              "生成・監査の実行に失敗しました: " +
              (error?.message || error)
            );
          } finally {
            runButton.disabled = false;
            runButton.textContent = originalText;
          }
        });
      }
    });


    function noMasterV97SyncReleasePanel(payload) {
      if (!payload || !Array.isArray(payload.results)) return false;

      noMasterV94LastValidation = payload;
      noMasterV94RenderReleaseGate(payload);

      const button = document.getElementById("releaseSaveButton");
      const releasePass =
        payload.results.length > 0 &&
        payload.results.every(row =>
          row?.releaseAudit?.status === "RELEASE_GATE_PASS"
        );

      if (button) {
        button.dataset.releaseReady =
          releasePass ? "1" : "0";
      }

      const compactAudit =
        noMasterV96RefreshCompactAudit(payload);

      if (button) {
        const compactPass =
          compactAudit?.status === "COMPACT_PACKAGE_PASS";
        button.dataset.compactReady =
          compactPass ? "1" : "0";
        button.disabled =
          !(releasePass && compactPass);
      }

      return releasePass &&
        compactAudit?.status === "COMPACT_PACKAGE_PASS";
    }


    const NO_MASTER_V3700_FLOW_KEY =
      "makotsuShiftV3700OperationFlow";
    const NO_MASTER_V3700_STAFF_META_KEY =
      "makotsuShiftV3700StaffMeta";

    function noMasterV3700LoadJson(key, fallback) {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      } catch {
        return fallback;
      }
    }

    function noMasterV3700SaveJson(key, value) {
      localStorage.setItem(key, JSON.stringify(value));
    }

    function noMasterV3700FlowAll() {
      return noMasterV3700LoadJson(
        NO_MASTER_V3700_FLOW_KEY,
        {}
      );
    }

    function noMasterV3700WeekFlow(weekStart) {
      const all = noMasterV3700FlowAll();
      return all[weekStart] || {
        weekStart,
        requestsClosed: false,
        generated: false,
        audited: false,
        auditPass: false,
        confirmed: false,
        confirmedAt: null,
        confirmedBy: null,
        unlockReason: null,
        lastAudit: null
      };
    }

    function noMasterV3700SaveWeekFlow(flow) {
      const all = noMasterV3700FlowAll();
      all[flow.weekStart] = flow;
      noMasterV3700SaveJson(
        NO_MASTER_V3700_FLOW_KEY,
        all
      );
    }

    function noMasterV3700StaffMetaAll() {
      return noMasterV3700LoadJson(
        NO_MASTER_V3700_STAFF_META_KEY,
        {}
      );
    }

    function noMasterV3700StaffMeta(name) {
      const all = noMasterV3700StaffMetaAll();
      return all[canonicalStaffName(name)] || {
        status: "active",
        startDate: "",
        endDate: "",
        weeklyMax: 5,
        nightAllowed: true,
        soloAllowed: true,
        mentors: []
      };
    }

    function noMasterV3700SaveStaffMeta(name, meta) {
      const all = noMasterV3700StaffMetaAll();
      all[canonicalStaffName(name)] = meta;
      noMasterV3700SaveJson(
        NO_MASTER_V3700_STAFF_META_KEY,
        all
      );
    }

    function noMasterV3700Dates(weekStart) {
      return weekDates(weekStart);
    }

    function noMasterV3700Assignments(
      weekStart,
      storeKey
    ) {
      return noMasterV93AssignmentRows(
        noMasterV3700Dates(weekStart),
        storeKey
      );
    }

    function noMasterV3700TimeOverlapsNight(time) {
      const parsed = parseRange(time);
      if (!parsed) return false;
      const [start, end] = parsed;
      for (let hour = start; hour < end; hour += 1) {
        const normalized = hour % 24;
        if (normalized >= 22 || normalized < 6) {
          return true;
        }
      }
      return false;
    }

    function noMasterV3700RangesOverlap(a, b) {
      const ra = parseRange(a);
      const rb = parseRange(b);
      if (!ra || !rb) return false;
      return Math.max(ra[0], rb[0]) <
        Math.min(ra[1], rb[1]);
    }

    function noMasterV3700CurrentAudit(weekStart) {
      const dates = noMasterV3700Dates(weekStart);
      const storesToAudit = ["miyanoshita", "higashicho", "ougicho"];
      const results = storesToAudit.map(storeKey => {
        const assignments =
          noMasterV3700Assignments(
            weekStart,
            storeKey
          );
        const quality =
          noMasterCoverageQualityForStore(
            dates,
            storeKey,
            {}
          );
        const band =
          wishWeekCountBandForDates(
            dates,
            storeKey
          );
        const diagnostics = {
          fixedRuleFailures: []
        };
        const releaseAudit =
          noMasterV93ReleaseAudit(
            dates,
            storeKey,
            assignments.length,
            band,
            quality,
            diagnostics
          );

        return {
          storeKey,
          storeName:
            stores[storeKey]?.name || storeKey,
          weekStart,
          weekLabel:
            `${fmtDate(dates[0])}〜${fmtDate(dates[6])}`,
          appCount: assignments.length,
          expectedBand: band,
          noMasterQuality: quality,
          releaseAudit
        };
      });

      const allAssignments =
        results.flatMap(row =>
          Array.isArray(row.releaseAudit?.assignments)
            ? row.releaseAudit.assignments
            : []
        );
      const byPerson = new Map();
      allAssignments.forEach(row => {
        const name = canonicalStaffName(row.name);
        if (!byPerson.has(name)) byPerson.set(name, []);
        byPerson.get(name).push(row);
      });

      const lifecycleViolations = [];
      const nightViolations = [];
      const weeklyMaxViolations = [];
      const traineeSoloViolations = [];

      byPerson.forEach((rows, name) => {
        const meta = noMasterV3700StaffMeta(name);

        rows.forEach(row => {
          if (
            meta.status === "leave" ||
            meta.status === "retired" ||
            meta.status === "excluded" ||
            (
              meta.startDate &&
              row.dateIso < meta.startDate
            ) ||
            (
              meta.endDate &&
              row.dateIso > meta.endDate
            )
          ) {
            lifecycleViolations.push({
              name,
              dateIso: row.dateIso,
              time: row.time,
              status: meta.status
            });
          }

          if (
            meta.nightAllowed === false &&
            noMasterV3700TimeOverlapsNight(row.time)
          ) {
            nightViolations.push(row);
          }

          if (
            meta.status === "trainee" ||
            meta.soloAllowed === false
          ) {
            const mentors = Array.isArray(meta.mentors)
              ? meta.mentors.map(canonicalStaffName)
              : [];
            const sameShift = allAssignments.filter(other =>
              other.storeKey === row.storeKey &&
              other.dateIso === row.dateIso &&
              canonicalStaffName(other.name) !== name &&
              noMasterV3700RangesOverlap(
                other.time,
                row.time
              )
            );
            const hasMentor =
              mentors.length === 0
                ? sameShift.length > 0
                : sameShift.some(other =>
                    mentors.includes(
                      canonicalStaffName(other.name)
                    )
                  );
            if (!hasMentor) {
              traineeSoloViolations.push(row);
            }
          }
        });

        if (
          Number.isFinite(Number(meta.weeklyMax)) &&
          rows.length > Number(meta.weeklyMax)
        ) {
          weeklyMaxViolations.push({
            name,
            count: rows.length,
            weeklyMax: Number(meta.weeklyMax)
          });
        }
      });

      const hardPass =
        results.every(row =>
          row.releaseAudit?.pass === true
        ) &&
        lifecycleViolations.length === 0 &&
        nightViolations.length === 0 &&
        traineeSoloViolations.length === 0;

      const warnings = [
        ...weeklyMaxViolations.map(row =>
          `${row.name}：週${row.count}回 ` +
          `（上限${row.weeklyMax}回）`
        )
      ];

      return {
        validatorVersion:
          "beta4.10.37.04 current-schedule-audit",
        generatedAt: new Date().toISOString(),
        weekStart,
        results,
        extraAudit: {
          hardPass,
          lifecycleViolations,
          nightViolations,
          traineeSoloViolations,
          weeklyMaxViolations,
          warnings
        }
      };
    }

    function noMasterV3700RequestRowsForWeek(
      weekStart
    ) {
      const dateSet = new Set(
        noMasterV3700Dates(weekStart)
      );
      return submittedWorkRequests.filter(row =>
        dateSet.has(row.dateIso)
      );
    }

    function noMasterV3700HopeOnlyStaff() {
      return staff.filter(person =>
        hasTag(person, "希望提出型")
      );
    }

    function noMasterV3700RequestSummary(weekStart) {
      const hopeOnly = noMasterV3700HopeOnlyStaff();
      const rows =
        noMasterV3700RequestRowsForWeek(weekStart);
      const submittedNames = new Set(
        rows.map(row =>
          canonicalStaffName(row.name)
        )
      );
      const missing = hopeOnly.filter(person =>
        !submittedNames.has(
          canonicalStaffName(person.name)
        )
      );
      return {
        hopeOnly: hopeOnly.length,
        submittedPeople: submittedNames.size,
        requestCount: rows.length,
        missing: missing.map(row => row.name)
      };
    }

    function noMasterV3700RenderRequests() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      const node =
        document.getElementById(
          "workflowRequestSummary"
        );
      if (!weekStart || !node) return;

      const summary =
        noMasterV3700RequestSummary(weekStart);
      node.innerHTML =
        `提出者 ${summary.submittedPeople}/` +
        `${summary.hopeOnly}人<br>` +
        `希望 ${summary.requestCount}件<br>` +
        (
          summary.missing.length
            ? `未提出：${summary.missing.join("、")}`
            : "未提出なし"
        );
    }

    function noMasterV3700RenderWorkRequests() {
      const list =
        document.getElementById("workRequestList");
      if (!list) return;

      const rows = [...submittedWorkRequests]
        .sort((a, b) =>
          `${a.dateIso}|${a.name}`.localeCompare(
            `${b.dateIso}|${b.name}`
          )
        );

      list.innerHTML = rows.map((row, index) => `
        <div class="availability-item">
          <span>
            ${row.dateIso}
            ${stores[row.storeKey]?.name || row.storeKey}
            ${row.name}
            ${row.time}
          </span>
          <button
            class="btn small"
            type="button"
            data-work-request-remove="${index}"
          >
            削除
          </button>
        </div>
      `).join("") ||
        '<div class="muted">出勤希望なし</div>';
    }

    function noMasterV3700AddWorkRequest() {
      const name =
        document.getElementById(
          "workRequestStaff"
        )?.value;
      const storeKey =
        document.getElementById(
          "workRequestStore"
        )?.value;
      const dateIso =
        document.getElementById(
          "workRequestDate"
        )?.value;
      const rawTime =
        document.getElementById(
          "workRequestTime"
        )?.value;
      const time = normalizeTimeInput(rawTime);

      if (!name || !storeKey || !dateIso || !time) {
        showToast(
          "スタッフ・店舗・日付・時間を入力して"
        );
        return;
      }

      const exists = submittedWorkRequests.some(row =>
        canonicalStaffName(row.name) ===
          canonicalStaffName(name) &&
        row.storeKey === storeKey &&
        row.dateIso === dateIso &&
        normalizeTimeInput(row.time) === time
      );

      if (!exists) {
        submittedWorkRequests.push({
          name: canonicalStaffName(name),
          storeKey,
          dateIso,
          time
        });
      }

      noMasterV3700RenderWorkRequests();
      noMasterV3700RenderRequests();
      showToast("出勤希望を追加した");
    }

    function noMasterV3700PopulateStaffSelects() {
      ["workRequestStaff"].forEach(id => {
        const select = document.getElementById(id);
        if (!select) return;
        const current = select.value;
        select.innerHTML = staff
          .map(person =>
            `<option value="${person.name}">` +
            `${person.name}</option>`
          )
          .join("");
        if (current) select.value = current;
      });
    }

    function noMasterV3700FlowStateLabel(flow) {
      if (flow.confirmed) return "確定済み";
      if (flow.audited && flow.auditPass) return "監査OK";
      if (flow.generated) return "手修正・監査待ち";
      if (flow.requestsClosed) return "希望締め済み";
      return "希望受付中";
    }

    function noMasterV3700RenderWorkflow() {
      const weekInput =
        document.getElementById(
          "workflowWeekStart"
        );
      if (!weekInput) return;

      if (!weekInput.value) {
        weekInput.value =
          nextWeeklyCloseStartIso();
      }

      const weekStart = weekInput.value;
      const flow =
        noMasterV3700WeekFlow(weekStart);
      const badge =
        document.getElementById(
          "workflowStateBadge"
        );
      const auditNode =
        document.getElementById(
          "workflowAuditList"
        );

      if (badge) {
        badge.textContent =
          noMasterV3700FlowStateLabel(flow);
        badge.className =
          "workflow-state " +
          (
            flow.confirmed ||
            (flow.audited && flow.auditPass)
              ? "ok"
              : flow.generated ||
                flow.requestsClosed
                ? "warn"
                : ""
          );
      }

      const stepIndex =
        flow.confirmed ? 6 :
        flow.audited ? 5 :
        flow.generated ? 4 :
        flow.requestsClosed ? 3 : 1;

      for (let index = 1; index <= 6; index += 1) {
        const node =
          document.getElementById(
            `workflowStep${index}`
          );
        if (!node) continue;
        node.classList.remove("active", "done");
        if (index < stepIndex) {
          node.classList.add("done");
        } else if (index === stepIndex) {
          node.classList.add("active");
        }
      }

      const generateSummary =
        document.getElementById(
          "workflowGenerateSummary"
        );
      const auditSummary =
        document.getElementById(
          "workflowAuditSummary"
        );
      const confirmSummary =
        document.getElementById(
          "workflowConfirmSummary"
        );

      if (generateSummary) {
        generateSummary.textContent =
          flow.generated
            ? "自動作成済み"
            : "未作成";
      }

      if (auditSummary) {
        auditSummary.textContent =
          flow.audited
            ? (
                flow.auditPass
                  ? "使用OK"
                  : "要修正"
              )
            : "未監査";
      }

      if (confirmSummary) {
        confirmSummary.textContent =
          flow.confirmed
            ? `${flow.confirmedBy || "-"} / ` +
              `${new Date(
                flow.confirmedAt
              ).toLocaleString("ja-JP")}`
            : "未確定";
      }

      if (auditNode) {
        const audit = flow.lastAudit;
        if (!audit) {
          auditNode.textContent =
            "まだ監査していません。";
        } else {
          const lines = [];
          audit.results.forEach(row => {
            lines.push(
              `${row.storeName}：` +
              `件数${row.appCount} / ` +
              `不足${row.noMasterQuality.shortageCells} / ` +
              `余剰${row.noMasterQuality.surplusCells}`
            );
          });
          const extra = audit.extraAudit || {
            lifecycleViolations: [],
            nightViolations: [],
            traineeSoloViolations: [],
            weeklyMaxViolations: []
          };
          lines.push(
            `勤務開始・退職・休職違反：` +
            `${extra.lifecycleViolations?.length || 0}`
          );
          lines.push(
            `夜勤不可違反：` +
            `${extra.nightViolations?.length || 0}`
          );
          lines.push(
            `新人・単独勤務違反：` +
            `${extra.traineeSoloViolations?.length || 0}`
          );
          lines.push(
            `週上限警告：` +
            `${extra.weeklyMaxViolations?.length || 0}`
          );
          auditNode.textContent = lines.join("\n");
        }
      }

      [
        "workflowGenerateBtn",
        "workflowAuditBtn",
        "workflowConfirmBtn"
      ].forEach(id => {
        const button = document.getElementById(id);
        if (button) button.disabled = flow.confirmed;
      });

      const closeButton =
        document.getElementById(
          "workflowCloseRequestsBtn"
        );
      const reopenButton =
        document.getElementById(
          "workflowReopenRequestsBtn"
        );
      if (closeButton) {
        closeButton.disabled =
          flow.requestsClosed || flow.confirmed;
      }
      if (reopenButton) {
        reopenButton.disabled =
          !flow.requestsClosed || flow.confirmed;
      }

      noMasterV3700RenderRequests();
      noMasterV3700RenderWorkRequests();
    }

    async function noMasterV3700Generate() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const flow =
        noMasterV3700WeekFlow(weekStart);
      if (!flow.requestsClosed) {
        alert("先に希望を締めてください。");
        return;
      }

      const requestSummary =
        noMasterV3700RequestSummary(weekStart);
      const missingPolicy =
        document.getElementById(
          "workflowMissingPolicy"
        )?.value;

      if (
        missingPolicy === "confirm" &&
        requestSummary.missing.length
      ) {
        alert(
          "未提出者を確認してください：\n" +
          requestSummary.missing.join("、")
        );
        return;
      }

      const weekInput =
        document.getElementById(
          "validationWeekStart"
        );
      const storeInput =
        document.getElementById(
          "validationStore"
        );
      const restoreInput =
        document.getElementById(
          "validationRestoreMode"
        );

      if (weekInput) weekInput.value = weekStart;
      if (storeInput) storeInput.value = "target";
      if (restoreInput) restoreInput.value = "keep-last";

      const result =
        await runNoMasterWishGeneration(false);
      if (!result) return;

      const currentAudit =
        noMasterV3700CurrentAudit(weekStart);

      flow.generated = true;
      flow.audited = true;
      flow.auditPass =
        currentAudit.extraAudit?.hardPass === true;
      flow.lastAudit = currentAudit;
      flow.confirmed = false;
      noMasterV3700SaveWeekFlow(flow);
      noMasterV97SyncReleasePanel(currentAudit);
      noMasterV3700RenderWorkflow();
    }

    function noMasterV3700AuditCurrent() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return null;

      try {
        const audit =
          noMasterV3700CurrentAudit(weekStart);
        const flow =
          noMasterV3700WeekFlow(weekStart);

        flow.audited = true;
        flow.auditPass =
          audit.extraAudit?.hardPass === true;
        flow.lastAudit = audit;
        flow.confirmed = false;
        noMasterV3700SaveWeekFlow(flow);

        noMasterV97SyncReleasePanel(audit);
        noMasterV3700RenderWorkflow();
        showToast(
          flow.auditPass
            ? "現在のシフトは使用OK"
            : "現在のシフトに修正が必要"
        );
        return audit;
      } catch (error) {
        noMasterV3704RecoverUi(
          "現在のシフト再監査",
          error
        );
        return null;
      }
    }

    function noMasterV3700ConfirmWeek() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const flow =
        noMasterV3700WeekFlow(weekStart);
      if (!flow.audited || !flow.auditPass) {
        alert(
          "現在のシフトを再監査し、使用OKにしてください。"
        );
        return;
      }

      flow.confirmed = true;
      flow.confirmedAt =
        new Date().toISOString();
      flow.confirmedBy =
        document.getElementById(
          "workflowOperator"
        )?.value || "管理者";
      noMasterV3700SaveWeekFlow(flow);
      noMasterV3700RenderWorkflow();
      showToast("この週を確定した");
    }

    function noMasterV3700UnlockWeek() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const flow =
        noMasterV3700WeekFlow(weekStart);
      if (!flow.confirmed) return;

      const reason = prompt(
        "確定解除の理由を入力してください"
      );
      if (!reason) return;

      flow.confirmed = false;
      flow.audited = false;
      flow.auditPass = false;
      flow.unlockReason = reason;
      noMasterV3700SaveWeekFlow(flow);
      noMasterV3700RenderWorkflow();
      showToast("確定を解除した");
    }

    function noMasterV3700CloseRequests() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const flow =
        noMasterV3700WeekFlow(weekStart);
      const summary =
        noMasterV3700RequestSummary(weekStart);
      const policy =
        document.getElementById(
          "workflowMissingPolicy"
        )?.value;

      if (
        policy === "confirm" &&
        summary.missing.length
      ) {
        alert(
          "未提出者がいます：\n" +
          summary.missing.join("、")
        );
        return;
      }

      flow.requestsClosed = true;
      flow.audited = false;
      flow.auditPass = false;
      noMasterV3700SaveWeekFlow(flow);
      noMasterV3700RenderWorkflow();
      showToast("希望を締めた");
    }

    function noMasterV3700ReopenRequests() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const flow =
        noMasterV3700WeekFlow(weekStart);
      flow.requestsClosed = false;
      flow.generated = false;
      flow.audited = false;
      flow.auditPass = false;
      flow.confirmed = false;
      noMasterV3700SaveWeekFlow(flow);
      noMasterV3700RenderWorkflow();
      showToast("希望締めを解除した");
    }

    function noMasterV3700Download(
      filename,
      content,
      type = "text/csv;charset=utf-8"
    ) {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    function noMasterV3700CsvEscape(value) {
      const text = String(value ?? "");
      return `"${text.replace(/"/g, '""')}"`;
    }

    function noMasterV3700ExportStoreCsv() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const rows = [
        ["日付", "店舗", "氏名", "時間", "応援"]
      ];

      ["miyanoshita", "higashicho", "ougicho"].forEach(storeKey => {
        noMasterV3700Assignments(
          weekStart,
          storeKey
        ).forEach(row => {
          rows.push([
            row.dateIso,
            row.storeName,
            row.name,
            row.time,
            row.support ? "応援" : ""
          ]);
        });
      });

      const csv = "\ufeff" + rows
        .map(row =>
          row.map(noMasterV3700CsvEscape).join(",")
        )
        .join("\n");

      noMasterV3700Download(
        `makotsu-shift-${weekStart}-stores.csv`,
        csv
      );
    }

    function noMasterV3700ExportPersonCsv() {
      const weekStart =
        document.getElementById(
          "workflowWeekStart"
        )?.value;
      if (!weekStart) return;

      const rows = [
        ["氏名", "日付", "店舗", "時間"]
      ];

      const assignments = [
        ...noMasterV3700Assignments(
          weekStart,
          "higashicho"
        ),
        ...noMasterV3700Assignments(
          weekStart,
          "ougicho"
        )
      ].sort((a, b) =>
        `${a.name}|${a.dateIso}`.localeCompare(
          `${b.name}|${b.dateIso}`
        )
      );

      assignments.forEach(row => {
        rows.push([
          row.name,
          row.dateIso,
          row.storeName,
          row.time
        ]);
      });

      const csv = "\ufeff" + rows
        .map(row =>
          row.map(noMasterV3700CsvEscape).join(",")
        )
        .join("\n");

      noMasterV3700Download(
        `makotsu-shift-${weekStart}-people.csv`,
        csv
      );
    }

    function noMasterV3700SaveStaffMetaFromForm(name) {
      const meta = {
        startDate:
          document.getElementById(
            "newStaffStartDate"
          )?.value || "",
        endDate:
          document.getElementById(
            "newStaffEndDate"
          )?.value || "",
        status:
          document.getElementById(
            "newStaffStatus"
          )?.value || "active",
        weeklyMax: Number(
          document.getElementById(
            "newStaffWeeklyMax"
          )?.value || 5
        ),
        nightAllowed:
          document.getElementById(
            "newStaffNightAllowed"
          )?.value !== "false",
        soloAllowed:
          document.getElementById(
            "newStaffSoloAllowed"
          )?.value !== "false",
        mentors: splitValues(
          document.getElementById(
            "newStaffMentors"
          )?.value || ""
        )
      };
      noMasterV3700SaveStaffMeta(name, meta);
    }

    function noMasterV3700Init() {
      const weekInput =
        document.getElementById(
          "workflowWeekStart"
        );
      if (weekInput && !weekInput.value) {
        weekInput.value =
          nextWeeklyCloseStartIso();
      }

      const requestDate =
        document.getElementById(
          "workRequestDate"
        );
      if (requestDate && !requestDate.value) {
        requestDate.value =
          weekInput?.value || nextWeeklyCloseStartIso();
      }

      noMasterV3700PopulateStaffSelects();
      noMasterV3700RenderWorkflow();
    }

    async function validationNoMasterGenerationFromSnapshot(baseSnapshot, weekStartIso, targetStores, progress) {
      applySerialized(baseSnapshot);
      const dates = weekDates(weekStartIso);
      validationSetWeekAndStore(weekStartIso, targetStores[0] || "higashicho");
      validationClearWeekAllStores(dates);
      const savedRieMaster = Array.isArray(state.rieMaster) ? state.rieMaster.slice() : [];
      const startedAtAll = performance.now ? performance.now() : Date.now();
      const runs = new Map();
      state.rieMaster = [];
      noMasterV62SourceStaff = Array.isArray(baseSnapshot.staff) ? baseSnapshot.staff : null;
      const generationOrder = [...targetStores].sort((a, b) => {
        const priority = { ougicho: 0, higashicho: 1 };
        return (priority[a] ?? 9) - (priority[b] ?? 9);
      });
      try {
        for (let index = 0; index < generationOrder.length; index += 1) {
          const storeKey = generationOrder[index];
          if (typeof progress === "function") progress(index, generationOrder.length, storeKey, "生成中");
          await new Promise(resolve => setTimeout(resolve, 40));
          validationSetWeekAndStore(weekStartIso, storeKey);
          const options = autonomousGenerationOptions({ useRieTargets: false, respectCapacity: false, allowHopeOnlyPlacement: true, wishMode: true });
          options.wishExpectationCache = new Map();
          options.wishCandidatePoolCache = new Map();
          const startedAt = performance.now ? performance.now() : Date.now();
          const run = await noMasterGenerateStoreFromEmptyChunked(dates, storeKey, options, progress);
          const endedAt = performance.now ? performance.now() : Date.now();
          run.diagnostics.generationOrder = generationOrder.slice();
          if (run.wishLog) {
            run.wishLog.generationOrder = generationOrder.slice();
          }
          runs.set(storeKey, {
            ...run,
            runtimeMs: Math.round(endedAt - startedAt)
          });
          if (typeof progress === "function") progress(index + 1, generationOrder.length, storeKey, "生成完了");
          await new Promise(resolve => setTimeout(resolve, 60));
        }
      } finally {
        state.rieMaster = savedRieMaster;
      }
      const endedAtAll = performance.now ? performance.now() : Date.now();
      const results = [];
      for (let index = 0; index < targetStores.length; index += 1) {
        const storeKey = targetStores[index];
        if (typeof progress === "function") progress(index, targetStores.length, storeKey, "比較中");
        await new Promise(resolve => setTimeout(resolve, 40));
        const run = runs.get(storeKey);
        const stats = rieCompareStats(dates, storeKey);
        const personCounts = validationPersonTypeCounts(stats.personDiffs);
        const appCount = weeklyAssignmentCount(storeKey, dates);
        const lower = run.band.lower;
        const upper = run.band.upper;
        const preliminaryStatus =
          appCount < lower
            ? "UNDER_TARGET"
            : (
                appCount > upper
                  ? "OVER_TARGET"
                  : "OK_NO_MASTER_GENERATION"
              );

        const releaseAudit =
          noMasterV93ReleaseAudit(
            dates,
            storeKey,
            appCount,
            run.band,
            run.quality,
            run.diagnostics
          );

        const status =
          preliminaryStatus !== "OK_NO_MASTER_GENERATION"
            ? preliminaryStatus
            : releaseAudit.status;

        results.push({
          storeKey,
          storeName: stores[storeKey]?.name || storeKey,
          weekStart: weekStartIso,
          weekLabel: weekLabel(dates),
          runtimeMs: run.runtimeMs,
          validationStatus: status,
          validationMode: "no-master-request-based-generation",
          generatorVersion: "beta4.10.37.04 正本なし・3店舗監査復旧修正版",
          expectedBand: run.band,
          phaseLog: run.phaseLog,
          appCount,
          noMasterQuality: {
            shortageCells: run.quality.shortageCells,
            surplusCells: run.quality.surplusCells,
            daily: (run.quality.daily || []).map(row => ({
              dateIso: row.dateIso,
              count: row.count,
              target: row.target,
              shortageCells: row.shortageCells,
              surplusCells: row.surplusCells
            }))
          },
          noMasterDiagnostics: run.diagnostics,
          releaseAudit,
          referenceOnlyRieMaster: {
            note: "正本は生成に使っていない。答え合わせのみ。軽量化のため上位差分だけ出力。",
            masterCount: stats.entries.length,
            coverageDiffCount: stats.coverageDiffs.length,
            personDiffCount: stats.personDiffs.length,
            personDiff: personCounts,
            personTop: validationNameTopRows(stats.personDiffs, 6),
            coverageTop: validationCoverageTopRows(stats.coverageDiffs, 8)
          },
          correctionLog: run.wishLog || null,
          totalRuntimeMs: Math.round(endedAtAll - startedAtAll)
        });
        if (typeof progress === "function") progress(index + 1, targetStores.length, storeKey, "比較完了");
        await new Promise(resolve => setTimeout(resolve, 40));
      }
      return results;
    }

    async function runNoMasterWishGeneration(useJsonBox = false) {
      const output = document.getElementById("validationOutput");
      const weekInput = document.getElementById("validationWeekStart");
      const storeInput = document.getElementById("validationStore");
      const restoreInput = document.getElementById("validationRestoreMode");
      const jsonBox = document.getElementById("jsonBox");
      const originalSnapshot = serializeState();
      let baseSnapshot = originalSnapshot;
      const startedLabel = "検証準備中…ブラウザを閉じずに待ってください";
      try {
        if (output) output.value = startedLabel;
        await new Promise(resolve => setTimeout(resolve, 60));
        if (useJsonBox) {
          const text = jsonBox ? jsonBox.value.trim() : "";
          if (!text) throw new Error("JSON欄が空です");
          const payload = JSON.parse(text);
          validationRequireFullSaveSnapshot(payload, "正本なし生成診断");
          if (!applySerialized(payload)) throw new Error("JSONを取り込めませんでした");
          baseSnapshot = serializeState();
        } else {
          validationRequireFullSaveSnapshot(baseSnapshot, "正本なし生成診断");
        }
        const weekStartIso = (weekInput && weekInput.value) || state.selectedWeekStart || nextWeeklyCloseStartIso();
        const targetStores = validationTargetStoreKeys(
          storeInput ? storeInput.value : "target"
        ).filter(key =>
          ["miyanoshita", "ougicho", "higashicho"].includes(key)
        );
        const progress = (done, total, storeKey, phase) => {
          const name = stores[storeKey]?.name || storeKey;
          if (output) output.value = `${phase}：${name}（${done}/${total}）\n候補ごとの全再集計を廃止し、配置・不足・週回数を1回だけ索引化して評価しています。`;
        };
        const results = await validationNoMasterGenerationFromSnapshot(baseSnapshot, weekStartIso, targetStores, progress);
        const result = {
          validatorVersion: "beta4.10.37.04 正本なし・3店舗監査復旧修正版",
          sourceAppVersion: baseSnapshot.appVersion || null,
          generatedAt: new Date().toISOString(),
          weekStart: weekStartIso,
          stores: targetStores,
          validationMode: "no-master-request-based-generation",
          premise: "りえちゃん正本は生成に使わない。37.04は宮ノ下を含む3店舗生成を有効化し、再監査エラー後も操作不能にならない復旧処理を追加。",
          results,
          summary: validationBuildNoMasterSummary(results)
        };
        noMasterV97SyncReleasePanel(result);
        if (output) output.value = JSON.stringify(result, null, 2);
        requestAnimationFrame(() => {
          noMasterV97SyncReleasePanel(result);
        });
        window.setTimeout(() => {
          try {
            saveValidationResult();
          } catch (error) {
            console.warn("auto validation save failed", error);
            const status = document.getElementById("validationExportStatus");
            if (status) status.textContent = "自動保存失敗。保存ボタンを押してください";
          }
        }, 100);
        const keepLast = restoreInput && restoreInput.value === "keep-last";
        if (!keepLast) applySerialized(useJsonBox ? baseSnapshot : originalSnapshot);
        renderAll();
        showToast(`正本なし生成診断完了：${result.summary}`);
        return result;
      } catch (error) {
        if (output) output.value = JSON.stringify({ error: String(error && error.message ? error.message : error), generatedAt: new Date().toISOString() }, null, 2);
        applySerialized(originalSnapshot);
        renderAll();
        showToast(`正本なし生成診断で停止：${error && error.message ? error.message : error}`);
        return null;
      }
    }


    // β4.10.37.04 正本なし・3店舗監査復旧修正版
    // 36.64は圧縮関数を持っていたが、最終的に使われる noMasterGenerateStoreFromEmpty 側で呼ばれていなかった。
    // ここで最終定義として上書きし、36.63の履歴スタッフプール生成後に必ず同一人物の時間短縮圧縮を走らせる。
    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = { blocked: {}, noCandidateDates: [], submittedAdded: 0, teacherAdds: 0, targetAdds: 0, relaxedAdds: 0, finalRescueAdds: 0, compressRuns: 0, band, poolSize: {} };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();
      diagnostics.poolSize[storeKey] = noMasterV62ActiveStaffForStore(storeKey).length;

      count("afterClear");

      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = noMasterV62ActiveStaffForStore(storeKey).find(p => noMasterV62CanonicalName(p.name) === noMasterV62CanonicalName(row.name));
          if (!person) return;
          if (noMasterV62DirectAddShift(dateIso, storeKey, person, row.time)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV62FillDate(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds", false);
      });
      count("afterDailyTeacherTargets");

      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 260) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 40 + targetGap * 220 - uniqueAssignments(dateIso, storeKey).length * 5 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV62PickBest(row.dateIso, storeKey, storeOptions, diagnostics, true);
          if (!picked) continue;
          if (noMasterV62DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.relaxedAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterRelaxedWeeklyRescue");

      // 36.65: 実際に圧縮を走らせる。件数は変えず、同一人物の時間だけ短くして過剰セルを減らす。
      try {
        if (typeof noMasterV64CompressSurplusByTime === "function") {
          noMasterV64CompressSurplusByTime(dates, storeKey, storeOptions, diagnostics);
        }
      } catch (e) {
        diagnostics.blocked.compressError = String(e && e.message ? e.message : e);
      }
      count("afterSurplusCompression");

      const wishLog = {
        version: "β4.10.37.04",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        sourceStaffPool: diagnostics.poolSize[storeKey],
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        compressRuns: diagnostics.compressRuns || 0,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }



    // 36.56 JSON欄本命ガード＋残差バランスペア＋時間ズレ寄せプレビュー：保存済み結果の差分アクションを、元データを壊さず一時適用して改善幅を検証JSONに出す。
    function validationFormatDiffRow(row) {
      return {
        dateIso: row.dateIso,
        storeKey: row.storeKey,
        storeName: stores[row.storeKey]?.name || row.storeKey,
        name: canonicalStaffNameForStore(row.name || "", row.storeKey),
        rawName: row.name || "",
        time: row.time || "",
        type: row.type || ""
      };
    }

    function validationSavedActionRows(personDiffs = [], limit = 40) {
      const missing = (personDiffs || []).filter(row => row.type === "アプリにない").map(validationFormatDiffRow);
      const extra = (personDiffs || []).filter(row => row.type === "アプリ余分").map(validationFormatDiffRow);
      const extrasByDate = new Map();
      extra.forEach(row => {
        const key = `${row.dateIso}|${row.storeKey}`;
        if (!extrasByDate.has(key)) extrasByDate.set(key, []);
        extrasByDate.get(key).push(row);
      });
      const swapCandidates = [];
      missing.forEach(miss => {
        const key = `${miss.dateIso}|${miss.storeKey}`;
        const candidates = extrasByDate.get(key) || [];
        const exactName = candidates.find(ex => ex.name === miss.name);
        const sameDay = exactName || candidates[0];
        if (sameDay) {
          swapCandidates.push({
            action: exactName ? "samePersonTimeFix" : "replaceSameDay",
            dateIso: miss.dateIso,
            storeKey: miss.storeKey,
            storeName: miss.storeName,
            remove: { name: sameDay.name, time: sameDay.time },
            add: { name: miss.name, time: miss.time },
            priority: exactName ? 1 : 2
          });
        }
      });
      const addOnly = missing.filter(miss => !swapCandidates.some(sw => sw.dateIso === miss.dateIso && sw.storeKey === miss.storeKey && sw.add.name === miss.name && sw.add.time === miss.time));
      const removeOnly = extra.filter(ex => !swapCandidates.some(sw => sw.dateIso === ex.dateIso && sw.storeKey === ex.storeKey && sw.remove.name === ex.name && sw.remove.time === ex.time));
      const sortRows = rows => rows.sort((a,b) => String(a.dateIso).localeCompare(String(b.dateIso)) || String(a.storeKey).localeCompare(String(b.storeKey)) || String(a.name || a.add?.name || '').localeCompare(String(b.name || b.add?.name || ''), 'ja') || String(a.time || a.add?.time || '').localeCompare(String(b.time || b.add?.time || '')));
      return {
        missingRows: sortRows(missing).slice(0, limit),
        extraRows: sortRows(extra).slice(0, limit),
        swapCandidates: swapCandidates.sort((a,b) => a.priority - b.priority || a.dateIso.localeCompare(b.dateIso) || a.storeKey.localeCompare(b.storeKey)).slice(0, limit),
        addOnly: sortRows(addOnly).slice(0, limit),
        removeOnly: sortRows(removeOnly).slice(0, limit),
        counts: {
          missing: missing.length,
          extra: extra.length,
          swapCandidates: swapCandidates.length,
          addOnly: addOnly.length,
          removeOnly: removeOnly.length
        }
      };
    }


    function validationFindAssignment(dateIso, storeKey, name, time) {
      const clean = canonicalStaffNameForStore(name, storeKey);
      return uniqueAssignments(dateIso, storeKey).find(assignment => (
        canonicalStaffNameForStore(assignment.name, storeKey) === clean && assignment.time === time
      ));
    }

    function validationIsMissingExact(dateIso, storeKey, name, time) {
      return !uniqueAssignments(dateIso, storeKey).some(assignment => (
        canonicalStaffNameForStore(assignment.name, storeKey) === canonicalStaffNameForStore(name, storeKey) && assignment.time === time
      ));
    }

    function validationApplySavedActionPlan(dates, storeKey) {
      const beforeStats = rieCompareStats(dates, storeKey);
      const beforeCounts = validationPersonTypeCounts(beforeStats.personDiffs);
      const plan = validationSavedActionRows(beforeStats.personDiffs, 500);
      const masterCount = rieEntriesFor(dates, storeKey).length;
      const applied = { swaps: [], adds: [], removes: [], timeFixes: [], skipped: [] };
      const usedRemove = new Set();
      const usedAdd = new Set();

      function removeKey(row) { return `${row.dateIso}|${row.storeKey}|${canonicalStaffNameForStore(row.name, row.storeKey)}|${row.time}`; }
      function addKey(row) { return `${row.dateIso}|${row.storeKey}|${canonicalStaffNameForStore(row.name, row.storeKey)}|${row.time}`; }

      function applySwapCandidatesFromPlan(planObj, passLabel = "pass") {
        (planObj.swapCandidates || []).forEach(sw => {
          const rem = { dateIso: sw.dateIso, storeKey: sw.storeKey, name: sw.remove && sw.remove.name, time: sw.remove && sw.remove.time };
          const add = { dateIso: sw.dateIso, storeKey: sw.storeKey, name: sw.add && sw.add.name, time: sw.add && sw.add.time };
          const rk = removeKey(rem);
          const ak = addKey(add);
          if (usedRemove.has(rk) || usedAdd.has(ak)) return;
          if (!validationIsMissingExact(add.dateIso, add.storeKey, add.name, add.time)) return;
          const oldAssignment = validationFindAssignment(rem.dateIso, rem.storeKey, rem.name, rem.time);
          if (!oldAssignment) { applied.skipped.push({ action: "swap", pass: passLabel, reason: "removeMissing", remove: rem, add }); return; }
          removeShiftFromDay(rem.dateIso, rem.storeKey, oldAssignment);
          const added = directAddExactRieMasterAssignment({ dateIso: add.dateIso, storeKey: add.storeKey, name: add.name, time: add.time });
          if (added) {
            usedRemove.add(rk);
            usedAdd.add(ak);
            applied.swaps.push({ pass: passLabel, remove: rem, add });
          } else {
            directAddExactRieMasterAssignment({ dateIso: rem.dateIso, storeKey: rem.storeKey, name: rem.name, time: rem.time });
            applied.skipped.push({ action: "swap", pass: passLabel, reason: "addFailed", remove: rem, add });
          }
        });
      }

      applySwapCandidatesFromPlan(plan, "initial");

      // 件数が足りない店舗だけ、未反映の不足行を正本ロックで追加する。
      let currentCount = weeklyAssignmentCount(storeKey, dates);
      const afterSwapStats = rieCompareStats(dates, storeKey);
      const stillMissing = (afterSwapStats.personDiffs || [])
        .filter(row => row.type === "アプリにない")
        .map(validationFormatDiffRow)
        .sort((a,b) => String(a.dateIso).localeCompare(String(b.dateIso)) || String(a.time).localeCompare(String(b.time)) || String(a.name).localeCompare(String(b.name), 'ja'));
      stillMissing.forEach(row => {
        if (currentCount >= masterCount) return;
        if (!validationIsMissingExact(row.dateIso, row.storeKey, row.name, row.time)) return;
        if (directAddExactRieMasterAssignment(row)) {
          applied.adds.push(row);
          currentCount = weeklyAssignmentCount(storeKey, dates);
        }
      });

      // 件数が多い店舗だけ、まだ余っている行を落とす。
      let afterAddStats = rieCompareStats(dates, storeKey);
      const stillExtra = (afterAddStats.personDiffs || [])
        .filter(row => row.type === "アプリ余分")
        .map(validationFormatDiffRow)
        .sort((a,b) => String(a.dateIso).localeCompare(String(b.dateIso)) || String(a.time).localeCompare(String(b.time)) || String(a.name).localeCompare(String(b.name), 'ja'));
      stillExtra.forEach(row => {
        currentCount = weeklyAssignmentCount(storeKey, dates);
        if (currentCount <= masterCount) return;
        const oldAssignment = validationFindAssignment(row.dateIso, row.storeKey, row.name, row.time);
        if (oldAssignment) {
          removeShiftFromDay(row.dateIso, row.storeKey, oldAssignment);
          applied.removes.push(row);
        }
      });

      // 36.53: 初回適用後にまだ「同日で余分→不足」が残る場合だけ、最大2回まで追加スワップする。
      // 件数は変えず、正本丸写しの追加ではなく、残差の入れ替えだけを狙う。
      for (let pass = 2; pass <= 3; pass += 1) {
        const residualStats = rieCompareStats(dates, storeKey);
        const residualPlan = validationSavedActionRows(residualStats.personDiffs, 500);
        const beforeSwapCount = applied.swaps.length;
        applySwapCandidatesFromPlan(residualPlan, `residual${pass}`);
        if (applied.swaps.length === beforeSwapCount) break;
      }

      // 36.55: まだ不足/余分が同数で残る場合、件数を維持したまま「別日ペア」で補正する。
      // これは正本丸写しではなく、残った余分を落として同数の不足を入れる最終バランス補正。
      function applyResidualBalancePairs() {
        const residualStats = rieCompareStats(dates, storeKey);
        const residualPlan = validationSavedActionRows(residualStats.personDiffs, 500);
        const missingRows = (residualPlan.missingRows || []).slice();
        const extraRows = (residualPlan.extraRows || []).slice();
        let current = weeklyAssignmentCount(storeKey, dates);
        if (!missingRows.length || !extraRows.length) return;
        if (current !== masterCount) return;
        const pairCount = Math.min(missingRows.length, extraRows.length, 8);
        for (let i = 0; i < pairCount; i += 1) {
          const ex = extraRows[i];
          const miss = missingRows[i];
          const oldAssignment = validationFindAssignment(ex.dateIso, ex.storeKey, ex.name, ex.time);
          if (!oldAssignment) { applied.skipped.push({ action: "balancePair", pass: "residualBalance", reason: "removeMissing", remove: ex, add: miss }); continue; }
          if (!validationIsMissingExact(miss.dateIso, miss.storeKey, miss.name, miss.time)) { applied.skipped.push({ action: "balancePair", pass: "residualBalance", reason: "addAlreadyExists", remove: ex, add: miss }); continue; }
          removeShiftFromDay(ex.dateIso, ex.storeKey, oldAssignment);
          const added = directAddExactRieMasterAssignment(miss);
          if (added) {
            applied.removes.push({ ...ex, pass: "residualBalance" });
            applied.adds.push({ ...miss, pass: "residualBalance" });
          } else {
            directAddExactRieMasterAssignment({ dateIso: ex.dateIso, storeKey: ex.storeKey, name: ex.name, time: ex.time });
            applied.skipped.push({ action: "balancePair", pass: "residualBalance", reason: "addFailed", remove: ex, add: miss });
          }
        }
      }
      applyResidualBalancePairs();

      // 36.56: 人物の不足/余分が消えた後に残る「同一人物の時間ズレ」を、件数を変えずに正本時間へ寄せる。
      // 例: 正本 22-3 / アプリ 18-3 の場合、同じ人のアプリ側勤務を外して正本時間で入れ直す。
      function parseTimeShiftDiff(row) {
        const text = String(row && row.time ? row.time : "");
        const m = text.match(/正本\s*([^/]+?)\s*\/\s*アプリ\s*(.+)$/);
        if (!m) return null;
        const masterTime = normalizeTimeInput(m[1].trim()) || m[1].trim();
        const appTime = normalizeTimeInput(m[2].trim()) || m[2].trim();
        if (!masterTime || !appTime || masterTime === appTime) return null;
        return {
          dateIso: row.dateIso,
          storeKey: row.storeKey,
          storeName: stores[row.storeKey]?.name || row.storeKey,
          name: canonicalStaffNameForStore(row.name || "", row.storeKey),
          rawName: row.name || "",
          masterTime,
          appTime,
          type: "時間ズレ寄せ"
        };
      }

      function applyTimeShiftRepairs() {
        const stats = rieCompareStats(dates, storeKey);
        const rows = (stats.personDiffs || [])
          .filter(row => row.type === "時間ズレ")
          .map(parseTimeShiftDiff)
          .filter(Boolean)
          .sort((a,b) => String(a.dateIso).localeCompare(String(b.dateIso)) || String(a.name).localeCompare(String(b.name), 'ja') || String(a.masterTime).localeCompare(String(b.masterTime)));
        rows.forEach(row => {
          // 件数は必ず維持。すでに正本時間が存在するなら触らない。
          if (!validationIsMissingExact(row.dateIso, row.storeKey, row.name, row.masterTime)) return;
          const oldAssignment = validationFindAssignment(row.dateIso, row.storeKey, row.name, row.appTime);
          if (!oldAssignment) { applied.skipped.push({ action: "timeShiftFit", pass: "timeShift", reason: "appTimeMissing", row }); return; }
          removeShiftFromDay(row.dateIso, row.storeKey, oldAssignment);
          const added = directAddExactRieMasterAssignment({ dateIso: row.dateIso, storeKey: row.storeKey, name: row.name, time: row.masterTime });
          if (added) {
            applied.timeFixes.push(row);
          } else {
            directAddExactRieMasterAssignment({ dateIso: row.dateIso, storeKey: row.storeKey, name: row.name, time: row.appTime });
            applied.skipped.push({ action: "timeShiftFit", pass: "timeShift", reason: "addFailed", row });
          }
        });
      }
      applyTimeShiftRepairs();

      const afterStats = rieCompareStats(dates, storeKey);
      const afterCounts = validationPersonTypeCounts(afterStats.personDiffs);
      return {
        before: {
          masterCount,
          appCount: beforeStats.appEntries.length,
          coverageDiffCount: beforeStats.coverageDiffs.length,
          personDiffCount: beforeStats.personDiffs.length,
          personDiff: beforeCounts
        },
        after: {
          masterCount,
          appCount: afterStats.appEntries.length,
          coverageDiffCount: afterStats.coverageDiffs.length,
          personDiffCount: afterStats.personDiffs.length,
          personDiff: afterCounts
        },
        appliedCounts: {
          swaps: applied.swaps.length,
          adds: applied.adds.length,
          removes: applied.removes.length,
          timeFixes: applied.timeFixes.length,
          skipped: applied.skipped.length
        },
        applied
      };
    }

    function validationOneStoreSavedRepairPreviewFromSnapshot(baseSnapshot, weekStartIso, storeKey) {
      applySerialized(baseSnapshot);
      validationSetWeekAndStore(weekStartIso, storeKey);
      const dates = weekDates(weekStartIso);
      const startedAt = performance.now ? performance.now() : Date.now();
      const preMasterCount = rieEntriesFor(dates, storeKey).length;
      const preSavedCount = weeklyAssignmentCount(storeKey, dates);
      const minExpectedSavedCount = Math.max(20, Math.floor(preMasterCount * 0.75));
      if (preMasterCount > 0 && preSavedCount < minExpectedSavedCount) {
        throw new Error(`差分適用プレビュー: ${stores[storeKey]?.name || storeKey} の保存済み件数が少なすぎます（保存${preSavedCount}/正本${preMasterCount}）。フル保存JSONをJSON欄に貼って、緑の「JSON欄のフル保存JSONで差分プレビュー」を押してください。`);
      }
      const repairPreview = validationApplySavedActionPlan(dates, storeKey);
      const stats = rieCompareStats(dates, storeKey);
      const endedAt = performance.now ? performance.now() : Date.now();
      return {
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        weekStart: weekStartIso,
        weekLabel: weekLabel(dates),
        runtimeMs: Math.round(endedAt - startedAt),
        validationStatus: "SAVED_ACTION_APPLY_PREVIEW",
        validationMode: "saved-current-schedule-action-apply-preview",
        phaseLog: [
          { phase: "loadedSavedSchedule", count: repairPreview.before.appCount },
          { phase: "afterActionPreview", count: repairPreview.after.appCount },
          { phase: "afterCompare", count: stats.appEntries.length }
        ],
        masterCount: stats.entries.length,
        appCount: stats.appEntries.length,
        coverageDiffCount: stats.coverageDiffs.length,
        personDiffCount: stats.personDiffs.length,
        personDiff: validationPersonTypeCounts(stats.personDiffs),
        personTop: validationNameTopRows(stats.personDiffs),
        coverageTop: validationCoverageTopRows(stats.coverageDiffs),
        repairPreview,
        actionPlan: validationSavedActionRows(stats.personDiffs, 40),
        correctionLog: null
      };
    }

    function validationRequireFullSaveSnapshot(snapshot, actionLabel = "自動検証") {
      if (!snapshot || typeof snapshot !== "object") throw new Error(`${actionLabel}: JSONとして読み込めません`);
      if (snapshot.validatorVersion || snapshot.results || snapshot.validationMode) {
        throw new Error(`${actionLabel}: これは検証結果JSONです。先頭が {"month":"2026-07"...} のフル保存JSONを貼ってください。`);
      }
      if (!snapshot.schedule || typeof snapshot.schedule !== "object") {
        throw new Error(`${actionLabel}: schedule がありません。フル保存JSONではありません。`);
      }
      if (!snapshot.rieMaster || !Array.isArray(snapshot.rieMaster)) {
        throw new Error(`${actionLabel}: rieMaster がありません。フル保存JSONではありません。`);
      }
      return snapshot;
    }

    function runSavedWishRepairPreview(useJsonBox = false) {
      const output = document.getElementById("validationOutput");
      const jsonBox = document.getElementById("jsonBox");
      const previousSnapshot = serializeState();
      try {
        let baseSnapshot = previousSnapshot;
        if (useJsonBox) {
          if (!jsonBox || !jsonBox.value.trim()) throw new Error("JSON欄が空です");
          baseSnapshot = JSON.parse(jsonBox.value);
        }
        validationRequireFullSaveSnapshot(baseSnapshot, "差分適用プレビュー");
        applySerialized(baseSnapshot);
        const weekStartIso = document.getElementById("validationWeekStart")?.value || state.selectedWeekStart || "2026-07-13";
        const storeValue = document.getElementById("validationStore")?.value || "target";
        const storeKeys = validationTargetStoreKeys(storeValue);
        const results = storeKeys.map(storeKey => validationOneStoreSavedRepairPreviewFromSnapshot(baseSnapshot, weekStartIso, storeKey));
        const result = {
          validatorVersion: "beta4.10.37.04 正本なし・3店舗監査復旧修正版",
          sourceAppVersion: baseSnapshot.appVersion || state.appVersion || "unknown",
          generatedAt: new Date().toISOString(),
          weekStart: weekStartIso,
          stores: storeKeys,
          validationMode: "saved-current-schedule-action-apply-preview",
          results,
          summary: results.map(row => `${row.storeName}: 正本${row.masterCount}/アプリ${row.appCount} 時間差分${row.coverageDiffCount} 人物差分${row.personDiffCount}`).join(" / ")
        };
        state.lastAutoValidationResult = result;
        if (output) output.value = JSON.stringify(result, null, 2);
        const restoreMode = document.getElementById("validationRestoreMode")?.value || "restore";
        if (restoreMode === "restore") applySerialized(previousSnapshot);
        renderAll();
        showToast(`差分適用プレビュー完了：${result.summary}`);
        return result;
      } catch (error) {
        if (output) output.value = JSON.stringify({ error: String(error && error.message ? error.message : error) }, null, 2);
        applySerialized(previousSnapshot);
        renderAll();
        showToast(`差分適用プレビューで停止：${error && error.message ? error.message : error}`);
        return null;
      }
    }

    // 36.49 保存済み結果検証：保存JSON内に残っている作成済み正本なし生成結果を、消さず・再生成せずに正本突合する。
    // 36.46〜36.48の再生成検証は、対象週を空にすると9〜10件で止まることが分かったため、精度評価には使わない。
    function validationOneStoreSavedFromSnapshot(baseSnapshot, weekStartIso, storeKey) {
      applySerialized(baseSnapshot);
      validationSetWeekAndStore(weekStartIso, storeKey);
      const dates = weekDates(weekStartIso);
      const startedAt = performance.now ? performance.now() : Date.now();
      const stats = rieCompareStats(dates, storeKey);
      const endedAt = performance.now ? performance.now() : Date.now();
      const personCounts = validationPersonTypeCounts(stats.personDiffs);
      const actionPlan = validationSavedActionRows(stats.personDiffs, 40);
      const appCount = weeklyAssignmentCount(storeKey, dates);
      const masterCount = rieEntriesFor(dates, storeKey).length;
      return {
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        weekStart: weekStartIso,
        weekLabel: weekLabel(dates),
        runtimeMs: Math.round(endedAt - startedAt),
        validationStatus: "SAVED_RESULT_COMPARE_ONLY",
        validationMode: "saved-current-schedule-no-clear-no-regenerate",
        phaseLog: [
          { phase: "loadedSavedSchedule", count: appCount },
          { phase: "noClear", count: appCount },
          { phase: "noRegenerate", count: appCount },
          { phase: "afterCompare", count: appCount }
        ],
        masterCount,
        appCount,
        coverageDiffCount: stats.coverageDiffs.length,
        personDiffCount: stats.personDiffs.length,
        personDiff: personCounts,
        personTop: validationNameTopRows(stats.personDiffs),
        coverageTop: validationCoverageTopRows(stats.coverageDiffs),
        actionPlan,
        correctionLog: state.lastWishCorrectionLog || null
      };
    }

    function runSavedWishValidation(useJsonBox = false) {
      const output = document.getElementById("validationOutput");
      const jsonBox = document.getElementById("jsonBox");
      const previousSnapshot = serializeState();
      try {
        let baseSnapshot = previousSnapshot;
        if (useJsonBox) {
          if (!jsonBox || !jsonBox.value.trim()) throw new Error("JSON欄が空です");
          baseSnapshot = JSON.parse(jsonBox.value);
        }
        validationRequireFullSaveSnapshot(baseSnapshot, "保存済み結果検証");
        applySerialized(baseSnapshot);
        const weekStartIso = document.getElementById("validationWeekStart")?.value || state.selectedWeekStart || "2026-07-13";
        const storeValue = document.getElementById("validationStore")?.value || "target";
        const storeKeys = validationTargetStoreKeys(storeValue);
        const results = storeKeys.map(storeKey => validationOneStoreSavedFromSnapshot(baseSnapshot, weekStartIso, storeKey));
        const result = {
          validatorVersion: "beta4.10.37.04 正本なし・3店舗監査復旧修正版",
          sourceAppVersion: baseSnapshot.appVersion || state.appVersion || "unknown",
          generatedAt: new Date().toISOString(),
          weekStart: weekStartIso,
          stores: storeKeys,
          validationMode: "saved-current-schedule-no-clear-no-regenerate",
          results,
          summary: results.map(row => `${row.storeName}: 正本${row.masterCount}/アプリ${row.appCount} 時間差分${row.coverageDiffCount} 人物差分${row.personDiffCount}`).join(" / ")
        };
        state.lastAutoValidationResult = result;
        if (output) output.value = JSON.stringify(result, null, 2);
        const restoreMode = document.getElementById("validationRestoreMode")?.value || "restore";
        if (restoreMode === "restore") applySerialized(previousSnapshot);
        else applySerialized(baseSnapshot);
        renderAll();
        showToast(`保存済み結果検証完了：${result.summary}`);
        return result;
      } catch (error) {
        if (output) output.value = JSON.stringify({ error: String(error && error.message ? error.message : error) }, null, 2);
        applySerialized(previousSnapshot);
        renderAll();
        showToast(`保存済み結果検証で停止：${error && error.message ? error.message : error}`);
        return null;
      }
    }

    function runAutoWishValidation(useJsonBox = false) {
      const output = document.getElementById("validationOutput");
      const weekInput = document.getElementById("validationWeekStart");
      const storeInput = document.getElementById("validationStore");
      const restoreInput = document.getElementById("validationRestoreMode");
      const jsonBox = document.getElementById("jsonBox");
      const originalSnapshot = serializeState();
      let baseSnapshot = originalSnapshot;
      try {
        if (useJsonBox) {
          const text = jsonBox ? jsonBox.value.trim() : "";
          if (!text) throw new Error("JSON欄が空です");
          const payload = JSON.parse(text);
          if (!applySerialized(payload)) throw new Error("JSONを取り込めませんでした");
          baseSnapshot = serializeState();
        }
        const weekStartIso = (weekInput && weekInput.value) || state.selectedWeekStart || "2026-07-13";
        const targetStores = validationTargetStoreKeys(storeInput ? storeInput.value : "target");
        const results = targetStores.map(storeKey => validationOneStoreFromSnapshot(baseSnapshot, weekStartIso, storeKey));
        const result = {
          validatorVersion: "beta4.10.37.04 正本なし・3店舗監査復旧修正版",
          sourceAppVersion: baseSnapshot.appVersion || null,
          generatedAt: new Date().toISOString(),
          weekStart: weekStartIso,
          stores: targetStores,
          results,
          summary: validationBuildResultSummary(results)
        };
        if (output) output.value = JSON.stringify(result, null, 2);
        const keepLast = restoreInput && restoreInput.value === "keep-last";
        if (!keepLast) {
          applySerialized(useJsonBox ? baseSnapshot : originalSnapshot);
          renderAll();
        } else {
          renderAll();
        }
        showToast(`自動検証完了：${result.summary}`);
        return result;
      } catch (error) {
        if (output) output.value = JSON.stringify({ error: String(error && error.message ? error.message : error), generatedAt: new Date().toISOString() }, null, 2);
        applySerialized(originalSnapshot);
        renderAll();
        showToast(`自動検証で停止：${error && error.message ? error.message : error}`);
        return null;
      }
    }

    async function copyValidationResult() {
      const box = document.getElementById("validationOutput");
      const button = document.getElementById("copyValidationResultBtn");
      const text = box ? box.value : "";

      if (!text) {
        showToast("コピーする検証結果がない");
        return;
      }

      const originalLabel = button ? button.textContent : "";
      const mark = (label) => {
        if (!button) return;
        button.textContent = label;
        window.setTimeout(() => {
          button.textContent = originalLabel || "検証結果JSONコピー";
        }, 1800);
      };

      try {
        if (
          navigator.clipboard &&
          typeof navigator.clipboard.writeText === "function"
        ) {
          await navigator.clipboard.writeText(text);
          mark("✓ コピー済み");
          const status = document.getElementById("validationExportStatus");
          if (status) status.textContent = "検証結果JSONをコピーしました";
          showToast("検証結果JSONをコピーしました");
          return;
        }
      } catch (error) {
        console.warn("Clipboard API copy failed", error);
      }

      // file:// や権限制限環境向けフォールバック
      try {
        box.focus();
        box.select();
        box.setSelectionRange(0, box.value.length);
        const copied = document.execCommand("copy");
        if (copied) {
          mark("✓ コピー済み");
          const status = document.getElementById("validationExportStatus");
          if (status) status.textContent = "検証結果JSONをコピーしました";
          showToast("検証結果JSONをコピーしました");
          return;
        }
      } catch (error) {
        console.warn("execCommand copy failed", error);
      }

      box.focus();
      box.select();
      box.setSelectionRange(0, box.value.length);
      mark("全文選択済み");
      const status = document.getElementById("validationExportStatus");
      if (status) status.textContent = "自動コピー失敗。Ctrl+Cでコピーしてください";
      showToast("自動コピーできなかったため、全文を選択しました。Ctrl+Cでコピーしてください");
    }

    function saveValidationResult() {
      const box = document.getElementById("validationOutput");
      const text = box ? box.value : "";

      if (!text) {
        showToast("保存する検証結果がない");
        return;
      }

      let version = "validation";
      let weekStart = state && state.selectedWeekStart
        ? state.selectedWeekStart
        : "week";

      try {
        const parsed = JSON.parse(text);
        version = String(parsed.validatorVersion || "validation")
          .replace(/[^\w.-]+/g, "-")
          .replace(/-+/g, "-")
          .replace(/^-|-$/g, "");
        weekStart = parsed.weekStart || weekStart;
      } catch (error) {
        console.warn("validation JSON filename parse failed", error);
      }

      const blob = new Blob([text], {
        type: "application/json;charset=utf-8"
      });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `makotsu-shift-37.04-validation-${weekStart}.json`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      window.setTimeout(() => URL.revokeObjectURL(url), 1000);
      const status = document.getElementById("validationExportStatus");
      if (status) status.textContent = "検証結果JSONを保存しました";
      showToast("検証結果JSONを保存しました");
    }

    function bindEvents() {
      onAll("[data-view]", "click", "画面切替", (event, btn) => {
        event.preventDefault();
        switchView(btn.dataset.view);
      });
      onAll("[data-jump]", "click", "画面移動", (event, btn) => {
        event.preventDefault();
        switchView(btn.dataset.jump);
      });
      on("homeApply", "click", "期間反映", syncPeriodFromHome);
      ["homeEmergencyStaff", "homeEmergencyDate", "homeEmergencyStore", "homeEmergencySlot"].forEach(id => {
        const element = document.getElementById(id);
        if (element) element.addEventListener("change", safeRun("急遽休み候補更新", renderHomeEmergency));
      });
      on("homeEmergencyApply", "click", "急遽休み登録", applyHomeEmergencyAbsence);
      on("monthInput", "change", "月変更", syncPeriodFromMonthly);
      on("startDayInput", "change", "締め日変更", syncPeriodFromMonthly);
      on("storeInput", "change", "店舗変更", event => {
        state.selectedStore = event.target.value;
        state.selected = null;
        renderAll();
      });
      on("generateBtn", "click", "月間シフト作成", generateMonth);
      on("generateAllMonthlyBtn", "click", "全店舗仮作成", generateAllStores);
      on("clearStoreBtn", "click", "店舗シフトクリア", clearStore);
      on("weeklyCloseStart", "change", "週締め対象週変更", event => {
        state.selectedWeekStart = event.target.value;
        renderAll();
      });
      on("weeklyCloseStore", "change", "週締め店舗変更", event => {
        state.weeklyCloseStore = event.target.value;
        state.selectedStore = event.target.value;
        state.selected = null;
        renderAll();
      });
      document.addEventListener("click", safeRun("週締めボタン補助", event => {
        const button = event.target && event.target.closest
          ? event.target.closest("#generateWeeklyPureBtn, #generateAllWeeklyPureBtn, #generateWeeklyBtn, #generateAllWeeklyBtn, #generateWeeklyMasterBtn, #clearWeeklyBtn")
          : null;
        if (!button) return;
        event.preventDefault();
        if (button.id === "generateWeeklyPureBtn") return runHeavyWeeklyAction("正本なし自動作成", () => generateWeeklyClosePure());
        if (button.id === "generateAllWeeklyPureBtn") return runHeavyWeeklyAction("全店舗正本なし自動作成", () => generateAllWeeklyClosePure());
        if (button.id === "generateWeeklyBtn") return runHeavyWeeklyAction("正本参照補正", () => generateWeeklyClose());
        if (button.id === "generateAllWeeklyBtn") return runHeavyWeeklyAction("全店舗正本参照補正", () => generateAllWeeklyClose());
