    // β4.10.37.04 正本なし・3店舗監査復旧修正版
    // 36.65は「短縮」中心だったため、扇町のように 6-9 / 22-6 などの過剰を別時間帯へ逃がせないケースで compressRuns=0 になった。
    // 36.67では同一人物・同日・同店舗のまま、長短にこだわらず時間帯を再配分し、不足を増やしすぎない範囲で過剰セルを下げる。
    function noMasterV66CandidateRedistributionTimes(person, storeKey, dateIso) {
      const map = new Map();
      function add(time, score, source) {
        const normalized = normalizeTimeInput(time) || time;
        if (!normalized) return;
        if (!assignmentSlots(normalized, { allowPartialOverlap: true, requireFullSlotCoverage: false }).length) return;
        const prev = map.get(normalized);
        if (!prev || score > prev.score) map.set(normalized, { time: normalized, score, source });
      }
      noMasterV62CandidateTimes(person, storeKey, dateIso, true).forEach(row => add(row.time, row.score || 0, row.source || "candidate"));
      ["6-9","9-13","9-15","9-17","9-18","12-17","13-17","13-22","15-24","16-22","17-21","17-22","18-22","19-24","21-24","22-3","22-6","24-6","24-9"].forEach(time => add(time, 1200, "redistributeFallback"));
      return [...map.values()];
    }

    function noMasterV66RedistributeSurplusByTime(dates, storeKey, options = {}, diagnostics = {}) {
      let totalFixes = 0;
      const active = noMasterV62ActiveStaffForStore(storeKey);
      const byName = new Map(active.map(p => [noMasterV62CanonicalName(p.name), p]));
      const maxPass = 8;
      for (let pass = 0; pass < maxPass; pass += 1) {
        let passFixes = 0;
        dates.forEach(date => {
          const dateIso = iso(date);
          const expectation = wishThirtyMinuteExpectationForDate(dateIso, storeKey, options);
          const current = wishDiffSummaryForDate(dateIso, storeKey, expectation);
          const assignments = uniqueAssignments(dateIso, storeKey).slice();
          let best = null;
          assignments.forEach(oldAssignment => {
            const key = noMasterV62CanonicalName(oldAssignment.name);
            const person = byName.get(key) || findStaff(oldAssignment.name) || { name: oldAssignment.name, stores: [storeKey], times: noMasterFallbackTimesForStore(storeKey), support: Boolean(oldAssignment.support) };
            if (noMasterV64ReasonForTimeReplace(dateIso, storeKey, person, oldAssignment.time) !== "ok") return;
            noMasterV66CandidateRedistributionTimes(person, storeKey, dateIso).forEach(row => {
              const newTime = normalizeTimeInput(row.time) || row.time;
              if (!newTime || newTime === oldAssignment.time) return;
              if (noMasterV64ReasonForTimeReplace(dateIso, storeKey, person, newTime) !== "ok") return;
              const nextAssignments = assignments.filter(a => assignmentKey(a) !== assignmentKey(oldAssignment));
              nextAssignments.push({ name: noMasterV62CanonicalName(oldAssignment.name), time: newTime, support: Boolean(oldAssignment.support), noMaster: true, generatedBy: "v66Redistribute" });
              const next = wishDiffSummaryFromAssignments(nextAssignments, storeKey, expectation);
              const surplusGain = current.surplus - next.surplus;
              const shortageDelta = next.shortage - current.shortage;
              const scoreGain = current.score - next.score;
              // 過剰が減る、または全体スコアが明確に良くなるものだけ採用。極端な不足増は拒否。
              if (shortageDelta > 2) return;
              if (surplusGain <= 0 && scoreGain <= 0) return;
              const oldLen = Math.max(1, parseRange(oldAssignment.time)[1] - parseRange(oldAssignment.time)[0]);
              const newLen = Math.max(1, parseRange(newTime)[1] - parseRange(newTime)[0]);
              const lengthPenalty = Math.max(0, newLen - oldLen) * 8;
              const totalScore = surplusGain * 600 + scoreGain * 120 - shortageDelta * 900 - lengthPenalty + (row.score || 0) * 0.02;
              if (!best || totalScore > best.totalScore) {
                best = { dateIso, oldAssignment, person, newTime, totalScore, next, surplusGain, shortageDelta, scoreGain };
              }
            });
          });
          if (best) {
            removeShiftFromDay(best.dateIso, storeKey, best.oldAssignment);
            if (noMasterV62DirectAddShift(best.dateIso, storeKey, best.person, best.newTime)) {
              passFixes += 1;
              totalFixes += 1;
            } else {
              noMasterV62DirectAddShift(best.dateIso, storeKey, best.person, best.oldAssignment.time);
            }
          }
        });
        if (!passFixes) break;
      }
      diagnostics.redistributeRuns = (diagnostics.redistributeRuns || 0) + totalFixes;
      diagnostics.compressRuns = (diagnostics.compressRuns || 0) + totalFixes;
      return totalFixes;
    }

    // 36.67 final override: 36.65の短縮圧縮に加え、時間帯再配分を必ず実行する。
    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = { blocked: {}, noCandidateDates: [], submittedAdded: 0, teacherAdds: 0, targetAdds: 0, relaxedAdds: 0, finalRescueAdds: 0, compressRuns: 0, redistributeRuns: 0, band, poolSize: {} };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();
      diagnostics.poolSize[storeKey] = noMasterV62ActiveStaffForStore(storeKey).length;

      count("afterClear");

      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = noMasterV62ActiveStaffForStore(storeKey).find(p => noMasterV62CanonicalName(p.name) === noMasterV62CanonicalName(row.name));
          if (!person) return;
          if (noMasterV62DirectAddShift(dateIso, storeKey, person, row.time)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV62FillDate(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds", false);
      });
      count("afterDailyTeacherTargets");

      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 260) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 40 + targetGap * 220 - uniqueAssignments(dateIso, storeKey).length * 5 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV62PickBest(row.dateIso, storeKey, storeOptions, diagnostics, true);
          if (!picked) continue;
          if (noMasterV62DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.relaxedAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterRelaxedWeeklyRescue");

      try {
        if (typeof noMasterV64CompressSurplusByTime === "function") {
          noMasterV64CompressSurplusByTime(dates, storeKey, storeOptions, diagnostics);
        }
        if (typeof noMasterV66RedistributeSurplusByTime === "function") {
          noMasterV66RedistributeSurplusByTime(dates, storeKey, storeOptions, diagnostics);
        }
      } catch (e) {
        diagnostics.blocked.compressError = String(e && e.message ? e.message : e);
      }
      count("afterSurplusRedistribution");
      count("afterNoMasterFinal");

      const wishLog = {
        version: "β4.10.37.04",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        sourceStaffPool: diagnostics.poolSize[storeKey],
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        compressRuns: diagnostics.compressRuns || 0,
        redistributeRuns: diagnostics.redistributeRuns || 0,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }

    staff.forEach(person => {
        const correction = corrections[person.name];
        if (!correction) return;
        if (correction.stores) person.stores = [...correction.stores];
        if (correction.days) person.days = [...correction.days];
        if (correction.times) person.times = [...correction.times];
        if (Object.prototype.hasOwnProperty.call(correction, "inactive")) person.inactive = Boolean(correction.inactive);
        person.tags = mergeUnique(person.tags, correction.requiredTags || []);
        person.slots = slotsFromTimes(person.times || []);
        if (!person.slots.length) person.slots = [...slots];
      });
    }

    function hasTag(person, text) {
      return Boolean(person && person.tags && person.tags.some(tag => tag.includes(text)));
    }

    function isInactiveStaff(person) {
      return Boolean(person && (
        person.inactive ||
        hasTag(person, "解雇") ||
        hasTag(person, "退職") ||
        hasTag(person, "自動配置停止")
      ));
    }

    function canWorkAtStore(person, storeKey) {
      return Boolean(person && !isInactiveStaff(person) && person.stores && person.stores.includes(storeKey));
    }

    function matchesDay(person, dateIso) {
      if (!person.days || !person.days.length) return true;
      const date = new Date(`${dateIso}T00:00:00`);
      return person.days.includes(dowLabel(date));
    }

    function areIncompatible(nameA, nameB) {
      return incompatiblePairs.some(([a, b]) => (
        (a === nameA && b === nameB) || (a === nameB && b === nameA)
      ));
    }

    function hasIncompatiblePerson(dateIso, storeKey, personName) {
      return slots.some(slot => ensureCell(dateIso, storeKey, slot).some(item => areIncompatible(item.name, personName)));
    }

    function hasResponsiblePerson(people) {
      return people.some(item => {
        const person = findStaff(item.name);
        return hasTag(person, "責任者候補") || hasTag(person, "社員") || hasTag(person, "店長");
      });
    }

    function requiresResponsibleCompanion(person) {
      return hasTag(person, "責任者同伴のみ");
    }

    function isManualSupportPerson(person) {
      return Boolean(person && (person.support || person.name === "まこつ。" || person.name === "りえ"));
    }

    function isExplicitRieMasterName(dateIso, storeKey, personName) {
      if (!dateIso || !storeKey || !personName) return false;
      const name = canonicalStaffName(personName);
      return rieMasterRowsForDateStore(dateIso, storeKey).some(row => canonicalStaffName(row.name) === name);
    }

    function canAutoUsePerson(person, dateIso, storeKey) {
      if (!person) return false;
      if (isManualSupportPerson(person)) return isExplicitRieMasterName(dateIso, storeKey, person.name);
      return true;
    }

    function hasResponsibleCompanionForShift(dateIso, storeKey, person, time, options = {}) {
      if (!requiresResponsibleCompanion(person)) return true;
      return assignmentSlots(time, options).every(slot => {
        const people = ensureCell(dateIso, storeKey, slot)
          .filter(assignment => canonicalStaffName(assignment.name) !== canonicalStaffName(person.name));
        return hasResponsiblePerson(people);
      });
    }

    function isAssignedAnywhere(dateIso, personName) {
      return storeOrder.some(storeKey => (
        slots.some(slot => ensureCell(dateIso, storeKey, slot).some(x => x.name === personName))
      ));
    }

    function assignmentKey(assignment) {
      return `${assignment.name}|${assignment.time}`;
    }

    function uniqueAssignments(dateIso, storeKey) {
      const map = new Map();
      slots.forEach(slot => {
        ensureCell(dateIso, storeKey, slot).forEach(assignment => {
          map.set(assignmentKey(assignment), assignment);
        });
      });
      return [...map.values()];
    }

    function displayAssignmentsForSlot(dateIso, storeKey, slot) {
      return uniqueAssignments(dateIso, storeKey).filter(assignment => overlapsSlot(assignment.time, slot));
    }

    function hourlyWageFor(name, hour) {
      if (name === "まこつ。" || name === "りえ") return 0;
      const clockHour = ((Math.floor(hour) % 24) + 24) % 24;
      if (clockHour >= 22 || clockHour < 6) return 1531;
      if (clockHour >= 6 && clockHour < 9) return 1250;
      return ["永井", "赤瀬"].includes(name) ? 1250 : 1225;
    }

    function wageOf(name) {
      return hourlyWageFor(name, 9);
    }

    function assignmentHours(assignment) {
      const [start, end] = parseRange(assignment.time);
      return Math.max(0, end - start);
    }

    function assignmentLaborCost(assignment) {
      const [start, end] = parseRange(assignment.time);
      let total = 0;
      for (let hour = start; hour < end; hour += 1) {
        const next = Math.min(hour + 1, end);
        total += (next - hour) * hourlyWageFor(assignment.name, hour);
      }
      return total;
    }

    function storeLabor(storeKey) {
      let total = 0;
      periodDates().forEach(date => {
        const dateIso = iso(date);
        uniqueAssignments(dateIso, storeKey).forEach(assignment => {
          total += assignmentLaborCost(assignment);
        });
      });
      return total;
    }

    function supportCount(storeKey = "all") {
      let count = 0;
      periodDates().forEach(date => {
        const dateIso = iso(date);
        storeOrder.forEach(key => {
          if (storeKey !== "all" && storeKey !== key) return;
          uniqueAssignments(dateIso, key).forEach(assignment => {
            if (assignment.support) count += 1;
          });
        });
      });
      return count;
    }

    function coveredSlots(time) {
      return slots.filter(slot => coversSlot(time, slot));
    }

    function assignmentSlots(time, options = {}) {
      if (!options.allowPartialOverlap) return coveredSlots(time);
      return slots.filter(slot => overlapsSlot(time, slot));
    }

    function assignmentExists(cell, assignment) {
      return cell.some(existing => assignmentKey(existing) === assignmentKey(assignment));
    }

    function canAddNonOverlappingSplitShift(dateIso, storeKey, personName, time, options = {}) {
      const assignments = personAssignmentsForDay(dateIso, personName);
      if (!assignments.length) return true;
      return assignments.every(existing => {
        const noOverlap = rangeOverlapHours(existing.time, time) <= 0;
        if (!noOverlap) return false;
        // 36.18: 正本アンカーだけは、非重複なら店舗またぎ分割も許可する。
        // 実紙では「午前A店・夕方B店」が存在するため、ここで弾くとミミ/工藤/下田系が戻らない。
        return existing.storeKey === storeKey || Boolean(options.allowCrossStoreSplitMaster);
      });
    }

    function strictStoreTimeBandViolation(person, storeKey, dateIso, time, targetSlot = "") {
      if (!person || !storeKey || !dateIso || !time) return false;
      const name = canonicalStaffName(person.name);
      const dow = dowLabel(new Date(`${dateIso}T00:00:00`));
      const exactMaster = hasExactRieMasterRow(dateIso, storeKey, person.name, time);
      if (exactMaster) return false;
      const overlaps = slot => overlapsSlot(time, slot);
      const [start, end] = parseRange(time);

      if (storeKey === "higashicho") {
        const morningForbidden = ["柳川", "高橋(東町)", "高木", "富田", "山梨", "東町 店長（小澤）", "大津", "キーズ"];
        if (overlaps("6-9") && morningForbidden.some(item => canonicalStaffName(item) === name)) return true;
        if (overlaps("9-13") && ["高木", "高橋(東町)", "山梨", "柳川"].some(item => canonicalStaffName(item) === name)) return true;
        if (name === canonicalStaffName("キーズ") && !["土", "日"].includes(dow)) return true;
        if (name === canonicalStaffName("キーズ") && !overlaps("9-13")) return true;
        if (name === canonicalStaffName("高木") && !overlaps("17-22")) return true;
        if (name === canonicalStaffName("高橋(東町)") && !overlaps("17-22")) return true;
        if (name === canonicalStaffName("柳川") && (overlaps("6-9") || overlaps("9-13") || overlaps("22-6"))) return true;
        if (name === canonicalStaffName("山梨") && !hasSubmittedWorkRequestTime(dateIso, storeKey, person.name, time)) return true;
        if (name === canonicalStaffName("東町 店長（小澤）") && overlaps("22-6")) return true;
        if (name === canonicalStaffName("富田") && (time === "22-6" || time === "22-7" || time === "24-9")) return true;
        if (targetSlot === "22-6" && end <= 24) return true;
      }

      if (storeKey === "ougicho") {
        if (overlaps("6-9") && ["加藤", "扇町 店長（齋藤）"].some(item => canonicalStaffName(item) === name)) return true;
        if (dow === "火" && overlaps("6-9") && name === canonicalStaffName("木村")) return true;
        if (name === canonicalStaffName("加藤") && time === "6-9") return true;
      }

      if (storeKey === "miyanoshita") {
        const isSunday = dow === "日";

        if (name === canonicalStaffName("柴田まちこ")) {
          if (!isSunday && time !== "6-9") return true;
          if (isSunday && (start < 6 || end > 22)) return true;
        }

        if (["柴田かずや", "柴田かずき"].some(item => canonicalStaffName(item) === name)) {
          if (start < 6 || end > 22) return true;
        }

        if (name === canonicalStaffName("幸本")) {
          if (!["月", "水"].includes(dow) || time !== "9-13") return true;
        }

        if (name === canonicalStaffName("古屋")) {
          const allowed =
            (dow === "月" && time === "12-17") ||
            (dow === "火" && time === "9-13") ||
            (dow === "土" && time === "12-17");
          if (!allowed) return true;
        }

        if (name === canonicalStaffName("西村")) {
          if (["土", "日"].includes(dow) || time !== "9-17") return true;
        }

        if (name === canonicalStaffName("高橋(宮下)")) {
          const allowed =
            (["火", "水"].includes(dow) && time === "13-17") ||
            (dow === "木" && time === "9-17");
          if (!allowed) return true;
        }

        if (name === canonicalStaffName("山崎")) {
          if (dow === "水" || end > 24) return true;
        }

        if (name === canonicalStaffName("笹島")) {
          if (!["22-9", "24-9", "22-6", "24-6"].includes(time)) return true;
        }

        if (name === canonicalStaffName("宮下 店長（小島）")) {
          const hours = Math.max(0, end - start);
          if (hours > 9 || end > 25) return true;
        }

        if (name === canonicalStaffName("下田") && time !== "18-24") return true;
      }

      return false;
    }

    function canPlaceShift(dateIso, storeKey, person, time, options = {}) {
      if (!person || !time) return false;
      const masterOverride = Boolean(options.masterOverride);
      if (!canWorkAtStore(person, storeKey)) return false;
      if (!masterOverride && options.strictTimeBand && strictStoreTimeBandViolation(person, storeKey, dateIso, time, options.targetSlot || "")) return false;
      if (hasTag(person, "希望日だけ配置") && !options.allowHopeOnlyPlacement && !hasSubmittedWorkRequestTime(dateIso, storeKey, person.name, time) && !hasExactRieMasterRow(dateIso, storeKey, person.name, time)) return false;
      if (!masterOverride && isUnavailable(person.name, dateIso)) return false;
      if (!masterOverride && !matchesDay(person, dateIso)) return false;
      if (!masterOverride && hasIncompatiblePerson(dateIso, storeKey, person.name)) return false;
      if (!masterOverride && !hasResponsibleCompanionForShift(dateIso, storeKey, person, time, options)) return false;
      if (options.requireFullSlotCoverage && options.targetSlot && !coversSlot(time, options.targetSlot)) return false;
      if (options.enforceCoreWorkLimit && isCoreEmployee(person) && !isPersonAssignedOnDate(dateIso, person.name)) {
        if (projectedWorkDays(person, options) >= targetWorkDays(person)) return false;
      }
      if (options.avoidLongStreak && !isPersonAssignedOnDate(dateIso, person.name)) {
        const maxDays = options.strictConsecutiveLimit
          ? (options.maxConsecutiveWorkDays || 5)
          : Math.max(options.maxConsecutiveWorkDays || 5, maxConsecutiveWorkDaysFor(person, time));
        if (projectedConsecutiveWorkDays(person.name, dateIso) > maxDays) return false;
      }
      const assignment = { name: person.name, time, support: person.support };
      const targets = assignmentSlots(time, options);
      if (!targets.length) return false;
      const alreadyAssigned = isAssignedAnywhere(dateIso, person.name);
      const sameAssignmentAlready = targets.every(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        return assignmentExists(cell, assignment);
      });
      if (options.preventDoubleBooking && alreadyAssigned && !sameAssignmentAlready) {
        const allowSplit = options.allowSplitShiftMaster && masterOverride && canAddNonOverlappingSplitShift(dateIso, storeKey, person.name, time, options);
        if (!allowSplit) return false;
      }
      if (options.respectCapacity) {
        return targets.every(slot => {
          const req = targetRequirementForSlot(dateIso, storeKey, slot, options);
          if (req <= 0) return false;
          const cell = ensureCell(dateIso, storeKey, slot);
          return assignmentExists(cell, assignment) || cell.length < req;
        });
      }
      return true;
    }

    function submittedWorkRequestsFor(dateIso, storeKey) {
      return submittedWorkRequests.filter(row => row.dateIso === dateIso && row.storeKey === storeKey);
    }

    function hasSubmittedWorkRequestTime(dateIso, storeKey, personName, time = "") {
      const name = canonicalStaffName(personName);
      return submittedWorkRequestsFor(dateIso, storeKey).some(row => (
        canonicalStaffName(row.name) === name && (!time || row.time === time)
      ));
    }

    function isSubmittedWorkAssignment(dateIso, storeKey, assignment) {
      const name = canonicalStaffName(assignment && assignment.name);
      const time = assignment && assignment.time;
      return submittedWorkRequestsFor(dateIso, storeKey).some(row => (
        canonicalStaffName(row.name) === name && row.time === time
      ));
    }

    function applySubmittedWorkRequestsForDate(dateIso, storeKey, options = {}) {
      let addedCount = 0;
      submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
        const person = findStaff(row.name);
        if (!person) return;
        const wasAssigned = isAssignedAnywhere(dateIso, person.name);
        const added = addShiftToDay(dateIso, storeKey, person, row.time, {
          ...options,
          allowHopeOnlyPlacement: true,
          allowPartialOverlap: true,
          requireFullSlotCoverage: false
        });
        if (added) {
          if (!wasAssigned && options.loadMap) {
            options.loadMap.set(person.name, (options.loadMap.get(person.name) || 0) + 1);
          }
          addedCount += 1;
        }
      });
      return addedCount;
    }

    function addShiftToDay(dateIso, storeKey, person, time, options = {}) {
      if (!canPlaceShift(dateIso, storeKey, person, time, options)) return false;
      const assignment = { name: person.name, time, support: person.support };
      assignmentSlots(time, options).forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        if (options.respectCapacity && cell.length >= targetRequirementForSlot(dateIso, storeKey, slot, options) && !assignmentExists(cell, assignment)) return;
        if (!assignmentExists(cell, assignment)) {
          cell.push(assignment);
        }
      });
      return true;
    }

    function isFixedPerson(person) {
      return Boolean(person && person.tags && person.tags.some(tag => (
        tag.includes("固定") && !tag.includes("固定休")
      )));
    }

    function fixedTimesForDate(person, dateIso) {
      if (!person || !dateIso) return [];
      const day = dowLabel(new Date(`${dateIso}T00:00:00`));
      const ranges = [];
      (person.tags || []).forEach(tag => {
        if (!tag.includes("固定") || !tag.includes(day)) return;
        const matches = tag.match(/\d{1,2}-\d{1,2}/g) || [];
        ranges.push(...matches);
      });
      return [...new Set(ranges.filter(time => (person.times || []).includes(time)))];
    }

    function candidateTimesFor(person, dateIso = null) {
      const fixedTimes = isFixedPerson(person) ? fixedTimesForDate(person, dateIso) : [];
      return fixedTimes.length ? fixedTimes : (person.times || []);
    }

    function fixedAppliesToStore(person, storeKey) {
      const fixedTags = (person.tags || []).filter(tag => tag.includes("固定") && !tag.includes("固定休"));
      const storeNames = Object.values(stores).map(store => store.name);
      return fixedTags.some(tag => {
        const mentionedStores = storeNames.filter(name => tag.includes(name));
        return !mentionedStores.length || tag.includes(stores[storeKey].name);
      });
    }

    function fixedPeopleFor(storeKey, dateIso) {
      return staff.filter(person => (
        !person.support &&
        isFixedPerson(person) &&
        fixedAppliesToStore(person, storeKey) &&
        canWorkAtStore(person, storeKey) &&
        matchesDay(person, dateIso) &&
        !isUnavailable(person.name, dateIso)
      ));
    }

    function prefillFixedShifts(dateIso, storeKey, options = {}) {
      let addedCount = 0;
      fixedPeopleFor(storeKey, dateIso).forEach(person => {
        const times = [...candidateTimesFor(person, dateIso)].sort((a, b) => {
          const aHours = assignmentHours({ time: a });
          const bHours = assignmentHours({ time: b });
          return aHours - bHours;
        });
        times.forEach(time => {
          if (addShiftToDay(dateIso, storeKey, person, time, options)) addedCount += 1;
        });
      });
      return addedCount;
    }

    function removeShiftFromDay(dateIso, storeKey, assignment) {
      slots.forEach(slot => {
        const cell = ensureCell(dateIso, storeKey, slot);
        const index = cell.findIndex(existing => assignmentKey(existing) === assignmentKey(assignment));
        if (index >= 0) cell.splice(index, 1);
      });
    }

    function removePersonFromDate(dateIso, personName) {
      const cleanName = canonicalStaffName(personName);
      let removed = 0;
      storeOrder.forEach(storeKey => {
        slots.forEach(slot => {
          const cell = ensureCell(dateIso, storeKey, slot);
          const before = cell.length;
          state.schedule[dateIso][storeKey][slot] = cell.filter(assignment => canonicalStaffName(assignment.name) !== cleanName);
          removed += before - state.schedule[dateIso][storeKey][slot].length;
        });
      });
      return removed;
    }

    function personAssignmentsForDay(dateIso, personName) {
      const assignments = [];
      storeOrder.forEach(storeKey => {
        uniqueAssignments(dateIso, storeKey).forEach(assignment => {
          if (assignment.name === personName) assignments.push({ ...assignment, storeKey });
        });
      });
      return assignments;
    }

    function personAssignedDaysInPeriod(personName) {
      return periodDates().filter(date => (
        isAssignedAnywhere(iso(date), personName)
      )).length;
    }

    function paidLeaveDaysInDates(personName, dates) {
      return dates.filter(date => isPaidLeave(personName, iso(date))).length;
    }

    function emergencyAbsenceDaysInDates(personName, dates) {
      return dates.filter(date => isEmergencyAbsence(personName, iso(date))).length;
    }

    function targetWorkDays(person) {
      return Math.max(0, periodDates().length - targetOffDays(person));
    }

    function projectedWorkDays(person, options = {}) {
      const name = canonicalStaffName(person.name);
      return options.loadMap ? (options.loadMap.get(name) || 0) : personAssignedDaysInPeriod(name);
    }

    function coreRestBalanceScore(person, dateIso, options = {}) {
      if (!isCoreEmployee(person) || !targetOffDays(person)) return 0;
      if (isUnavailable(person.name, dateIso)) return -10000;
      const currentWork = projectedWorkDays(person, options);
      const targetWork = targetWorkDays(person);
      const deficit = targetWork - currentWork;
      if (deficit > 0) return Math.min(520, deficit * 32);
      if (deficit === 0) return -35;
      return Math.max(-420, deficit * 120);
    }

    function isPersonAssignedOnDate(dateIso, personName, storeFilter = "all") {
      return storeOrder.some(storeKey => {
        if (storeFilter !== "all" && storeFilter !== storeKey) return false;
        return slots.some(slot => (
          readCell(dateIso, storeKey, slot).some(item => item.name === personName)
        ));
      });
    }

    function assignedStoreKeysForPersonOnDate(dateIso, personName, storeFilter = "all") {
      return storeOrder.filter(storeKey => {
        if (storeFilter !== "all" && storeFilter !== storeKey) return false;
        return slots.some(slot => (
          readCell(dateIso, storeKey, slot).some(item => item.name === personName)
        ));
      });
    }

    function projectedConsecutiveWorkDays(personName, dateIso, storeFilter = "all") {
      const date = new Date(`${dateIso}T00:00:00`);
      let before = 0;
      for (let cursor = addDays(date, -1); isPersonAssignedOnDate(iso(cursor), personName, storeFilter); cursor = addDays(cursor, -1)) {
        before += 1;
      }
      let after = 0;
      for (let cursor = addDays(date, 1); isPersonAssignedOnDate(iso(cursor), personName, storeFilter); cursor = addDays(cursor, 1)) {
        after += 1;
      }
      return before + 1 + after;
    }

    function buildLoadMap() {
      return new Map(staff.map(person => [person.name, personAssignedDaysInPeriod(person.name)]));
    }

    function generationOptions(extra = {}) {
      return {
        respectCapacity: true,
        preventDoubleBooking: true,
        avoidLongStreak: true,
        maxConsecutiveWorkDays: 5,
        allowPartialOverlap: false,
        requireFullSlotCoverage: true,
        enforceCoreWorkLimit: true,
        loadMap: buildLoadMap(),
        ...extra
      };
    }

    function hasLateShift(dateIso, personName) {
      return personAssignmentsForDay(dateIso, personName).some(assignment => parseRange(assignment.time)[1] > 24);
    }

    function hasEarlyShift(dateIso, personName) {
      return personAssignmentsForDay(dateIso, personName).some(assignment => parseRange(assignment.time)[0] < 9);
    }

    function restScore(person, slot, dateIso) {
      const date = new Date(`${dateIso}T00:00:00`);
      const previousIso = iso(addDays(date, -1));
      const nextIso = iso(addDays(date, 1));
      const [slotStart] = parseRange(slot);
      let score = 0;
      if (slotStart < 13 && hasLateShift(previousIso, person.name)) score -= 140;
      if (slotStart >= 22 && hasEarlyShift(nextIso, person.name)) score -= 100;
      if (personAssignmentsForDay(dateIso, person.name).length) score -= 90;
      return score;
    }

    const workPatternPriority = {
      higashicho: {
        "下田": ["6-15", "9-15"],
        "富田": ["15-24", "13-22", "9-18", "24-9", "22-7"],
        "東町 店長（小澤）": ["13-22", "9-18", "22-7", "24-9"],
        "柳川": ["17-21", "17-22", "13-18", "13-17"],
        "高橋(東町)": ["18-22", "19-22", "18-21"],
        "ミミ": ["18-3", "22-3", "6-9", "9-13", "17-24"],
        "加藤": ["24-9", "22-7", "21-6", "22-6", "6-9"],
        "工藤": ["24-9", "22-3", "18-3", "6-9", "17-22"],
        "山梨": ["22-6"],
        "碓井": ["22-3", "22-2", "24-6"],
        "ダハム": ["13-19", "13-17"],
        "キーズ": ["9-15", "9-14", "12-24", "6-18"],
        "松永": ["19-24", "9-13"],
        "多田": ["6-9"],
        "済藤": ["6-9"],
        "降旗": ["6-9"]
      },
      ougicho: {
        "扇町 店長（齋藤）": ["13-22", "12-21", "9-18", "22-6", "6-15"],
        "赤瀬": ["9-17"],
        "グルン": ["9-17", "9-13"],
        "下田": ["9-15", "6-15", "17-22"],
        "芳澤": ["17-21", "19-22", "6-9", "12-14", "17-22"],
        "ミミ": ["17-24", "16-22", "9-18", "18-3", "6-9"],
        "木村": ["21-6", "24-6", "24-9", "22-7"],
        "加藤": ["24-9", "24-6", "22-7", "6-9"],
        "工藤": ["17-22", "22-3", "18-3", "6-9"],
        "分部": ["21-24"],
        "ゆうな": ["13-17"],
        "永井": ["9-16", "9-17"],
        "植村": ["6-9"],
        "安彦": ["6-9"],
        "宮崎": ["22-2"],
        "河野": ["22-2"],
        "ディパック": ["22-2"]
      },
      miyanoshita: {
        "宮下 店長（小島）": ["15-24", "16-25", "13-22", "12-21", "9-18", "6-15"],
        "笹島": ["22-9", "24-9", "22-6", "24-6"],
        "幸本": ["9-13"],
        "古屋": ["12-17", "9-13"],
        "西村": ["9-17"],
        "高橋(宮下)": ["13-17", "9-17"],
        "山崎": ["9-18", "13-22", "17-24", "18-24", "6-9"],
        "松本": ["24-6", "22-6", "18-24", "13-22", "6-15", "6-9"],
        "鈴木（たいせい）": ["16-20", "9-13"],
        "柴田まちこ": ["6-9", "9-13", "13-17", "17-22"],
        "柴田かずや": ["9-17", "12-18", "13-22", "17-21", "6-9"],
        "柴田かずき": ["9-17", "12-18", "13-22", "17-21", "6-9"],
        "金子": ["17-22"],
        "下田": ["18-24"],
        "芳澤": ["18-24", "19-24"]
      }
    };

    function preferredPatternsFor(person, storeKey) {
      if (!person || !storeKey) return [];
      const storePatterns = workPatternPriority[storeKey] || {};
      return storePatterns[person.name] || [];
    }

    function candidateTimesForGeneration(person, storeKey, dateIso = null) {
      const masterTimes = (dateIso && storeKey)
        ? rieMasterRowsForDateStore(dateIso, storeKey)
          .filter(row => canonicalStaffName(row.name) === canonicalStaffName(person && person.name))
          .map(row => row.time)
        : [];
      const teacherTimes = (dateIso && storeKey && person)
        ? teacherPreferredTimesFor(person.name, storeKey, dateIso)
        : [];
      return mergeUnique([...masterTimes, ...teacherTimes, ...(preferredPatternsFor(person, storeKey) || []), ...candidateTimesFor(person, dateIso)]);
    }

    function rieMasterRowsForDateStore(dateIso, storeKey) {
      if (!Array.isArray(state.rieMaster) || !dateIso || !storeKey) return [];
      return state.rieMaster.filter(row => row.dateIso === dateIso && row.storeKey === storeKey);
    }

    function hasRieMasterForDateStore(dateIso, storeKey) {
      return rieMasterRowsForDateStore(dateIso, storeKey).length > 0;
    }

    function rangeOverlapHours(timeA, timeB) {
      const [aStart, aEnd] = parseRange(timeA);
      const [bStart, bEnd] = parseRange(timeB);
      return Math.max(0, Math.min(aEnd, bEnd) - Math.max(aStart, bStart));
    }

    function rangeUnionHours(timeA, timeB) {
      const [aStart, aEnd] = parseRange(timeA);
      const [bStart, bEnd] = parseRange(timeB);
      return Math.max(1, Math.max(aEnd, bEnd) - Math.min(aStart, bStart));
    }

    function timeSimilarityScore(masterTime, candidateTime) {
      if (!masterTime || !candidateTime) return 0;
      if (masterTime === candidateTime) return 520;
      const [mStart, mEnd] = parseRange(masterTime);
      const [cStart, cEnd] = parseRange(candidateTime);
      const overlap = rangeOverlapHours(masterTime, candidateTime);
      const union = rangeUnionHours(masterTime, candidateTime);
      const overlapRatio = overlap / union;
      const edgeDistance = Math.abs(mStart - cStart) + Math.abs(mEnd - cEnd);
      return Math.round(overlapRatio * 280 + overlap * 18 - edgeDistance * 14);
    }

    function rieMasterMatchScore(dateIso, storeKey, person, time, slot = null) {
      const rows = rieMasterRowsForDateStore(dateIso, storeKey);
      if (!rows.length || !person || !time) return 0;
      const name = canonicalStaffName(person.name);
      const samePerson = rows.filter(row => canonicalStaffName(row.name) === name);
      if (!samePerson.length) {
        const slotRows = slot ? rows.filter(row => overlapsSlot(row.time, slot)) : rows;
        return slotRows.length ? -280 : -90;
      }
      let best = -250;
      samePerson.forEach(row => {
        let score = 340 + timeSimilarityScore(row.time, time);
        if (row.time === time) score += 520;
        if (slot && overlapsSlot(row.time, slot) && overlapsSlot(time, slot)) score += 90;
        if (slot && coversSlot(time, slot) && overlapsSlot(row.time, slot)) score += 45;
        best = Math.max(best, score);
      });
      return best;
    }


    const storeBrainCore = {
      higashicho: {
        anchorNames: ["下田", "守屋", "柳川", "高橋(東町)", "富田", "工藤", "加藤", "碓井", "ミミ", "山梨"],
        preferredBySlot: {
          "6-9": ["多田", "工藤", "下田", "加藤", "ミミ", "斉藤", "済藤", "降旗", "塚脇"],
          "9-13": ["下田", "工藤", "東町 店長（小澤）", "永井", "佐々木（綾）", "ミミ", "キーズ"],
          "13-17": ["守屋", "ダハム", "富田", "東町 店長（小澤）", "柳川"],
          "17-22": ["松永", "高橋(東町)", "高木", "柳川", "工藤", "ミミ", "富田", "東町 店長（小澤）"],
          "22-6": ["加藤", "碓井", "工藤", "ミミ", "富田", "山梨"]
        },
        discourageIfNotMaster: ["キーズ", "大津", "山梨", "東町 店長（小澤）", "高橋(東町)", "高木", "柳川"]
      },
      ougicho: {
        anchorNames: ["芳澤", "ミミ", "河野", "宮崎", "木村", "下田", "グルン", "扇町 店長（齋藤）", "ディパック"],
        preferredBySlot: {
          "6-9": ["安彦", "植村", "木村", "塚脇", "芳澤"],
          "9-13": ["赤瀬", "グルン", "永井", "下田", "ミミ", "芳澤"],
          "13-17": ["扇町 店長（齋藤）", "赤瀬", "グルン", "ミミ", "芳澤", "ゆうな"],
          "17-22": ["扇町 店長（齋藤）", "芳澤", "ミミ", "分部", "下田", "工藤"],
          "22-6": ["木村", "河野", "宮崎", "ディパック", "加藤"]
        },
        discourageIfNotMaster: ["分部", "下田", "芳澤"]
      },
      miyanoshita: { anchorNames: [], preferredBySlot: {}, discourageIfNotMaster: [] }
    };



    const teacherPatternHints = {
      higashicho: {
        bySlot: {
          "6-9": ["多田", "下田", "工藤", "加藤", "ミミ", "済藤", "降旗"],
