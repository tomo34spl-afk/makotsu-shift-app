  <section id="operationWorkflowPanel" class="workflow-panel">
    <div class="workflow-header">
      <div class="workflow-title">次週シフト作成</div>
      <div id="workflowStateBadge" class="workflow-state">未開始</div>
    </div>

    <div class="controls">
      <label>対象週
        <input id="workflowWeekStart" type="date">
      </label>
      <label>確定担当
        <input id="workflowOperator" type="text" value="りえ">
      </label>
      <label>未提出者の扱い
        <select id="workflowMissingPolicy">
          <option value="normal">通常条件で候補にする</option>
          <option value="unavailable">出勤不可として扱う</option>
          <option value="confirm">要確認にする</option>
        </select>
      </label>
    </div>

    <div class="workflow-steps">
      <div id="workflowStep1" class="workflow-step">1. 希望確認</div>
      <div id="workflowStep2" class="workflow-step">2. 希望締め</div>
      <div id="workflowStep3" class="workflow-step">3. 自動作成</div>
      <div id="workflowStep4" class="workflow-step">4. 手修正・再監査</div>
      <div id="workflowStep5" class="workflow-step">5. 確定</div>
      <div id="workflowStep6" class="workflow-step">6. 配布</div>
    </div>

    <div class="workflow-actions">
      <button id="workflowCloseRequestsBtn" class="btn" type="button">希望を締める</button>
      <button id="workflowReopenRequestsBtn" class="btn" type="button">締め解除</button>
      <button id="workflowGenerateBtn" class="btn primary" type="button">シフトを自動作成</button>
      <button id="workflowAuditBtn" class="btn" type="button">現在のシフトを再監査</button>
      <button id="workflowConfirmBtn" class="btn primary" type="button">この週を確定</button>
      <button id="workflowUnlockBtn" class="btn" type="button">確定解除</button>
      <button id="workflowStoreCsvBtn" class="btn" type="button">店舗別CSV</button>
      <button id="workflowPersonCsvBtn" class="btn" type="button">個人別CSV</button>
      <button id="workflowPrintBtn" class="btn" type="button">掲示用印刷</button>
      <button id="workflowRecoverBtn" class="btn" type="button">操作を復旧</button>
    </div>

    <div class="workflow-summary">
      <div class="workflow-summary-card">
        <strong>希望提出</strong>
        <div id="workflowRequestSummary">未確認</div>
      </div>
      <div class="workflow-summary-card">
        <strong>生成状態</strong>
        <div id="workflowGenerateSummary">未作成</div>
      </div>
      <div class="workflow-summary-card">
        <strong>監査状態</strong>
        <div id="workflowAuditSummary">未監査</div>
      </div>
      <div class="workflow-summary-card">
        <strong>確定情報</strong>
        <div id="workflowConfirmSummary">未確定</div>
      </div>
    </div>

    <div id="workflowAuditList" class="workflow-audit-list">対象週を選んでください。</div>
    <div class="workflow-audit-list">
      宮ノ下ロジック：柴田まちこ・柴田かずや・柴田かずきを別人管理。
      22〜24は2名、24〜6は1名を基準に監査します。
    </div>
  </section>

<main class="main">
        <section class="panel" id="dashboardView">
          <h2>ホーム</h2>
          <div class="controls">
            <label>対象月
              <input id="homeMonth" type="month" value="2026-07">
            </label>
            <label>締め開始日
              <select id="homeStartDay">
                <option value="1" selected>1日</option>
                <option value="16">16日</option>
              </select>
            </label>
            <button class="btn primary" id="homeApply" type="button">期間を反映</button>
          </div>
          <div class="cards">
            <div class="card">
              <div class="metric-label">作成期間</div>
              <div class="metric-value" id="metricPeriod">-</div>
              <div class="metric-sub">給与・月間土台用</div>
            </div>
            <div class="card">
              <div class="metric-label">月間不足枠</div>
              <div class="metric-value" id="metricShortage">-</div>
              <div class="metric-sub">配置不足の時間帯</div>
            </div>
            <div class="card">
              <div class="metric-label">応援候補</div>
              <div class="metric-value">2</div>
              <div class="metric-sub">まこつ。 / りえ</div>
            </div>
            <div class="card">
              <div class="metric-label">反映スタッフ</div>
              <div class="metric-value" id="metricStaff">-</div>
              <div class="metric-sub">手書きメモ + 応援マルチ</div>
            </div>
          </div>
          <div class="status-row">
            <a class="btn" href="#todayView" data-jump="today">今日のシフトを見る</a>
            <a class="btn" href="#ownerView" data-jump="owner">全店舗を見る</a>
            <a class="btn" href="#monthlyView" data-jump="monthly">月間の土台を作る</a>
            <a class="btn primary" href="#weeklyCloseView" data-jump="weeklyClose">翌週分を締める</a>
            <a class="btn" href="#finishedView" data-jump="finished">完成シフトを見る</a>
            <a class="btn" href="#shortageView" data-jump="shortage">不足だけ見る</a>
          </div>
          <div class="detail-box">
            <h3>急遽休み対応</h3>
            <div class="controls">
              <label>休む人
                <select id="homeEmergencyStaff"></select>
              </label>
              <label>日付
                <input id="homeEmergencyDate" type="date" value="2026-07-07">
              </label>
              <label>店舗
                <select id="homeEmergencyStore">
                  <option value="miyanoshita">宮ノ下</option>
                  <option value="higashicho">東町</option>
                  <option value="ougicho">扇町</option>
                </select>
              </label>
              <label>時間帯
                <select id="homeEmergencySlot">
                  <option value="6-9">6-9</option>
                  <option value="9-13">9-13</option>
                  <option value="13-17">13-17</option>
                  <option value="17-22">17-22</option>
                  <option value="22-6">22-6</option>
                </select>
              </label>
              <button class="btn primary" id="homeEmergencyApply" type="button">急遽休み登録</button>
            </div>
            <div id="homeEmergencyCandidates" class="candidate-list">
              <div class="muted">休む人・日付・時間帯を選ぶとピンチヒッター候補が出ます。</div>
            </div>
          </div>
        </section>

        <section class="panel hidden" id="todayView">
          <h2>今日のシフト</h2>
          <div class="controls">
            <label>表示日
              <input id="todayInput" type="date" value="2026-07-07">
            </label>
            <button class="btn" id="prevDayBtn" type="button">前日</button>
            <button class="btn" id="nextDayBtn" type="button">翌日</button>
          </div>
          <div class="today-grid" id="todayGrid"></div>
        </section>

        <section class="panel hidden" id="ownerView">
          <h2>まこつ。ダッシュボード</h2>
          <div class="owner-grid">
            <div class="grid">
              <div class="cards">
                <div class="card">
                  <div class="metric-label">全店舗不足</div>
                  <div class="metric-value" id="ownerShortage">-</div>
                  <div class="metric-sub">月間の不足枠</div>
                </div>
                <div class="card">
                  <div class="metric-label">危険チェック</div>
                  <div class="metric-value" id="ownerIssues">-</div>
                  <div class="metric-sub">希望休・重複・過剰など</div>
                </div>
                <div class="card">
                  <div class="metric-label">応援投入</div>
                  <div class="metric-value" id="ownerSupport">-</div>
                  <div class="metric-sub">まこつ。/りえの配置数</div>
                </div>
                <div class="card">
                  <div class="metric-label">概算人件費</div>
                  <div class="metric-value" id="ownerLabor">-</div>
                  <div class="metric-sub">早朝1250 / 日勤1225-1250 / 夜勤1531</div>
                </div>
              </div>
              <div class="table-wrap">
                <table aria-label="店舗別状況">
                  <thead>
                    <tr>
                      <th>店舗</th>
                      <th>不足</th>
                      <th>危険</th>
                      <th>応援投入</th>
                      <th>概算人件費</th>
                    </tr>
                  </thead>
                  <tbody id="ownerStoreBody"></tbody>
                </table>
              </div>
            </div>
            <aside class="side-card">
              <div class="detail-box">
                <h3>優先対応</h3>
                <div id="ownerPriority"></div>
              </div>
              <div class="detail-box">
                <h3>判断ボタン</h3>
                <div class="status-row">
                  <button class="btn primary" id="fillAllBtn" type="button">全店舗を仮作成</button>
                  <a class="btn" href="#issuesView" data-jump="issues">危険チェックへ</a>
                  <a class="btn" href="#shortageView" data-jump="shortage">不足へ</a>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="panel hidden" id="monthlyView">
          <h2>月間シフト作成</h2>
          <div class="detail-box">
            <h3>月間は土台作成</h3>
            <div class="muted">毎週希望が出るスタッフがいるため、ここで最終確定しない。ざっくり作って、翌週分は「週締め」で埋める。</div>
          </div>
          <div class="controls">
            <label>対象月
              <input id="monthInput" type="month" value="2026-07">
            </label>
            <label>締め開始日
              <select id="startDayInput">
                <option value="1" selected>1日</option>
                <option value="16">16日</option>
              </select>
            </label>
            <label>店舗
              <select id="storeInput">
                <option value="miyanoshita">宮ノ下</option>
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
              </select>
            </label>
            <button class="btn primary" id="generateBtn" type="button">1か月分を仮作成</button>
            <button class="btn" id="generateAllMonthlyBtn" type="button">全店舗を仮作成</button>
            <button class="btn" id="clearStoreBtn" type="button">表示店舗を空にする</button>
            <div class="toolbar-right">
              <button class="btn" id="autoFillShortageBtn" type="button">表示店舗の不足を補充</button>
              <button class="btn" id="trimOverstaffBtn" type="button">表示店舗の余剰を整理</button>
            </div>
          </div>

          <div class="requirements" id="requirements"></div>

          <div class="split">
            <div class="table-wrap">
              <table aria-label="月間シフト作成表">
                <thead id="monthlyHead"></thead>
                <tbody id="monthlyBody"></tbody>
              </table>
            </div>

            <aside class="side-card no-print">
              <div class="detail-box">
                <h3>選択中の枠</h3>
                <div id="selectedDetail" class="muted">不足セル、または編集したい枠を押す。</div>
              </div>
              <div class="detail-box">
                <h3>候補</h3>
                <div id="candidateList" class="candidate-list">
                  <div class="muted">枠を選ぶと候補が出る。</div>
                </div>
              </div>
              <div class="detail-box">
                <h3>出力</h3>
                <div class="status-row">
                  <button class="btn" id="csvBtn" type="button">CSV出力</button>
                  <button class="btn" id="printBtn" type="button">印刷</button>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="panel hidden" id="weeklyCloseView">
          <h2>週締め</h2>
          <div class="detail-box">
            <h3>毎週火曜に翌週分を締める</h3>
            <div class="muted">松永のように毎週希望が出る人は、月間土台では固定しすぎず、週締め時点の調整要員として使う。正本なし自動作成は、複数週の同曜日傾向＋教師データで作成し、目標件数帯に入った後は追加・削除せず30分セル補正、アンカー差し替え、不足/過剰ペア交換で配置を整える。正本参照補正は正本突合を使って配置を補正する。</div>
          </div>
          <div class="controls">
            <label>対象週
              <select id="weeklyCloseStart"></select>
            </label>
            <label>店舗
              <select id="weeklyCloseStore">
                <option value="miyanoshita">宮ノ下</option>
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
              </select>
            </label>
            <button class="btn" id="generateWeeklyPureBtn" type="button">正本なし自動作成（選択店舗）</button>
            <button class="btn" id="generateAllWeeklyPureBtn" type="button">正本なし自動作成（全店舗）</button>
            <button class="btn primary" id="generateWeeklyBtn" type="button">正本参照補正（選択店舗）</button>
            <button class="btn" id="generateAllWeeklyBtn" type="button">正本参照補正（全店舗）</button>
            <button class="btn" id="generateWeeklyMasterBtn" type="button">正本を反映</button>
            <button class="btn" id="clearWeeklyBtn" type="button">この週を空にする</button>
          </div>
          <div class="cards">
            <div class="card">
              <div class="metric-label">対象週</div>
              <div class="metric-value" id="weeklyClosePeriod">-</div>
              <div class="metric-sub">火曜確認、翌週分を締める</div>
            </div>
            <div class="card">
              <div class="metric-label">週不足</div>
              <div class="metric-value" id="weeklyCloseShortage">-</div>
              <div class="metric-sub">対象週・対象店舗</div>
            </div>
            <div class="card">
              <div class="metric-label">希望提出型</div>
              <div class="metric-value" id="weeklyCloseHopeOnly">-</div>
              <div class="metric-sub">週締めで使う穴埋め候補</div>
            </div>
          </div>
          <div class="split">
            <div class="table-wrap">
              <table aria-label="週締め表">
                <thead id="weeklyCloseHead"></thead>
                <tbody id="weeklyCloseBody"></tbody>
              </table>
            </div>
            <div class="weekly-mobile-list" id="weeklyCloseMobile"></div>
            <aside class="side-card no-print">
              <div class="detail-box">
                <h3>週締めメモ</h3>
                <div id="weeklyCloseMemo"></div>
              </div>
              <div class="detail-box">
                <h3>選択中の枠</h3>
                <div id="weeklySelectedDetail" class="muted">不足セル、または編集したい枠を押す。</div>
              </div>
              <div class="detail-box">
                <h3>候補</h3>
                <div id="weeklyCandidateList" class="candidate-list"></div>
              </div>
            </aside>
          </div>
        </section>

        <section class="panel hidden" id="rieMasterView">
          <h2>りえ正本突合</h2>
          <div class="detail-box">
            <h3>実勤務時間ベースで正本と比較</h3>
            <div class="muted">紙シフトを「日付・店舗・名前・実勤務時間」で入れる。6-15、15-24、18-3、24-9のような枠またぎを、1時間単位でカバー判定する。</div>
          </div>
          <div class="controls">
            <label>対象週
              <select id="rieWeekStart"></select>
            </label>
            <label>店舗
              <select id="rieStore">
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
                <option value="miyanoshita">宮ノ下</option>
                <option value="all">全店舗</option>
              </select>
            </label>
            <button class="btn" id="rieRefreshBtn" type="button">突合更新</button>
            <button class="btn" id="applyRieMasterBtn" type="button">りえ正本をアプリに反映（確認あり）</button>
            <button class="btn" id="clearRieWeekBtn" type="button">この週の正本を消す</button>
          </div>
          <div class="cards">
            <div class="card">
              <div class="metric-label">正本入力</div>
              <div class="metric-value" id="rieMasterCount">-</div>
              <div class="metric-sub">対象週・対象店舗</div>
            </div>
            <div class="card">
              <div class="metric-label">時間差分</div>
              <div class="metric-value" id="rieCoverageDiffCount">-</div>
              <div class="metric-sub">1時間単位の人数差</div>
            </div>
            <div class="card">
              <div class="metric-label">人の差分</div>
              <div class="metric-value" id="riePersonDiffCount">-</div>
              <div class="metric-sub">アプリにない/余分</div>
            </div>
          </div>
          <div class="split">
            <div class="grid">
              <div class="detail-box">
                <h3>1件追加</h3>
                <div class="controls">
                  <label>日付
                    <input id="rieEntryDate" type="date" value="2026-07-13">
                  </label>
                  <label>店舗
                    <select id="rieEntryStore">
                      <option value="higashicho">東町</option>
                      <option value="ougicho">扇町</option>
                      <option value="miyanoshita">宮ノ下</option>
                    </select>
                  </label>
                  <label>名前
                    <input id="rieEntryName" type="text" placeholder="例: 下田">
                  </label>
                  <label>実勤務時間
                    <input id="rieEntryTime" type="text" placeholder="例: 6-15 / 15-24 / 18-3">
                  </label>
                  <button class="btn primary" id="addRieEntryBtn" type="button">正本に追加</button>
                </div>
              </div>
              <div class="detail-box">
                <h3>一括取り込み</h3>
                <textarea id="rieBulkBox" class="textarea" placeholder="1行1シフト。例: 7/13,東町,多田,6-9&#10;7/13,東町,富田,15-24&#10;7/13,扇町,木村,24-6"></textarea>
                  <div class="muted">※「7/13,東町,6-9,多田 / 下田 6〜」形式はここではなく、紙シフト統合に貼る。</div>
                <div class="status-row">
                  <button class="btn primary" id="importRieBulkBtn" type="button">一括取り込み</button>
                  <button class="btn" id="copyAppAsRieBtn" type="button">⚠ アプリ版を正本にコピー（検証用）</button>
                </div>
                <div class="small-note">画像から起こす時は、まず日付・店舗・名前・実勤務時間だけでOK。休憩や細かい理由は後回し。</div>
              </div>
              <div class="detail-box">
                <h3>正本リスト</h3>
                <div class="rie-master-list" id="rieMasterList"></div>
              </div>
            </div>
            <aside class="side-card no-print">
              <div class="detail-box">
                <h3>判定メモ</h3>
                <div id="rieCompareMemo"></div>
              </div>
              <div class="detail-box">
                <h3>時間カバー差分</h3>
                <div class="table-wrap">
                  <table aria-label="りえ正本との時間カバー差分">
                    <thead>
                      <tr><th>日付</th><th>店舗</th><th>時間</th><th>正本</th><th>アプリ</th><th>差</th></tr>
                    </thead>
                    <tbody id="rieCoverageDiffBody"></tbody>
                  </table>
                </div>
              </div>
              <div class="detail-box">
                <h3>人・時間の差分</h3>
                <div class="table-wrap">
                  <table aria-label="りえ正本との人時間差分">
                    <thead>
                      <tr><th>区分</th><th>日付</th><th>店舗</th><th>内容</th></tr>
                    </thead>
                    <tbody id="riePersonDiffBody"></tbody>
                  </table>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="panel hidden" id="paperImportView">
          <h2>紙シフト統合</h2>
          <div class="detail-box">
            <h3>セル単位で取り込んで、30分タイムラインで勤務を統合</h3>
            <div class="muted">紙に書いてあるまま「日付・店舗・枠・セル内容」で入れる。下田 6〜 + 下田 〜15、加藤 24〜 + 翌朝の加藤、のような分割表記をアプリ側で1本の実勤務に寄せる。</div>
          </div>
          <div class="controls">
            <label>対象週
              <select id="paperWeekStart"></select>
            </label>
            <label>店舗
              <select id="paperStore">
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
                <option value="miyanoshita">宮ノ下</option>
              </select>
            </label>
            <button class="btn" id="paperRefreshBtn" type="button">表示更新</button>
            <button class="btn" id="clearPaperCellsBtn" type="button">この週の紙セルを消す</button>
          </div>
          <div class="cards">
            <div class="card">
              <div class="metric-label">紙セル</div>
              <div class="metric-value" id="paperCellCount">-</div>
              <div class="metric-sub">対象週・対象店舗</div>
            </div>
            <div class="card">
              <div class="metric-label">統合勤務</div>
              <div class="metric-value" id="paperUnifiedCount">-</div>
              <div class="metric-sub">30分タイムライン化後</div>
            </div>
            <div class="card">
              <div class="metric-label">要確認</div>
              <div class="metric-value" id="paperWarningCount">-</div>
              <div class="metric-sub">24〜 / 〜15 など</div>
            </div>
          </div>
          <div class="split">
            <div class="grid">
              <div class="detail-box">
                <h3>紙セル一括取り込み</h3>
                <textarea id="paperCellBulkBox" class="textarea" placeholder="1行1セル。例:&#10;7/13,東町,6-9,多田 / 下田 6〜&#10;7/13,東町,9-13,ミミ / 下田 〜15&#10;7/13,東町,13-17,富田 15〜24 / 守屋&#10;7/13,東町,22-6,山梨 / 碓井 24〜6"></textarea>
                <div class="status-row">
                  <button class="btn primary" id="importPaperCellsBtn" type="button">紙セルを取り込み</button>
                  <button class="btn primary" id="paperToRieMasterBtn" type="button">統合して正本へ反映</button>
                  <button class="btn" id="copyPaperUnifiedBtn" type="button">統合結果をコピー</button>
                </div>
                <div class="small-note">コンマ区切り推奨。セル内の複数人は「/」で分ける。曖昧な 24〜 / 〜15 は勝手に完全確定せず、要確認に出す。</div>
              </div>
              <div class="detail-box">
                <h3>取り込んだ紙セル</h3>
                <div class="paper-cell-list" id="paperCellList"></div>
              </div>
            </div>
            <aside class="side-card no-print">
              <div class="detail-box">
                <h3>統合勤務</h3>
                <div id="paperUnifiedList" class="paper-cell-list"></div>
              </div>
              <div class="detail-box">
                <h3>要確認メモ</h3>
                <div id="paperWarningList" class="warning-list"></div>
              </div>
            </aside>
          </div>
        </section>


        <section class="panel hidden" id="teacherView">
          <h2>教師データ学習</h2>
          <div class="detail-box">
            <h3>過去シフトを「学習用」として取り込む</h3>
            <div class="muted">ここは正本突合用ではなく、過去1か月分の紙シフトから店舗別・曜日別・勤務型別のクセを読む場所。7/13〜7/19の検証週は入れない方が、実力判定ができる。</div>
          </div>
          <div class="controls">
            <label>店舗
              <select id="teacherStore">
                <option value="all">全店舗</option>
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
                <option value="miyanoshita">宮ノ下</option>
              </select>
            </label>
            <button class="btn" id="teacherRefreshBtn" type="button">学習状況更新</button>
            <button class="btn" id="clearTeacherStoreBtn" type="button">表示店舗の教師データを消す</button>
            <button class="btn" id="clearTeacherAllBtn" type="button">全教師データを消す</button>
          </div>
          <div class="cards">
            <div class="card">
              <div class="metric-label">教師セル</div>
              <div class="metric-value" id="teacherCellCount">-</div>
              <div class="metric-sub">紙の枠単位</div>
            </div>
            <div class="card">
              <div class="metric-label">統合勤務</div>
              <div class="metric-value" id="teacherUnifiedCount">-</div>
              <div class="metric-sub">1勤務1行化</div>
            </div>
            <div class="card">
              <div class="metric-label">学習パターン</div>
              <div class="metric-value" id="teacherPatternCount">-</div>
              <div class="metric-sub">人×曜日×時間型</div>
            </div>
          </div>
          <div class="split">
            <div class="grid">
              <div class="detail-box">
                <h3>教師セル一括取り込み</h3>
                <textarea id="teacherCellBulkBox" class="textarea" placeholder="1行1セル。例:\n6/8,東町,6-9,多田 / 下田 6〜\n6/8,東町,9-13,工藤 8.5〜13 / 下田 〜15\n6/8,扇町,17-22,分部 21〜24 / ミミ 17〜2"></textarea>
                <div class="status-row">
                  <button class="btn primary" id="importTeacherCellsBtn" type="button">教師データを取り込み</button>
                  <button class="btn" id="copyTeacherUnifiedBtn" type="button">統合結果をコピー</button>
                </div>
                <div class="small-note">8:30は 8.5 として扱う。教師データは自動生成のスコアに使うだけで、正本には反映しない。</div>
              </div>
              <div class="detail-box">
                <h3>学習上位パターン</h3>
                <div class="table-wrap">
                  <table aria-label="教師データ学習パターン">
                    <thead><tr><th>店舗</th><th>曜日</th><th>人</th><th>時間型</th><th>回数</th></tr></thead>
                    <tbody id="teacherPatternBody"></tbody>
                  </table>
                </div>
              </div>
            </div>
            <aside class="side-card no-print">
              <div class="detail-box">
                <h3>取り込んだ教師セル</h3>
                <div class="paper-cell-list" id="teacherCellList"></div>
              </div>
              <div class="detail-box">
                <h3>統合勤務</h3>
                <div class="paper-cell-list" id="teacherUnifiedList"></div>
              </div>
            </aside>
          </div>
        </section>


        <section class="panel hidden" id="finishedView">
          <h2>完成シフト</h2>
          <div class="controls">
            <label>店舗
              <select id="finishedStore">
                <option value="miyanoshita">宮ノ下</option>
                <option value="higashicho">東町</option>
                <option value="ougicho">扇町</option>
              </select>
            </label>
            <label>週
              <select id="finishedWeekStart"></select>
            </label>
            <button class="btn primary" id="weeklyPrintBtn" type="button">この週を印刷</button>
            <button class="btn" id="finishedPrintBtn" type="button">月間を印刷</button>
          </div>
          <div class="print-sheet weekly-sheet weekly-print-section">
            <div class="print-head">
              <div>
                <strong id="weeklyFinishedTitle">週シフト</strong>
                <div class="weekly-meta" id="weeklyFinishedPeriod">-</div>
              </div>
              <span class="muted">月曜始まり / 日曜終わり</span>
            </div>
            <div class="table-wrap">
              <table aria-label="週単位完成シフト表">
                <thead id="weeklyFinishedHead"></thead>
                <tbody id="weeklyFinishedBody"></tbody>
              </table>
            </div>
            <div class="rest-summary" id="weeklyRestSummary"></div>
            <p class="weekly-print-note">りえちゃん確認用。1週間だけ印刷する時は「この週を印刷」。</p>
