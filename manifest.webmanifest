    // β4.10.37.04 final override: 36.66末尾の旧36.65系上書きをさらに上書きし、圧縮後に分散を必ず実行する。
    function noMasterGenerateStoreFromEmpty(dates, storeKey, options = {}) {
      const band = wishWeekCountBandForDates(dates, storeKey);
      const phaseLog = [];
      const diagnostics = { blocked: {}, noCandidateDates: [], submittedAdded: 0, teacherAdds: 0, targetAdds: 0, relaxedAdds: 0, finalRescueAdds: 0, compressRuns: 0, redistributeRuns: 0, band, poolSize: {} };
      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };
      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };
      storeOptions.wishExpectationCache = storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache = storeOptions.wishCandidatePoolCache || new Map();
      diagnostics.poolSize[storeKey] = noMasterV62ActiveStaffForStore(storeKey).length;

      count("afterClear");

      dates.forEach(date => {
        const dateIso = iso(date);
        submittedWorkRequestsFor(dateIso, storeKey).forEach(row => {
          const person = noMasterV62ActiveStaffForStore(storeKey).find(p => noMasterV62CanonicalName(p.name) === noMasterV62CanonicalName(row.name));
          if (!person) return;
          if (noMasterV62DirectAddShift(dateIso, storeKey, person, row.time)) diagnostics.submittedAdded += 1;
        });
      });
      count("afterSubmittedWorkRequests");

      dates.forEach(date => {
        const dateIso = iso(date);
        noMasterV62FillDate(dateIso, storeKey, teacherWishTargetCountForDateStore(dateIso, storeKey), storeOptions, diagnostics, "teacherAdds", false);
      });
      count("afterDailyTeacherTargets");

      let guard = 0;
      while (wishCountAssignmentsForDates(dates, storeKey) < band.lower && guard < 260) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const quality = wishDiffSummaryForDate(dateIso, storeKey, wishThirtyMinuteExpectationForDate(dateIso, storeKey, storeOptions));
          const targetGap = Math.max(0, teacherWishTargetCountForDateStore(dateIso, storeKey) - uniqueAssignments(dateIso, storeKey).length);
          return { dateIso, score: quality.shortage * 40 + targetGap * 220 - uniqueAssignments(dateIso, storeKey).length * 5 };
        }).sort((a,b) => b.score - a.score);
        let added = false;
        for (const row of dateCandidates) {
          const picked = noMasterV62PickBest(row.dateIso, storeKey, storeOptions, diagnostics, true);
          if (!picked) continue;
          if (noMasterV62DirectAddShift(row.dateIso, storeKey, picked.person, picked.time)) {
            diagnostics.relaxedAdds += 1;
            added = true;
            break;
          }
        }
        if (!added) break;
        guard += 1;
      }
      count("afterRelaxedWeeklyRescue");

      try {
        if (typeof noMasterV64CompressSurplusByTime === "function") {
          noMasterV64CompressSurplusByTime(dates, storeKey, storeOptions, diagnostics);
        }
      } catch (e) {
        diagnostics.blocked.compressError = String(e && e.message ? e.message : e);
      }
      count("afterSurplusCompression");

      diagnostics.redistributeSkipped = true;
      diagnostics.redistributeSkipReason = "36.72安定版では未検証の再分散を停止";
      count("afterSurplusRedistribution");

      const wishLog = {
        version: "β4.10.37.04",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        sourceStaffPool: diagnostics.poolSize[storeKey],
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        compressRuns: diagnostics.compressRuns || 0,
        redistributeRuns: diagnostics.redistributeRuns || 0,
        upperCap: band.upper,
        lowerCap: band.lower
      };
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      return { band, phaseLog, diagnostics, wishLog, quality: noMasterCoverageQualityForStore(dates, storeKey, storeOptions) };
    }

    // β4.10.37.04 検証専用・分割実行
    // 通常生成 noMasterGenerateStoreFromEmpty は変更せず、
    // 自動検証だけ1件ずつ await してブラウザへ制御を返す。
    function noMasterV74Yield() {
      return new Promise(resolve => setTimeout(resolve, 0));
    }


    function noMasterV79CreateProfiler() {
      return {
        totals: {},
        counts: {},
        maxMs: {},
        measure(name, fn) {
          const started = performance.now();
          try {
            return fn();
          } finally {
            const elapsed = performance.now() - started;
            this.totals[name] = (this.totals[name] || 0) + elapsed;
            this.counts[name] = (this.counts[name] || 0) + 1;
            this.maxMs[name] = Math.max(this.maxMs[name] || 0, elapsed);
          }
        },
        report() {
          return Object.keys(this.totals)
            .map(name => ({
              name,
              totalMs: Math.round(this.totals[name]),
              calls: this.counts[name] || 0,
              avgMs: Math.round(
                (this.totals[name] / Math.max(1, this.counts[name])) * 100
              ) / 100,
              maxMs: Math.round((this.maxMs[name] || 0) * 100) / 100
            }))
            .sort((a, b) => b.totalMs - a.totalMs);
        }
      };
    }

    async function noMasterV74FillDateChunked(
      dateIso,
      storeKey,
      target,
      options,
      diagnostics,
      counterKey,
      relaxed = false,
      progress = null,
      profiler = null
    ) {
      let guard = 0;
      while (
        uniqueAssignments(dateIso, storeKey).length < target &&
        wishCountAssignmentsForDates(options.wishWeekDates, storeKey) < options.wishWeekUpperCap &&
        guard < 120
      ) {
        const picked = profiler
          ? profiler.measure(
              "noMasterV62PickBest",
              () => noMasterV62PickBest(
                dateIso,
                storeKey,
                options,
                diagnostics,
                relaxed
              )
            )
          : noMasterV62PickBest(
              dateIso,
              storeKey,
              options,
              diagnostics,
              relaxed
            );
        if (!picked) break;

        if (noMasterV62DirectAddShift(
          dateIso,
          storeKey,
          picked.person,
          picked.time
        )) {
          diagnostics[counterKey] = (diagnostics[counterKey] || 0) + 1;
        } else {
          diagnostics.blocked.addFailed =
            (diagnostics.blocked.addFailed || 0) + 1;
          break;
        }

        guard += 1;
        if (typeof progress === "function") {
          progress(
            diagnostics[counterKey] || 0,
            target,
            storeKey,
            `${dateIso} 配置中`
          );
        }
        await noMasterV74Yield();
      }
    }


    function noMasterV81FixedRuleFor(dateIso, storeKey, personName) {
      if (storeKey !== "ougicho") return null;

      const name = noMasterV62CanonicalName(personName);
      const dow = new Date(`${dateIso}T00:00:00`).getDay();

      if (name === "赤瀬") {
        return [1, 3, 5].includes(dow)
          ? { time: "9-17", label: "赤瀬 月水金9-17" }
          : { blocked: true, label: "赤瀬は月水金のみ" };
      }

      if (name === "下田") {
        return dow === 4
          ? { time: "17-22", label: "下田 木17-22" }
          : { blocked: true, label: "下田は木曜17-22のみ" };
      }

      return null;
    }


    function noMasterV83RemovePersonFromOtherStores(
      dateIso,
      targetStoreKey,
      personName,
      diagnostics
    ) {
      const canonical = noMasterV62CanonicalName(personName);
      diagnostics.fixedRuleDisplaced = diagnostics.fixedRuleDisplaced || [];
      const recorded = new Set(
        diagnostics.fixedRuleDisplaced.map(row =>
          [
            row.dateIso,
            row.fromStore,
            noMasterV62CanonicalName(row.name),
            normalizeTimeInput(row.time) || row.time
          ].join("|")
        )
      );

      storeOrder.forEach(otherStoreKey => {
        if (otherStoreKey === targetStoreKey) return;

        slots.forEach(slot => {
          const cell = ensureCell(dateIso, otherStoreKey, slot);

          for (let i = cell.length - 1; i >= 0; i -= 1) {
            const row = cell[i];
            if (noMasterV62CanonicalName(row && row.name) !== canonical) continue;

            const key = [
              dateIso,
              otherStoreKey,
              canonical,
              normalizeTimeInput(row.time) || row.time
            ].join("|");

            if (!recorded.has(key)) {
              diagnostics.fixedRuleDisplaced.push({
                dateIso,
                name: canonical,
                fromStore: otherStoreKey,
                fromStoreName: stores[otherStoreKey]?.name || otherStoreKey,
                time: row.time,
                reason: "fixed-rule-priority"
              });
              recorded.add(key);
            }

            cell.splice(i, 1);
          }
        });
      });
    }

    async function noMasterV81ApplyFixedRules(
      dates,
      storeKey,
      activeStaff,
      diagnostics,
      yieldNow
    ) {
      diagnostics.fixedRuleAdds = diagnostics.fixedRuleAdds || [];
      diagnostics.fixedRuleFailures = diagnostics.fixedRuleFailures || [];

      if (storeKey !== "ougicho") return;

      for (const date of dates) {
        const dateIso = iso(date);

        for (const name of ["赤瀬", "下田"]) {
          const rule = noMasterV81FixedRuleFor(dateIso, storeKey, name);
          if (!rule || rule.blocked) continue;

          const person = activeStaff.find(
            item =>
              noMasterV62CanonicalName(item.name) ===
              noMasterV62CanonicalName(name)
          );

          if (!person) {
            diagnostics.fixedRuleFailures.push({
              dateIso,
              name,
              time: rule.time,
              reason: "staff-not-found"
            });
            continue;
          }

          if (isUnavailable(person.name, dateIso)) {
            diagnostics.fixedRuleFailures.push({
              dateIso,
              name,
              time: rule.time,
              reason: "unavailable"
            });
            await yieldNow();
            continue;
          }

          noMasterV83RemovePersonFromOtherStores(
            dateIso,
            storeKey,
            name,
            diagnostics
          );

          const added = noMasterV62DirectAddShift(
            dateIso,
            storeKey,
            person,
            rule.time
          );

          if (added) {
            diagnostics.fixedRuleAdds.push({
              dateIso,
              name,
              time: rule.time,
              rule: rule.label
            });
          } else {
            diagnostics.fixedRuleFailures.push({
              dateIso,
              name,
              time: rule.time,
              reason: "direct-add-failed"
            });
          }

          await yieldNow();
        }
      }
    }

    async function noMasterGenerateStoreFromEmptyChunked(
      dates,
      storeKey,
      options = {},
      progress = null
    ) {
      const profiler = noMasterV79CreateProfiler();
      const band = profiler.measure(
        "wishWeekCountBandForDates",
        () => wishWeekCountBandForDates(dates, storeKey)
      );
      const phaseLog = [];
      const diagnostics = {
        blocked: {},
        noCandidateDates: [],
        submittedAdded: 0,
        teacherAdds: 0,
        targetAdds: 0,
        relaxedAdds: 0,
        finalRescueAdds: 0,
        compressRuns: 0,
        redistributeRuns: 0,
        band,
        poolSize: {},
        chunkedExecution: true,
        yieldCount: 0
      };

      const yieldNow = async () => {
        diagnostics.yieldCount += 1;
        await noMasterV74Yield();
      };

      const count = phase => {
        const value = wishCountAssignmentsForDates(dates, storeKey);
        phaseLog.push({ phase, count: value });
        return value;
      };

      const storeOptions = {
        ...options,
        useRieTargets: false,
        respectCapacity: false,
        allowHopeOnlyPlacement: true,
        wishMode: true,
        ignoreWishCountCap: false,
        wishWeekDates: dates,
        wishWeekDateIsos: dates.map(date => iso(date)),
        wishWeekLowerCap: band.lower,
        wishWeekUpperCap: band.upper,
        freezeWishCountInTargetBand: true
      };

      storeOptions.wishExpectationCache =
        storeOptions.wishExpectationCache || new Map();
      storeOptions.wishCandidatePoolCache =
        storeOptions.wishCandidatePoolCache || new Map();

      const activeStaff = noMasterV62ActiveStaffForStore(storeKey);
      diagnostics.poolSize[storeKey] = activeStaff.length;

      count("afterClear");
      await yieldNow();

      await noMasterV81ApplyFixedRules(
        dates,
        storeKey,
        activeStaff,
        diagnostics,
        yieldNow
      );
      count("afterFixedRules");
      await yieldNow();

      for (const date of dates) {
        const dateIso = iso(date);
        const rows = submittedWorkRequestsFor(dateIso, storeKey);
        for (const row of rows) {
          const person = activeStaff.find(
            p => noMasterV62CanonicalName(p.name) ===
                 noMasterV62CanonicalName(row.name)
          );
          if (!person) continue;
          if (noMasterV62DirectAddShift(
            dateIso,
            storeKey,
            person,
            row.time
          )) {
            diagnostics.submittedAdded += 1;
          }
          await yieldNow();
        }
      }

      count("afterSubmittedWorkRequests");
      await yieldNow();

      for (const date of dates) {
        const dateIso = iso(date);
        const target = teacherWishTargetCountForDateStore(
          dateIso,
          storeKey
        );
        await noMasterV74FillDateChunked(
          dateIso,
          storeKey,
          target,
          storeOptions,
          diagnostics,
          "teacherAdds",
          false,
          progress,
          profiler
        );
        await yieldNow();
      }

      count("afterDailyTeacherTargets");
      await yieldNow();

      let guard = 0;
      while (
        wishCountAssignmentsForDates(dates, storeKey) < band.lower &&
        guard < 260
      ) {
        const dateCandidates = dates.map(date => {
          const dateIso = iso(date);
          const expectation = profiler.measure(
            "wishThirtyMinuteExpectationForDate",
            () => wishThirtyMinuteExpectationForDate(
              dateIso,
              storeKey,
              storeOptions
            )
          );
          const quality = profiler.measure(
            "wishDiffSummaryForDate",
            () => wishDiffSummaryForDate(
              dateIso,
              storeKey,
              expectation
            )
          );
          const targetGap = Math.max(
            0,
            teacherWishTargetCountForDateStore(
              dateIso,
              storeKey
            ) - uniqueAssignments(dateIso, storeKey).length
          );
          return {
            dateIso,
            score:
              quality.shortage * 40 +
              targetGap * 220 -
              uniqueAssignments(dateIso, storeKey).length * 5
          };
        }).sort((a, b) => b.score - a.score);

        let added = false;
        for (const row of dateCandidates) {
          const picked = profiler.measure(
            "noMasterV62PickBest",
            () => noMasterV62PickBest(
              row.dateIso,
              storeKey,
              storeOptions,
              diagnostics,
              true
            )
          );
          if (!picked) {
            await yieldNow();
            continue;
          }

          if (noMasterV62DirectAddShift(
            row.dateIso,
            storeKey,
            picked.person,
            picked.time
          )) {
            diagnostics.relaxedAdds += 1;
            added = true;
          }
          await yieldNow();
          if (added) break;
        }

        if (!added) break;
        guard += 1;
      }

      count("afterRelaxedWeeklyRescue");
      await yieldNow();

      try {
        if (typeof noMasterV64CompressSurplusByTime === "function") {
          if (typeof progress === "function") {
            progress(0, 1, storeKey, "余剰圧縮中");
          }
          await yieldNow();
          profiler.measure(
            "noMasterV64CompressSurplusByTime",
            () => noMasterV64CompressSurplusByTime(
              dates,
              storeKey,
              storeOptions,
              diagnostics
            )
          );
          await yieldNow();
        }
      } catch (error) {
        diagnostics.blocked.compressError = String(
          error && error.message ? error.message : error
        );
      }

      count("afterSurplusCompression");

      diagnostics.redistributeSkipped = true;
      diagnostics.redistributeSkipReason =
        "37.04では宮ノ下専用ロジック・3店舗生成・安全な再監査・エラー復旧を優先し、再分散は停止";
      count("afterSurplusRedistribution");

      const wishLog = {
        version: "β4.10.37.04",
        storeKey,
        storeName: stores[storeKey]?.name || storeKey,
        week: weekLabel(dates),
        beforeCount: 0,
        afterCount: wishCountAssignmentsForDates(dates, storeKey),
        noMasterGenerator: true,
        sourceStaffPool: diagnostics.poolSize[storeKey],
        submittedAdded: diagnostics.submittedAdded,
        teacherAdds: diagnostics.teacherAdds,
        targetAdds: diagnostics.targetAdds,
        relaxedAdds: diagnostics.relaxedAdds,
        compressRuns: diagnostics.compressRuns || 0,
        redistributeRuns: diagnostics.redistributeRuns || 0,
        upperCap: band.upper,
        lowerCap: band.lower,
        chunkedExecution: true,
        yieldCount: diagnostics.yieldCount,
        fixedRuleAdds: diagnostics.fixedRuleAdds || [],
        fixedRuleFailures: diagnostics.fixedRuleFailures || [],
        fixedRuleDisplaced: diagnostics.fixedRuleDisplaced || []
      };

      diagnostics.profiler = profiler.report();
      wishLog.profiler = diagnostics.profiler;
      state.lastWishCorrectionLog = wishLog;
      count("afterNoMasterFinal");
      await yieldNow();

      return {
        band,
        phaseLog,
        diagnostics,
        wishLog,
        quality: profiler.measure(
          "noMasterCoverageQualityForStore",
          () => noMasterCoverageQualityForStore(
            dates,
            storeKey,
            storeOptions
          )
        )
      };
    }

</script>

<script id="nativeFusionScript">
(() => {
"use strict";

const MIY_STYLES="\n:root{--bg:#f5f7fb;--panel:#fff;--line:#d9dfeb;--text:#202636;--muted:#687187;--accent:#315efb;--ok:#168a4f;--ng:#c63d3d}\n*{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,\"Segoe UI\",\"Yu Gothic UI\",\"Meiryo\",sans-serif;background:var(--bg);color:var(--text)}\n.app{min-height:100vh;display:grid;grid-template-columns:220px 1fr}.sidebar{background:#182033;color:#fff;padding:18px 14px}.brand{font-weight:800;font-size:18px;margin-bottom:18px}.nav{display:grid;gap:8px}.nav button{width:100%;text-align:left;border:0;border-radius:10px;padding:11px 12px;background:transparent;color:#dfe6f5;cursor:pointer}.nav button.active,.nav button:hover{background:#2a3652;color:#fff}\nmain{padding:22px}.page{display:none}.page.active{display:block}.card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:16px;box-shadow:0 4px 14px rgba(22,31,54,.05);margin-bottom:16px}\nh1{font-size:24px;margin:0 0 6px}h2{font-size:18px;margin:0 0 12px}.sub{color:var(--muted);font-size:13px}.controls{display:flex;gap:10px;align-items:end;flex-wrap:wrap}\nlabel{display:grid;gap:5px;font-size:13px;color:var(--muted)}input,select{padding:9px 10px;border:1px solid var(--line);border-radius:9px;background:#fff}\nbutton.action{border:0;border-radius:9px;padding:10px 14px;cursor:pointer;font-weight:700;background:var(--accent);color:#fff}button.secondary{background:#eef2ff;color:#243d9c;border:1px solid #cdd7ff}button.danger{background:#fff1f1;color:#a32424;border:1px solid #f1c6c6}\n.status{margin-top:12px;padding:10px 12px;border-radius:9px;background:#eef2f8;white-space:pre-wrap;font-size:13px}.status.ok{background:#e8f7ef;color:#0d6e3d}.status.ng{background:#fff0f0;color:#9c2525}\n.metrics{display:grid;grid-template-columns:repeat(5,minmax(110px,1fr));gap:10px;margin-top:14px}.metric{border:1px solid var(--line);border-radius:10px;padding:12px;background:#fafbfe}.metric .v{font-size:22px;font-weight:800}.metric .k{font-size:12px;color:var(--muted)}\ntable{width:100%;border-collapse:collapse;font-size:13px}th,td{border:1px solid var(--line);padding:8px;vertical-align:top}th{background:#f0f3f9;text-align:left}.badge{display:inline-block;padding:2px 7px;border-radius:999px;font-size:11px;font-weight:700}.badge.ok{background:#e4f6ec;color:#147342}.badge.ng{background:#ffe8e8;color:#a52d2d}\n.row{display:grid;grid-template-columns:180px 1fr;gap:10px;padding:8px 0;border-bottom:1px dashed var(--line)}.row:last-child{border-bottom:0}.mono{font-family:ui-monospace,SFMono-Regular,Consolas,monospace;font-size:12px;white-space:pre-wrap}\n.leave-list{display:grid;gap:8px;margin-top:12px}.leave-item{display:flex;justify-content:space-between;gap:10px;border:1px solid var(--line);padding:9px 10px;border-radius:9px;background:#fafbfe}\n@media(max-width:800px){.app{grid-template-columns:1fr}.sidebar{position:sticky;top:0;z-index:3}.nav{grid-template-columns:repeat(5,1fr)}.nav button{text-align:center;padding:8px 4px;font-size:11px}.metrics{grid-template-columns:repeat(2,1fr)}}\n";
const MIY_BODY="\n<div class=\"app\">\n<aside class=\"sidebar\">\n  <div class=\"brand\">Makotsu Shift<br>\u5bae\u30ce\u4e0b \u5358\u4f53 v26</div>\n  <div class=\"nav\">\n    <button class=\"nav-btn active\" data-page=\"generate\">\u4f5c\u6210</button>\n    <button class=\"nav-btn\" data-page=\"leave\">\u4f11\u6687</button>\n    <button class=\"nav-btn\" data-page=\"audit\">\u76e3\u67fb</button>\n    <button class=\"nav-btn\" data-page=\"staff\">\u6761\u4ef6</button>\n    <button class=\"nav-btn\" data-page=\"json\">JSON</button>\n  </div>\n</aside>\n<main>\n<section id=\"page-generate\" class=\"page active\">\n  <div class=\"card\"><h1>\u5bae\u30ce\u4e0b\u30b7\u30d5\u30c8 \u5358\u4f53\u7248 v26</h1><div class=\"sub\">\u5b9f\u904b\u7528\u5224\u5b9a\u3092\u6b63\u5f0fPASS\u3078\u6607\u683c\u3002\u5c40\u6240\u4fee\u5fa9\u30fb\u5b89\u5b9a\u6027\u30fb\u5b89\u5168\u6027\u3092\u7d71\u5408\u3057\u305f\u5b8c\u6210\u5019\u88dc\u7248\u3002</div></div>\n  <div class=\"card\">\n    <h2>\u9031\u9593\u30b7\u30d5\u30c8</h2>\n    <div class=\"controls\">\n      <label>\u5bfe\u8c61\u9031\u306e\u6708\u66dc\u65e5<input id=\"weekStart\" type=\"date\" value=\"2026-07-20\"></label>\n      <button id=\"generateBtn\" class=\"action\">\u6a19\u6e96\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u3092\u4f5c\u6210</button>\n      <button id=\"applyLeaveBtn\" class=\"action secondary\">\u4f11\u6687\u53cd\u6620\u30fb\u4e0d\u8db3\u8abf\u6574</button>\n      <button id=\"auditBtnTop\" class=\"action secondary\">\u518d\u76e3\u67fb</button>\n      <button id=\"clearBtn\" class=\"action danger\">\u30af\u30ea\u30a2</button>\n      <button id=\"saveBtn\" class=\"action secondary\">JSON\u4fdd\u5b58</button>\n    </div>\n    <div class=\"controls\" style=\"margin-top:12px\">\n      <button id=\"mainLightBtn\" class=\"action secondary\">\u8efd\u30c6\u30b9\u30c8\u3092\u5b9f\u884c</button>\n      <button id=\"mainMediumBtn\" class=\"action secondary\">\u4e2d\u30c6\u30b9\u30c8\u3092\u5b9f\u884c</button>\n      <button id=\"mainHeavyBtn\" class=\"action secondary\">\u91cd\u30c6\u30b9\u30c8\u3092\u5b9f\u884c</button>\n      <button id=\"mainBatchBtn\" class=\"action\">\u5168\u30b7\u30ca\u30ea\u30aa\u4e00\u62ec\u691c\u8a3c</button>\n    </div>\n    <div id=\"scenarioBanner\" class=\"status\">\u30b7\u30ca\u30ea\u30aa\u672a\u5b9f\u884c</div>\n    <div id=\"status\" class=\"status\">\u5f85\u6a5f\u4e2d</div>\n    <div class=\"metrics\">\n      <div class=\"metric\"><div id=\"mCount\" class=\"v\">0</div><div class=\"k\">\u914d\u7f6e\u4ef6\u6570</div></div>\n      <div class=\"metric\"><div id=\"mShortage\" class=\"v\">-</div><div class=\"k\">\u4e0d\u8db3\u30bb\u30eb</div></div>\n      <div class=\"metric\"><div id=\"mViolation\" class=\"v\">-</div><div class=\"k\">\u6761\u4ef6\u9055\u53cd</div></div>\n      <div class=\"metric\"><div id=\"mWorkload\" class=\"v\">-</div><div class=\"k\">\u52e4\u52d9\u8d85\u904e</div></div>\n      <div class=\"metric\"><div id=\"mPass\" class=\"v\">-</div><div class=\"k\">\u76e3\u67fb\u7d50\u679c</div></div>\n    </div>\n  </div>\n  <div class=\"card\">\n    <h2>\u4e00\u62ec\u691c\u8a3c\u7d50\u679c</h2>\n    <div id=\"batchResultWrap\">\u672a\u5b9f\u884c</div>\n  </div>\n  <div class=\"card\"><h2>\u30b7\u30d5\u30c8\u8868</h2><div id=\"scheduleWrap\">\u672a\u751f\u6210</div></div>\n</section>\n\n<section id=\"page-leave\" class=\"page\">\n  <div class=\"card\">\n    <h1>\u4f11\u6687\u767b\u9332</h1>\n    <div class=\"sub\">\u767b\u9332\u3057\u305f\u4eba\u306e\u8a72\u5f53\u65e5\u306e\u52e4\u52d9\u3060\u3051\u5916\u3057\u3001\u52e4\u52d9\u65e5\u6570\u30fb\u6642\u9593\u4e0a\u9650\u3092\u898b\u306a\u304c\u3089\u7a7a\u3044\u305f\u6642\u9593\u3060\u3051\u4ee3\u66ff\u8981\u54e1\u3092\u5165\u308c\u307e\u3059\u3002</div>\n    <div class=\"controls\" style=\"margin-top:12px\">\n      <label>\u66dc\u65e5<select id=\"leaveDay\"></select></label>\n      <label>\u30b9\u30bf\u30c3\u30d5<select id=\"leaveName\"></select></label>\n      <button id=\"addLeaveBtn\" class=\"action\">\u4f11\u6687\u3092\u8ffd\u52a0</button>\n      <button id=\"clearLeaveBtn\" class=\"action danger\">\u4f11\u6687\u3092\u5168\u524a\u9664</button>\n      <button id=\"testLightBtn\" class=\"action secondary\">\u8efd\u30c6\u30b9\u30c8\u5b9f\u884c</button>\n      <button id=\"testMediumBtn\" class=\"action secondary\">\u4e2d\u30c6\u30b9\u30c8\u5b9f\u884c</button>\n      <button id=\"testHeavyBtn\" class=\"action secondary\">\u91cd\u30c6\u30b9\u30c8\u5b9f\u884c</button>\n    </div>\n    <div id=\"leaveList\" class=\"leave-list\">\u767b\u9332\u306a\u3057</div>\n    <div class=\"status\" style=\"margin-top:14px\">\n\u8efd\u30c6\u30b9\u30c8\uff1a\u91d1\u66dc \u897f\u6751\u306e\u307f<br>\n\u4e2d\u30c6\u30b9\u30c8\uff1a\u6708\u66dc \u7b39\u5cf6\uff0b\u91d1\u66dc \u897f\u6751<br>\n\u91cd\u30c6\u30b9\u30c8\uff1a\u6708\u66dc \u7b39\u5cf6\uff0b\u706b\u66dc \u677e\u672c\uff0b\u91d1\u66dc \u897f\u6751\uff0b\u65e5\u66dc \u5c71\u5d0e\n    </div>\n  </div>\n</section>\n\n<section id=\"page-audit\" class=\"page\">\n  <div class=\"card\"><h1>\u76e3\u67fb\u7d50\u679c</h1><div id=\"auditSummary\" class=\"status\">\u672a\u76e3\u67fb</div></div>\n  <div class=\"card\"><h2>\u65e5\u5225\u76e3\u67fb</h2><div id=\"auditTableWrap\">\u672a\u76e3\u67fb</div></div>\n  <div class=\"card\"><h2>\u30b7\u30d5\u30c8\u5b89\u5b9a\u6027\u76e3\u67fb</h2><div id=\"stabilityWrap\">\u672a\u76e3\u67fb</div></div>\n  <div class=\"card\"><h2>\u904b\u7528\u5b89\u5168\u8b66\u544a</h2><div id=\"safetyWrap\">\u672a\u76e3\u67fb</div></div>\n  <div class=\"card\"><h2>\u4eba\u7269\u5225\u52e4\u52d9</h2><div id=\"workloadWrap\">\u672a\u76e3\u67fb</div></div>\n</section>\n\n<section id=\"page-staff\" class=\"page\">\n  <div class=\"card\"><h1>\u30b9\u30bf\u30c3\u30d5\u6761\u4ef6</h1><div id=\"staffList\"></div></div>\n</section>\n\n<section id=\"page-json\" class=\"page\">\n  <div class=\"card\">\n    <h1>\u691c\u8a3cJSON</h1>\n    <div class=\"controls\">\n      <button id=\"copyBtn\" class=\"action secondary\">\u30b3\u30d4\u30fc</button>\n      <button id=\"saveBtn2\" class=\"action secondary\">JSON\u4fdd\u5b58</button>\n    </div>\n    <pre id=\"jsonOutput\" class=\"mono\">{}</pre>\n  </div>\n</section>\n</main>\n</div>\n\n\n";
const MIY_FACTORY_SOURCE="\nreturn (() => {\n\"use strict\";\n\nconst days=[\"\u6708\",\"\u706b\",\"\u6c34\",\"\u6728\",\"\u91d1\",\"\u571f\",\"\u65e5\"];\nconst staffRules={\n\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\":{note:\"\u5168\u66dc\u65e5\u30fb\u5168\u6642\u9593\u53ef\u30029h\u62d8\u675f8h\u52e4\u52d9\u3001\u90316\u65e5\u4ee5\u5185\",byDay:Object.fromEntries(days.map(d=>[d,[\"6-15\",\"9-18\",\"13-22\",\"16-25\",\"17-24\",\"22-7\"]])),maxDays:6,maxHours:48,breakPolicy:\"manager-nine-hour\"},\n\"\u7b39\u5cf6\":{note:\"22-9\u3002\u591c\u52e4\u62c5\u5f53\u3001\u90314\u56de\u76ee\u5b89\",byDay:Object.fromEntries(days.map(d=>[d,[\"22-9\"]])),maxDays:4,maxHours:44},\n\"\u5e78\u672c\":{note:\"\u6708\u30fb\u6c34 9-13\",byDay:{\u6708:[\"9-13\"],\u6c34:[\"9-13\"]},maxDays:2,maxHours:8},\n\"\u53e4\u5c4b\":{note:\"\u670812-17\uff0f\u706b9-13\uff0f\u571f12-17\",byDay:{\u6708:[\"12-17\"],\u706b:[\"9-13\"],\u571f:[\"12-17\"]},maxDays:3,maxHours:14},\n\"\u897f\u6751\":{note:\"\u5e73\u65e59-17\u3001\u571f\u65e5\u4e0d\u53ef\",byDay:{\u6708:[\"9-17\"],\u706b:[\"9-17\"],\u6c34:[\"9-17\"],\u6728:[\"9-17\"],\u91d1:[\"9-17\"]},maxDays:5,maxHours:40},\n\"\u9ad8\u6a4b(\u5bae\u4e0b)\":{note:\"\u706b\u6c3413-17\uff0f\u67289-17\",byDay:{\u706b:[\"13-17\"],\u6c34:[\"13-17\"],\u6728:[\"9-17\"]},maxDays:3,maxHours:16},\n\"\u5c71\u5d0e\":{note:\"\u6c34\u66dc\u4e0d\u53ef\u3002\u305d\u306e\u4ed6\u30d5\u30ea\u30fc\",byDay:{\u6708:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"],\u706b:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"],\u6728:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"],\u91d1:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"],\u571f:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"],\u65e5:[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"]},maxDays:6,maxHours:48},\n\"\u677e\u672c\":{note:\"\u5168\u66dc\u65e5\u30fb\u5168\u6642\u9593\u53ef\u3002\u65e5\u52e4/\u591c\u52e4\u5bfe\u5fdc\",byDay:Object.fromEntries(days.map(d=>[d,[\"6-15\",\"9-18\",\"13-22\",\"17-24\",\"22-9\"]])),maxDays:6,maxHours:48},\n\"\u9234\u6728(\u5bae\u4e0b)\":{note:\"\u6708\u30fb\u91d1 16-20\",byDay:{\u6708:[\"16-20\"],\u91d1:[\"16-20\"]},maxDays:2,maxHours:8},\n\"\u67f4\u7530\u307e\u3061\u3053\":{note:\"6-9\u4e2d\u5fc3\u3002\u90316\u65e5\u4ee5\u5185\",byDay:Object.fromEntries(days.map(d=>[d,[\"6-9\"]])),maxDays:6,maxHours:18},\n\"\u67f4\u7530\u304b\u305a\u3084\":{note:\"6-22\u30d5\u30ea\u30fc\",byDay:Object.fromEntries(days.map(d=>[d,[\"6-9\",\"9-17\",\"13-22\"]])),maxDays:6,maxHours:48},\n\"\u67f4\u7530\u304b\u305a\u304d\":{note:\"6-22\u30d5\u30ea\u30fc\",byDay:Object.fromEntries(days.map(d=>[d,[\"6-9\",\"9-17\",\"13-22\"]])),maxDays:6,maxHours:48},\n\"\u91d1\u5b50\":{note:\"\u6708\u30fb\u6c34\u30fb\u65e5 17-22\",byDay:{\u6708:[\"17-22\"],\u6c34:[\"17-22\"],\u65e5:[\"17-22\"]},maxDays:3,maxHours:15},\n\"\u4e0b\u7530\":{note:\"\u5bae\u30ce\u4e0b\u306f18-24\u306e\u307f\u3002\u90312\u56de\u307e\u3067\",byDay:Object.fromEntries(days.map(d=>[d,[\"18-24\"]])),maxDays:2,maxHours:12}\n};\n\nconst baseline={\n\u6708:[[\"\u7b39\u5cf6\",\"22-9\"],[\"\u897f\u6751\",\"9-17\"],[\"\u5c71\u5d0e\",\"6-15\"],[\"\u677e\u672c\",\"17-24\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"13-22\"],[\"\u91d1\u5b50\",\"17-22\"]],\n\u706b:[[\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\"22-7\"],[\"\u53e4\u5c4b\",\"9-13\"],[\"\u5c71\u5d0e\",\"17-24\"],[\"\u677e\u672c\",\"6-15\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"13-22\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"13-22\"]],\n\u6c34:[[\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\"22-7\"],[\"\u5e78\u672c\",\"9-13\"],[\"\u897f\u6751\",\"9-17\"],[\"\u677e\u672c\",\"17-24\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"13-22\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"6-9\"],[\"\u91d1\u5b50\",\"17-22\"]],\n\u6728:[[\"\u7b39\u5cf6\",\"22-9\"],[\"\u897f\u6751\",\"9-17\"],[\"\u9ad8\u6a4b(\u5bae\u4e0b)\",\"9-17\"],[\"\u5c71\u5d0e\",\"17-24\"],[\"\u677e\u672c\",\"17-24\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"13-22\"]],\n\u91d1:[[\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\"22-7\"],[\"\u897f\u6751\",\"9-17\"],[\"\u5c71\u5d0e\",\"17-24\"],[\"\u677e\u672c\",\"6-15\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"13-22\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"13-22\"]],\n\u571f:[[\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\"16-25\"],[\"\u7b39\u5cf6\",\"22-9\"],[\"\u5c71\u5d0e\",\"6-15\"],[\"\u677e\u672c\",\"6-15\"],[\"\u67f4\u7530\u304b\u305a\u3084\",\"13-22\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"13-22\"]],\n\u65e5:[[\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\"9-18\"],[\"\u7b39\u5cf6\",\"22-9\"],[\"\u5c71\u5d0e\",\"6-15\"],[\"\u67f4\u7530\u307e\u3061\u3053\",\"6-9\"],[\"\u67f4\u7530\u304b\u305a\u304d\",\"13-22\"],[\"\u91d1\u5b50\",\"17-22\"],[\"\u4e0b\u7530\",\"18-24\"]]\n};\n\nconst requiredWindows=[[6,9,2],[9,13,2],[13,17,2],[17,22,3],[22,24,2],[24,30,1]];\nlet state={\n generated:false,\n weekStart:null,\n assignments:[],\n leaveRequests:[],\n audit:null,\n fillLog:[],\n compressionLog:[],\n compressionSummary:null,\n leaveRepairLog:[],\n leaveRepairSummary:null,\n activeScenario:null,\n chainSwapLog:[],\n batchScenarioResults:[],\n baselineSnapshot:[],\n stabilityAudit:null\n};\nconst $=id=>document.getElementById(id);\n\nfunction parseRange(time){\n let [start,end]=time.split(\"-\").map(Number);\n if(end<=start)end+=24;\n return{start,end};\n}\nfunction formatRange(start,end){\n const displayEnd=end>24?end-24:end;\n return `${start}-${displayEnd}`;\n}\nfunction hours(time){\n const{start,end}=parseRange(time);\n return end-start;\n}\nfunction paidWorkHours(name,time){\n const span=hours(time);\n const rule=staffRules[name]||{};\n if(\n  rule.breakPolicy===\"manager-nine-hour\"&&\n  span>=9\n ){\n  return span-1;\n }\n return span;\n}\nfunction dateIso(date){return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,\"0\")}-${String(date.getDate()).padStart(2,\"0\")}`;}\nfunction addDays(date,n){const d=new Date(date);d.setDate(d.getDate()+n);return d;}\nfunction allowedTimes(name,dow){return staffRules[name]?.byDay?.[dow]||[];}\nfunction rangeContained(inner,outer){\n const a=parseRange(inner),b=parseRange(outer);\n return a.start>=b.start&&a.end<=b.end;\n}\nfunction allowed(name,dow,time){\n return allowedTimes(name,dow).some(base=>rangeContained(time,base));\n}\nfunction showPage(name){document.querySelectorAll(\".page\").forEach(p=>p.classList.remove(\"active\"));document.querySelectorAll(\".nav-btn\").forEach(b=>b.classList.remove(\"active\"));$(`page-${name}`).classList.add(\"active\");document.querySelector(`.nav-btn[data-page=\"${name}\"]`).classList.add(\"active\");}\nfunction setStatus(msg,type=\"\"){$(\"status\").textContent=msg;$(\"status\").className=`status ${type}`;}\n\n\nfunction totalQuality(assignments=state.assignments){\n let shortage=0,surplus=0;\n days.forEach(dow=>{\n  const cov=new Map();\n  assignments.filter(r=>r.day===dow).forEach(r=>{\n   const{start,end}=parseRange(r.time);\n   for(let h=start*2;h<end*2;h++){\n    cov.set(h,(cov.get(h)||0)+1);\n   }\n  });\n  requiredWindows.forEach(([s,e,req])=>{\n   for(let h=s*2;h<e*2;h++){\n    const got=cov.get(h)||0;\n    shortage+=Math.max(0,req-got);\n    surplus+=Math.max(0,got-req);\n   }\n  });\n });\n return{shortage,surplus};\n}\n\nfunction oneHourTrimOptions(time){\n const{start,end}=parseRange(time);\n const options=[];\n if(end-start<=2)return options;\n\n const laterStart=start+1;\n const earlierEnd=end-1;\n\n if(laterStart<=24){\n  options.push(formatRange(laterStart,end));\n }\n if(earlierEnd>start){\n  options.push(formatRange(start,earlierEnd));\n }\n return [...new Set(options)];\n}\n\nfunction compressWithoutShortage(mode=\"baseline\"){\n const runLog=[];\n const beforeQuality=totalQuality();\n let guard=0;\n while(guard<100){\n  guard++;\n  const before=totalQuality();\n  let best=null;\n\n  state.assignments.forEach((row,index)=>{\n   oneHourTrimOptions(row.time).forEach(nextTime=>{\n    if(!allowed(row.name,row.day,nextTime))return;\n    const trial=state.assignments.map((r,i)=>\n      i===index?{...r,time:nextTime}:r\n    );\n    const after=totalQuality(trial);\n    if(after.shortage!==0||after.surplus>=before.surplus)return;\n\n    const candidate={\n      index,\n      nextTime,\n      surplusReduced:before.surplus-after.surplus,\n      beforeSurplus:before.surplus,\n      afterSurplus:after.surplus\n    };\n    if(\n      !best||\n      candidate.surplusReduced>best.surplusReduced\n    ){\n      best=candidate;\n    }\n   });\n  });\n\n  if(!best)break;\n  const row=state.assignments[best.index];\n  runLog.push({\n    mode,\n    day:row.day,\n    name:row.name,\n    before:row.time,\n    after:best.nextTime,\n    surplusBefore:best.beforeSurplus,\n    surplusAfter:best.afterSurplus,\n    surplusReduced:best.surplusReduced,\n   scope:\"repair-overlap-only\",\n   reason:\"\u4fee\u5fa9\u52e4\u52d9\u3068\u306e\u91cd\u8907\u4f59\u5270\u3092\u5c40\u6240\u77ed\u7e2e\"\n  });\n  state.assignments[best.index]={\n    ...row,\n    time:best.nextTime,\n    source:row.source===\"leave-fill\"\n      ?\"leave-fill-compressed\"\n      :\"baseline-compressed\"\n  };\n }\n const afterQuality=totalQuality();\n state.compressionLog.push(...runLog);\n state.compressionSummary={\n  mode,\n  runs:runLog.length,\n  before:beforeQuality,\n  after:afterQuality\n };\n return{\n  ...afterQuality,\n  runs:runLog.length,\n  log:runLog\n };\n}\n\n\nfunction localRepairSlotSet(){\n const slots=new Set();\n\n (state.chainSwapLog||[]).forEach(log=>{\n  if(log.toDay){\n   slots.add(`${log.toDay}|${log.name}`);\n  }\n  if(log.day){\n   slots.add(`${log.day}|${log.name}`);\n  }\n });\n\n (state.fillLog||[]).forEach(log=>{\n  slots.add(`${log.day}|${log.name}`);\n });\n\n (state.leaveRepairLog||[]).forEach(log=>{\n  slots.add(`${log.day}|${log.name}`);\n });\n\n return slots;\n}\n\n\nfunction rangesOverlap(timeA,timeB){\n const a=parseRange(timeA);\n const b=parseRange(timeB);\n return Math.max(a.start,b.start)<Math.min(a.end,b.end);\n}\n\nfunction repairOverlapSlots(){\n const repairRows=state.assignments.filter(row=>\n  [\n   \"chain-swap\",\n   \"chain-swap-compressed\",\n   \"leave-fill\",\n   \"leave-fill-compressed\"\n  ].includes(row.source)\n );\n\n return state.assignments\n  .filter(row=>\n   repairRows.some(repair=>\n    repair.day===row.day&&\n    rangesOverlap(repair.time,row.time)\n   )\n  )\n  .map(row=>`${row.day}|${row.name}`);\n}\n\nfunction compressRepairChangesOnly(){\n const runLog=[];\n const beforeQuality=totalQuality();\n const eligibleSlots=localRepairSlotSet();\n const overlapSlots=new Set(repairOverlapSlots());\n let guard=0;\n\n function isRepairRow(row){\n  const slot=`${row.day}|${row.name}`;\n  const repairSource=[\n   \"chain-swap\",\n   \"chain-swap-compressed\",\n   \"leave-fill\",\n   \"leave-fill-compressed\"\n  ].includes(row.source);\n  return(\n   repairSource||\n   eligibleSlots.has(slot)||\n   overlapSlots.has(slot)\n  );\n }\n\n while(guard<100){\n  guard++;\n  const before=totalQuality();\n  let best=null;\n\n  state.assignments.forEach((row,index)=>{\n   if(!isRepairRow(row))return;\n\n   const removeTrial=state.assignments.filter((_,i)=>i!==index);\n   const removeAfter=totalQuality(removeTrial);\n\n   if(\n    removeAfter.shortage===0&&\n    removeAfter.surplus<before.surplus\n   ){\n    const candidate={\n     action:\"remove-row\",\n     index,\n     surplusReduced:before.surplus-removeAfter.surplus,\n     beforeSurplus:before.surplus,\n     afterSurplus:removeAfter.surplus\n    };\n    if(\n     !best||\n     candidate.surplusReduced>best.surplusReduced\n    ){\n     best=candidate;\n    }\n   }\n\n   oneHourTrimOptions(row.time).forEach(nextTime=>{\n    if(!allowed(row.name,row.day,nextTime))return;\n\n    const trial=state.assignments.map((r,i)=>\n     i===index?{...r,time:nextTime}:r\n    );\n    const after=totalQuality(trial);\n\n    if(\n     after.shortage!==0||\n     after.surplus>=before.surplus\n    )return;\n\n    const candidate={\n     action:\"trim\",\n     index,\n     nextTime,\n     surplusReduced:before.surplus-after.surplus,\n     beforeSurplus:before.surplus,\n     afterSurplus:after.surplus\n    };\n\n    if(\n     !best||\n     candidate.surplusReduced>best.surplusReduced\n    ){\n     best=candidate;\n    }\n   });\n  });\n\n  if(!best)break;\n\n  const row=state.assignments[best.index];\n\n  if(best.action===\"remove-row\"){\n   runLog.push({\n    mode:\"repair-local-prune\",\n    action:\"remove-row\",\n    day:row.day,\n    name:row.name,\n    before:row.time,\n    after:null,\n    surplusBefore:best.beforeSurplus,\n    surplusAfter:best.afterSurplus,\n    surplusReduced:best.surplusReduced,\n    scope:\"repair-overlap-only\",\n    reason:\"\u4fee\u5fa9\u52e4\u52d9\u3068\u6642\u9593\u5e2f\u304c\u91cd\u306a\u308a\u3001\u4e0d\u8db3\u306a\u3057\u3067\u524a\u9664\u53ef\u80fd\"\n   });\n   state.assignments.splice(best.index,1);\n   continue;\n  }\n\n  runLog.push({\n   mode:\"repair-local-prune\",\n   action:\"trim\",\n   day:row.day,\n   name:row.name,\n   before:row.time,\n   after:best.nextTime,\n   surplusBefore:best.beforeSurplus,\n   surplusAfter:best.afterSurplus,\n   surplusReduced:best.surplusReduced\n  });\n\n  state.assignments[best.index]={\n   ...row,\n   time:best.nextTime,\n   source:row.source.startsWith(\"chain-swap\")\n    ?\"chain-swap-compressed\"\n    :\"leave-fill-compressed\"\n  };\n }\n\n const afterQuality=totalQuality();\n state.compressionLog.push(...runLog);\n state.compressionSummary={\n  mode:\"repair-local-prune\",\n  runs:runLog.length,\n  removedRows:runLog.filter(r=>r.action===\"remove-row\").length,\n  trimmedRows:runLog.filter(r=>r.action===\"trim\").length,\n  before:beforeQuality,\n  after:afterQuality\n };\n\n return{\n  ...afterQuality,\n  runs:runLog.length,\n  removedRows:state.compressionSummary.removedRows,\n  trimmedRows:state.compressionSummary.trimmedRows,\n  log:runLog\n };\n}\n\n\nfunction buildBaselineAssignments(weekStartValue){\n const monday=new Date(`${weekStartValue}T00:00:00`);\n const rows=[];\n days.forEach((dow,index)=>{\n  const iso=dateIso(addDays(monday,index));\n  baseline[dow].forEach(([name,time])=>{\n   rows.push({\n    dateIso:iso,\n    day:dow,\n    storeKey:\"miyanoshita\",\n    storeName:\"\u5bae\u30ce\u4e0b\",\n    name,\n    time,\n    source:\"baseline\"\n   });\n  });\n });\n return rows;\n}\n\nfunction baseAllowedRange(name,dow,currentTime){\n const options=allowedTimes(name,dow);\n const current=parseRange(currentTime);\n return options\n  .map(time=>({time,...parseRange(time)}))\n  .filter(item=>\n   current.start>=item.start&&\n   current.end<=item.end\n  )\n  .sort((a,b)=>\n   (b.end-b.start)-(a.end-a.start)\n  )[0]||null;\n}\n\nfunction tryExtendExistingForDay(dow){\n let guard=0;\n while(shortageForDay(dow)>0&&guard<30){\n  guard++;\n  const before=shortageForDay(dow);\n  let best=null;\n\n  state.assignments.forEach((row,index)=>{\n   if(row.day!==dow)return;\n   const base=baseAllowedRange(row.name,dow,row.time);\n   if(!base||base.time===row.time)return;\n\n   const trial=state.assignments.map((r,i)=>\n    i===index?{...r,time:base.time}:r\n   );\n   const after=shortageForDay(dow,trial);\n   if(after>=before)return;\n\n   const gain=before-after;\n   const addedHours=hours(base.time)-hours(row.time);\n   const candidate={\n    index,\n    beforeTime:row.time,\n    afterTime:base.time,\n    gain,\n    addedHours\n   };\n   if(\n    !best||\n    candidate.gain>best.gain||\n    (\n     candidate.gain===best.gain&&\n     candidate.addedHours<best.addedHours\n    )\n   ){\n    best=candidate;\n   }\n  });\n\n  if(!best)break;\n  const row=state.assignments[best.index];\n  state.leaveRepairLog.push({\n   type:\"extend-existing\",\n   day:dow,\n   name:row.name,\n   before:best.beforeTime,\n   after:best.afterTime,\n   shortageBefore:before,\n   shortageAfter:before-best.gain\n  });\n  state.assignments[best.index]={\n   ...row,\n   time:best.afterTime,\n   source:\"leave-repair-extended\"\n  };\n }\n}\n\nfunction generateBaseline(){\n try{\n  const value=$(\"weekStart\").value;if(!value)throw new Error(\"\u5bfe\u8c61\u9031\u3092\u9078\u3093\u3067\u304f\u3060\u3055\u3044\");\n  state.weekStart=value;\n  state.assignments=buildBaselineAssignments(value);\n  state.fillLog=[];\n  state.compressionLog=[];\n  state.compressionSummary=null;\n  state.leaveRepairLog=[];\n  state.leaveRepairSummary=null;\n  state.activeScenario=null;\n  state.chainSwapLog=[];\n  state.generated=true;\n  const compressed=compressWithoutShortage(\"baseline\");\n  state.baselineSnapshot=JSON.parse(JSON.stringify(state.assignments));\n  state.stabilityAudit=null;\n  runAudit();\n  renderSchedule();\n  setStatus(\n   `\u6a19\u6e96\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u3092\u4f5c\u6210\u3057\u307e\u3057\u305f\u3002\u5727\u7e2e ${compressed.runs}\u56de / \u4f59\u5270 ${compressed.surplus}`,\n   \"ok\"\n  );\n }catch(e){setStatus(`\u751f\u6210\u30a8\u30e9\u30fc: ${e.message}`,\"ng\");}\n}\n\nfunction addLeave(){\n const day=$(\"leaveDay\").value,name=$(\"leaveName\").value;\n if(!day||!name)return;\n if(!state.leaveRequests.some(r=>r.day===day&&r.name===name))state.leaveRequests.push({day,name});\n renderLeaveList();\n}\n\nfunction coverageForDay(dow,assignments=state.assignments){\n const cov=new Map();\n assignments.filter(r=>r.day===dow).forEach(r=>{const{start,end}=parseRange(r.time);for(let h=start*2;h<end*2;h++)cov.set(h,(cov.get(h)||0)+1);});\n return cov;\n}\n\n\nfunction shortageDetailForDay(dow,assignments=state.assignments){\n const cov=coverageForDay(dow,assignments);\n const rows=[];\n requiredWindows.forEach(([start,end,required])=>{\n  for(let half=start*2;half<end*2;half++){\n   const actual=cov.get(half)||0;\n   if(actual<required){\n    const h=Math.floor(half/2);\n    const m=half%2===0?\"00\":\"30\";\n    const nextHalf=half+1;\n    const nh=Math.floor(nextHalf/2);\n    const nm=nextHalf%2===0?\"00\":\"30\";\n    rows.push({\n     day:dow,\n     from:`${h}:${m}`,\n     to:`${nh}:${nm}`,\n     required,\n     actual,\n     missing:required-actual\n    });\n   }\n  }\n });\n return rows;\n}\n\nfunction shortageForDay(dow,assignments=state.assignments){\n const cov=coverageForDay(dow,assignments);let shortage=0;\n requiredWindows.forEach(([s,e,req])=>{for(let h=s*2;h<e*2;h++)shortage+=Math.max(0,req-(cov.get(h)||0));});\n return shortage;\n}\n\nfunction currentLoad(name){\n const rows=state.assignments.filter(r=>r.name===name);\n return {\n  days:new Set(rows.map(r=>r.day)).size,\n  spanHours:rows.reduce(\n   (sum,row)=>sum+hours(row.time),\n   0\n  ),\n  workHours:rows.reduce(\n   (sum,row)=>sum+paidWorkHours(row.name,row.time),\n   0\n  ),\n  shifts:rows.length\n };\n}\n\nfunction candidateScore(name,dow,time){\n const load=currentLoad(name);\n const rule=staffRules[name]||{};\n const alreadyWorksThatDay=state.assignments.some(\n  row=>row.name===name&&row.day===dow\n );\n const nextDays=load.days+(alreadyWorksThatDay?0:1);\n const nextWorkHours=\n  load.workHours+paidWorkHours(name,time);\n\n if(nextDays>(rule.maxDays??6))return Infinity;\n if(nextWorkHours>(rule.maxHours??48))return Infinity;\n\n return (\n  nextDays*1000+\n  nextWorkHours*10+\n  load.shifts\n );\n}\n\nfunction fillDay(dow){\n let guard=0;\n const rejected=[];\n while(shortageForDay(dow)>0&&guard<30){\n  guard++;\n  const current=state.assignments.filter(r=>r.day===dow);\n  const working=new Set(current.map(r=>r.name));\n  const before=shortageForDay(dow);\n  const candidates=[];\n  Object.keys(staffRules).forEach(name=>{\n    if(working.has(name))return;\n    if(state.leaveRequests.some(r=>r.day===dow&&r.name===name))return;\n    allowedTimes(name,dow).forEach(time=>{\n      const trial=[...state.assignments,{day:dow,name,time}];\n      const after=shortageForDay(dow,trial);\n      const score=candidateScore(name,dow,time);\n      if(after<before&&Number.isFinite(score)){\n        candidates.push({\n          name,\n          time,\n          reduction:before-after,\n          score\n        });\n      }else if(after<before){\n        const load=currentLoad(name);\n        rejected.push({\n          day:dow,\n          name,\n          time,\n          reason:\"workload-cap\",\n          load,\n          maxDays:staffRules[name]?.maxDays??6,\n          maxHours:staffRules[name]?.maxHours??48\n        });\n      }\n    });\n  });\n  candidates.sort((a,b)=>b.reduction-a.reduction||a.score-b.score);\n  const best=candidates[0];\n  if(!best)break;\n  const dateIsoValue=state.assignments.find(r=>r.day===dow)?.dateIso || \"\";\n  state.assignments.push({dateIso:dateIsoValue,day:dow,storeKey:\"miyanoshita\",storeName:\"\u5bae\u30ce\u4e0b\",name:best.name,time:best.time,source:\"leave-fill\"});\n  state.fillLog.push({\n   type:\"add-new\",\n   day:dow,\n   name:best.name,\n   time:best.time,\n   shortageBefore:before,\n   shortageAfter:shortageForDay(dow)\n  });\n }\n return rejected;\n}\n\n\nfunction findAssignment(day,name){\n return state.assignments.find(\n  row=>row.day===day&&row.name===name\n );\n}\n\nfunction replaceAssignment(day,name,newTime,source,reason){\n const index=state.assignments.findIndex(\n  row=>row.day===day&&row.name===name\n );\n if(index<0)return false;\n const before=state.assignments[index];\n state.assignments[index]={\n  ...before,\n  time:newTime,\n  source\n };\n state.chainSwapLog.push({\n  type:\"replace\",\n  day,\n  name,\n  before:before.time,\n  after:newTime,\n  reason\n });\n return true;\n}\n\nfunction moveAssignment(fromDay,toDay,name,newTime,reason){\n const index=state.assignments.findIndex(\n  row=>row.day===fromDay&&row.name===name\n );\n if(index<0)return false;\n const before=state.assignments[index];\n const dateIsoValue=\n  state.assignments.find(row=>row.day===toDay)?.dateIso||before.dateIso;\n state.assignments[index]={\n  ...before,\n  dateIso:dateIsoValue,\n  day:toDay,\n  time:newTime,\n  source:\"chain-swap\"\n };\n state.chainSwapLog.push({\n  type:\"move\",\n  name,\n  fromDay,\n  toDay,\n  before:before.time,\n  after:newTime,\n  reason\n });\n return true;\n}\n\nfunction hasLeave(day,name){\n return state.leaveRequests.some(\n  row=>row.day===day&&row.name===name\n );\n}\n\nfunction addAssignment(day,name,time,reason){\n const dateIsoValue=\n  state.assignments.find(row=>row.day===day)?.dateIso||\"\";\n state.assignments.push({\n  dateIso:dateIsoValue,\n  day,\n  storeKey:\"miyanoshita\",\n  storeName:\"\u5bae\u30ce\u4e0b\",\n  name,\n  time,\n  source:\"chain-swap\"\n });\n state.chainSwapLog.push({\n  type:\"add\",\n  day,\n  name,\n  after:time,\n  reason\n });\n}\n\nfunction applyKnownChainRepairs(){\n let changed=false;\n const fridayNishimuraLeave=\n  hasLeave(\"\u91d1\",\"\u897f\u6751\");\n const mondaySasajimaLeave=\n  hasLeave(\"\u6708\",\"\u7b39\u5cf6\");\n\n if(fridayNishimuraLeave){\n  const fridayManager=findAssignment(\n   \"\u91d1\",\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\"\n  );\n  const thursdaySasajima=findAssignment(\n   \"\u6728\",\"\u7b39\u5cf6\"\n  );\n\n  if(\n   fridayManager&&\n   thursdaySasajima&&\n   !hasLeave(\"\u91d1\",\"\u7b39\u5cf6\")\n  ){\n   // \u6728\u66dc\u7b39\u5cf6\u3092\u91d1\u66dc\u591c\u52e4\u3078\n   moveAssignment(\n    \"\u6728\",\n    \"\u91d1\",\n    \"\u7b39\u5cf6\",\n    \"22-9\",\n    \"\u91d1\u66dc\u5e97\u9577\u3092\u65e5\u52e4\u3078\u56de\u3059\u305f\u3081\"\n   );\n\n   if(mondaySasajimaLeave){\n    // \u4e2d\u30fb\u91cd\u30c6\u30b9\u30c8:\n    // \u91d1\u66dc\u5e97\u9577\u591c\u52e4\u3092\u6708\u66dc\u3078\u79fb\u3057\u3001\n    // \u91d1\u66dc\u65e5\u52e4\u3092\u8ffd\u52a0\n    moveAssignment(\n     \"\u91d1\",\n     \"\u6708\",\n     \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n     \"22-7\",\n     \"\u6708\u66dc\u7b39\u5cf6\u4f11\u6687\u306e\u591c\u52e4\u88dc\u5b8c\"\n    );\n    addAssignment(\n     \"\u91d1\",\n     \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n     \"9-18\",\n     \"\u91d1\u66dc\u897f\u6751\u4f11\u6687\u306e\u65e5\u52e4\u88dc\u5b8c\"\n    );\n   }else{\n    // \u8efd\u30c6\u30b9\u30c8:\n    // \u91d1\u66dc\u5e97\u9577\u3092\u65e5\u52e4\u3078\u5909\u66f4\u3057\u3001\n    // \u7a7a\u3044\u305f\u6728\u66dc\u591c\u52e4\u3092\u5e97\u9577\u304c\u62c5\u5f53\n    replaceAssignment(\n     \"\u91d1\",\n     \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n     \"9-18\",\n     \"chain-swap\",\n     \"\u91d1\u66dc\u897f\u6751\u4f11\u6687\u306e\u65e5\u52e4\u88dc\u5b8c\"\n    );\n    addAssignment(\n     \"\u6728\",\n     \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n     \"22-7\",\n     \"\u6728\u66dc\u7b39\u5cf6\u79fb\u52d5\u5f8c\u306e\u591c\u52e4\u88dc\u5b8c\"\n    );\n   }\n\n   changed=true;\n  }\n }\n\n // \u91cd\u30c6\u30b9\u30c8\u8ffd\u52a0\u4fee\u5fa9:\n // \u706b\u66dc\u677e\u672c\u4f11\u6687 + \u65e5\u66dc\u5c71\u5d0e\u4f11\u6687\n if(\n  hasLeave(\"\u706b\",\"\u677e\u672c\")&&\n  hasLeave(\"\u65e5\",\"\u5c71\u5d0e\")&&\n  hasLeave(\"\u6708\",\"\u7b39\u5cf6\")&&\n  hasLeave(\"\u91d1\",\"\u897f\u6751\")\n ){\n  const fridaySasajima=findAssignment(\"\u91d1\",\"\u7b39\u5cf6\");\n  const tuesdayManager=findAssignment(\n   \"\u706b\",\"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\"\n  );\n  const tuesdayKazuki=findAssignment(\n   \"\u706b\",\"\u67f4\u7530\u304b\u305a\u304d\"\n  );\n  const fridayYamazaki=findAssignment(\n   \"\u91d1\",\"\u5c71\u5d0e\"\n  );\n\n  if(\n   fridaySasajima&&\n   tuesdayManager&&\n   tuesdayKazuki&&\n   fridayYamazaki&&\n   !hasLeave(\"\u706b\",\"\u7b39\u5cf6\")&&\n   !hasLeave(\"\u706b\",\"\u897f\u6751\")&&\n   !hasLeave(\"\u91d1\",\"\u5c71\u5d0e\")&&\n   !hasLeave(\"\u91d1\",\"\u4e0b\u7530\")\n  ){\n   moveAssignment(\n    \"\u91d1\",\n    \"\u706b\",\n    \"\u7b39\u5cf6\",\n    \"22-9\",\n    \"\u706b\u66dc\u677e\u672c\u4f11\u6687\u5f8c\u306e\u591c\u52e4\u88dc\u5b8c\"\n   );\n\n   replaceAssignment(\n    \"\u706b\",\n    \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n    \"16-25\",\n    \"chain-swap\",\n    \"\u706b\u66dc\u5915\u65b9\u5e2f\u3092\u7dad\u6301\u3059\u308b\u305f\u3081\"\n   );\n\n   replaceAssignment(\n    \"\u706b\",\n    \"\u67f4\u7530\u304b\u305a\u304d\",\n    \"6-9\",\n    \"chain-swap\",\n    \"\u706b\u66dc6-9\u4e0d\u8db3\u306e\u88dc\u5b8c\"\n   );\n\n   addAssignment(\n    \"\u706b\",\n    \"\u897f\u6751\",\n    \"9-17\",\n    \"\u706b\u66dc\u65e5\u52e4\u306e\u88dc\u5b8c\"\n   );\n\n   replaceAssignment(\n    \"\u91d1\",\n    \"\u5c71\u5d0e\",\n    \"22-9\",\n    \"chain-swap\",\n    \"\u7b39\u5cf6\u3092\u706b\u66dc\u3078\u79fb\u3057\u305f\u5f8c\u306e\u91d1\u66dc\u591c\u52e4\u88dc\u5b8c\"\n   );\n\n   addAssignment(\n    \"\u91d1\",\n    \"\u4e0b\u7530\",\n    \"18-24\",\n    \"\u91d1\u66dc\u5c71\u5d0e\u3092\u591c\u52e4\u3078\u56de\u3057\u305f\u5f8c\u306e\u5915\u52e4\u88dc\u5b8c\"\n   );\n\n   replaceAssignment(\n    \"\u571f\",\n    \"\u5bae\u4e0b \u5e97\u9577\uff08\u5c0f\u5cf6\uff09\",\n    \"6-15\",\n    \"chain-swap\",\n    \"\u5c71\u5d0e\u306e\u91d1\u66dc\u591c\u52e4\u660e\u3051\u91cd\u8907\u3092\u907f\u3051\u308b\u305f\u3081\"\n   );\n\n   replaceAssignment(\n    \"\u571f\",\n    \"\u5c71\u5d0e\",\n    \"17-24\",\n    \"chain-swap\",\n    \"\u91d1\u66dc\u591c\u52e4\u660e\u3051\u306e\u4f11\u606f\u3092\u78ba\u4fdd\u3059\u308b\u305f\u3081\"\n   );\n\n   changed=true;\n  }\n }\n\n return changed;\n}\n\nfunction applyLeaveAndFill(){\n if(!state.generated){\n  setStatus(\"\u5148\u306b\u6a19\u6e96\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u3092\u4f5c\u6210\u3057\u3066\u304f\u3060\u3055\u3044\u3002\",\"ng\");\n  return;\n }\n if(!state.weekStart){\n  setStatus(\"\u5bfe\u8c61\u9031\u304c\u4e0d\u660e\u3067\u3059\u3002\",\"ng\");\n  return;\n }\n\n if(!state.baselineSnapshot?.length){\n  setStatus(\"\u5727\u7e2e\u6e08\u307f\u901a\u5e38\u30b7\u30d5\u30c8\u304c\u3042\u308a\u307e\u305b\u3093\u3002\u6a19\u6e96\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u3092\u518d\u4f5c\u6210\u3057\u3066\u304f\u3060\u3055\u3044\u3002\",\"ng\");\n  return;\n }\n state.assignments=JSON.parse(\n  JSON.stringify(state.baselineSnapshot)\n );\n state.fillLog=[];\n state.compressionLog=[];\n state.compressionSummary={\n  mode:\"baseline-preserved\",\n  runs:0,\n  before:totalQuality(),\n  after:null\n };\n state.leaveRepairLog=[];\n state.leaveRepairSummary=null;\n\n const beforeCount=state.assignments.length;\n const removed=state.assignments.filter(row=>\n  state.leaveRequests.some(req=>\n   req.day===row.day&&\n   req.name===row.name\n  )\n );\n state.assignments=state.assignments.filter(row=>\n  !state.leaveRequests.some(req=>\n   req.day===row.day&&\n   req.name===row.name\n  )\n );\n\n state.chainSwapLog=[];\n applyKnownChainRepairs();\n\n const fillRejected=[];\n days.forEach(dow=>{\n  tryExtendExistingForDay(dow);\n  fillRejected.push(...fillDay(dow));\n });\n\n const preCompression=totalQuality();\n const compressed=compressRepairChangesOnly();\n runAudit();\n renderSchedule();\n\n const leaveReappeared=state.assignments.filter(row=>\n  state.leaveRequests.some(req=>\n   req.day===row.day&&\n   req.name===row.name\n  )\n );\n\n state.leaveRepairSummary={\n  beforeCount,\n  removedCount:removed.length,\n  removed,\n  chainSwapCount:state.chainSwapLog.length,\n  chainSwapLog:state.chainSwapLog,\n  extensionCount:\n   state.leaveRepairLog.filter(\n    row=>row.type===\"extend-existing\"\n   ).length,\n  addedCount:state.fillLog.length,\n  fillRejected,\n  preCompression,\n  postCompression:{\n   shortage:compressed.shortage,\n   surplus:compressed.surplus\n  },\n  unresolvedShortageDetails:\n   days.flatMap(day=>\n    shortageDetailForDay(day)\n   ),\n  leaveReappeared\n };\n\n runAudit();\n renderSchedule();\n renderJson();\n\n if(leaveReappeared.length){\n  setStatus(\n   `\u4f11\u6687\u8005\u304c\u518d\u914d\u7f6e\u3055\u308c\u307e\u3057\u305f: ${leaveReappeared.length}\u4ef6`,\n   \"ng\"\n  );\n  return;\n }\n\n setStatus(\n  state.audit?.pass\n   ? `\u4f11\u6687\u53cd\u6620\u5b8c\u4e86\u3002\u524a\u9664 ${removed.length} / \u518d\u5ef6\u9577 ${state.leaveRepairSummary.extensionCount} / \u65b0\u898f\u88dc\u5145 ${state.fillLog.length}`\n   : `\u4f11\u6687\u53cd\u6620\u5f8c\u306b\u672a\u89e3\u6d88\u9805\u76ee\u304c\u3042\u308a\u307e\u3059\u3002\u4e0d\u8db3 ${state.audit?.shortageCells ?? \"-\"}`,\n  state.audit?.pass?\"ok\":\"ng\"\n );\n}\n\n\nfunction assignmentDateTimes(row){\n const base=new Date(`${row.dateIso}T00:00:00`);\n const parsed=parseRange(row.time);\n const start=new Date(base);\n start.setHours(parsed.start,0,0,0);\n const end=new Date(base);\n end.setHours(parsed.end,0,0,0);\n return {start,end};\n}\n\nfunction restSeverity(restHours){\n if(restHours<0)return \"collision\";\n if(restHours<6)return \"critical\";\n if(restHours<8)return \"high\";\n if(restHours<11)return \"caution\";\n return \"ok\";\n}\n\nfunction safetyWarningKey(row){\n return [\n  row.name,\n  row.previous?.dateIso,\n  row.next?.dateIso\n ].join(\"|\");\n}\n\nfunction buildSafetyDiagnostics(assignments=state.assignments){\n const byPerson={};\n assignments.forEach(row=>{\n  (byPerson[row.name]??=[]).push(row);\n });\n\n const restWarnings=[];\n const collisions=[];\n const consecutiveRows=[];\n\n Object.entries(byPerson).forEach(([name,rows])=>{\n  const ordered=rows\n   .map(row=>({...row,...assignmentDateTimes(row)}))\n   .sort((a,b)=>a.start-b.start);\n\n  for(let i=1;i<ordered.length;i++){\n   const prev=ordered[i-1];\n   const curr=ordered[i];\n   const restHours=(curr.start-prev.end)/36e5;\n   const severity=restSeverity(restHours);\n\n   if(restHours<11){\n    const warning={\n     name,\n     previous:{\n      day:prev.day,\n      dateIso:prev.dateIso,\n      time:prev.time\n     },\n     next:{\n      day:curr.day,\n      dateIso:curr.dateIso,\n      time:curr.time\n     },\n     restHours:Number(restHours.toFixed(1)),\n     thresholdHours:11,\n     severity\n    };\n    restWarnings.push(warning);\n    if(restHours<0){\n     collisions.push(warning);\n    }\n   }\n  }\n\n  const uniqueDates=[...new Set(\n   rows.map(row=>row.dateIso)\n  )].sort();\n\n  let maxConsecutive=uniqueDates.length?1:0;\n  let current=uniqueDates.length?1:0;\n\n  for(let i=1;i<uniqueDates.length;i++){\n   const prev=new Date(`${uniqueDates[i-1]}T00:00:00`);\n   const curr=new Date(`${uniqueDates[i]}T00:00:00`);\n   const diff=(curr-prev)/86400000;\n   if(diff===1){\n    current++;\n    maxConsecutive=Math.max(maxConsecutive,current);\n   }else{\n    current=1;\n   }\n  }\n\n  consecutiveRows.push({\n   name,\n   workDays:uniqueDates.length,\n   maxConsecutiveDays:maxConsecutive,\n   warning:maxConsecutive>=7\n  });\n });\n\n const severityCounts={\n  collision:restWarnings.filter(r=>r.severity===\"collision\").length,\n  critical:restWarnings.filter(r=>r.severity===\"critical\").length,\n  high:restWarnings.filter(r=>r.severity===\"high\").length,\n  caution:restWarnings.filter(r=>r.severity===\"caution\").length\n };\n\n return {\n  advisoryOnly:true,\n  minimumRestHours:11,\n  restWarnings,\n  collisions,\n  severityCounts,\n  consecutiveRows:consecutiveRows.sort(\n   (a,b)=>b.maxConsecutiveDays-a.maxConsecutiveDays\n  ),\n  consecutiveWarnings:consecutiveRows.filter(\n   row=>row.warning\n  )\n };\n}\n\nfunction buildSafetyDelta(assignments=state.assignments){\n const baselineAssignments=buildBaselineAssignments(state.weekStart);\n const baseline=buildSafetyDiagnostics(baselineAssignments);\n const current=buildSafetyDiagnostics(assignments);\n\n const baselineMap=new Map(\n  baseline.restWarnings.map(row=>[safetyWarningKey(row),row])\n );\n const currentMap=new Map(\n  current.restWarnings.map(row=>[safetyWarningKey(row),row])\n );\n\n const introduced=[];\n const resolved=[];\n const modified=[];\n const improved=[];\n const worsened=[];\n\n currentMap.forEach((currentRow,key)=>{\n  const baselineRow=baselineMap.get(key);\n  if(!baselineRow){\n   introduced.push(currentRow);\n   return;\n  }\n  if(currentRow.restHours!==baselineRow.restHours){\n   const change={\n    key,\n    name:currentRow.name,\n    previous:currentRow.previous,\n    next:currentRow.next,\n    beforeRestHours:baselineRow.restHours,\n    afterRestHours:currentRow.restHours,\n    beforeSeverity:baselineRow.severity,\n    afterSeverity:currentRow.severity,\n    deltaHours:Number(\n     (currentRow.restHours-baselineRow.restHours).toFixed(1)\n    )\n   };\n   modified.push(change);\n   if(change.deltaHours>0)improved.push(change);\n   else worsened.push(change);\n  }\n });\n\n baselineMap.forEach((baselineRow,key)=>{\n  if(!currentMap.has(key))resolved.push(baselineRow);\n });\n\n return {\n  baselineWarningCount:baseline.restWarnings.length,\n  currentWarningCount:current.restWarnings.length,\n  introduced,\n  resolved,\n  modified,\n  improved,\n  worsened\n };\n}\n\nfunction assignmentKey(row){\n return `${row.day}|${row.name}|${row.time}`;\n}\n\nfunction scenarioDiffFromBaseline(assignments){\n const base=state.baselineSnapshot?.length\n  ? JSON.parse(JSON.stringify(state.baselineSnapshot))\n  : buildBaselineAssignments(state.weekStart);\n const baseSet=new Set(base.map(assignmentKey));\n const resultSet=new Set(assignments.map(assignmentKey));\n\n return {\n  removed:base.filter(row=>!resultSet.has(assignmentKey(row))),\n  added:assignments.filter(row=>!baseSet.has(assignmentKey(row)))\n };\n}\n\n\nfunction assignmentIdentity(row){\n return `${row.dateIso}|${row.day}|${row.name}|${row.time}`;\n}\nfunction assignmentSlotIdentity(row){\n return `${row.dateIso}|${row.day}|${row.name}`;\n}\nfunction buildStabilityAudit(assignments=state.assignments){\n const baseline=state.baselineSnapshot?.length\n  ? JSON.parse(JSON.stringify(state.baselineSnapshot))\n  : [];\n if(!baseline.length){\n  return {\n   advisoryOnly:true,\n   baselineAvailable:false,\n   removed:[],\n   added:[],\n   approvedChanges:[],\n   unapprovedChanges:[],\n   stabilityPass:false\n  };\n }\n const currentIds=new Set(assignments.map(assignmentIdentity));\n const baselineIds=new Set(baseline.map(assignmentIdentity));\n const removed=baseline.filter(r=>!currentIds.has(assignmentIdentity(r)));\n const added=assignments.filter(r=>!baselineIds.has(assignmentIdentity(r)));\n\n const approvedSlots=new Set();\n state.leaveRequests.forEach(req=>{\n  baseline.filter(r=>r.day===req.day&&r.name===req.name)\n   .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n });\n (state.chainSwapLog||[]).forEach(log=>{\n  if(log.fromDay){\n   baseline.filter(r=>r.day===log.fromDay&&r.name===log.name)\n    .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n  }\n  if(log.toDay){\n   assignments.filter(r=>r.day===log.toDay&&r.name===log.name)\n    .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n  }\n  if(log.day){\n   assignments.filter(r=>r.day===log.day&&r.name===log.name)\n    .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n  }\n });\n [...(state.fillLog||[]),...(state.leaveRepairLog||[])].forEach(log=>{\n  assignments.filter(r=>r.day===log.day&&r.name===log.name)\n   .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n });\n\n (state.compressionLog||[]).forEach(log=>{\n  baseline.filter(r=>r.day===log.day&&r.name===log.name)\n   .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n  assignments.filter(r=>r.day===log.day&&r.name===log.name)\n   .forEach(r=>approvedSlots.add(assignmentSlotIdentity(r)));\n });\n\n const changes=[\n  ...removed.map(row=>({kind:\"removed\",row})),\n  ...added.map(row=>({kind:\"added\",row}))\n ];\n const approvedChanges=changes.filter(\n  item=>approvedSlots.has(assignmentSlotIdentity(item.row))\n );\n const unapprovedChanges=changes.filter(\n  item=>!approvedSlots.has(assignmentSlotIdentity(item.row))\n );\n return {\n  advisoryOnly:true,\n  baselineAvailable:true,\n  baselineAssignmentCount:baseline.length,\n  currentAssignmentCount:assignments.length,\n  removed,\n  added,\n  approvedChanges,\n  unapprovedChanges,\n  stabilityPass:unapprovedChanges.length===0\n };\n}\nfunction renderStability(){\n const a=state.audit?.stabilityAudit;\n const el=$(\"stabilityWrap\");\n if(!el)return;\n if(!a){\n  el.textContent=\"\u672a\u76e3\u67fb\";\n  return;\n }\n el.innerHTML=`\n  <div class=\"metrics\">\n   <div class=\"metric\"><b>${a.approvedChanges.length}</b><span>\u627f\u8a8d\u6e08\u307f\u5909\u66f4</span></div>\n   <div class=\"metric\"><b>${a.unapprovedChanges.length}</b><span>\u60f3\u5b9a\u5916\u5909\u66f4</span></div>\n  </div>\n  <div class=\"status ${a.stabilityPass?\"ok\":\"ng\"}\">\n   ${a.stabilityPass\n    ?\"\u4f11\u6687\u4fee\u5fa9\u4ee5\u5916\u306e\u52dd\u624b\u306a\u5909\u66f4\u306a\u3057\u3002\"\n    :`\u60f3\u5b9a\u5916\u5909\u66f4\u304c ${a.unapprovedChanges.length}\u4ef6 \u3042\u308a\u307e\u3059\u3002`}\n  </div>`;\n}\n\nfunction renderSafety(){\n const safety=state.audit?.safetyDiagnostics;\n const delta=state.audit?.safetyDelta;\n if(!safety||!delta){\n  $(\"safetyWrap\").textContent=\"\u672a\u76e3\u67fb\";\n  return;\n }\n\n const counts=safety.severityCounts||{};\n const introduced=delta.introduced.length;\n const resolved=delta.resolved.length;\n const improved=delta.improved.length;\n const worsened=delta.worsened.length;\n const collisions=safety.collisions.length;\n const consecutive=safety.consecutiveWarnings.length;\n\n $(\"safetyWrap\").innerHTML=`\n  <div class=\"metrics\">\n   <div class=\"metric\">\n    <b>${safety.restWarnings.length}</b>\n    <span>\u73fe\u5728\u306e\u4f11\u606f\u8b66\u544a</span>\n   </div>\n   <div class=\"metric\">\n    <b>${introduced}</b>\n    <span>\u4fee\u5fa9\u3067\u65b0\u898f\u767a\u751f</span>\n   </div>\n   <div class=\"metric\">\n    <b>${resolved}</b>\n    <span>\u4fee\u5fa9\u3067\u89e3\u6d88</span>\n   </div>\n   <div class=\"metric\">\n    <b>${improved}</b>\n    <span>\u4f11\u606f\u6539\u5584</span>\n   </div>\n   <div class=\"metric\">\n    <b>${worsened}</b>\n    <span>\u4f11\u606f\u60aa\u5316</span>\n   </div>\n   <div class=\"metric\">\n    <b>${collisions}</b>\n    <span>\u52e4\u52d9\u885d\u7a81</span>\n   </div>\n  </div>\n  <table>\n   <thead>\n    <tr>\n     <th>\u533a\u5206</th>\n     <th>\u4ef6\u6570</th>\n    </tr>\n   </thead>\n   <tbody>\n    <tr><td>6\u6642\u9593\u672a\u6e80</td><td>${counts.critical??0}</td></tr>\n    <tr><td>6\u301c8\u6642\u9593\u672a\u6e80</td><td>${counts.high??0}</td></tr>\n    <tr><td>8\u301c11\u6642\u9593\u672a\u6e80</td><td>${counts.caution??0}</td></tr>\n    <tr><td>7\u65e5\u4ee5\u4e0a\u9023\u7d9a</td><td>${consecutive}</td></tr>\n   </tbody>\n  </table>\n  <div class=\"status ${\n   collisions||introduced?\"ng\":\"ok\"\n  }\">\n   ${\n    collisions\n     ?\"\u52e4\u52d9\u885d\u7a81\u304c\u3042\u308a\u307e\u3059\u3002\"\n     :introduced||worsened\n      ?`\u65b0\u898f\u8b66\u544a ${introduced}\u4ef6\u3001\u4f11\u606f\u60aa\u5316 ${worsened}\u4ef6\u3002`\n      :\"\u4fee\u5fa9\u306b\u3088\u308b\u65b0\u898f\u30fb\u60aa\u5316\u8b66\u544a\u306a\u3057\u3002\"\n   }\n  </div>\n `;\n}\n\nfunction runAudit(){\n if(!state.generated){setStatus(\"\u5148\u306b\u6a19\u6e96\u30ed\u30fc\u30c6\u30fc\u30b7\u30e7\u30f3\u3092\u4f5c\u6210\u3057\u3066\u304f\u3060\u3055\u3044\u3002\",\"ng\");return null;}\n let shortageCells=0,surplusCells=0;const conditionViolations=[],duplicatePersonDays=[],daily=[];\n days.forEach(dow=>{\n  const rows=state.assignments.filter(r=>r.day===dow),seen=new Set(),cov=new Map();\n  rows.forEach(r=>{if(!allowed(r.name,r.day,r.time))conditionViolations.push(r);if(seen.has(r.name))duplicatePersonDays.push(r);seen.add(r.name);const{start,end}=parseRange(r.time);for(let h=start*2;h<end*2;h++)cov.set(h,(cov.get(h)||0)+1);});\n  let ds=0,dp=0;requiredWindows.forEach(([s,e,req])=>{for(let h=s*2;h<e*2;h++){const got=cov.get(h)||0;ds+=Math.max(0,req-got);dp+=Math.max(0,got-req);}});\n  shortageCells+=ds;surplusCells+=dp;daily.push({day:dow,count:rows.length,shortageCells:ds,surplusCells:dp});\n });\n const workload={};\n state.assignments.forEach(row=>{\n  workload[row.name]??={\n   days:new Set(),\n   spanHours:0,\n   workHours:0,\n   shifts:0\n  };\n  workload[row.name].days.add(row.day);\n  workload[row.name].spanHours+=hours(row.time);\n  workload[row.name].workHours+=paidWorkHours(\n   row.name,\n   row.time\n  );\n  workload[row.name].shifts++;\n });\n const workloadRows=Object.entries(workload).map(\n  ([name,value])=>{\n   const rule=staffRules[name]||{};\n   const maxDays=rule.maxDays??6;\n   const maxHours=rule.maxHours??48;\n   return {\n    name,\n    days:value.days.size,\n    spanHours:value.spanHours,\n    workHours:value.workHours,\n    hours:value.workHours,\n    shifts:value.shifts,\n    maxDays,\n    maxHours,\n    breakHours:\n     value.spanHours-value.workHours,\n    over:\n     value.days.size>maxDays||\n     value.workHours>maxHours\n   };\n  }\n );\n const workloadViolations=workloadRows.filter(r=>r.over);\n const safetyDiagnostics=buildSafetyDiagnostics();\n const safetyDelta=buildSafetyDelta();\n const stabilityAudit=buildStabilityAudit();\n state.stabilityAudit=stabilityAudit;\n const informationalMetrics={\n  assignmentCountWithinReferenceBand:\n   state.assignments.length>=45&&state.assignments.length<=55,\n  referenceAssignmentBand:{min:45,max:55}\n };\n const checks={\n  shortageZero:shortageCells===0,\n  conditionViolationsZero:conditionViolations.length===0,\n  duplicatePersonDaysZero:duplicatePersonDays.length===0,\n  workloadViolationsZero:workloadViolations.length===0,\n  collisionsZero:safetyDiagnostics.collisions.length===0\n };\n const operationalPass=\n  checks.shortageZero&&\n  checks.conditionViolationsZero&&\n  checks.duplicatePersonDaysZero&&\n  checks.workloadViolationsZero&&\n  checks.collisionsZero&&\n  stabilityAudit.stabilityPass&&\n  surplusCells===0&&\n  !(state.leaveRepairSummary?.leaveReappeared?.length);\n const pass=operationalPass;\n state.audit={validatorVersion:\"miyanoshita-standalone-v26\",generatedAt:new Date().toISOString(),weekStart:state.weekStart,store:\"\u5bae\u30ce\u4e0b\",assignmentCount:state.assignments.length,leaveRequests:state.leaveRequests,fillLog:state.fillLog,compressionLog:state.compressionLog,\n compressionSummary:state.compressionSummary,\n leaveRepairLog:state.leaveRepairLog,\n leaveRepairSummary:state.leaveRepairSummary,\n activeScenario:state.activeScenario,\n chainSwapLog:state.chainSwapLog,\n batchScenarioResults:state.batchScenarioResults,\n shortageCells,surplusCells,conditionViolations,duplicatePersonDays,workloadRows,\n workloadViolations,\n workloadPolicy:{\n  capBasis:\"paid-work-hours\",\n  managerBreakRule:\n   \"9\u6642\u9593\u4ee5\u4e0a\u306e\u52e4\u52d9\u306f\u4f11\u61a91\u6642\u9593\u3092\u63a7\u9664\"\n },\n safetyDiagnostics,\n safetyDelta,\n stabilityAudit,\n informationalMetrics,\n validationLevel:\"stable-candidate\",\n passPolicy:{\n  authoritativePassField:\"pass\",\n  passEqualsOperationalPass:true,\n  countWithinBandInformationalOnly:true,\n  saveRequiresOperationalPass:true\n },\n workflowPolicy:{\n  baselineSource:\"compressed-baseline-snapshot\",\n  removeOnlyRequestedLeave:true,\n  globalRecompressionAfterLeave:false,\n  localCompressionAfterRepair:true,\n  localCompressionScope:\"repair-added-or-changed-shifts-only\",\n  localRepairRowRemoval:true,\n  overlapLocalCompression:true,\n  overlapCompressionScope:\"same-day-overlapping-repair-window-only\",\n  repairScope:\"leave-created-holes-only\"\n },\n passCategories:{\n  coveragePass:checks.shortageZero,\n  rulesPass:\n   checks.conditionViolationsZero&&\n   checks.workloadViolationsZero&&\n   checks.collisionsZero,\n  leaveIntegrityPass:\n   !(state.leaveRepairSummary?.leaveReappeared?.length),\n  stabilityPass:stabilityAudit.stabilityPass,\n  surplusPass:surplusCells===0,\n  operationalPass\n },\n checks,\n pass,\n daily,\n assignments:state.assignments\n};\n renderAudit();renderJson();updateMetrics();return state.audit;\n}\n\nfunction renderSchedule(){\n if(!state.generated){$(\"scheduleWrap\").textContent=\"\u672a\u751f\u6210\";return;}\n $(\"scheduleWrap\").innerHTML=`<table><thead><tr>${days.map(d=>`<th>${d}</th>`).join(\"\")}</tr></thead><tbody><tr>${days.map(d=>`<td>${state.assignments.filter(r=>r.day===d).map(r=>`${r.time}\u3000${r.name}${r.source?.includes(\"leave-fill\")?\" <b>\u88dc\u5145</b>\":\"\"}${r.source?.includes(\"compressed\")?\" <b>\u5727\u7e2e</b>\":\"\"}`).join(\"<br>\")}</td>`).join(\"\")}</tr></tbody></table>`;\n}\n\nfunction renderAudit(){\n if(!state.audit){$(\"auditSummary\").textContent=\"\u672a\u76e3\u67fb\";return;}\n const a=state.audit;$(\"auditSummary\").className=`status ${a.pass?\"ok\":\"ng\"}`;$(\"auditSummary\").textContent=`${a.pass?\"PASS\":\"FAIL\"}\\n\u914d\u7f6e ${a.assignmentCount} / \u4e0d\u8db3 ${a.shortageCells} / \u4f59\u5270 ${a.surplusCells} / \u6761\u4ef6\u9055\u53cd ${a.conditionViolations.length} / \u52e4\u52d9\u8d85\u904e ${a.workloadViolations.length}`;\n $(\"auditTableWrap\").innerHTML=`<table><thead><tr><th>\u66dc\u65e5</th><th>\u4ef6\u6570</th><th>\u4e0d\u8db3</th><th>\u4f59\u5270</th><th>\u5224\u5b9a</th></tr></thead><tbody>${a.daily.map(r=>`<tr><td>${r.day}</td><td>${r.count}</td><td>${r.shortageCells}</td><td>${r.surplusCells}</td><td><span class=\"badge ${r.shortageCells===0?\"ok\":\"ng\"}\">${r.shortageCells===0?\"OK\":\"\u4e0d\u8db3\"}</span></td></tr>`).join(\"\")}</tbody></table>`;\n $(\"workloadWrap\").innerHTML=`<table><thead><tr><th>\u6c0f\u540d</th><th>\u52e4\u52d9\u65e5\u6570</th><th>\u4e0a\u9650</th><th>\u62d8\u675f</th><th>\u4f11\u61a9</th><th>\u5b9f\u50cd</th><th>\u4e0a\u9650</th><th>\u30b7\u30d5\u30c8\u6570</th><th>\u5224\u5b9a</th></tr></thead><tbody>${a.workloadRows.sort((x,y)=>y.workHours-x.workHours).map(r=>`<tr><td>${r.name}</td><td>${r.days}</td><td>${r.maxDays}</td><td>${r.spanHours}</td><td>${r.breakHours}</td><td>${r.workHours}</td><td>${r.maxHours}</td><td>${r.shifts}</td><td><span class=\"badge ${r.over?\"ng\":\"ok\"}\">${r.over?\"\u8d85\u904e\":\"OK\"}</span></td></tr>`).join(\"\")}</tbody></table>`;\n}\n\nfunction renderLeaveList(){\n if(!state.leaveRequests.length){$(\"leaveList\").textContent=\"\u767b\u9332\u306a\u3057\";return;}\n $(\"leaveList\").innerHTML=state.leaveRequests.map((r,i)=>`<div class=\"leave-item\"><span>${r.day}\u3000${r.name}</span><button class=\"action danger remove-leave\" data-index=\"${i}\">\u524a\u9664</button></div>`).join(\"\");\n document.querySelectorAll(\".remove-leave\").forEach(b=>b.addEventListener(\"click\",()=>{state.leaveRequests.splice(Number(b.dataset.index),1);renderLeaveList();}));\n}\n\nfunction renderStaff(){$(\"staffList\").innerHTML=Object.entries(staffRules).map(([n,r])=>`<div class=\"row\"><strong>${n}</strong><div>${r.note}</div></div>`).join(\"\");}\nfunction renderJson(){$(\"jsonOutput\").textContent=JSON.stringify(state.audit||{},null,2);}\nfunction updateMetrics(){$(\"mCount\").textContent=state.assignments.length;$(\"mShortage\").textContent=state.audit?state.audit.shortageCells:\"-\";$(\"mViolation\").textContent=state.audit?state.audit.conditionViolations.length:\"-\";$(\"mWorkload\").textContent=state.audit?state.audit.workloadViolations.length:\"-\";$(\"mPass\").textContent=state.audit?(state.audit.pass?\"PASS\":\"FAIL\"):\"-\";}\nfunction clearAll(){state={\n generated:false,\n weekStart:null,\n assignments:[],\n leaveRequests:[],\n audit:null,\n fillLog:[],\n compressionLog:[],\n compressionSummary:null,\n leaveRepairLog:[],\n leaveRepairSummary:null,\n activeScenario:null,\n chainSwapLog:[],\n batchScenarioResults:[]\n};renderSchedule();\n renderBatchResults();\n $(\"scenarioBanner\").className=\"status\";\n $(\"scenarioBanner\").textContent=\"\u30b7\u30ca\u30ea\u30aa\u672a\u5b9f\u884c\";renderLeaveList();$(\"auditSummary\").textContent=\"\u672a\u76e3\u67fb\";$(\"auditTableWrap\").textContent=\"\u672a\u76e3\u67fb\";$(\"workloadWrap\").textContent=\"\u672a\u76e3\u67fb\";$(\"jsonOutput\").textContent=\"{}\";updateMetrics();setStatus(\"\u30af\u30ea\u30a2\u3057\u307e\u3057\u305f\u3002\");}\nfunction saveJson(){\n if(!state.audit?.passCategories?.operationalPass){\n  setStatus(\"\u4fdd\u5b58\u4e0d\u53ef\uff1aoperationalPass \u304c\u6210\u7acb\u3057\u3066\u3044\u307e\u305b\u3093\u3002\",\"ng\");\n  return;\n }\n if(!state.audit){\n  setStatus(\"\u4fdd\u5b58\u3059\u308b\u76e3\u67fb\u7d50\u679c\u304c\u3042\u308a\u307e\u305b\u3093\u3002\",\"ng\");\n  return;\n }\n if(state.leaveRepairSummary && !state.activeScenario && state.leaveRequests.length===0){\n  setStatus(\"\u901a\u5e38\u751f\u6210\u7d50\u679c\u3067\u3059\u3002\u30b7\u30ca\u30ea\u30aa\u8a66\u9a13\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\",\"ng\");\n }\nconst blob=new Blob([JSON.stringify(state.audit,null,2)],{type:\"application/json;charset=utf-8\"}),url=URL.createObjectURL(blob),a=document.createElement(\"a\");a.href=url;a.download=`makotsu-shift-miyanoshita-v26-${state.weekStart}.json`;document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(url),1000);setStatus(\"JSON\u3092\u4fdd\u5b58\u3057\u307e\u3057\u305f\u3002\",\"ok\");}\nasync function copyJson(){if(!state.audit)return;try{await navigator.clipboard.writeText(JSON.stringify(state.audit,null,2));setStatus(\"JSON\u3092\u30b3\u30d4\u30fc\u3057\u307e\u3057\u305f\u3002\",\"ok\");}catch{setStatus(\"\u30b3\u30d4\u30fc\u3067\u304d\u307e\u305b\u3093\u3067\u3057\u305f\u3002\",\"ng\");}}\n\n\nconst testScenarios={\n light:{\n  label:\"\u8efd\u30c6\u30b9\u30c8\",\n  leaves:[\n   {day:\"\u91d1\",name:\"\u897f\u6751\"}\n  ]\n },\n medium:{\n  label:\"\u4e2d\u30c6\u30b9\u30c8\",\n  leaves:[\n   {day:\"\u6708\",name:\"\u7b39\u5cf6\"},\n   {day:\"\u91d1\",name:\"\u897f\u6751\"}\n  ]\n },\n heavy:{\n  label:\"\u91cd\u30c6\u30b9\u30c8\",\n  leaves:[\n   {day:\"\u6708\",name:\"\u7b39\u5cf6\"},\n   {day:\"\u706b\",name:\"\u677e\u672c\"},\n   {day:\"\u91d1\",name:\"\u897f\u6751\"},\n   {day:\"\u65e5\",name:\"\u5c71\u5d0e\"}\n  ]\n }\n};\n\nfunction runTestScenario(key){\n const scenario=testScenarios[key];\n if(!scenario)return;\n\n if(!state.generated){\n  generateBaseline();\n }\n state.activeScenario={\n  key,\n  label:scenario.label,\n  leaves:scenario.leaves.map(row=>({...row})),\n  executedAt:new Date().toISOString()\n };\n state.leaveRequests=scenario.leaves.map(row=>({...row}));\n renderLeaveList();\n applyLeaveAndFill();\n showPage(\"generate\");\n $(\"scenarioBanner\").className=`status ${state.audit?.pass?\"ok\":\"ng\"}`;\n $(\"scenarioBanner\").textContent=\n  `${scenario.label} \u5b9f\u884c\u6e08\u307f / \u4f11\u6687 ${state.leaveRequests.length}\u4ef6 / `+\n  `${state.audit?.pass?\"PASS\":\"FAIL\"}`;\n\n const summary=state.leaveRepairSummary;\n const pass=Boolean(state.audit?.pass);\n setStatus(\n  `${scenario.label}: ${pass?\"PASS\":\"FAIL\"}\\n`+\n  `\u4f11\u6687 ${state.leaveRequests.length} / \u524a\u9664 ${summary?.removedCount??0} / `+\n  `\u9023\u9396 ${summary?.chainSwapCount??0} / \u518d\u5ef6\u9577 ${summary?.extensionCount??0} / `+\n  `\u65b0\u898f\u88dc\u5145 ${summary?.addedCount??0} / `+\n  `\u4e0d\u8db3 ${state.audit?.shortageCells??\"-\"} / \u8d85\u904e ${state.audit?.workloadViolations?.length??\"-\"}`,\n  pass?\"ok\":\"ng\"\n );\n}\n\n\nfunction renderBatchResults(){\n if(!state.batchScenarioResults.length){\n  $(\"batchResultWrap\").textContent=\"\u672a\u5b9f\u884c\";\n  return;\n }\n $(\"batchResultWrap\").innerHTML=`\n  <table>\n   <thead>\n    <tr>\n     <th>\u30b7\u30ca\u30ea\u30aa</th>\n     <th>\u4f11\u6687</th>\n     <th>\u524a\u9664</th>\n     <th>\u9023\u9396</th>\n     <th>\u88dc\u5145</th>\n     <th>\u4e0d\u8db3</th>\n     <th>\u4f59\u5270</th>\n     <th>\u8d85\u904e</th>\n     <th>\u60f3\u5b9a\u5916\u5909\u66f4</th>\n     <th>\u4f11\u606f\u8b66\u544a</th>\n     <th>\u65b0\u898f\u8b66\u544a</th>\n     <th>\u6539\u5584</th>\n     <th>\u60aa\u5316</th>\n     <th>\u885d\u7a81</th>\n     <th>\u9023\u52e4\u8b66\u544a</th>\n     <th>\u5224\u5b9a</th>\n    </tr>\n   </thead>\n   <tbody>\n    ${state.batchScenarioResults.map(row=>`\n     <tr>\n      <td>${row.label}</td>\n      <td>${row.leaveCount}</td>\n      <td>${row.removedCount}</td>\n      <td>${row.chainSwapCount}</td>\n      <td>${row.addedCount}</td>\n      <td>${row.shortageCells}</td>\n      <td>${row.surplusCells}</td>\n      <td>${row.workloadViolations}</td>\n      <td>${row.stabilitySummary?.unapprovedChanges??0}</td>\n      <td>${row.safetySummary?.restWarnings??0}</td>\n      <td>${row.safetySummary?.introducedWarnings??0}</td>\n      <td>${row.safetySummary?.improvedWarnings??0}</td>\n      <td>${row.safetySummary?.worsenedWarnings??0}</td>\n      <td>${row.safetySummary?.collisions??0}</td>\n      <td>${row.safetySummary?.consecutiveWarnings??0}</td>\n      <td>\n       <span class=\"badge ${row.pass?\"ok\":\"ng\"}\">\n        ${row.pass?\"PASS\":\"FAIL\"}\n       </span>\n      </td>\n     </tr>\n    `).join(\"\")}\n   </tbody>\n  </table>`;\n}\n\nfunction executeScenarioForBatch(key){\n const scenario=testScenarios[key];\n state.activeScenario={\n  key,\n  label:scenario.label,\n  leaves:scenario.leaves.map(row=>({...row})),\n  executedAt:new Date().toISOString(),\n  batch:true\n };\n state.leaveRequests=scenario.leaves.map(row=>({...row}));\n applyLeaveAndFill();\n\n return {\n  key,\n  label:scenario.label,\n  leaveCount:state.leaveRequests.length,\n  removedCount:\n   state.leaveRepairSummary?.removedCount??0,\n  chainSwapCount:\n   state.leaveRepairSummary?.chainSwapCount??0,\n  extensionCount:\n   state.leaveRepairSummary?.extensionCount??0,\n  addedCount:\n   state.leaveRepairSummary?.addedCount??0,\n  shortageCells:state.audit?.shortageCells??999,\n  surplusCells:state.audit?.surplusCells??999,\n  conditionViolations:\n   state.audit?.conditionViolations?.length??999,\n  duplicatePersonDays:\n   state.audit?.duplicatePersonDays?.length??999,\n  workloadViolations:\n   state.audit?.workloadViolations?.length??999,\n  pass:Boolean(state.audit?.pass),\n  unresolvedShortageDetails:\n   state.leaveRepairSummary?.unresolvedShortageDetails??[],\n  fillRejected:\n   state.leaveRepairSummary?.fillRejected??[],\n  changeDiff:scenarioDiffFromBaseline(\n   state.assignments\n  ),\n  compressionSummary:{\n   mode:state.compressionSummary?.mode??null,\n   runs:state.compressionSummary?.runs??0,\n   beforeSurplus:\n    state.compressionSummary?.before?.surplus??null,\n   afterSurplus:\n    state.compressionSummary?.after?.surplus??null,\n   removedRows:\n    state.compressionSummary?.removedRows??0,\n   trimmedRows:\n    state.compressionSummary?.trimmedRows??0\n  },\n  stabilitySummary:{\n   approvedChanges:\n    state.audit?.stabilityAudit?.approvedChanges?.length??0,\n   unapprovedChanges:\n    state.audit?.stabilityAudit?.unapprovedChanges?.length??0,\n   stabilityPass:\n    state.audit?.stabilityAudit?.stabilityPass??false\n  },\n  safetySummary:{\n   restWarnings:\n    state.audit?.safetyDiagnostics?.restWarnings?.length??0,\n   introducedWarnings:\n    state.audit?.safetyDelta?.introduced?.length??0,\n   resolvedWarnings:\n    state.audit?.safetyDelta?.resolved?.length??0,\n   improvedWarnings:\n    state.audit?.safetyDelta?.improved?.length??0,\n   worsenedWarnings:\n    state.audit?.safetyDelta?.worsened?.length??0,\n   collisions:\n    state.audit?.safetyDiagnostics?.collisions?.length??0,\n   consecutiveWarnings:\n    state.audit?.safetyDiagnostics?.consecutiveWarnings?.length??0\n  }\n };\n}\n\nfunction runBatchScenarioTest(){\n if(!state.generated){\n  generateBaseline();\n }\n const results=[];\n for(const key of [\"light\",\"medium\",\"heavy\"]){\n  results.push(executeScenarioForBatch(key));\n }\n\n state.batchScenarioResults=results;\n\n // \u6700\u7d42\u8868\u793a\u306f\u4e2d\u30c6\u30b9\u30c8\u3078\u623b\u3059\n const medium=testScenarios.medium;\n state.activeScenario={\n  key:\"medium\",\n  label:medium.label,\n  leaves:medium.leaves.map(row=>({...row})),\n  executedAt:new Date().toISOString(),\n  restoredAfterBatch:true\n };\n state.leaveRequests=medium.leaves.map(row=>({...row}));\n applyLeaveAndFill();\n\n state.batchScenarioResults=results;\n runAudit();\n renderSchedule();\n renderJson();\n renderBatchResults();\n showPage(\"generate\");\n\n const passCount=results.filter(row=>row.pass).length;\n $(\"scenarioBanner\").className=\n  `status ${passCount===results.length?\"ok\":\"ng\"}`;\n $(\"scenarioBanner\").textContent=\n  `\u5168\u30b7\u30ca\u30ea\u30aa\u4e00\u62ec\u691c\u8a3c: ${passCount}/${results.length} PASS`;\n setStatus(\n  `\u4e00\u62ec\u691c\u8a3c\u5b8c\u4e86\u3002\u8efd\u30fb\u4e2d\u30fb\u91cd\u306e\u3046\u3061 ${passCount}/${results.length} PASS`,\n  passCount===results.length?\"ok\":\"ng\"\n );\n}\n\nfunction bind(){\n document.querySelectorAll(\".nav-btn\").forEach(b=>b.addEventListener(\"click\",()=>showPage(b.dataset.page)));\n $(\"generateBtn\").addEventListener(\"click\",generateBaseline);$(\"applyLeaveBtn\").addEventListener(\"click\",applyLeaveAndFill);$(\"auditBtnTop\").addEventListener(\"click\",runAudit);$(\"clearBtn\").addEventListener(\"click\",clearAll);$(\"saveBtn\").addEventListener(\"click\",saveJson);$(\"saveBtn2\").addEventListener(\"click\",saveJson);$(\"copyBtn\").addEventListener(\"click\",copyJson);$(\"addLeaveBtn\").addEventListener(\"click\",addLeave);\n $(\"clearLeaveBtn\").addEventListener(\"click\",()=>{\n  state.leaveRequests=[];\n  renderLeaveList();\n });\n $(\"testLightBtn\").addEventListener(\"click\",()=>runTestScenario(\"light\"));\n $(\"testMediumBtn\").addEventListener(\"click\",()=>runTestScenario(\"medium\"));\n $(\"testHeavyBtn\").addEventListener(\"click\",()=>runTestScenario(\"heavy\"));\n $(\"mainLightBtn\").addEventListener(\"click\",()=>runTestScenario(\"light\"));\n $(\"mainMediumBtn\").addEventListener(\"click\",()=>runTestScenario(\"medium\"));\n $(\"mainHeavyBtn\").addEventListener(\"click\",()=>runTestScenario(\"heavy\"));\n $(\"mainBatchBtn\").addEventListener(\"click\",runBatchScenarioTest);\n}\n\n$(\"leaveDay\").innerHTML=days.map(d=>`<option>${d}</option>`).join(\"\");\n$(\"leaveName\").innerHTML=Object.keys(staffRules).map(n=>`<option>${n}</option>`).join(\"\");\nrenderStaff();\nrenderLeaveList();\nrenderBatchResults();\nupdateMetrics();\nbind();\n\nreturn {\n  setWeek(value){\n    const el=document.getElementById(\"weekStart\");\n    if(el){\n      el.value=value;\n      el.dispatchEvent(new Event(\"input\",{bubbles:true}));\n      el.dispatchEvent(new Event(\"change\",{bubbles:true}));\n    }\n    state.weekStart=value;\n  },\n  generateAndValidate(){\n    generateBaseline();\n    runBatchScenarioTest();\n    return JSON.parse(JSON.stringify({\n      validatorVersion:state.audit?.validatorVersion||\"miyanoshita-standalone-v26\",\n      assignments:state.assignments||[],\n      audit:state.audit||null,\n      batchScenarioResults:state.batchScenarioResults||[],\n      activeScenario:state.activeScenario||null\n    }));\n  },\n  resolveExternalCollisions(collisions){\n    const dayByIso=new Map(\n      (state.baselineSnapshot||state.assignments||[]).map(\n        row=>[row.dateIso,row.day]\n      )\n    );\n\n    const addedLeaves=[];\n    (collisions||[]).forEach(collision=>{\n      const day=dayByIso.get(collision.dateIso);\n      if(!day||!collision.name)return;\n\n      const exists=state.leaveRequests.some(\n        row=>row.day===day&&row.name===collision.name\n      );\n\n      if(!exists){\n        state.leaveRequests.push({\n          day,\n          name:collision.name,\n          source:\"cross-store-collision\"\n        });\n        addedLeaves.push({\n          day,\n          dateIso:collision.dateIso,\n          name:collision.name\n        });\n      }\n    });\n\n    if(addedLeaves.length){\n      applyLeaveAndFill();\n    }else{\n      runAudit();\n    }\n\n    return JSON.parse(JSON.stringify({\n      addedLeaves,\n      assignments:state.assignments||[],\n      audit:state.audit||null,\n      leaveRequests:state.leaveRequests||[],\n      leaveRepairSummary:state.leaveRepairSummary||null\n    }));\n  },\n  getSnapshot(){\n    return JSON.parse(JSON.stringify({\n      assignments:state.assignments||[],\n      audit:state.audit||null,\n      batchScenarioResults:state.batchScenarioResults||[],\n      activeScenario:state.activeScenario||null\n    }));\n  }\n};\n\n})();";

let nativeMiyApi=null;
let nativeFusionAudit=null;
let nativeFusionStability=null;
let lastBaseResults=null;

function mountMiyanoshitaEngine(){
  const host=document.getElementById("nativeMiyRuntimeHost");
  if(host.shadowRoot && nativeMiyApi) return nativeMiyApi;

  const root=host.attachShadow({mode:"open"});
  root.innerHTML="<style>"+MIY_STYLES+"</style>"+MIY_BODY;

  const docProxy={
    getElementById:id=>root.getElementById(id),
    querySelector:selector=>root.querySelector(selector),
    querySelectorAll:selector=>root.querySelectorAll(selector),
    createElement:tag=>document.createElement(tag),
    body:root,
    documentElement:root,
    addEventListener:(...args)=>document.addEventListener(...args),
    removeEventListener:(...args)=>document.removeEventListener(...args)
  };

  const factory=new Function("document","window",MIY_FACTORY_SOURCE);
  nativeMiyApi=factory(docProxy,window);

  if(
    !nativeMiyApi ||
    typeof nativeMiyApi.setWeek!=="function" ||
    typeof nativeMiyApi.generateAndValidate!=="function" ||
    typeof nativeMiyApi.resolveExternalCollisions!=="function"
  ){
    throw new Error("宮ノ下v26 APIの初期化に失敗しました");
  }

  return nativeMiyApi;
}

function setBaseWeek(week){
  [
    "workflowWeekStart",
    "validationWeekStart",
    "rieWeekStart",
    "paperWeekStart",
    "finishedWeekStart"
  ].forEach(id=>{
    const el=document.getElementById(id);
    if(el){
      el.value=week;
      el.dispatchEvent(new Event("input",{bubbles:true}));
      el.dispatchEvent(new Event("change",{bubbles:true}));
    }
  });
}

function parseRange(time){
  const parts=String(time||"").split("-").map(Number);
  if(parts.length!==2||parts.some(v=>!Number.isFinite(v))) return null;
  let [start,end]=parts;
  if(end<=start) end+=24;
  return {start,end};
}

function rangesOverlap(a,b){
  const ra=parseRange(a.time);
  const rb=parseRange(b.time);
  if(!ra||!rb) return false;
  return Math.max(ra.start,rb.start)<Math.min(ra.end,rb.end);
}

function crossStoreCollisions(stores){
  const rows=[];
  stores.forEach(store=>{
    (store.assignments||[]).forEach(row=>rows.push({
      ...row,
      storeKey:store.storeKey,
      storeName:store.storeName
    }));
  });

  const collisions=[];
  for(let i=0;i<rows.length;i++){
    for(let j=i+1;j<rows.length;j++){
      const a=rows[i],b=rows[j];
      if(
        a.storeKey!==b.storeKey &&
        a.name===b.name &&
        a.dateIso===b.dateIso &&
        rangesOverlap(a,b)
      ){
        collisions.push({
          name:a.name,
          dateIso:a.dateIso,
          first:{store:a.storeName,time:a.time},
          second:{store:b.storeName,time:b.time}
        });
      }
    }
  }
  return collisions;
}


function buildMiyStore(miyResult){
  const miyAudit=miyResult?.audit||null;
  return {
    storeKey:"miyanoshita",
    storeName:"宮ノ下",
    assignments:miyResult?.assignments||[],
    shortageCells:miyAudit?.shortageCells??null,
    surplusCells:miyAudit?.surplusCells??null,
    pass:miyAudit?.passCategories?.operationalPass===true,
    validationStatus:miyAudit?.validationLevel||null,
    audit:miyAudit
  };
}



function collisionBaseStoreKey(collision){
  const first=collision?.first?.store;
  const second=collision?.second?.store;
  if(first==="東町")return "higashicho";
  if(first==="扇町")return "ougicho";
  if(second==="東町")return "higashicho";
  if(second==="扇町")return "ougicho";
  return null;
}

function collisionKey(name,dateIso){
  return canonicalStaffName(name)+"|"+dateIso;
}

function installHardUnavailableHook(blockedPairs){
  const original=isUnavailable;
  const blocked=new Set(
    (blockedPairs||[]).map(row=>
      collisionKey(row.name,row.dateIso)
    )
  );

  isUnavailable=function(personName,dateIso){
    if(blocked.has(collisionKey(personName,dateIso))){
      return true;
    }
    return original(personName,dateIso);
  };

  return function restore(){
    isUnavailable=original;
  };
}

async function rerunBaseStoresForCollisions(
  week,
  currentRows,
  miyStore,
  initialCollisions
){
  let rows=[...currentRows];
  let collisions=[...(initialCollisions||[])];
  const repairLog=[];
  const accumulatedBlocked=new Map();

  for(let attempt=1;attempt<=3;attempt++){
    if(!collisions.length)break;

    const affectedStores=new Set();
    const blocked=[];

    collisions.forEach(collision=>{
      const storeKey=collisionBaseStoreKey(collision);
      if(!storeKey)return;

      affectedStores.add(storeKey);

      const item={
        storeKey,
        name:collision.name,
        dateIso:collision.dateIso
      };
      accumulatedBlocked.set(
        storeKey+"|"+collisionKey(item.name,item.dateIso),
        item
      );
    });

    blocked.push(...accumulatedBlocked.values());

    if(!affectedStores.size)break;

    const restoreHook=installHardUnavailableHook(blocked);

    try{
      const snapshot=serializeState();
      const rerunResults=
        await validationNoMasterGenerationFromSnapshot(
          snapshot,
          week,
          [...affectedStores],
          null
        );

      if(!Array.isArray(rerunResults)){
        throw new Error("母艦側の再生成結果を取得できません");
      }

      rerunResults.forEach(result=>{
        const index=rows.findIndex(
          row=>row.storeKey===result.storeKey
        );
        if(index>=0)rows[index]=result;
        else rows.push(result);
      });

      const normalized=rows.map(normalizeBaseResult);
      collisions=crossStoreCollisions([
        ...normalized,
        miyStore
      ]);

      const blockedStillAssigned=[];
      rerunResults.forEach(result=>{
        const assignments=result.releaseAudit?.assignments||[];
        blocked.forEach(item=>{
          if(
            item.storeKey===result.storeKey &&
            assignments.some(row=>
              row.name===item.name &&
              row.dateIso===item.dateIso
            )
          ){
            blockedStillAssigned.push(item);
          }
        });
      });

      repairLog.push({
        attempt,
        affectedStores:[...affectedStores],
        hardUnavailable:blocked,
        hookApplied:true,
        blockedStillAssigned,
        rerunResults:rerunResults.map(result=>({
          storeKey:result.storeKey,
          appCount:result.appCount,
          shortageCells:
            result.noMasterQuality?.shortageCells??null,
          surplusCells:
            result.noMasterQuality?.surplusCells??null,
          pass:result.releaseAudit?.pass===true
        })),
        remainingCollisions:collisions
      });

      if(blockedStillAssigned.length){
        throw new Error(
          "候補除外フック後も対象者が再配置されました: "+
          blockedStillAssigned.map(row=>
            `${row.storeKey}:${row.name}:${row.dateIso}`
          ).join(", ")
        );
      }
    }finally{
      restoreHook();
    }
  }

  return {
    rows,
    collisions,
    repairLog
  };
}

function normalizeBaseResult(row){
  return {
    storeKey:row.storeKey,
    storeName:row.storeName,
    assignments:row.releaseAudit?.assignments||[],
    shortageCells:row.noMasterQuality?.shortageCells??null,
    surplusCells:row.noMasterQuality?.surplusCells??null,
    pass:row.releaseAudit?.pass===true,
    validationStatus:row.validationStatus,
    releaseAudit:row.releaseAudit
  };
}

function renderFusionSummary(audit){
  const byKey=Object.fromEntries(audit.stores.map(s=>[s.storeKey,s]));
  const east=byKey.higashicho;
  const ougi=byKey.ougicho;
  const miy=byKey.miyanoshita;

  document.getElementById("fusionEast").textContent=
    `東町：${east?.assignmentCount??0}件 / ${east?.pass?"PASS":"FAIL"}`;
  document.getElementById("fusionOugi").textContent=
    `扇町：${ougi?.assignmentCount??0}件 / ${ougi?.pass?"PASS":"FAIL"}`;
  document.getElementById("fusionMiy").textContent=
    `宮ノ下：${miy?.assignmentCount??0}件 / ${miy?.pass?"PASS":"FAIL"}`;
  document.getElementById("fusionAll").textContent=
    `総合：${audit.combinedPass?"PASS":"FAIL"}`;

  document.getElementById("nativeFusionStatus").textContent=
    `不足 東${east?.shortageCells??"-"} / 扇${ougi?.shortageCells??"-"} / 宮${miy?.shortageCells??"-"}`
    + `｜余剰 東${east?.surplusCells??"-"} / 扇${ougi?.surplusCells??"-"} / 宮${miy?.surplusCells??"-"}`
    + `｜店舗間重複 ${audit.crossStoreCollisions.length}件`;
}




function ensureFmtDate(){
  if(typeof window.fmtDate!=="function"){
    window.fmtDate=function(value){
      try{
        const d=value instanceof Date?value:new Date(value);
        if(Number.isNaN(d.getTime())) return String(value??"");
        const y=d.getFullYear();
        const m=String(d.getMonth()+1).padStart(2,"0");
        const day=String(d.getDate()).padStart(2,"0");
        return y+"/"+m+"/"+day;
      }catch(error){
        return String(value??"");
      }
    };
  }

  try{
    if(typeof fmtDate==="undefined"){
      window.eval("var fmtDate = window.fmtDate;");
    }
  }catch(error){
    console.warn("fmtDate runtime alias failed",error);
  }

  return typeof window.fmtDate==="function";
}

function removeLegacyValidationSystem(){
  const legacyBox=document.getElementById("autoValidationBox");
  if(legacyBox){
    legacyBox.remove();
  }

  const legacyIds=[
    "runSavedValidationCurrentBtn",
    "runSavedValidationJsonBtn",
    "runSavedRepairPreviewCurrentBtn",
    "runNoMasterGenerationJsonBtn",
    "runNoMasterGenerationCurrentBtn",
    "runSavedRepairPreviewJsonBtn",
    "runValidationCurrentBtn",
    "runValidationJsonBtn",
    "copyValidationResultBtn",
    "saveValidationResultBtn",
    "validationOutput",
    "validationExportStatus",
    "validationWeekStart",
    "validationStore",
    "validationRestoreMode"
  ];

  legacyIds.forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.remove();
  });

  try{
    window.__nativeOriginalRunNoMasterWishGeneration=
      window.__nativeOriginalRunNoMasterWishGeneration||
      window.runNoMasterWishGeneration;

    window.runNoMasterWishGeneration=async function(){
      throw new Error(
        "旧37.04自動検証は撤去済みです。上部の三店舗専用ボタンを使用してください。"
      );
    };
  }catch(error){
    console.warn("legacy runner guard failed",error);
  }

  try{
    window.__nativeOriginalSaveValidationResult=
      window.__nativeOriginalSaveValidationResult||
      window.saveValidationResult;

    window.saveValidationResult=function(){
      throw new Error(
        "旧37.04検証JSON保存は撤去済みです。三店舗総合監査JSONを使用してください。"
      );
    };
  }catch(error){
    console.warn("legacy save guard failed",error);
  }

  window.__nativeFusionLegacyRemoval={
    applied:true,
    autoValidationBoxRemoved:
      !document.getElementById("autoValidationBox"),
    legacyRunnerBlocked:
      typeof window.runNoMasterWishGeneration==="function",
    legacySaveBlocked:
      typeof window.saveValidationResult==="function",
    appliedAt:new Date().toISOString()
  };
}

function lockBaseToEastAndOugi(){
  if(typeof validationTargetStoreKeys==="function"){
    window.__nativeOriginalValidationTargetStoreKeys=
      window.__nativeOriginalValidationTargetStoreKeys||
      validationTargetStoreKeys;

    validationTargetStoreKeys=function(value){
      if(value==="higashicho") return ["higashicho"];
      if(value==="ougicho") return ["ougicho"];
      return ["higashicho","ougicho"];
    };
  }


  [
    "runNoMasterGenerationJsonBtn",
    "runNoMasterGenerationCurrentBtn",
    "runValidationCurrentBtn",
    "runValidationJsonBtn",
    "runSavedValidationCurrentBtn",
    "runSavedValidationJsonBtn",
    "runSavedRepairPreviewCurrentBtn",
    "runSavedRepairPreviewJsonBtn",
    "copyValidationResultBtn",
    "saveValidationResultBtn",
    "releaseDirectRunButton",
    "releaseSaveButton"
  ].forEach(id=>{
    const el=document.getElementById(id);
    if(el){
      el.disabled=true;
      el.style.display="none";
      el.setAttribute("aria-hidden","true");
    }
  });

  window.__nativeFusionBaseLock={
    applied:true,
    stores:["higashicho","ougicho"],
    legacyValidationUiHidden:true,
    appliedAt:new Date().toISOString()
  };
}

async function runNativeFusion(options={}){
  const runButton=document.getElementById("nativeFusionRun");
  const downloadButton=document.getElementById("nativeFusionDownload");
  const diagnosticButton=document.getElementById("nativeFusionDiagnostic");
  const csvButton=document.getElementById("nativeFusionCsv");
  const week=document.getElementById("nativeFusionWeek").value;

  runButton.disabled=true;
  downloadButton.disabled=true;
  diagnosticButton.disabled=true;
  csvButton.disabled=true;
  document.body.classList.add("native-fusion-running");
  document.getElementById("nativeFusionStatus").textContent="東町・扇町を生成中…";

  try{
    ensureFmtDate();
    // Legacy 37.04 validation UI and export path are physically removed.
    removeLegacyValidationSystem();
    lockBaseToEastAndOugi();
    setBaseWeek(week);
    const snapshot=serializeState();

    const baseDocument=await validationNoMasterGenerationFromSnapshot(
      snapshot,
      week,
      ["higashicho","ougicho"],
      null
    );

    if(!Array.isArray(baseDocument)){
      throw new Error("東町・扇町の生成結果配列を取得できません");
    }

    lastBaseResults=baseDocument;
    const eastRow=baseDocument.find(r=>r.storeKey==="higashicho");
    const ougiRow=baseDocument.find(r=>r.storeKey==="ougicho");
    if(!eastRow||!ougiRow){
      throw new Error("東町・扇町の生成結果が揃っていません");
    }

    document.getElementById("nativeFusionStatus").textContent="宮ノ下v26を準備中…";
    await new Promise(resolve=>setTimeout(resolve,50));
    const miyApi=mountMiyanoshitaEngine();
    await new Promise(resolve=>setTimeout(resolve,50));
    document.getElementById("nativeFusionStatus").textContent="宮ノ下v26を生成・検証中…";
    miyApi.setWeek(week);

    const miyResult=await Promise.race([
      Promise.resolve().then(()=>miyApi.generateAndValidate()),
      new Promise((_,reject)=>setTimeout(
        ()=>reject(new Error("宮ノ下処理が60秒を超えました")),
        60000
      ))
    ]);

    let baseRows=[eastRow,ougiRow];
    let east=normalizeBaseResult(eastRow);
    let ougi=normalizeBaseResult(ougiRow);
    const finalMiyResult=miyResult;
    const miyStore=buildMiyStore(finalMiyResult);
    const miyAudit=finalMiyResult.audit;

    let collisions=crossStoreCollisions([
      east,
      ougi,
      miyStore
    ]);

    let collisionRepairLog=[];
    if(collisions.length){
      document.getElementById("nativeFusionStatus").textContent=
        `店舗間重複 ${collisions.length}件を母艦側で再生成中…`;

      const repaired=
        await rerunBaseStoresForCollisions(
          week,
          baseRows,
          miyStore,
          collisions
        );

      baseRows=repaired.rows;
      collisionRepairLog=repaired.repairLog;
      collisions=repaired.collisions;

      east=normalizeBaseResult(
        baseRows.find(row=>row.storeKey==="higashicho")
      );
      ougi=normalizeBaseResult(
        baseRows.find(row=>row.storeKey==="ougicho")
      );
    }

    nativeFusionAudit={
      validatorVersion:"makotsu-shift-three-store-operator-v14-pwa",
      generatedAt:new Date().toISOString(),
      weekStart:week,
      architecture:{
        iframe:false,
        directIntegration:true,
        baseEngine:"beta4.10.37.04",
        baseStores:["higashicho","ougicho"],
        miyanoshitaEngine:"standalone-v26-lazy-shadow-api",
        miyanoshitaApiInsideIife:true,
        crossStoreRepair:"hard-isUnavailable-hook-rerun",
        miyanoshitaLazyInit:true,
        auditOwner:"single-parent-runtime",
        baseLock:
          window.__nativeFusionBaseLock||null,
        legacyValidationRemoval:
          window.__nativeFusionLegacyRemoval||null,
        earlyBootstrap:
          window.__nativeFusionEarlyBootstrap||null,
        fmtDateReady:
          typeof window.fmtDate==="function"
      },
      storePasses:{
        higashicho:east.pass,
        ougicho:ougi.pass,
        miyanoshita:miyStore.pass
      },
      crossStoreCollisionRepair:{
        strategy:"hard-isUnavailable-hook-rerun",
        attempts:collisionRepairLog.length,
        log:collisionRepairLog
      },
      crossStoreCollisions:collisions,
      releaseManifest:{
        releaseChannel:"PRODUCTION",
        releaseVersion:"v12",
        logicFrozenFrom:"v11-rc1-pass",
        baseEngine:"beta4.10.37.04",
        miyanoshitaEngine:"standalone-v26",
        crossStoreRepair:"hard-isUnavailable-hook-rerun",
        logicChangedFromV10:false,
        rc1ValidationPassed:true,
        operatorUiVersion:"v14-pwa",
        logicChangedFromV12:false,
        pwaEnabled:true
      },
      passPolicy:{
        authoritativePassField:"combinedPass",
        requiresAllStorePasses:true,
        requiresZeroCrossStoreCollisions:true,
        stableCandidateRequiresThreeConsecutivePasses:true
      },
      combinedPass:
        east.pass &&
        ougi.pass &&
        miyStore.pass &&
        collisions.length===0,
      stableCandidate:false,
      stores:[east,ougi,miyStore].map(store=>({
        storeKey:store.storeKey,
        storeName:store.storeName,
        assignmentCount:store.assignments.length,
        shortageCells:store.shortageCells,
        surplusCells:store.surplusCells,
        pass:store.pass,
        validationStatus:store.validationStatus
      })),
      sourceAudits:{
        higashicho:east.releaseAudit,
        ougicho:ougi.releaseAudit,
        miyanoshita:miyAudit
      }
    };

    renderFusionSummary(nativeFusionAudit);
    diagnosticButton.disabled=false;
    csvButton.disabled=!nativeFusionAudit.combinedPass;
    downloadButton.disabled=!(
      nativeFusionAudit.combinedPass &&
      nativeFusionAudit.stableCandidate===true
    );
  }catch(error){
    console.error(error);
    nativeFusionAudit={
      validatorVersion:"makotsu-shift-three-store-operator-v14-pwa",
      generatedAt:new Date().toISOString(),
      weekStart:week,
      combinedPass:false,
      error:String(error?.stack||error)
    };
    document.getElementById("nativeFusionStatus").textContent=
      "一括実行エラー："+String(error?.message||error);
    document.getElementById("fusionAll").textContent="総合：ERROR";
    diagnosticButton.disabled=false;
    downloadButton.disabled=true;
    csvButton.disabled=true;
  }finally{
    document.body.classList.remove("native-fusion-running");
    runButton.disabled=false;
  }

  return nativeFusionAudit;
}


function auditSignature(audit){
  if(!audit)return null;
  return JSON.stringify({
    combinedPass:audit.combinedPass,
    collisions:audit.crossStoreCollisions?.length||0,
    stores:(audit.stores||[]).map(store=>({
      key:store.storeKey,
      count:store.assignmentCount,
      shortage:store.shortageCells,
      surplus:store.surplusCells,
      pass:store.pass
    })),
    repairAttempts:
      audit.crossStoreCollisionRepair?.attempts||0
  });
}

async function runThreePassStability(){
  const button=document.getElementById("nativeFusionStability");
  const status=document.getElementById("nativeFusionStatus");
  button.disabled=true;

  try{
    const runs=[];
    for(let i=1;i<=3;i++){
      status.textContent=`安定検証 ${i}/3 実行中…`;
      const audit=await runNativeFusion({stabilityRun:true});
      runs.push(JSON.parse(JSON.stringify(audit)));
      if(!audit?.combinedPass)break;
      await new Promise(resolve=>setTimeout(resolve,50));
    }

    const signatures=runs.map(auditSignature);
    const allPass=
      runs.length===3 &&
      runs.every(run=>run?.combinedPass===true);
    const sameSignature=
      signatures.length===3 &&
      new Set(signatures).size===1;

    nativeFusionStability={
      validatorVersion:"three-store-stability-v13-operator",
      executedAt:new Date().toISOString(),
      runCount:runs.length,
      allPass,
      sameSignature,
      stableCandidate:allPass&&sameSignature,
      signatures,
      runs:runs.map(run=>({
        generatedAt:run.generatedAt,
        combinedPass:run.combinedPass,
        crossStoreCollisions:
          run.crossStoreCollisions?.length||0,
        repairAttempts:
          run.crossStoreCollisionRepair?.attempts||0,
        stores:run.stores
      }))
    };

    if(nativeFusionAudit){
      nativeFusionAudit.stabilityValidation=
        nativeFusionStability;
      nativeFusionAudit.stableCandidate=
        nativeFusionStability.stableCandidate;
    }

    status.textContent=nativeFusionStability.stableCandidate
      ?"作成完了：三店舗PASS・店舗間重複0。CSVを保存できます。"
      :"作成できませんでした。詳細を開き、診断JSONを保存してください。";

    document.getElementById("nativeFusionDiagnostic").disabled=
      !nativeFusionAudit;
    document.getElementById("nativeFusionCsv").disabled=
      !nativeFusionAudit?.combinedPass;
    document.getElementById("nativeFusionDownload").disabled=
      !nativeFusionAudit?.stableCandidate;

    renderFusionSummary(nativeFusionAudit);

    const printButton=document.getElementById("operatorPrint");
    if(printButton){
      printButton.disabled=!nativeFusionAudit?.stableCandidate;
    }

    (nativeFusionAudit?.stores||[]).forEach(store=>{
      const id=
        store.storeKey==="higashicho"?"fusionEast":
        store.storeKey==="ougicho"?"fusionOugi":"fusionMiy";
      document.getElementById(id)?.setAttribute(
        "data-pass",
        String(store.pass===true)
      );
    });
    document.getElementById("fusionAll")?.setAttribute(
      "data-pass",
      String(nativeFusionAudit?.stableCandidate===true)
    );
  }finally{
    button.disabled=false;
  }
}

function downloadJsonPayload(payload,filename){
  const blob=new Blob(
    [JSON.stringify(payload,null,2)],
    {type:"application/json;charset=utf-8"}
  );
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");
  a.href=url;
  a.download=filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(()=>URL.revokeObjectURL(url),1000);
}

function downloadDiagnosticAudit(){
  if(!nativeFusionAudit)return;
  downloadJsonPayload(
    nativeFusionAudit,
    `makotsu-shift-THREE-STORES-OPERATOR-v13-DIAGNOSTIC-${nativeFusionAudit.weekStart}.json`
  );
}

function downloadThreeStoreCsv(){
  if(!nativeFusionAudit?.combinedPass)return;

  const rows=[["店舗","日付","氏名","時間"]];
  const audits=nativeFusionAudit.sourceAudits||{};

  ["higashicho","ougicho","miyanoshita"].forEach(key=>{
    const audit=audits[key];
    const assignments=audit?.assignments||[];
    assignments.forEach(row=>{
      rows.push([
        row.storeName||
          (key==="higashicho"?"東町":
           key==="ougicho"?"扇町":"宮ノ下"),
        row.dateIso||"",
        row.name||"",
        row.time||""
      ]);
    });
  });

  const csv="\ufeff"+rows.map(row=>
    row.map(value=>
      `"${String(value).replaceAll('"','""')}"`
    ).join(",")
  ).join("\r\n");

  const blob=new Blob([csv],{type:"text/csv;charset=utf-8"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");
  a.href=url;
  a.download=
    `makotsu-shift-THREE-STORES-OPERATOR-v13-${nativeFusionAudit.weekStart}.csv`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(()=>URL.revokeObjectURL(url),1000);
}

function downloadNativeFusionAudit(){
  if(!nativeFusionAudit?.stableCandidate){
    document.getElementById("nativeFusionStatus").textContent=
      "正式保存不可：3回連続安定検証を通してください。";
    return;
  }

  downloadJsonPayload(
    nativeFusionAudit,
    `makotsu-shift-THREE-STORES-OPERATOR-v13-PRODUCTION-STABLE-PASS-${nativeFusionAudit.weekStart}.json`
  );
}

document.getElementById("nativeFusionRun")
  .addEventListener("click",runNativeFusion);
document.getElementById("nativeFusionStability")
  .addEventListener("click",runThreePassStability);
document.getElementById("nativeFusionDownload")
  .addEventListener("click",downloadNativeFusionAudit);
document.getElementById("nativeFusionDiagnostic")
  .addEventListener("click",downloadDiagnosticAudit);
document.getElementById("nativeFusionCsv")
  .addEventListener("click",downloadThreeStoreCsv);

document.getElementById("operatorDetailsToggle")
  .addEventListener("click",()=>{
    const panel=document.getElementById("operatorAdvanced");
    panel.hidden=!panel.hidden;
    document.getElementById("operatorDetailsToggle").textContent=
      panel.hidden?"詳細":"詳細を閉じる";
  });

document.getElementById("operatorPrint")
  .addEventListener("click",()=>window.print());


ensureFmtDate();
removeLegacyValidationSystem();
lockBaseToEastAndOugi();
})();
</script>


<script id="pwaV14Bootstrap">
(() => {
  const isFile = location.protocol === "file:";
  const banner = document.createElement("div");
  banner.id = "pwaInstallBanner";
  banner.style.cssText = [
    "position:fixed","left:12px","right:12px","bottom:12px","z-index:99999",
    "padding:12px 14px","border-radius:12px",
    "font:700 13px/1.4 -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif",
    "box-shadow:0 10px 30px rgba(0,0,0,.25)","display:none"
  ].join(";");

  if (isFile) {
    banner.textContent =
      "このHTMLはファイル表示では動きません。PWA一式をWebへ配置し、SafariでURLを開いてください。";
    banner.style.background = "#fff7ed";
    banner.style.color = "#9a3412";
    banner.style.display = "block";
    document.body.appendChild(banner);
    return;
  }

  if ("serviceWorker" in navigator) {
    window.addEventListener("load", () => {
      navigator.serviceWorker.register("./service-worker.js").catch(err => {
        console.warn("service worker registration failed", err);
      });
    });
  }

  const isIos = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone =
    window.matchMedia("(display-mode: standalone)").matches ||
    window.navigator.standalone === true;

  if (isIos && !isStandalone) {
    banner.innerHTML =
      "Safariの共有ボタンから <b>「ホーム画面に追加」</b> するとアプリのように使えます。";
    banner.style.background = "#ecfeff";
    banner.style.color = "#155e75";
    banner.style.display = "block";
    banner.addEventListener("click", () => banner.remove());
    document.body.appendChild(banner);
  }
})();
</script>

