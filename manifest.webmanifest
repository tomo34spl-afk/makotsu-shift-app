    let editingStaffName = "";

    function pad(n) {
      return String(n).padStart(2, "0");
    }

    function iso(date) {
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
    }

    function parseMonth(value) {
      const [year, month] = value.split("-").map(Number);
      return { year, month };
    }

    function addDays(date, days) {
      const copy = new Date(date);
      copy.setDate(copy.getDate() + days);
      return copy;
    }

    function periodDates() {
      const { year, month } = parseMonth(state.month);
      const start = new Date(year, month - 1, state.startDay);
      const end = state.startDay === 1
        ? new Date(year, month, 0)
        : new Date(year, month, state.startDay - 1);
      const dates = [];
      for (let d = new Date(start); d <= end; d = addDays(d, 1)) {
        dates.push(new Date(d));
      }
      return dates;
    }

    function mondayOf(date) {
      const copy = new Date(date);
      const day = copy.getDay();
      const diff = day === 0 ? -6 : 1 - day;
      return addDays(copy, diff);
    }

    function weekDates(startIso) {
      const start = new Date(`${startIso}T00:00:00`);
      return Array.from({ length: 7 }, (_, index) => addDays(start, index));
    }

    function nextWeeklyCloseStartIso(baseIso = state.today) {
      const base = new Date(`${baseIso}T00:00:00`);
      const thisMonday = mondayOf(base);
      return iso(addDays(thisMonday, 7));
    }

    function weekOptions() {
      const dates = periodDates();
      if (!dates.length) return [];
      const firstMonday = mondayOf(dates[0]);
      const lastDate = dates[dates.length - 1];
      const weeks = [];
      for (let d = new Date(firstMonday); d <= lastDate; d = addDays(d, 7)) {
        weeks.push(new Date(d));
      }
      return weeks;
    }

    function ensureSelectedWeekStart() {
      const weeks = weekOptions();
      if (!weeks.length) {
        state.selectedWeekStart = "";
        return "";
      }
      const valid = weeks.map(date => iso(date));
      if (!state.selectedWeekStart || !valid.includes(state.selectedWeekStart)) {
        const nextWeek = nextWeeklyCloseStartIso();
        state.selectedWeekStart = valid.includes(nextWeek) ? nextWeek : valid[0];
      }
      return state.selectedWeekStart;
    }

    function selectedWeekDates() {
      const weekStartIso = ensureSelectedWeekStart();
      if (!weekStartIso) return [];
      return weekDates(weekStartIso);
    }

    function weekLabel(dates) {
      if (!dates.length) return "-";
      const last = dates[dates.length - 1];
      return `${dateLabel(dates[0])}(${dowLabel(dates[0])})〜${dateLabel(last)}(${dowLabel(last)})`;
    }

    function dateLabel(date) {
      return `${date.getMonth() + 1}/${date.getDate()}`;
    }

    function dowLabel(date) {
      return ["日", "月", "火", "水", "木", "金", "土"][date.getDay()];
    }

    function periodLabel() {
      const dates = periodDates();
      if (!dates.length) return "-";
      return `${dateLabel(dates[0])}〜${dateLabel(dates[dates.length - 1])}`;
    }

    function ensureCell(dateIso, storeKey, slot) {
      if (!state.schedule[dateIso]) state.schedule[dateIso] = {};
      if (!state.schedule[dateIso][storeKey]) state.schedule[dateIso][storeKey] = {};
      if (!state.schedule[dateIso][storeKey][slot]) state.schedule[dateIso][storeKey][slot] = [];
      return state.schedule[dateIso][storeKey][slot];
    }

    function readCell(dateIso, storeKey, slot) {
      return (((state.schedule[dateIso] || {})[storeKey] || {})[slot]) || [];
    }

    function requirement(storeKey, slot) {
      return stores[storeKey] && stores[storeKey].requirements[slot] ? stores[storeKey].requirements[slot] : 0;
    }

    function setRequirement(slot, value) {
      stores[state.selectedStore].requirements[slot] = Math.max(0, Number(value) || 0);
      renderAll();
    }

    function isInDateList(map, personName, dateIso) {
      const name = canonicalStaffName(personName);
      return (map[name] || []).includes(dateIso);
    }

    function isPaidLeave(personName, dateIso) {
      return isInDateList(paidLeave, personName, dateIso);
    }

    function isEmergencyAbsence(personName, dateIso) {
      return isInDateList(emergencyAbsences, personName, dateIso);
    }

    function isUnavailable(personName, dateIso) {
      const name = canonicalStaffName(personName);
      const meta = noMasterV3700StaffMeta(name);
      const lifecycleBlocked =
        meta.status === "leave" ||
        meta.status === "retired" ||
        meta.status === "excluded" ||
        (meta.startDate && dateIso < meta.startDate) ||
        (meta.endDate && dateIso > meta.endDate);

      return lifecycleBlocked ||
        isInDateList(availability, name, dateIso) ||
        isPaidLeave(name, dateIso) ||
        isEmergencyAbsence(name, dateIso);
    }

    function findStaff(name) {
      return staff.find(person => person.name === canonicalStaffName(name));
    }

    function canonicalStaffName(name) {
      const value = String(name || "").trim();
      return staffNameAliases[value] || value;
    }

    function canonicalStaffNameForStore(name, storeKey = "") {
      const value = canonicalStaffName(name);
      if (value === "店長") {
        if (storeKey === "higashicho") return "東町 店長（小澤）";
        if (storeKey === "ougicho") return "扇町 店長（齋藤）";
        if (storeKey === "miyanoshita") return "宮下 店長（小島）";
      }
      return value;
    }

    function applySeededAvailability() {
      Object.entries(seededAvailability).forEach(([name, dates]) => {
        const cleanName = canonicalStaffName(name);
        availability[cleanName] = mergeUnique(availability[cleanName], dates);
      });
    }

    function mergeUnique(base, additions) {
      return [...new Set([...(base || []), ...(additions || [])])];
    }

