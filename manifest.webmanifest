}
#nativeFusionBar .fusion-row{
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
}
#nativeFusionBar strong{font-size:18px;margin-right:8px}
#nativeFusionBar input,
#nativeFusionBar button{
  min-height:38px;
  border-radius:8px;
  border:1px solid #475569;
  padding:7px 11px;
  font:inherit;
}
#nativeFusionBar button{
  cursor:pointer;
  background:#fff;
  color:#111827;
  font-weight:750;
}
#nativeFusionBar button.primary{
  background:#14b8a6;
  border-color:#14b8a6;
  color:#052e2b;
}
#nativeFusionBar button:disabled{opacity:.45;cursor:not-allowed}
#nativeFusionStatus{
  margin-top:8px;
  font-size:12px;
  color:#cbd5e1;
  white-space:pre-wrap;
}
#nativeFusionSummary{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:8px;
  margin-top:8px;
}
.native-fusion-card{
  background:#fff;
  color:#111827;
  border-radius:8px;
  padding:8px 10px;
  min-height:54px;
}
.native-fusion-card b{display:block;font-size:16px}
.native-fusion-card span{font-size:11px;color:#64748b}
#nativeMiyRuntimeHost{display:none!important}
body.native-fusion-running{cursor:progress}
body.native-fusion-running::after{
  content:"三店舗を生成・監査中…";
  position:fixed;
  inset:0;
  z-index:100000;
  display:flex;
  align-items:center;
  justify-content:center;
  background:rgba(255,255,255,.65);
  color:#0f172a;
  font-size:24px;
  font-weight:900;
  pointer-events:auto;
}
@media(max-width:900px){
  #nativeFusionSummary{grid-template-columns:repeat(2,minmax(0,1fr))}
}
</style>


