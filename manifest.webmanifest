  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    (function () {
      function byId(id) {
        return document.getElementById(id);
      }

      function findActionButton(target) {
        while (target && target !== document.body) {
          if (target.getAttribute && (target.getAttribute("data-view") || target.getAttribute("data-jump") || target.id === "managerMode" || target.id === "ownerMode")) {
            return target;
          }
          target = target.parentNode;
        }
        return null;
      }

      function isFormControl(target) {
        while (target && target !== document.body) {
          var name = target.tagName ? target.tagName.toLowerCase() : "";
          if (name === "select" || name === "option" || name === "input" || name === "textarea" || name === "label") return true;
          target = target.parentNode;
        }
        return false;
      }

      function setStatus(text, className) {
        var status = byId("jsStatus");
        if (!status) return;
        status.className = "status-bar " + (className || "");
        status.textContent = text;
      }

      function switchPanel(view) {
        var ids = {
          dashboard: "dashboardView",
          today: "todayView",
          owner: "ownerView",
          monthly: "monthlyView",
          weeklyClose: "weeklyCloseView",
          rieMaster: "rieMasterView",
          paperImport: "paperImportView",
          teacher: "teacherView",
          finished: "finishedView",
          shortage: "shortageView",
          issues: "issuesView",
          availability: "availabilityView",
          staff: "staffView",
          data: "dataView"
        };
        var key;
        for (key in ids) {
          if (Object.prototype.hasOwnProperty.call(ids, key)) {
            var panel = byId(ids[key]);
            if (panel) {
              if (key === view) panel.className = panel.className.replace(/\s*hidden/g, "");
              else if (panel.className.indexOf("hidden") === -1) panel.className += " hidden";
            }
          }
        }
        var buttons = document.querySelectorAll ? document.querySelectorAll("[data-view]") : [];
        for (var i = 0; i < buttons.length; i += 1) {
          var button = buttons[i];
          button.className = button.className.replace(/\s*active/g, "");
          if (button.getAttribute("data-view") === view) button.className += " active";
        }
        setStatus("簡易操作OK。ボタンで画面移動できます", "fallback");
      }

      function handleTap(event) {
        if (isFormControl(event.target)) return;
        var button = findActionButton(event.target);
        if (!button) return;
        var view = button.getAttribute("data-view") || button.getAttribute("data-jump");
        if (button.id === "managerMode") view = "weeklyClose";
        if (button.id === "ownerMode") view = "owner";
        if (!view) return;
        switchPanel(view);
      }

      window.makotsuLegacySwitchView = switchPanel;
      if (document.addEventListener) {
        document.addEventListener("click", handleTap, false);
        document.addEventListener("touchend", handleTap, false);
        document.addEventListener("DOMContentLoaded", function () {
          document.body.className += " js-ready";
          setStatus("簡易操作OK。読み込み中でも画面移動できます", "fallback");
        }, false);
      }
    }());
  </script>
